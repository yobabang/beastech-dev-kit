void ETH_TP_SetTransportParameters(dword ECULogicAddress,dword TesterLogicAddress,dword FunctionalLogicAddress,char ipv4Address[],char netmask[])
{
  dword result;
  dword interfaceIndex;
  
  ETH_TesterLogicAddress=TesterLogicAddress;
  //ETH_RawECULogicAddress=ECULogicAddress;
  ETH_ECULogicAddress = ECULogicAddress;
  ETH_FunctionalLogicAddress = FunctionalLogicAddress;
  ETH_ipv4Address = ipGetAddressAsNumber(ipv4Address);
  ETH_netmask = ipGetAddressAsNumber(netmask);
  
  interfaceIndex = 1;
  result= ipAddAdapterAddress(interfaceIndex, ETH_ipv4Address, ETH_netmask);
  if( result != 0 )
  {
    write( "IpAddAdapterAddress failed, error code %d, last error %d", result, IpGetLastError());
  }
}

void Server_Listen()
{
  write("listening ...");
  gListenSocket = TcpOpen( 0, 13400 );//建立一个TCP Socket
//  if(gListenSocket!=~0)
//  {
//    write("built TCP socket success ");
//  }
//  else
//    write()
    // Begin listening on TCP port.
  TcpListen(gListenSocket);// listen for incoming connection requests
  if (IpGetLastError() != 0)//判断监听TCP Socket是否成功
  {
    // if UdpSocket::Open fails, we print a message to the write window
    write( "ETHTP_Err:<%BASE_FILE_NAME%> TcpSocket::Open failed with result %d", IpGetLastError() );
  }
  else
    write("ETHTP:listen success,timeNow=%.6f",timeNow()/100000.0);
}


//
// Callback OnTcpListen is called on incomming connect request.
//
void OnTcpListen( dword socket, long result)
{
  int result111;
  dword IHUHandle_Temp;
  dword IHUHandle_DigIP;
  IHUHandle_Temp=0;
  IHUHandle_DigIP=0;
  write("OnTcpListen:listen success, timeNow=%.6f",timeNow()/100000.0);
  // Accept connection request and setup gConnectionSocket
  
  if((strstr(NodeName,"ADCU")>=0) && (ECUAddress_Temp == 0x1301))
    ConnectionSocketGet_ADCU(socket);
  else if((strstr(NodeName,"ADMC")>=0) && (ECUAddress_Temp == 0x1301))
    ConnectionSocketGet_ADMC(socket);
  else if((strstr(NodeName,"ADSC")>=0) && (ECUAddress_Temp == 0x1302))
    ConnectionSocketGet_ADSC(socket);
  else
    gConnectionSocket = TcpAccept(socket);
  
  // to recieve data from the socket, we have to call TCPReceive.
//      TCPReceive(gConnectionSocket, gRxBuffer, elcount(gRxBuffer) );

  if(gConnectionSocket!=~0)
  {
    write("ETHTP:TCPaccept success ,gConnectionSocket=%d",gConnectionSocket);
//          TCPReceive(gConnectionSocket, gRxBuffer, elcount(gRxBuffer) );
    result=TCPReceive(gConnectionSocket, gTcpRxBuffer, elcount(gTcpRxBuffer) );//20190107
    write("OnTcpListen result=%d",result);
    
    result111=ipGetLastSocketError(gConnectionSocket) ;
    write("OnTcpListen result111=%d",result111);
  }
  else
  {
   write("ETHTP_Err:TCPaccept error");
  }
  setTimerCyclic(TesterPresentKeep,4000);
}

// error
void OnTcpClose( dword socket, long result)
{
  if (result == 0)
  {
//     Client has close the socket, so we can relase our gConnectionSocket object.
    tcpClose(gConnectionSocket);
  }
  cancelTimer(TesterPresentKeep);
}

