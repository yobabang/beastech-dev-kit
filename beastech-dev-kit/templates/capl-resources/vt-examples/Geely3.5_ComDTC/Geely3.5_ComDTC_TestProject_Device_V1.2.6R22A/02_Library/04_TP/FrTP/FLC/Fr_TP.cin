void FrTP_TxConfirmationInd( long connHandle)
{
  testSupplyTextEvent("TxSuccessful");
  write( "Data transmission on connection %d successful", connHandle); 
}

void FrTP_ReceptionInd( long connHandle, byte data[])
{
  TpRxLength=elcount( data);
  memcpy( TpRxData, data, TpRxLength);

  TestSupplyTextEvent("TPreciveData");
} 

void FrTP_FrameRxInd( long connHandle, long typeOfCPDU, BYTE buffer[])
{
  long SubTpye;
  if(typeOfCPDU == 0 || typeOfCPDU == 1)
  {
    TestSupplyTextEvent("TPFirstCFrecived");
  }
}

enum ResponseState FR_ECU_Response(int P2)
{
  if(P2 != 5000)
  {
    gNRC78Flag=0;//
  }
  
  if(testWaitForTextEvent("TPFirstCFrecived",P2)==0)
  {
    return Timeout;
  }

  if(testWaitForTextEvent("TPreciveData",5000)==1)
  {
    if(TpRxData[0]==0x7f)
    {
      switch(TpRxData[2])
      {
        case 0x78:
        {
          gNRC78Flag=1;//
//          write("NRC78 time=%f",timeNow()/100.0);
          return FR_ECU_Response(5000);
        }
        default:
        //  NRC_Info(TpRxData[2]);
          break;
      }
//      t2 = timeNow()/100.0;
      return Neg;
    }
    else
    {
//      t2 = timeNow()/100.0;
      return Pos;
    }
  }
  else
  {
    testStepFail("Chk","The CF is not incomplete");
    return Timeout;
  }
}

int FR_TP_Send(byte Data[],enum AddressMode Mode)
{
//  testJoinTextEvent("TxSuccessful");
  if(FR_HandleFlag==1)
  {
    if(Mode==0)
      FrTP_DataRequest(FR_ConnHandleAPP_Phys, Data, elCount(Data));
    else
      FrTP_DataRequest(FR_ConnHandleAPP_Func, Data, elCount(Data));
  }
  else
  {  
     FrTP_DataRequest(FR_ConnHandleBL, Data, elCount(Data));
  }
//  if(testWaitForAnyJoinedEvent(3000)>0)
//  {
////    t1 = timeNow()/100.0;
////    testStep("Info","diag request received!");
//    return 1;
//  }
  return 1;
}

int FR_TP_Send(byte Data[],long length,enum AddressMode Mode)
{
//  testJoinTextEvent("TxSuccessful");
  if(length>elcount(Data))
  {
    if(FR_HandleFlag==1)
    {
      if(Mode==0)
        FrTP_DataRequest(FR_ConnHandleAPP_Phys, Data, elCount(Data));
      else
        FrTP_DataRequest(FR_ConnHandleAPP_Func, Data, elCount(Data));
    }
    else
    {  
       FrTP_DataRequest(FR_ConnHandleBL, Data, elCount(Data));
    }
    write("Worning tp send data size small than given length");
  }
  else
  {
    if(FR_HandleFlag==1)
    {
      if(Mode==0)
        FrTP_DataRequest(FR_ConnHandleAPP_Phys, Data, length);
      else
        FrTP_DataRequest(FR_ConnHandleAPP_Func, Data, length);
    }
    else
    {  
       FrTP_DataRequest(FR_ConnHandleBL, Data, length);
    }
  }
//  if(testWaitForAnyJoinedEvent(3000)>0)
//  {
////    t2 = timeNow()/100.0;
//    return 1;
//  }
  return 1;;
}