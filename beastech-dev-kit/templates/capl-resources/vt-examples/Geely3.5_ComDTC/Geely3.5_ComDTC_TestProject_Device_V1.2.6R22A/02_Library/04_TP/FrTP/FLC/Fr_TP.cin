/*@!Encoding:936*/
includes
{
  #include "Schedule_Config.cin"
  #include "FRconfig.cin"
}

variables
{
  long FR_ConnHandleAPP_Phys;
  long FR_ConnHandleAPP_Func;
  long FR_ConnHandleBL;
  
  int FR_HandleFlag=0;
  long FR_timeoutAS, FR_timeoutAR, FR_timeoutBS, FR_timeBR, FR_timeCS, FR_timeoutCR;
}

long FR_Tp_ConfigAPP_Phys(int remoteAddress,int localAddress )
{
  setFRConf_AS();
  FR_ConnHandleAPP_Phys = FrTP_CreateConnUnicast(39,1,AppSlot1,1);
  FrTP_AddConnSlots(FR_ConnHandleAPP_Phys,39, 3, -1,0);
  FrTP_AddConnSlots(FR_ConnHandleAPP_Phys,-1, 0, AppSlot2,1);
  FrTP_AddConnSlots(FR_ConnHandleAPP_Phys,-1, 0, AppSlot3,1);
  FrTP_SetConnMode(FR_ConnHandleAPP_Phys, 1);
  FrTP_SetAddresses(FR_ConnHandleAPP_Phys, localAddress, remoteAddress);
  FR_timeoutAS = 1000;
  FR_timeoutAR = 1000;
  FR_timeoutBS = 1000;
  FR_timeBR    = 20;
  FR_timeCS    = 20;
  FR_timeoutCR = 4000;
  FrTP_SetTimingParams(FR_ConnHandleAPP_Phys, FR_timeoutAS, FR_timeoutAR, FR_timeoutBS, FR_timeBR, FR_timeCS, FR_timeoutCR);
  FrTP_SetMaxPDULength(FR_ConnHandleAPP_Phys, 22);//
  FrTP_SetBandwidthControl(FR_ConnHandleAPP_Phys, 0, 0);
  FrTP_SetBufferSize(FR_ConnHandleAPP_Phys, 0);
  FrTP_SetFillByte(FR_ConnHandleAPP_Phys, 0x00);
  FrTP_SetExpertParam(FR_ConnHandleAPP_Phys, 68, 1);
  FR_HandleFlag=1;
  return FR_ConnHandleAPP_Phys;
}

long FR_Tp_ConfigAPP_Func(int remoteAddress,int localAddress )
{
  setFRConf_AS();
  
  FR_Tp_ConfigAPP_Phys(ECUAddress,LocalAddress);//
  
  FR_ConnHandleAPP_Func = FrTP_CreateConnUnicast(42,1,AppSlot1,1);
  FrTP_AddConnSlots(FR_ConnHandleAPP_Func,-1, 0, AppSlot2,1);
  FrTP_AddConnSlots(FR_ConnHandleAPP_Func,-1, 0, AppSlot3,1);
  FrTP_SetConnMode(FR_ConnHandleAPP_Func, 1);
  FrTP_SetAddresses(FR_ConnHandleAPP_Func, localAddress, remoteAddress);
//  FrTP_Set2ndAddresses(ConnHandleAPP, 0x01, localAddress, ECUAddress);////
  FR_timeoutAS = 1000;
  FR_timeoutAR = 1000;
  FR_timeoutBS = 1000;
  FR_timeBR    = 20;
  FR_timeCS    = 20;
  FR_timeoutCR = 1000;
  FrTP_SetTimingParams(FR_ConnHandleAPP_Func, FR_timeoutAS, FR_timeoutAR, FR_timeoutBS, FR_timeBR, FR_timeCS, FR_timeoutCR);
  FrTP_SetMaxPDULength(FR_ConnHandleAPP_Func, 22);//
  FrTP_SetBandwidthControl(FR_ConnHandleAPP_Func, 0, 0);
  FrTP_SetBufferSize(FR_ConnHandleAPP_Func, 0);
  FrTP_SetFillByte(FR_ConnHandleAPP_Func, 0x00);
  FrTP_SetExpertParam(FR_ConnHandleAPP_Func, 68, 1);
  FR_HandleFlag=1;
  return FR_ConnHandleAPP_Func;
}

long FR_Tp_ConfigBL(int remoteAddress,int localAddress )
{
  setFRConf_BS();
  FR_ConnHandleBL = FrTP_CreateConnUnicast(37,26,BLSlot1,1);
  FrTP_AddConnSlots(FR_ConnHandleBL,-1, 0, BLSlot2,1);
  FrTP_SetConnMode(FR_ConnHandleBL, 1);
  FrTP_SetAddresses(FR_ConnHandleBL, localAddress, remoteAddress);
  FrTP_Set2ndAddresses(FR_ConnHandleBL, 0x01, localAddress, ECUAddress);/////
  FR_timeoutAS = 1000;
  FR_timeoutAR = 1000;
  FR_timeoutBS = 1000;
  FR_timeBR    = 15;
  FR_timeCS    = 15;
  FR_timeoutCR = 1000;
  FrTP_SetTimingParams(FR_ConnHandleBL, FR_timeoutAS, FR_timeoutAR, FR_timeoutBS, FR_timeBR, FR_timeCS, FR_timeoutCR);
  FrTP_SetMaxPDULength(FR_ConnHandleBL, 254);
  FrTP_SetBandwidthControl(FR_ConnHandleBL, 0, 0);
  FrTP_SetBufferSize(FR_ConnHandleBL, 0);
  FrTP_SetFillByte(FR_ConnHandleBL, 0x00);
  FrTP_SetExpertParam(FR_ConnHandleBL, 68, 1);
  FR_HandleFlag=2;
  return FR_ConnHandleBL;
}



void FRTp_Close( long connHandle)
{
  if(connHandle == FR_ConnHandleAPP_Func)
  {
    testWaitForTimeout(10);
    FrTP_DeleteConn(FR_ConnHandleAPP_Phys);
  }
  testWaitForTimeout(10);
  FrTP_DeleteConn(connHandle);
}

