includes
{

}

variables
{      
  //  int SoutcesID,TargetID,DiagMode,BlockSize,STmin,AddressingMode,N_AS,N_AR,N_BS,N_BR,N_CS,N_CR;
  //SoutcesID:源物理地址，//TargetID：目标地址；//DiagMode：诊断模式 //BlockSize：流控分包数
  //STmin：流控分包时间间隔 //AddressingMode：寻址模式  //N_AS,N_BS,N_BR,N_CS,N_CR：  时间参数
  long  CANFD_handlefun;
  long  CANFD_connHandle;
  dword   CANFD_TP_PhyRequestID  = 0x700;
  dword   CANFD_TP_FuncRequestID = 0x7DF;
  dword   CANFD_TP_ResponseID    = 0x600;
  
  int   CANFD_TP_AS = 25;
  int   CANFD_TP_AR = 25;
  int   CANFD_TP_BS = 75;
  int   CANFD_TP_BR = 10;
  int   CANFD_TP_CS = 20;
  int   CANFD_TP_CR = 150;
  int   CANFD_TP_BlockSize = 0;
  int   CANFD_TP_STmin = 0x14; 
  int   CANFD_TP_MaxCANFDFrameLenth = 64;
  int   CANFD_TP_BRSBit = 0;
  
  msTimer CANFD_TP_TesterPresentTimer;
  message 0x000 CANFD_TP_TesterPresentFrame = {dlc = 8,FDF = 1,byte(0) = 0x02,byte(1) = 0x3E,byte(2) = 0x80};
}

on timer CANFD_TP_TesterPresentTimer
{
  output(CAN_TP_TesterPresentFrame);
  write("CANFDTP:Send TesterPresent");
}

void CANFD_TP_Init()
{
  CANFD_TP_PhyRequestID = 0x700 + (ECUAddress_Temp & 0xff);
  CANFD_TP_ResponseID = 0x600 + (ECUAddress_Temp & 0xff);
  CANFD_TP_FuncRequestID = 0x7ff;
}

void CANFD_TP_Release()
{
  CanTpCloseConnection(CANFD_handlefun);
  CanTpCloseConnection(CANFD_connHandle);
}

void CANFD_TP_CreatConnection(int InputReqID,int InputResID,int InputFuncReqID,char NowBusContext[])
{
  CANFD_TP_PhyRequestID = InputReqID ;
  CANFD_TP_ResponseID = InputResID ;
  CANFD_TP_FuncRequestID = InputFuncReqID ;
  
  CANFD_TP_Config(CANFD_TP_PhyRequestID,CANFD_TP_ResponseID);
  CANFD_TP_Fun_Config(CANFD_TP_FuncRequestID,CANFD_TP_ResponseID);
  
  CANFD_TP_TesterPresentFrame.id = InputFuncReqID;
  CANFD_TP_TesterPresentFrame.can = getBusNameContext(NowBusContext)-65536;
}

