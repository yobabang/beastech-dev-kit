int SID27_SecurityAccess_SendKey(int level,enum AddressMode Mode)
{
  byte SID27[34];
  long ActualSize[1];
  byte Challenge8Byte[32];
  int k;
  
  SID27[0]=0x27;
  SID27[1]=level+0x1;
  SecurityLevel=level;

  memcpy(Challenge8Byte,SeedArray,16);
  memcpy_off(Challenge8Byte,16,FixedBytes,0,16);
  //GenerateKeyExOpt(KeyArray,MaxKeyArraySize,dllName);
  for(k=0;k<elcount(Challenge8Byte);k++)
  {
    write("Challenge8Byte[%d]:0x%02x",k,Challenge8Byte[k]);
  }
  snprintf(dllName,400,"%s02_Library\\03_SecurityHandle\\GenerateKeyExOpt.dll",gAbsPath);
  write("dllName:%s",dllName);

//  SKDLL_GenKeyEx(Challenge8Byte,elcount(Challenge8Byte),SecurityLevel,"",KeyArray,MaxKeyArraySize,ActualSize,dllName);
  SeedParameter(Challenge8Byte,32,1);
  GenerateKeyExOpt(KeyArray, 16, dllName);
  testWaitForTimeout(5);
  
  SID27[2]=KeyArray[0];
  SID27[3]=KeyArray[1];
	SID27[4]=KeyArray[2];
  SID27[5]=KeyArray[3];
	SID27[6]=KeyArray[4];
	SID27[7]=KeyArray[5];
  SID27[8]=KeyArray[6];
	SID27[9]=KeyArray[7];
	SID27[10]=KeyArray[8];
  SID27[11]=KeyArray[9];
	SID27[12]=KeyArray[10];
	SID27[13]=KeyArray[11];
  SID27[14]=KeyArray[12];
	SID27[15]=KeyArray[13];
	SID27[16]=KeyArray[14];
  SID27[17]=KeyArray[15];  
  
  PrintPID("Info","Key ",KeyArray, elCount(KeyArray));
  PrintPID("Request","Request ",SID27, 18/*elCount(SID27)*/);
//  TP_Send(SID27, Mode);
  TP_Send(SID27, elCount(KeyArray)+2, Mode);
  Rss=-1;
  switch(ECU_Response(UDS_P2Client))
  {
    case Pos:
      unlockflag=1;
      PrintPID("Response","Pos.Response",TpRxData,TpRxLength);
      Rss=Pos;
      return 0;
    case Timeout:
      //testStepFail("Response","P2/P2* timeout during test");
      Rss=Timeout;
      return -1;
    default:
      NRC_Info(TpRxData[2]);
      Rss=Neg;
      return TpRxData[2];
  }
}
