		testSteppass("UDS_Ser","Response DID is [0x%2x %2x]",TpRxData[2],TpRxData[3]);
//	if(TpRxData[4]!=0x01 && TpRxData[4]!=0x00)
//		testStepFail("UDS_Ser","Response routineStatusRecord  is [0x%2x]",TpRxData[4]);
//	else
