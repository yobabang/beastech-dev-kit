		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if((DTC[0]==TpRxData[2])&&(DTC[1]==TpRxData[3])&&(DTC[2]==TpRxData[4]))
	{
		testStepPass("UDS_Ser","DTC is 0x%02x 0x%02x 0x%02x",DTC[0],DTC[1],DTC[2]);
		PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
//		testStepWarning("UDS_Ser","Please check the positive Response");
	}
	else
	{
		testStepFail("UDS_Ser","Expect DTC is 0x%02x 0x%02x 0x%02x",DTC[0],DTC[1],DTC[2]);
	}
}
