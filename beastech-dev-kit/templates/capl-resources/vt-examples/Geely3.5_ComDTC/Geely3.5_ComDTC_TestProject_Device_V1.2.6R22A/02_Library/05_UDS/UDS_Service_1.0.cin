void SID31_RoutineControl_EraseMemory(byte memoryaddress[],byte memorysize[],enum AddressMode Mode)
{
	byte SID31[12];

	SID31[0]=0x31;
	SID31[1]=0x01;
	SID31[2]=0xFF;
	SID31[3]=0x00;
	SID31[4] =memoryaddress[0];
	SID31[5] =memoryaddress[1];
	SID31[6] =memoryaddress[2];
	SID31[7] =memoryaddress[3];
	SID31[8] =memorysize[0];
	SID31[9] =memorysize[1];
	SID31[10]=memorysize[2];
	SID31[11]=memorysize[3];
	PrintPID("UDS_Ser","RoutineControl_EraseMemory",SID31,elCount(SID31));
	TP_Send(SID31,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void CheckPosResponse_SID31_EraseMemory(byte ExpectResult)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x71)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]!=0x01)
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if(TpRxData[2]!=0xFF && TpRxData[3]!=0x00)
		testStepFail("UDS_Ser","Response DID is [0x%2x %2x]",TpRxData[2],TpRxData[3]);
	if(TpRxData[4]!=ExpectResult)
		testStepFail("UDS_Ser","Response routineStatusRecord  is [0x%2x]",TpRxData[4]);
	if(5!=TpRxLength)
		testStepFail("UDS_Ser","Response data length is not correct");
}

Void SID31_RoutineControl_CheckProgrammingCondition(enum AddressMode Mode)
{
	byte SID31[4];

	SID31[0]=0x31;
	SID31[1]=0x01;
	SID31[2]=0x02;
	SID31[3]=0x03;
	PrintPID("UDS_Ser","RoutineControl_CheckProgrammingCondition",SID31,elCount(SID31));
	TP_Send(SID31,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void CheckPosResponse_SID31_CheckProgrammingCondition(enum RoutineStatusRecord Result)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]==0x71)
	{
		testStepPass("UDS_Ser","PositiveResponseServiceID %x",TpRxData[0]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]==0x01)
	{
		testStepPass("UDS_Ser","PositiveResponseSubfunction %x",TpRxData[1]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if(TpRxData[2]!=0x02 && TpRxData[3]!=0x03)
		testStepFail("UDS_Ser","Response DID is [0x%2x %2x]",TpRxData[2],TpRxData[3]);
	else
		testSteppass("UDS_Ser","Response DID is [0x%2x %2x]",TpRxData[2],TpRxData[3]);
//	if(TpRxData[4]!=0x01 && TpRxData[4]!=0x00)
//		testStepFail("UDS_Ser","Response routineStatusRecord  is [0x%2x]",TpRxData[4]);
//	else
//		testSteppass("UDS_Ser","Response routineStatusRecord  is [0x%2x]",TpRxData[4]);
	if(5==TpRxLength)
		testStepPass("UDS_Ser","Response data length is correct");
	else
		testStepFail("UDS_Ser","Response data length is not correct");
  if((Result==0x00)&&(TpRxData[4]==0x00))
  {
    testStepPass("UDS_Ser","Expected result %d",TpRxData[4]);
  }
  else if((Result==0x00)&&(TpRxData[4]!=0x00))
  {
    testStepFail("UDS_Ser","Unexpected result %d",TpRxData[4]);
  }
  else if((Result==0x01)&&(TpRxData[4]==0x01))
  {
    testStepPass("UDS_Ser","Expected result %d",TpRxData[4]);
  }
  else if((Result==0x01)&&(TpRxData[4]!=0x01))
  {
    testStepFail("UDS_Ser","Unexpected result %d",TpRxData[4]);
  }
}

