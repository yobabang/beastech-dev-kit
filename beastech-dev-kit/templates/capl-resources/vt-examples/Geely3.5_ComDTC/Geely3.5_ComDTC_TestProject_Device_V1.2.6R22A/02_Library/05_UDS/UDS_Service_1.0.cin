int SID27_SecurityAccess_RequestSeed(int level,enum AddressMode Mode)
{
  int i;
  byte SID27[2];
  SID27[0]=0x27;
  SID27[1]=level;
  SecurityLevel=level;
  PrintPID("Request","Request ",SID27, elCount(SID27));
  TP_Send(SID27,Mode);
  Rss=-1;
  switch(ECU_Response(UDS_P2Client))
  {
    case Pos:
      PrintPID("Response","Pos.Response",TpRxData,TpRxLength);
      for(i=0;i<elcount(SeedArray);i++)
      {
        SeedArray[i] = TpRxData[i+2];
      }
//      SeedParameter(SeedArray,3,level);
      PrintPID("Info","Seed ",SeedArray,16);
      Rss=Pos;
      return 0;
    case Timeout:
      //testStepFail("Response","P2/P2* timeout during test");
      Rss=Timeout;
      return -1;
    default:
      NRC_Info(TpRxData[2]);
      Rss=Neg;
      return TpRxData[2];
  }
}

void CheckPosResponse_SID27_ReqSeed(int level,int ByteNumOfSeed)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	//PrintPID("Response","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x67)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]!=level)
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if(TpRxLength!=ByteNumOfSeed+2)
		testStepFail("UDS_Ser","Response data length is not correct");
}

void CheckPosResponse_SID27_ReqSeed(int level,int ByteNumOfSeed,byte expectseed[])
{
	int i;

	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]==0x67)
	{
		//testStepPass("Chk","PositiveResponseServiceID %x",TpRxData[0]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]==level)
	{
		//testStepPass("Chk","PositiveResponseSubfunction %x",TpRxData[1]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if(TpRxLength!=ByteNumOfSeed+2)
		testStepFail("UDS_Ser","Response data length is not correct");
	for(i=2; i<elCount(expectseed)-1; i++)
	{
		if(TpRxData[i]!=expectseed[i-2])
			testStepFail("UDS_Ser","The seed is not rigth");
	}
}

void CheckPosResponse_SID27_SenKey(int level)
{
	if(Rss!=Pos)
