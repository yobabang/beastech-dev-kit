void SID36_TransferData(byte Data[],long length,int Counter,enum AddressMode Mode)
{
	byte SID36[65536];
	int n;
	SID36[0]=0x36;
	SID36[1]=Counter;
	//testStep("Chk 0x36","Transfer data. Send Counter=%d,SID36[1]=%d",Counter,SID36[1]);
	for(n=0; n<length; n++)
	{
		SID36[n+2]=Data[n];
	}

	//PrintPID("Request","TransferData",SID36,10,"......"); //函数发生变化，需修改
	TP_Send(SID36,length+2,Mode);
	//writeLineEx(4,1,"%s-%f: Send $36 data",timeBuf,(timeNow()/100000.0));
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

