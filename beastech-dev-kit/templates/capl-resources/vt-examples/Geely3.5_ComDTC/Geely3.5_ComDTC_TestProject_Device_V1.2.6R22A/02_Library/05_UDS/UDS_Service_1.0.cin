	if(5==TpRxLength)
		testStepPass("UDS_Ser","Response data length is correct");
	else
		testStepFail("UDS_Ser","Response data length is not correct");
  if((Result==0x00)&&(TpRxData[4]==0x00))
  {
    testStepPass("UDS_Ser","Expected result %d",TpRxData[4]);
  }
  else if((Result==0x00)&&(TpRxData[4]!=0x00))
