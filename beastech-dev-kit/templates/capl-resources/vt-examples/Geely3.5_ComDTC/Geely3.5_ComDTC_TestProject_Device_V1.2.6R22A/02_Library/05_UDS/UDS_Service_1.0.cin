includes
{
  #pragma library("GenSAKey2.dll")
}

variables
{
  
  //TimingParameters
  int UDS_P2Client = 150;
  int UDS_P2ClientDelay = 5000;
  int UDS_P6Client = 5000;
  int UDS_P6ClientDelay = 5000;
  
  int UDS_S3Client = 2000;
  int UDS_S3Server = 5000;

	int Rss;
	//enum AddressMode {physical,functional};
	enum SPRMIB {SPRMIB_True=0x01,SPRMIB_False=0x00};
	//Service0x10
	enum DiagSession {DefaultSession=0x01,ProgrammingSession=0x02,ExtendedSession=0x03,SafetySession=0x04};
  //Service0x11
  enum ResetType {HardReset=0x01,SoftReset=0x03};
  //Service0x22
  struct group
	{
  	int StartPosition;
  	int lenth;
  	int CodingType;
 	};
	//Service0x27
  byte SeedArray[16]={0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0,0x0};
	int MaxKeyArraySize;
	//int SecurityLevel;
	int unlockflag;
	//Service0x28
	enum CommunicationType {NormalCommunicationMessage=0x01,NetworkManagementMessage=0x02,NCMAndNMM=0x03};
	//Service0x2A
	enum TransmissionMode {SendAtSlowRate=0x01,SendAtMediumRate=0x02,SendAtFastRate=0x03,StopSending=0x04};
	//Service0x19
  char supdtcString[15000];//3000 for 200 DTC
  byte AvailiableMask=0xFF;//DTC有效掩码
  byte   supdtc[3000];
  struct DTC
  {
  byte DTCNumber[3];
  byte DTCStatus;
  };
  
  struct RecordStruct
  {
  	dword DTCNumber;
	  byte DTCStatus;
  };
  
  struct DTC DTCNEW[1000];
  struct RecordStruct StorageDTC[1000];
  struct DTC recdtc[1000];
  struct DTC TestDtc[2];
  
  dword  testdtc[2];
	//byte AvailiableMask;
	//Service0x2F
	enum InputOutputControlParameter {ReturnControlToECU=0x00,ResetToDefault=0x01,FreezeCurrentState=0x02};
	//Service0x31
  enum RoutineStatusRecord {CorrectResult=0x00,IncerectResult=0x01};
	enum RoutineControlType {StartRoutine=0x01,StopRoutine=0x02,RequestRoutineStop=0x03};
	//Service0x3E
	
	//Service0x34
	int MaxNumberOfBlockLenth;
	//Service0x36
	int Counter;
	//Service0x37
	int transferResponseParameterRecord;
  
//  byte FixedBytes[5] = {0x43,0x45,0x4D,0x30,0x33};
  byte FixedBytes[16] = {0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff,0xff};
  dword gHandle;
  //27服务的参数
  int SecurityLevel ;
  byte KeyArray[16]={0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01,0x01};//key初始化
//  byte SeedArray[3];
  
  char dllName[400];  //for security constant calculate
  msTimer TesterPresentKeep;
  enum on_offState {P_on,P_off};
}

on timer TesterPresentKeep
{
//  SID3E_TesterPresent(0x80,Physical);
  SID3E_TesterPresent(0x80,Functional);
}


void UDS_ParametersSet(int P2C,int P2CD,int P6C,int P6CD,int S3C,int S3S)
{
  UDS_P2Client = P2C;
  UDS_P2ClientDelay = P2CD;
  UDS_P6Client = P6C;
  UDS_P6ClientDelay = P6CD;
  UDS_S3Client = S3C;
  UDS_S3Server = S3S;
  testStep("UDS_Ser","Parameters configuration:\n  P2Client is %d\n  P2ClientDelay is %d\n  P6Client is %d\n  P6ClientDelay is %d\n  S3Client is %d\n  S3Server is %d");
}


void SID10_DiagnosticSessionControl(int subfunction,enum AddressMode Mode,enum SPRMIB Response)
{
	byte SID10[2];
	SID10[0]=0x10;
	if(Response==0)
		SID10[1]=subfunction;
	else
		SID10[1]=subfunction+0x80;
	PrintPID("UDS_Ser","Request",SID10,elCount(SID10));
	TP_Send(SID10,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void CheckPosResponse_SID10(byte Subfunction)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived when request service0x10");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]==0x50)
	{
		//testStepPass("Chk","PositiveResponseServiceID %x",TpRxData[0]);
	}
	else
	{
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	}
	if(TpRxData[1]==Subfunction)
	{
		//testStepPass("Chk","PositiveResponseSubfunction %x",TpRxData[1]);
	}
	else
	{
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	}
	if(TpRxLength==0x06)
	{
		//testStepPass("Chk","Response data length is correct");
	}
	else
	{
		testStepFail("UDS_Ser","Response data length is not correct");
	}

}

void CheckPosResponse_SID10(byte Subfunction,int P2Server,int P2ServerDelay)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]==0x50)
	{
		//testStepPass("Chk","PositiveResponseServiceID %x",TpRxData[0]);
	}
	else
	{
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	}
	if(TpRxData[1]==Subfunction)
	{
		//testStepPass("Chk","PositiveResponseSubfunction %x",TpRxData[1]);
	}
	else
	{
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	}
	if(TpRxLength==0x06)
	{
		//testStepPass("Chk","Response data length is correct");
	}
	else
	{
		testStepFail("UDS_Ser","Response data length is not correct");
	}
	if((((TpRxData[2]<<8)|TpRxData[3])==P2Server)&&(((TpRxData[4]<<8)|TpRxData[5])==P2ServerDelay))
	{
		//testSteppass("Chk","Parameter P2 is 0x%02x 0x%02x",TpRxData[2],TpRxData[3]);
		//testSteppass("Chk","Parameter P2* is 0x%02x 0x%02x",TpRxData[4],TpRxData[5]);
	}
	else
	{
		testStepfail("UDS_Ser","Parameter P2 is 0x%02x 0x%02x,Expect P2 is 0x%02x",TpRxData[2],TpRxData[3],P2Server);
		testStepfail("UDS_Ser","Parameter P2* is 0x%02x 0x%02x,Expect P2* is 0x%02x",TpRxData[4],TpRxData[5],P2ServerDelay);
	}

}

void SID11_ECUReset(enum ResetType Subfunction,enum SPRMIB Supress,enum AddressMode Mode)
{
	byte SID11[2];
  int usgmod;
  if((gCndtnOfClrDtc==1)||(gCndtnOfClrDtc==3))
  {
    usgmod=gUagMode;
    gUagMode=gUsgCndtnOfClrDtc;
    testStep("Info","Switch UsageMode to 0x%X, in order to reset DUT",gUsgCndtnOfClrDtc);
    testWaitForTimeout(1000);
  }
  
  
	SID11[0]=0x11;
	if(Supress==0)
		SID11[1]=Subfunction;
	else
		SID11[1]=Subfunction+0x80;
	PrintPID("UDS_Ser","hardReset ",SID11,elCount(SID11));
	TP_Send(SID11,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
  
  if((gCndtnOfClrDtc==1)||(gCndtnOfClrDtc==3))
  {
    gUagMode=usgmod;
    testStep("Info","Resume UsageMode to 0x%X",usgmod);
    testWaitForTimeout(1000);
  }
}

void CheckPosResponse_SID11(enum ResetType Subfunction)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x51)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]!=Subfunction)
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if(0x02!=TpRxLength)
		testStepFail("UDS_Ser","Response data length is not correct");
}

void CheckPosResponse_SID11(byte Subfunction,int powerDownTime)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x51)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(0x04!=Subfunction)
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if(0x03!=TpRxLength)
		testStepFail("UDS_Ser","Response data length is not correct");
	if(powerDownTime!=TpRxData[2])
		testStepFail("UDS_Ser","Power down time is not correct");
}

