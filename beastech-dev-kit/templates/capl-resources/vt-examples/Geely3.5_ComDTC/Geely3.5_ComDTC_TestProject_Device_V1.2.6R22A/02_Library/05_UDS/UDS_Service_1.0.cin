	SID2C[4]=sourceDataIdentifier[0];
	SID2C[5]=sourceDataIdentifier[1];
	SID2C[6]=positionInSourceDataRecord;
	SID2C[7]=memorySize;
	PrintPID("UDS_Ser","Request",SID2C,elCount(SID2C));
	TP_Send(SID2C,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
