//  }
}

void CheckPosResponse_SID3D_14(byte MemoryAddress[],byte MemorySize[])
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]==0x7D)
	{
		testStepPass("UDS_Ser","PositiveResponseServiceID %x",TpRxData[0]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]==0x14)
	{
		testStepPass("UDS_Ser","addressAndLengthFormatIdentifier %x",TpRxData[1]);
	}
	else
		testStepFail("UDS_Ser","Unexpect addressAndLengthFormatIdentifier %x",TpRxData[1]);
	if(TpRxData[2]==MemoryAddress[0]&&TpRxData[3]==MemoryAddress[1]&&TpRxData[4]==MemoryAddress[2]&&TpRxData[5]==MemoryAddress[3])
	{
		testSteppass("UDS_Ser","MemoryAddress is 0x%02x,0x%02x,0x%02x,0x%02x",TpRxData[2],TpRxData[3],TpRxData[4],TpRxData[5]);
	}
	else
	{
		testStepfail("UDS_Ser","MemoryAddress is 0x%02x,0x%02x,0x%02x,0x%02x",TpRxData[2],TpRxData[3],TpRxData[4],TpRxData[5]);
	}
	if(TpRxData[6]==MemorySize[0])
	{
		testSteppass("UDS_Ser","MemorySize is 0x%02x",TpRxData[6]);
	}
	else
	{
		testStepfail("UDS_Ser","MemorySize is 0x%02x",TpRxData[6]);
	}
	if(7==TpRxLength)
		testStepPass("UDS_Ser","Response data length is correct");
	else
		testStepFail("UDS_Ser","Response data length is not correct");
}


