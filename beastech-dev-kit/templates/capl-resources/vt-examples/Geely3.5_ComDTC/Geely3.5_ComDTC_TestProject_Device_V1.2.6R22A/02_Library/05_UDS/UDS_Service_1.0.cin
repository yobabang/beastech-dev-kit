{
	byte SID37[10];
	int  i;
	SID37[0]=0x37;
	for(i=0; i<elCount(TransferRequestParameterRecord); i++)
		SID37[i+1]=TransferRequestParameterRecord[i];
	PrintPID("UDS_Ser","RequestTransferExit",SID37,elCount(SID37));
	TP_Send(SID37,elCount(TransferRequestParameterRecord)+1,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void CheckPosResponse_SID37_RequestTransferExit()
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x77)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	transferResponseParameterRecord =TpRxData[1]<<8 + TpRxData[2];
	if(3==TpRxLength)
		testStepPass("UDS_Ser","Response data length is correct");
	else
		testStepFail("UDS_Ser","Response data length is not correct");
}

void CheckPosResponse_SID37_RequestTransferExit(int LenthOfRecord)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x77)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(LenthOfRecord+1!=TpRxLength)
		testStepFail("UDS_Ser","Response data length is not correct");
}

Void SID38_RequestFileTransfer(int modeOfOperation,byte filePathAndNameLength[],int filePathAndName,int dataFormatIdentifier,byte fileSizeparameterLength[],byte fileSizeUncompressed[],byte filesizeCompressed[],enum AddressMode Mode)
{
	byte SID38[12];
	SID38[0]  = 0x38;
	SID38[1]  = modeOfOperation;
	SID38[2]  = filePathAndNameLength[0];
	SID38[3]  = filePathAndNameLength[1];
	SID38[4]  = filePathAndName;
	SID38[5]  = dataFormatIdentifier;
	SID38[6]  = fileSizeparameterLength[0];
	SID38[7]  = fileSizeparameterLength[1];
	SID38[8]  = fileSizeUncompressed[0];
	SID38[9]  = fileSizeUncompressed[1];
	SID38[10] = filesizeCompressed[0];
	SID38[11] = filesizeCompressed[1];
	PrintPID("UDS_Ser","RequestFileTransfer",SID38,elCount(SID38));
	TP_Send(SID38,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void CheckPosResponse_SID38_RequestFileTransfer(int modeOfOperation)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]==0x78)
	{
		testStepPass("UDS_Ser","PositiveResponseServiceID %x",TpRxData[0]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]==modeOfOperation)
	{
		testStepPass("UDS_Ser","PositiveResponsemodeOfOperation %x",TpRxData[1]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[1]);
}


void TPSendRawMessage(byte RawData[],enum AddressMode Mode)
{
	PrintPID("UDS_Ser","Request",RawData,elCount(RawData));
	TP_Send(RawData,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}









void CheckPosResponse(byte SID,int ExpectLength)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	if(SID==(TpRxData[0]-0x40))
	{
		testStepPass("UDS_Ser","PositiveResponseServiceID %x",TpRxData[0]);
		PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(ExpectLength==TpRxLength)
		testStepPass("UDS_Ser","Response data length is correct");
	else
		testStepFail("UDS_Ser","Response data length is not correct");
}

void CheckPosResponse(byte SID)
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	if(SID==(TpRxData[0]-0x40))
	{
		testStepPass("UDS_Ser","PositiveResponseServiceID %x",TpRxData[0]);
		PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
}

int CheckNegResponse(int expectNRC)
{
	if(Rss!=Neg)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return 0;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Nr.Response 0x%02x but get Pos.Response 0x%02x,0x%02x",expectNRC,TpRxData[0],TpRxData[1]);
			return 1;
		}
	}
	if(expectNRC == TpRxData[2])
	{
		PrintPID("UDS_Ser","Neg.Response: ",TpRxData,TpRxLength);
		testStepPass("UDS_Ser","Expect NegativeResponseCode 0x%2x",TpRxData[2]);
    return 1;
	}
	else
	{
		PrintPID("UDS_Ser","Neg.Response: ",TpRxData,TpRxLength);
		NRC_Info(TpRxData[2]);
		testStepFail("UDS_Ser","Unexpect NegativeResponseCode 0x%2x instead of 0x%2x",TpRxData[2],expectNRC);
    return 0;
	}
}


int CheckNegResponse(byte ExpectNRC[],int PosFlag,int NonFlag)
{
	int i;
	int NRCFlag=0;
	if(Rss!=Neg)
	{
		if(Rss==Timeout)
		{
			if(NonFlag==0)
			{
				testStepFail("UDS_Ser","Timeout Non Response recived");
				return 0;
			}
			else
			{
				testStepPass("UDS_Ser","Timeout Non Response recived");
				return 1;
			}

		}
		else
		{
			if(PosFlag==0)
			{
				testStepFail("UDS_Ser","Expect Nr.Response but get Pos.Response");
				return 0;
			}
			else
			{
				testStepPass("UDS_Ser","Get pos response");
				return 1;
			}
		}
	}
	for(i=0; i<elCount(ExpectNRC); i++)
	{
		if(ExpectNRC[i]==TpRxData[2])
			NRCFlag=1;
	}
	if(NRCFlag==1)
	{
		PrintPID("UDS_Ser","Neg.Response: ",TpRxData,TpRxLength);
		testStepPass("UDS_Ser","Expect NegativeResponseCode 0x%2x",TpRxData[2]);
    return 1;
	}
	else
	{
		PrintPID("UDS_Ser","Neg.Response: ",TpRxData,TpRxLength);
		NRC_Info(TpRxData[2]);
		testStepFail("UDS_Ser","Unexpect NegativeResponseCode 0x%2x",TpRxData[2]);
    return 0;
	}
}

void CheckNonResponse()
{
	if(Rss!=Timeout)
	{
		if(Rss==Neg)
		{
			testStepFail("UDS_Ser","Expect No response received but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect No response received but get Pos.Response 0x%02x,0x%02x",TpRxData[0],TpRxData[1]);
			return;
		}
	}
	else
		testStepPass("UDS_Ser","Non Response recived");
}



void CheckCurrentSession(byte expectSession,enum AddressMode Mode)
{
	byte SID22_F186[3]= {0x22,0xf1,0x86};
	TP_Send(SID22_F186,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
	switch(Rss)
	{
	case Pos:
		if(expectSession==TpRxData[3])
			testStepPass("UDS_Ser","Current Session [0x%2x]",TpRxData[3]);
		else
		{
			testStepFail("UDS_Ser","Current Session [0x%2x] Expect [0x%2x]",TpRxData[3],expectSession);
		}
		Rss=Pos;
		break;
	case Timeout:
		Rss=Timeout;
		testStepFail("UDS_Ser","p2/p2* timeout during test");
		break;
	default:
		Rss=Neg;
		testStepfail("UDS_Ser","Unexpect NegativeResponseCode 0x%2x",TpRxData[2]);
		break;
	}
}

void PrintPID(char stepTile[],char Info[],byte Data[],int len)
{
	int i;
	char PrintData[102400];
	for(i=0; i<len; i++)
	{
		if((Data[i]>>4)<10)
			PrintData[i*3]=((Data[i]>>4)+0x30);
		else
			PrintData[i*3]=((Data[i]>>4)+0x37);
		if((Data[i]&0x0F)<10)
			PrintData[i*3+1]=((Data[i]&0x0F)+0x30);
		else
			PrintData[i*3+1]=((Data[i]&0x0F)+0x37);
		PrintData[i*3+2]=0x20;
	}
	PrintData[len*3]='\0';
	testStep(stepTile,"%s [%s]",Info,PrintData);
}

int CheckRxLength(int length)
{
	if(TpRxLength>length)
		return 1;
	else if(TpRxLength==length)
		return 0;
	else
		return -1;
}

