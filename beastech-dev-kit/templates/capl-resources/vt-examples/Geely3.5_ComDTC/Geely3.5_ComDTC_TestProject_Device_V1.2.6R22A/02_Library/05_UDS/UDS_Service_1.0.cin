void SID34_RequestDownload(int dataFormatIdentifier,byte addressAndLengthFormatIdentifier,byte memoryaddress[],byte memorysize[],enum AddressMode Mode)
{
	byte SID34[11];
	int  i,Size,Address;
	SID34[0]  = 0x34;
	SID34[1]  = dataFormatIdentifier;
	SID34[2]  = addressAndLengthFormatIdentifier;
	Size=addressAndLengthFormatIdentifier>>8;
	Address=addressAndLengthFormatIdentifier&0xFF;
	/////MemoryAddress//////
	for(i=0; i<Address; i++)
		SID34[i+3]  = memoryaddress[i];
	/////MemorySize/////////
	for(i=0; i<Size; i++)
		SID34[i+3+Address]  = memorysize[i];
	PrintPID("UDS_Ser","RequestDownload",SID34,elCount(SID34));
	TP_Send(SID34,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

int CheckPosResponse_SID34_RequestDownload(byte lengthFormatIdentifier)
{
	int MaxNumberOfBlockLenth;
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return 0;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return 0;
		}
	}
	MaxNumberOfBlockLenth = (TpRxData[2]<<8) + TpRxData[3] - 2;
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x74)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]==lengthFormatIdentifier)
		testStepFail("UDS_Ser","Unexpect PositiveResponselengthFormatIdentifier  %x",TpRxData[1]);
	if(4!=TpRxLength)
		testStepFail("UDS_Ser","Response data length is not correct");
	return MaxNumberOfBlockLenth;
}

