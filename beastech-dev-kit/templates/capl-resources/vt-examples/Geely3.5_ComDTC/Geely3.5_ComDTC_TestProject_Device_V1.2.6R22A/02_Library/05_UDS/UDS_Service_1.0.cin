void SID2F_IOControl(byte PID[],byte ControlOptionRecord[],enum AddressMode Mode)
{
	int i,length;
	byte SID2F[10];
	SID2F[0]=0x2F;
	SID2F[1]=PID[0];
	SID2F[2]=PID[1];
	SID2F[3]=0x03;
	for(i=0; i<elcount(ControlOptionRecord); i++)
	{
		SID2F[i+4]=ControlOptionRecord[i];
	}
	length=4+elCount(ControlOptionRecord);

	TP_Send(SID2F,length,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void SID2F_IOControl(byte PID[],enum InputOutputControlParameter IOParameter,enum AddressMode Mode)
{
	int i;
	byte SID2F[4];
	SID2F[0]=0x2F;
	SID2F[1]=PID[0];
	SID2F[2]=PID[1];
	SID2F[3]=IOParameter;
	TP_Send(SID2F, Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void CheckPosResponse_SID2F(byte inputOutputControlParameter,byte PID[])
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]!=0x6F)
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]!=PID[0] &&TpRxData[2]!=PID[1])
		testStepFail("UDS_Ser","Response PID is [0x%2x %2x]",TpRxData[1],TpRxData[2]);
//	if(TpRxData[3]!=inputOutputControlParameter)
//		testStepFail("UDS_Ser","Response inputOutputControlParameter is not correct");
}

void SID31_RoutineControl(enum RoutineControlType RoutineType,byte RoutineIdentifier[],byte RoutineControlOptionRecord[],int RecordLenth,enum AddressMode Mode)
{
	int i,length;
	byte SID31[50];
	SID31[0]=0x31;
	SID31[1]=RoutineType;
	SID31[2]=RoutineIdentifier[0];
	SID31[3]=RoutineIdentifier[1];
	for(i=0; i<RecordLenth; i++)
	{
		SID31[i+4]=RoutineControlOptionRecord[i];
	}
	length=4+RecordLenth;
	PrintPID("UDS_Ser","RoutineControl_StartRoutine",SID31,elCount(SID31));
	TP_Send(SID31,length,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
}

void CheckPosResponse_SID31(enum RoutineControlType RoutineType,byte RoutineIdentifier[])
{
	if(Rss!=Pos)
	{
		if(Rss==Timeout)
		{
			testStepFail("UDS_Ser","Timeout Non Response recived");
			return;
		}
		else
		{
			testStepFail("UDS_Ser","Expect Pos.Response but get Neg.Response 0x%02x",TpRxData[2]);
			return;
		}
	}
	PrintPID("UDS_Ser","Pos.Response",TpRxData,TpRxLength);
	if(TpRxData[0]==0x71)
	{
		testStepPass("UDS_Ser","PositiveResponseServiceID %x",TpRxData[0]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseServiceID %x",TpRxData[0]);
	if(TpRxData[1]==RoutineType)
	{
		testStepPass("UDS_Ser","PositiveResponseSubfunction %x",TpRxData[1]);
	}
	else
		testStepFail("UDS_Ser","Unexpect PositiveResponseSubfunction %x",TpRxData[1]);
	if(TpRxData[2]!=RoutineIdentifier[0] && TpRxData[3]!=RoutineIdentifier[1])
		testStepFail("UDS_Ser","Response DID is [0x%2x %2x]",TpRxData[2],TpRxData[3]);
	else
		testSteppass("UDS_Ser","Response DID is [0x%2x %2x]",TpRxData[2],TpRxData[3]);
}

void SID3D_WriteMemoryByAdress_14(byte MemoryAddress[],byte MemorySize[],byte dataRecord[],enum AddressMode Mode)
{
	int i,length;
	byte SID3D[100];
	SID3D[0]=0x3D;
	SID3D[1]=0x14;
	SID3D[2]=MemoryAddress[0];
	SID3D[3]=MemoryAddress[1];
	SID3D[4]=MemoryAddress[2];
	SID3D[5]=MemoryAddress[3];
	SID3D[6]=MemorySize[0];
	for(i=0; i<elcount(dataRecord); i++)
	{
		SID3D[i+7]=dataRecord[i];
	}
	length=7+elCount(dataRecord);

	TP_Send(SID3D,length,Mode);
  if((gBusFlag == 1)||(gBusFlag == 2))
	  Rss=ECU_Response(UDS_P2Client,UDS_P6Client);
  else
    Rss=ECU_Response(UDS_P6Client);
