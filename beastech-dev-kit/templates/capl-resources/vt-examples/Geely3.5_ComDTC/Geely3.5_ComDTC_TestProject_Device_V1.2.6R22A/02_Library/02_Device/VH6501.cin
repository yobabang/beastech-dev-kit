void VH6501_AllAckDelimiterDisturbanceComb(dword DistCycle, dword DistNumber,int index)
{
    CanDisturbanceCombinedFrameTrigger   combFrameTrigger;
    CanDisturbanceFrameTrigger         FrameTrigger;
    CanDisturbanceSequence             Sequence;
    CanDisturbanceTriggerRepetitions   Repetitions;
    long                               Result;
    message*                           TriggerMessage;
    long                               ValidityMask;
    int i;
    Sequence.Clear();
    combFrameTrigger.Clear();
    for(i=0;i<gMsgCont;i++)
    {
      if((i==30)||(NetwrkMsgTemp[index].gAllMsgOfDut[i]==0))
      {
        break;
      }
      TriggerMessage.id=NetwrkMsgTemp[index].gAllMsgOfDut[i];
      FrameTrigger.SetMessage(TriggerMessage, DeviceID, ValidityMask);
      result=combFrameTrigger.AddFrameTrigger(FrameTrigger);
      if(Result==1)
      {}
      else
      {
        teststepFail("Fail","Add frame Trigger failed at %dth times.",i+1);
      }
    }
    combFrameTrigger.TriggerFieldType = @sysvar::CanDisturbance::Enums::FieldType::AckSlot;
    combFrameTrigger.TriggerFieldOffset = 0;
  
    Repetitions.Cycles=DistCycle;
    Repetitions.HoldOffCycles = 0;
    Repetitions.HoldOffRepetitions = 0;
    Repetitions.Repetitions = DistNumber;
    Result = Sequence.AppendToSequence(3*320, 'd');
  
    if(Result == 1)
    {
      Result = canDisturbanceTriggerEnable(DeviceID, combFrameTrigger, Sequence,Repetitions);
      if(Result == 1)
      {
        write("Trigger is successful");
      }
      else
      {
        teststepfail("Step","Enable trigger error Result =%d", Result);
      }
    }
    else
    {
      teststepfail("Append segment to Sequence");
    }
}

