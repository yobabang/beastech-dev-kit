void ALL_BOB_Reset()
{
  byte BOB_SendData[13] = {0x08,0x00,0x00,0x07,0xfe,0x01,0x00,0x00,0x00,0x00,0x00,0x00,0x00};
  @sysvar::PreCmd::BOB_PreCmd::ALL_BOB_Reset=1;
  testWaitForTimeout(200);
  @sysvar::PreCmd::BOB_PreCmd::ALL_BOB_Reset=1;
}


void BackBoneOpen(char NetWork[],enum OperName opername)
{
  char cmd[300];
  char BOB_ID[10]="";
  char BOBID1[20]="";
  dword BOBID;
  long BOB_ID1;
  long BOB_ID2;
  long BOB_ID3;
  long BOB_ID4;
  
  if(strncmp(NetWork,"PropulsionCAN",strlen(NetWork))==0)
  {
    strncpy(BOB_ID,"040F",10);
  }
  if(strncmp(NetWork,"BodyCAN",strlen(NetWork))==0)
  {
    strncpy(BOB_ID,"030B",10);
  }
  if(strncmp(NetWork,"PassiveSafetyCAN",strlen(NetWork))==0)
  {
    strncpy(BOB_ID,"0507",10);
  }
  if(strncmp(NetWork,"ChassisCAN2",strlen(NetWork))==0)
  {
    strncpy(BOB_ID,"051A",10);
  }
  if(strncmp(NetWork,"ChassisCAN1",strlen(NetWork))==0)
  {
    strncpy(BOB_ID,"0514",10);
  }
  if(strncmp(NetWork,"BodyExposedCAN",strlen(NetWork))==0)
  {
    strncpy(BOB_ID,"0523",10);
  }
  
  if(strlen(BOB_ID)>0)
    write("Set bob id to %s",BOB_ID);
  else
    testStepFail("Result","Fail-->Set BOB ID failed, please check Network name and ECUName!");
  snprintf(BOBID1,elcount(BOBID1),"0x%s",BOB_ID);
  BOBID=atol(BOBID1);
  write("BOB_ID:%s",BOBID1);
  write("BOBID:%d",BOBID);
//  BOB_ID1 = BOBID/1000;
//  
//  BOB_ID2 = (BOBID%1000)/100; 
//  BOB_ID3 = (BOBID%100)/10;  
//  BOB_ID4 = BOBID%10;  
//  BOBID =  BOB_ID1*16*16*16+BOB_ID2*16*16+BOB_ID3*16+BOB_ID4;
  BOB_SendData[3] =(byte)(BOBID>>8);
  BOB_SendData[4] =(byte)BOBID;
  BOB_SendData[5] = (byte)(OperCmd[opername]>>56);
  BOB_SendData[6] = (byte)(OperCmd[opername]>>48);
  BOB_SendData[7] = (byte)(OperCmd[opername]>>40);
  
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[0]=BOB_SendData[0];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[1]=BOB_SendData[1];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[2]=BOB_SendData[2];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[3]=BOB_SendData[3];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[4]=BOB_SendData[4];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[5]=BOB_SendData[5];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[6]=BOB_SendData[6];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[7]=BOB_SendData[7];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[8]=BOB_SendData[8];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[9]=BOB_SendData[9];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[10]=BOB_SendData[10];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[11]=BOB_SendData[11];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[12]=BOB_SendData[12];
  @sysvar::PreCmd::BOB_PreCmd::BOBControl=1;
  testWaitForTimeout(200);
  @sysvar::PreCmd::BOB_PreCmd::BOBControl=1;
}
void BOBControl(char NetWork[],char ECUName[],enum OperName opername)
{
  char cmd[300];
  char BOB_ID[10]="";
  dword BOBID;
  long BOB_ID1;
  long BOB_ID2;
  long BOB_ID3;
  long BOB_ID4;
 
      
 
     
  //CAN1-Body CAN（车身）
  if(strncmp(NetWork,"BodyCAN",strlen(NetWork))==0)
  {
    BOBID=BodyCANsetBOBId(ECUName);
  }
  
  //CAN2-Propulsion CAN(动力)
  if(strncmp(NetWork,"PropulsionCAN",strlen(NetWork))==0)
  {
    BOBID=PropulsionCANsetBOBId(ECUName);
  }
  
  
  //CAN3-Passive Safety CAN(被动安全)
  if(strncmp(NetWork,"PassiveSafetyCAN",strlen(NetWork))==0)
  {
    BOBID=PassiveSafetyCANsetBOBId(ECUName);
//    strncpy(BOB_ID,PassiveSafetyCANsetBOBId(ECUName),elCount(PassiveSafetyCANsetBOBId(ECUName)));
  }
 
  //CAN4-Connectivity CAN
  if(strncmp(NetWork,"ConnectivityCAN",strlen(NetWork))==0)
  {
    BOBID=ConnectivityCANsetBOBId(ECUName);
  }
  

  //CAN5-Chassis CAN2
  if(strncmp(NetWork,"ChassisCAN2",strlen(NetWork))==0)
  {
    BOBID=ChassisCAN2setBOBId(ECUName);
  }
  
  //CAN6-Chassis CAN1
  if(strncmp(NetWork,"ChassisCAN1",strlen(NetWork))==0)
  {
    BOBID=ChassisCAN1setBOBId(ECUName);
  }
  
  //CAN7-BodyExposed CAN
  if(strncmp(NetWork,"BodyExposedCAN",strlen(NetWork))==0)
  {
    BOBID=BodyExposedCANsetBOBId(ECUName);
  }
  
  //CAN8  CANFD1
  if(strncmp(NetWork,"SafetyCANFD1",strlen(NetWork))==0)
  {
    BOBID=SafetyCANFD1setBOBId(ECUName);
  }
  
  //CAN9  CANFD2
  if(strncmp(NetWork,"SafetyCANFD2",strlen(NetWork))==0)
  {
    BOBID=SafetyCANFD2setBOBId(ECUName);
  }
  
  //CAN10  CANFD3
  if(strncmp(NetWork,"SafetyCANFD3",strlen(NetWork))==0)
  {
    BOBID=SafetyCANFD3setBOBId(ECUName);
  }
  
  //CAN11  CANFD4
  if(strncmp(NetWork,"SafetyCANFD4",strlen(NetWork))==0)
  {
    BOBID=SafetyCANFD4setBOBId(ECUName);
  }
  
  //CAN12  AD RedundancyCAN
  if(strncmp(NetWork,"ADRedundancyCAN",strlen(NetWork))==0)
  {
    
    BOBID=ADRedundancyCANsetBOBId(ECUName);
  }
  
  
  
    //CAN13-Diagnostic CAN
  if(strncmp(NetWork,"DiagnosticsCan",strlen(NetWork))==0)
  {
    BOBID=DiagnosticsCANsetBOBId(ECUName);
  }
  
  
     //CAN14-IHU Private CAN
  if(strncmp(NetWork,"PrivateInfoCAN",strlen(NetWork))==0)
  {
    BOBID=PrivateInfoCANsetBOBId(ECUName);
  }
 
  
  //CAN15-FLC Private CAN
  if(strncmp(NetWork,"FLC_Flexray",strlen(NetWork))==0)
  {
    BOBID=FLC_PrivateCANsetBOBId(ECUName);
  }
 
  
  //CAN16-SODL_SOLR CANFD
  
  
  /***********Recognize BOB's CAN1 and CAN2************/
  if((strncmp(NetWork,"PropulsionCAN",strlen(NetWork))==0 && strncmp(ECUName,"ECM",strlen(ECUName))==0)||
    (strncmp(NetWork,"ConnectivityCAN",strlen(NetWork))==0 && strncmp(ECUName,"VGM",strlen(ECUName))==0)||
    (strncmp(NetWork,"PassiveSafetyCAN",strlen(NetWork))==0 && strncmp(ECUName,"SRS",strlen(ECUName))==0)||
    (strncmp(NetWork,"ChassisCAN1",strlen(NetWork))==0 && ((strncmp(ECUName,"ECM",strlen(ECUName))==0)||(strncmp(ECUName,"VDDM",strlen(ECUName))==0)||(strncmp(ECUName,"ASDM",strlen(ECUName))==0)))||
    (strncmp(NetWork,"BodyExposedCAN",strlen(NetWork))==0 && strncmp(ECUName,"CEM",strlen(ECUName))==0)||
    (strncmp(NetWork,"SafetyCANFD2",strlen(NetWork))==0 && strncmp(ECUName,"ASDM",strlen(ECUName))==0)||
    (strncmp(NetWork,"SafetyCANFD4",strlen(NetWork))==0 && ((strncmp(ECUName,"ASDM",strlen(ECUName))==0)||(strncmp(ECUName,"PAS",strlen(ECUName))==0)))||
    (strncmp(NetWork,"ADRedundancyCAN",strlen(NetWork))==0 && ((strncmp(ECUName,"BBM",strlen(ECUName))==0)||(strncmp(ECUName,"FLC",strlen(ECUName))==0))))
  {
    switch(opername)
    {
      case CAN1H_OPEN:
        opername=CAN2H_OPEN;
        break;
      case CAN1H_OPEN_R:
        opername=CAN2H_OPEN_R;
        break;
      case CAN1H_BAT:
        opername=CAN2H_BAT;
        break;
      case CAN1H_BAT_R:
        opername=CAN2H_BAT_R;
        break;
      case CAN1H_GND:
        opername=CAN2H_GND;
        break;
      case CAN1H_GND_R:
        opername=CAN2H_GND_R;
        break;
      case CAN1H_CAN1L:
        opername=CAN2H_CAN2L;
        break;
      case CAN1H_CAN1L_R:
        opername=CAN2H_CAN2L_R;
        break;  
      case CAN1L_OPEN:
        opername=CAN2L_OPEN;
        break;
      case CAN1L_OPEN_R:
        opername=CAN2L_OPEN_R;
        break;  
      case CAN1L_BAT:
        opername=CAN2L_BAT;
        break;
      case CAN1L_BAT_R:
        opername=CAN2L_BAT_R;
        break;
      case CAN1L_GND:
        opername=CAN2L_GND;
        break;
      case CAN1L_GND_R:
        opername=CAN2L_GND_R;
        break;
      case CAN1H_CAN1L_OPEN:
        opername=CAN2H_CAN2L_OPEN;
        break; 
      case CAN1H_CAN1L_OPEN_R:
        opername=CAN2H_CAN2L_OPEN_R;
        break;  
    }
  }
  
  if((strncmp(ECUName,"ECM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=PropulsionCANsetBOBId("ECM");
  }
  if((strncmp(ECUName,"ASDM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FlexRaysetBOBId("ASDM");
  }
  if((strncmp(ECUName,"MVEM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=PropulsionCANsetBOBId("MVEM");
  }
  if((strncmp(ECUName,"PSCM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=ChassisCAN1setBOBId("PSCM");
  }
  if((strncmp(ECUName,"TCM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=PropulsionCANsetBOBId("TCM");
  }
  if((strncmp(ECUName,"VGM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FlexRaysetBOBId("VGM");
  }
  if((strncmp(ECUName,"SRS",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FlexRaysetBOBId("SRS");
  }
  if((strncmp(ECUName,"BBM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FlexRaysetBOBId("BBM");
  }
  if((strncmp(ECUName,"IHU",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FlexRaysetBOBId("IHU");
  }
  if((strncmp(ECUName,"CEM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FlexRaysetBOBId("CEM");
  }
  if((strncmp(ECUName,"FLC",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FLC_FlexraysetBOBId("FLC");
  }
  if((strncmp(ECUName,"VDDM",strlen(ECUName))==0)&&(opername==KL30_KL15_OPEN || opername==KL30_KL15_OPEN_R || opername==OFFSET_GND_EN || opername==OFFSET_GND_Dis||opername==ECU_GND_OPEN||opername==ECU_GND_OPEN_R))
  {
    BOBID=FlexRaysetBOBId("VDDM");
  }
   //LIN
  if(strncmp(NetWork,"LIN",strlen(NetWork))==0)
  {
    BOBID=LINsetBOBId(ECUName);
  }
  
  
  if(BOBID>0)
    write("Set bob id to 0x%x",BOBID);
  else
    testStepFail("Result","Fail-->Set BOB ID failed, please check Network name and ECUName!");
  
  BOB_SendData[3] =(byte)(BOBID>>8);
  BOB_SendData[4] =(byte)BOBID;
  BOB_SendData[5] = (byte)(OperCmd[opername]>>56);
  BOB_SendData[6] = (byte)(OperCmd[opername]>>48);
  BOB_SendData[7] = (byte)(OperCmd[opername]>>40);
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[0]=BOB_SendData[0];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[1]=BOB_SendData[1];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[2]=BOB_SendData[2];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[3]=BOB_SendData[3];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[4]=BOB_SendData[4];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[5]=BOB_SendData[5];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[6]=BOB_SendData[6];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[7]=BOB_SendData[7];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[8]=BOB_SendData[8];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[9]=BOB_SendData[9];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[10]=BOB_SendData[10];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[11]=BOB_SendData[11];
  @sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[12]=BOB_SendData[12];
  @sysvar::PreCmd::BOB_PreCmd::BOBControl=1;
  testWaitForTimeout(200);
  @sysvar::PreCmd::BOB_PreCmd::BOBControl=1;
}

dword PropulsionCANsetBOBId(char ECUName[])
{
  char BOB_ID[10]="";
  char BOB_ID1[10]="";
  dword BOBID;

  if(strncmp(ECUName,"SRS",strlen(ECUName))==0)
    strncpy(BOB_ID,"020D",10);
  if(strncmp(ECUName,"VDDM",strlen(ECUName))==0)
    strncpy(BOB_ID,"0211",10);
  if(strncmp(ECUName,"VGM",strlen(ECUName))==0)
    strncpy(BOB_ID,"020B",10);
  if(strncmp(ECUName,"CAN2_RESERVED1",strlen(ECUName))==0)
    strncpy(BOB_ID,"0207",10);
  if(strncmp(ECUName,"ECM",strlen(ECUName))==0)
    strncpy(BOB_ID,"0201",10);
  if(strncmp(ECUName,"MVEM",strlen(ECUName))==0)
    strncpy(BOB_ID,"050B",10);
  if(strncmp(ECUName,"CAN2_RESERVED2",strlen(ECUName))==0)
    strncpy(BOB_ID,"0412",10);
  if(strncmp(ECUName,"CAN2_RESERVED3",strlen(ECUName))==0)
    strncpy(BOB_ID,"0411",10);
  if(strncmp(ECUName,"CAN2_RESERVED4",strlen(ECUName))==0)
    strncpy(BOB_ID,"0410",10);
  if(strncmp(ECUName,"TACM",strlen(ECUName))==0)
    strncpy(BOB_ID,"040F",10);
  if(strncmp(ECUName,"CAN2_RESERVED5",strlen(ECUName))==0)
    strncpy(BOB_ID,"040E",10);
  if(strncmp(ECUName,"DEM",strlen(ECUName))==0)
    strncpy(BOB_ID,"040D",10);
  if(strncmp(ECUName,"EGSM",strlen(ECUName))==0)
    strncpy(BOB_ID,"040C",10);
  if(strncmp(ECUName,"MVCM",strlen(ECUName))==0)
    strncpy(BOB_ID,"040B",10);
  if(strncmp(ECUName,"MVBM",strlen(ECUName))==0)
    strncpy(BOB_ID,"040A",10);
  if(strncmp(ECUName,"ISGM",strlen(ECUName))==0)
    strncpy(BOB_ID,"0409",10);
  if(strncmp(ECUName,"MGM",strlen(ECUName))==0)
    strncpy(BOB_ID,"0408",10);
  if(strncmp(ECUName,"CDD",strlen(ECUName))==0)
    strncpy(BOB_ID,"0407",10);
  if(strncmp(ECUName,"IGM",strlen(ECUName))==0)
    strncpy(BOB_ID,"0406",10);
  if(strncmp(ECUName,"OBC",strlen(ECUName))==0)
    strncpy(BOB_ID,"0405",10);
  if(strncmp(ECUName,"ESM",strlen(ECUName))==0)
    strncpy(BOB_ID,"0404",10);
  if(strncmp(ECUName,"IEM",strlen(ECUName))==0)
    strncpy(BOB_ID,"0403",10);
  if(strncmp(ECUName,"WPT",strlen(ECUName))==0)
    strncpy(BOB_ID,"0402",10);
