/*@!Encoding:936*/

void VTSystem_InitConfig()
{
  
  VT7001_InitConfig();
}

void VT7001_InitConfig()
{
  if(gVTIntSupplyFlag)
  {
    sysvar::VTS::M1_VT7001.SetInterconnectionMode(eVTSInterconnectionModeSupInt);
    sysvar::VTS::M1_SupInt.SetRefVoltageMode(eVTSRefVoltageModeConstant);
  }
  else
  {
    sysvar::VTS::M1_VT7001.SetInterconnectionMode(1);
  }
}

void VT7001_OutNumActSet(int OutNum,int Sts)
{
  switch(OutNum)
  {
    case 1:
      @sysvar::VTS::M1_Out1::Active = Sts;
      break;
    case 2:
      @sysvar::VTS::M1_Out2::Active = Sts;
      break;
    default:
      testStepWarning("VT","Invalid channel used only 1/2 are avliable.");
      break;
  }
}
