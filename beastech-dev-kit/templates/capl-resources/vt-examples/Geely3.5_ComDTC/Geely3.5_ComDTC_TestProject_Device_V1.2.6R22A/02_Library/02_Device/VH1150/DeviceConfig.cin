/// <FaultOnLIN>
void LINBusFaultSet(enum LinFaultType fault)
{
  switch(fault)
  {
    case LIN_BAT:
//      LIN2BAT(T_on);
      VHDevSetBusFaults(gDevHandle,0,2,0);
      break;
      
    case LIN_GND:
//      LIN2GND(T_on);
      VHDevSetBusFaults(gDevHandle,0,1,0);
      break;
    case LIN_FltRst:
      VHDevSetBusFaults(gDevHandle,0,0,0);
      break;
  }
}
