/// <FaultOnFR>
void FRBusFaultSet(enum FRFaultType fault)
{
  switch(fault)
  {
    case BP_ShortTo_BM:      
      StopKeySlot();
      resetFlexRayCCEx(gresumFrmChnl_FR,1,50,180,60,"");
      testWaitForTimeout(100);
      testStep("Info","Stop the keyslot");
//      BP2BM(T_on);
      break;
      
    case BP_BAT:
      
      break;
      
    case BP_GND:
//      CANH2G(T_on);
      break;
      
    case BM_BAT:
      break;
      
    case BM_GND:
      break;
      
    case BP_Open:
      
      break;
      
    case BM_Open:
      break;
      
    case FrFlt_Rst:
      if(gresumFrmChnl_FR==1)
      {
        frSetKeySlot(1,1,1,KeySlot1,3);//RXQ, 
        frSetKeySlot(1,1,2,KeySlot2,1);
        resetFlexRayCCEx(gresumFrmChnl_FR,1,50,180,60,"");
        NetwrkRequestOnTPBus();
        TRC();
        SimVehBat(gUbat12);
      }
      testStep("Info","Reset FR Fault.");      
      break;
    
    Default:
      testStepFail("Fail","Set fail -> Unknown type of VH6501_CANBusFaultSet!");
      break;
  }
}
/// <FaultOnFR>
void FRBusFaultReset()
{
//  AllDeviceInit();
  testWaitForTimeout(100);
  resetFlexRayCCEx(gresumFrmChnl_FR,1,50,180,60,"");
  TRC();
  SimVehBat(0x82);
}

