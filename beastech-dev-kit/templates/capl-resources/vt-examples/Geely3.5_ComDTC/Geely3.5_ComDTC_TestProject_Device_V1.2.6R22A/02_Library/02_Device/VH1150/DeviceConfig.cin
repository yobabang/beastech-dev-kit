void TestWaitForCurInRange(float current,long time)
{
  int i;
  float Cur[1];
  for(i=0;i<(time/1000);i++)
  {
    VH1150_CurrentGet(Cur);
    testWaitForTimeout(1000);
    if(Cur[0]<=current)
    {
      testStepPass("Pass","The current is %5.3fmA",Cur[0]);
      break;
    }
    
  }
  if(i==(time/1000))
  {
    testStepWarning("Warning","Time out! The current is %5.3fmA, expected is %5.3fmA",Cur[0],current);
  }
  testWaitForTimeout(2000);

}

float GetVolt()
{
  float volt[1];
  VH1150_VoltageGet(volt);
  return volt[0];
}