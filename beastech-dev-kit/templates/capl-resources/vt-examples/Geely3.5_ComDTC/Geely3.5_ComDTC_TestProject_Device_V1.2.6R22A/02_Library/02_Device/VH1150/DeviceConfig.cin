/// <FaultOnCAN>
void CANBusFaultSet(enum FRFaultType fault)
{
  switch(fault)
  {
    case BP_ShortTo_BM:
//      ENV_CANH_CANL();
//      testWaitForTimeout(100);
      testStep("Info","Short CANH to CANL");
      break;
      
    case BP_BAT:
//      ENV_CANH_VB();
//      testWaitForTimeout(100);
      testStep("Info","Short CANH to BAT");
      break;
      
    case BP_GND:
//      ENV_CANH_GND();
//      testWaitForTimeout(100);
      testStep("Info","Short CANH to GND");
      break;
      
    case BM_BAT:
//      ENV_CANL_VB();
//      testWaitForTimeout(100);
      testStep("Info","Short CANL to BAT");
      break;
      
    case BM_GND:
//      ENV_CANL_GND();
//      testWaitForTimeout(100);
      testStep("Info","Short CANL to GND");
      break;
      
    case BP_Open:
//      CANHIN_CANHOUT();
//      testWaitForTimeout(100);
      VHDevSetBusFaults(gDevHandle,1,0,0);
      testStep("Info","Open CANH");
      break;
    case BM_Open:
//      CANLIN_CANLOUT();
//      testWaitForTimeout(100);
      VHDevSetBusFaults(gDevHandle,2,0,0);
      testStep("Info","Open CANL");
      break;
    case FrFlt_Rst:
//      ENV_Reset();
//      testWaitForTimeout(100);
      VHDevSetBusFaults(gDevHandle,0,0,0);
      testStep("Info","Reset CAN Bus Fault.");
      break;
    Default:
      testStepFail("Fail","Unknown type of CAN bus Fault!");
      break;
  }
}
