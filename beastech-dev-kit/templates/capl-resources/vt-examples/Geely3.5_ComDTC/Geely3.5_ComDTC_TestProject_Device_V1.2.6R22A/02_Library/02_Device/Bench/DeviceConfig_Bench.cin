/// <FaultOnCAN>
void CANBusFaultSet(enum FRFaultType fault)
{
  switch(fault)
  {
    case BP_ShortTo_BM:
      ENV_CANH_CANL();
      testWaitForTimeout(100);
      testStep("Info","Short CANH to CANL");
      break;
      
    case BP_BAT:
      ENV_CANH_VB();
      testWaitForTimeout(100);
      testStep("Info","Short CANH to BAT");
      break;
      
    case BP_GND:
      ENV_CANH_GND();
      testWaitForTimeout(100);
      testStep("Info","Short CANH to GND");
      break;
      
    case BM_BAT:
      ENV_CANL_VB();
      testWaitForTimeout(100);
      testStep("Info","Short CANL to BAT");
      break;
      
    case BM_GND:
      ENV_CANL_GND();
      testWaitForTimeout(100);
      testStep("Info","Short CANL to GND");
      break;
      
    case BP_Open:
      CANHIN_CANHOUT();
      testWaitForTimeout(100);
      testStep("Info","Open CANH");
      break;
      
    case BM_Open:
      CANLIN_CANLOUT();
      testWaitForTimeout(100);
      testStep("Info","Open CANL");
      break;
    case FrFlt_Rst:
      ENV_Reset();
      testWaitForTimeout(100);
      testStep("Info","Reset CAN Bus Fault.");
      break;
    Default:
      testStepFail("Fail","Unknown type of CAN bus Fault!");
      break;
  }
}
/// <FaultOnCAN>
void CANBusFaultReset()
{
  ENV_Reset();
  testWaitForTimeout(100);
  DRB_ALL_RESET();
  
  testStep("Info","Reset all channel.");
  testwaitfortimeout(500);
}


void TestWaitForCurInRange(float current,long time)
{
  float cur;
  if(testWaitForSignalInRange(sysvar::VTS::M1_Out1::AvgCurrent,0,current/1000.0,time)>0)
  {
    cur=@sysvar::VTS::M1_Out1::AvgCurrent;
    testStepPass("Pass","The current is %5.3fmA",cur*1000);
  }
  else
  {
    cur=@sysvar::VTS::M1_Out1::AvgCurrent;
    testStepWarning("Warning","Time out! The current is %5.3fmA, expected is %5.3fmA",cur*1000,current);
  }
  testWaitForTimeout(2000);

}

