void ALL_BOB_Reset()
{
  byte BOB_SendData[13] = {0x08,0x00,0x00,0x07,0xfe,0x01,0x00,0x00,0x00,0x00,0x00,0x00,0x00};
  SendTcpData_BYTE(BOB_SendData,TEH_CAN0_Socket);
}

on sysvar_update sysvar::PreCmd::BOB_PreCmd::ALL_BOB_Reset
{
  byte BOB_SendData[13] = {0x08,0x00,0x00,0x07,0xfe,0x01,0x00,0x00,0x00,0x00,0x00,0x00,0x00};
  SendTcpData_BYTE(BOB_SendData,TEH_CAN0_Socket);
}

