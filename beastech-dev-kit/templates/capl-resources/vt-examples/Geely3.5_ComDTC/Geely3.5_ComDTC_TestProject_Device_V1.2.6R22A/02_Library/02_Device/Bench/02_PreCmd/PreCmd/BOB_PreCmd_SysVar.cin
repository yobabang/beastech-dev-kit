on sysvar_update sysvar::PreCmd::BOB_PreCmd::BOBControl
{
  byte BOB_SendData[13];
  BOB_SendData[0]=@sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[0];
  BOB_SendData[1]=@sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[1];
