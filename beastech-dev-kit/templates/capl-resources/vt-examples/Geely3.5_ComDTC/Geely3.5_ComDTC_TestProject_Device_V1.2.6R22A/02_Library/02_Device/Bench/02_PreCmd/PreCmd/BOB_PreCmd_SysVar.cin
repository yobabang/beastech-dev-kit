  BOB_SendData[5]=@sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[5];
  BOB_SendData[6]=@sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[6];
  BOB_SendData[7]=@sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[7];
  BOB_SendData[8]=@sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[8];
  BOB_SendData[9]=@sysvarMember::PreCmd::BOB_PreCmd::BOB_SendData[9];
