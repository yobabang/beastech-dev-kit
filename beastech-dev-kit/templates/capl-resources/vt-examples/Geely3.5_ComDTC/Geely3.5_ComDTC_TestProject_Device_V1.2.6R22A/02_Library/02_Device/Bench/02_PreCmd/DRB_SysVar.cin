/*@!Encoding:936*/
includes
{

}
variables
{
  int Offset_Volt_CANH_State = 0 ;
  int Offset_Volt_CANL_State = 0;
  msTimer timer1;
  msTimer timer2;
  msTimer timer3;
  msTimer timer4;
  
}
On timer timer1
{
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
}
On timer timer2
{
  DRB2_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
}
On timer timer3
{
  DRB3_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
}
On timer timer4
{
  DRB4_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
}

