void DRB_ALL_RESET()
{
  DRB1_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
  //testWaitForTimeout(100);
    DRB2_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
  //testWaitForTimeout(100);
    DRB3_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
  //testWaitForTimeout(100);
    DRB4_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
  //testWaitForTimeout(100);
  
}

on sysvar_update sysvar::DRB::DRB_ALL_RESET
{
  DRB1_Cmd ();
  DRB_Reset();
  SendTcpData_BYTE(DRB_SendData,TEH_CAN1_Socket);
  //testWaitForTimeout(100);
  setTimer(timer2,100);
  //testWaitForTimeout(100);
  setTimer(timer3,200);
  //testWaitForTimeout(100);
  setTimer(timer4,300);
  //testWaitForTimeout(100);
  
}


