on sysvar_update sysvar::PreCmd::Agilennt_PCS_PreCmd::TIMebase_SCALE
{
  SendTcpData(":TIMebase:SCALe 0.00001\n",PCS_Socket);
}
on sysvar_update sysvar::PreCmd::Agilennt_PCS_PreCmd::OSC_TRIGger_MODE_SOF
{
  SendTcpData(":TRIGger:MODE SBUS1\n",PCS_Socket);
  SendTcpData(":SBUS1:MODE CAN\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SOURce CHAnnel1\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SIGNal:BAUDrate 500000\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SIGNal:DEFinition CANH\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:TRIGger SOF\n",PCS_Socket);
}
on sysvar_update sysvar::PreCmd::Agilennt_PCS_PreCmd::MEASure_PEDGes_CHAnnel1
{
  SendTcpData(":MEASure:PEDGes CHANnel1 \n",PCS_Socket);
  SendTcpData(":MARKer:MODE WAVeform\n",PCS_Socket);
}
on sysvar_update sysvar::PreCmd::Agilennt_PCS_PreCmd::OSC_Cursor_Xdelta_Meas
{
  SendTcpData(":MEASure:TDELta\n",PCS_Socket);
}

on sysvar_update sysvar::PCS::PCS_BitsTime_Get
{
  BitsTime=atodbl(PCS_RecvData)*1000000;
  write("BitsTime:%f",BitsTime);
  @sysvar::PCS::PCS_BitsTime=BitsTime;
}