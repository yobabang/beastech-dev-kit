void OSC_Picture_Name_Set_Dominant()//新增函数
{

  sysGetVariableString(sysvar::PCS::Node_Name,nodename,200);
  getlocaltime(t1);
  for(seq=0;seq<9;seq++)
  {
    t2[seq]=t1[seq];
  }
  snprintf(t3,50,"%d-%d-%d_%d-%d-%d",t2[5]+1900,t2[4]+1,t2[3],t2[2],t2[1],t2[0]);
  
  //图片名区别
  
  snprintf(picname,150,"");
  snprintf(picname,150,"%s_%d_%s",nodename,@sysvar::PCS::PCS_Picture_Outer_Cycle+1,t3); 
  
  //保存图片
  snprintf(picpath,200,"");
  snprintf(sharepath,200,"");         
  snprintf(picpath,200,"C:\\pic\\%s_dominant.png",picname);
  snprintf(sharepath,200,"\\\\192.168.7.1\\pic\\%s_dominant.png",picname);
  sysSetVariableString(sysvar::PCS::PCS_Picture_Sharepath,sharepath);//将图片地址传给系统变量
  
}

on sysvar_update sysvar::PCS::PCS_Picture_Name_Dominant
{
  OSC_Picture_Name_Set_Dominant();
}

