void OSC_CAN_Init()
{
  SendTcpData(":RUN\n",PCS_Socket);
  SendTcpData(":CHANnel1:SCALe 1V\n",PCS_Socket);
  SendTcpData(":CHANnel2:SCALe 1V\n",PCS_Socket);
  SendTcpData("CHANnel1:OFFSet 1\n",PCS_Socket);
  SendTcpData("CHANnel2:OFFSet 1\n",PCS_Socket);
  SendTcpData(":CHANnel1:DISPlay 1\n",PCS_Socket);
  SendTcpData(":CHANnel2:DISPlay 1\n",PCS_Socket);
  
  SendTcpData(":TIMebase:REFerence LEFT\n",PCS_Socket);
  SendTcpData(":TIMebase:SCALe 0.000002\n",PCS_Socket);
  SendTcpData(":TIMebase:POSition 0\n",PCS_Socket);
  
  SendTcpData(":SBUS1:MODE CAN\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SOURce CHAnnel1\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SIGNal:BAUDrate 500000\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SIGNal:DEFinition CANH\n",PCS_Socket);
  
  SendTcpData(":TRIGger:SWEep NORMAL\n",PCS_Socket);
  SendTcpData(":TRIGger:MODE EDGE\n",PCS_Socket);
  SendTcpData(":TRIGger:EDGE:SLOPe POSitive\n",PCS_Socket);
  SendTcpData(":TRIGger:EDGE:SOURce CHAN1 \n",PCS_Socket);
  SendTcpData(":TRIGger:EDGE:LEVel 3.1 \n",PCS_Socket);
  
  SendTcpData(":FUNCtion2:DISPlay 1\n",PCS_Socket);
  testWaitForTimeout(500);
  SendTcpData(":FUNCtion2:SOURCE1 CHANnel1\n",PCS_Socket);
  SendTcpData(":FUNCtion2:SOURCE2 CHANnel2\n",PCS_Socket);
  SendTcpData(":FUNCtion2:OPERation SUBTract\n",PCS_Socket);
  testWaitForTimeout(500);
  SendTcpData(":FUNCtion2:SCALe 1V\n",PCS_Socket);
  testWaitForTimeout(500);
  SendTcpData(":FUNCtion2:OFFSet 3\n",PCS_Socket);
  testWaitForTimeout(500);
  
  SendTcpData(":MEASure:STATistics:DISPlay 0\n",PCS_Socket);
  SendTcpData(":MEASure:STATistics ON\n",PCS_Socket);
  SendTcpData(":CHANnel3:DISplay OFF \n",PCS_Socket);
  
}

on sysvar_update sysvar::PreCmd::Agilennt_PCS_PreCmd::OSC_CAN_Init
{
  OSC_CAN_Init();
}
  
on sysvar_update sysvar::PreCmd::Agilennt_PCS_PreCmd::OSC_ID_VALUE
{
  OSC_ID_Result();
}
  
