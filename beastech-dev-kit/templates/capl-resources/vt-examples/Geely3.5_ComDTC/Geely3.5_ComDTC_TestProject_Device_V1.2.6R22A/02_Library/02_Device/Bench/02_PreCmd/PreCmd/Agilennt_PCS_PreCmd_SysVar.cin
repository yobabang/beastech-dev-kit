  SendTcpData(":CHANnel1:DISPlay 1\n",PCS_Socket);
  SendTcpData(":CHANnel2:DISPlay 0\n",PCS_Socket);
  SendTcpData(":FUNCtion:DISPlay 0\n",PCS_Socket);
  SendTcpData(":TIMebase:SCALe 0.0002\n",PCS_Socket);
  SendTcpData(":TIMebase:POSition 0\n",PCS_Socket);
  SendTcpData(":TRIGger:SWEep AUTO\n",PCS_Socket);
  
}

