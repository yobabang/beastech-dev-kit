{
  OSC_id_trigger();
}

void OSC_id_trigger()
{
  SendTcpData("*CLS\n",PCS_Socket);
  SendTcpData(":RUN\n",PCS_Socket);
  SendTcpData(":CHANnel1:SCALe 1V\n",PCS_Socket);
  SendTcpData(":CHANnel2:SCALe 1V\n",PCS_Socket);
  SendTcpData("CHANnel1:OFFSet 1\n",PCS_Socket);
  SendTcpData("CHANnel2:OFFSet 1\n",PCS_Socket);
  SendTcpData(":CHANnel1:DISPlay 1\n",PCS_Socket);
  SendTcpData(":CHANnel2:DISPlay 1\n",PCS_Socket);
 
  SendTcpData(":TRIGger:SWEep NORMAL\n",PCS_Socket);
  SendTcpData(":TIMebase:SCALe 0.000002\n",PCS_Socket);
  SendTcpData(":TIMebase:Position 0\n",PCS_Socket);
  SendTcpData(":TIMebase:REFerence CENTer\n",PCS_Socket);
  SendTcpData(":TRIGger:EDGE:LEVel 3.50 \n",PCS_Socket); 
  SendTcpData(":TRIGger:MODE SBUS1\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SOURce CHAnnel1\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:SIGNal:DEFinition CANH\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:TRIGger:PATTern:ID:MODE STANdard\n",PCS_Socket);
  SendTcpData(":SBUS1:CAN:TRIGger IDData\n",PCS_Socket);
  SendTcpData(":FUNCtion:DISPlay 1\n",PCS_Socket);
  SendTcpData(":FUNCtion:SOURCE1 CHANnel1\n",PCS_Socket);
  SendTcpData(":FUNCtion:SOURCE2 CHANnel2\n",PCS_Socket);
  SendTcpData(":FUNCtion:OPERation SUBTract\n",PCS_Socket);
  SendTcpData(":FUNCtion:SCALe 1V\n",PCS_Socket);
  SendTcpData(":FUNCtion:OFFSet 3\n",PCS_Socket);
  SendTcpData(":MEASure:STATistics:DISPlay 1\n",PCS_Socket);
  SendTcpData(":MEASure:STATistics ON\n",PCS_Socket);
  
  OSC_IDTrigger();
}


void OSC_IDTrigger()
{
  char c1[200]="";
  char id[20]="";
  char cmd[200]="";
  long res;
  char buf[20];
  sysGetVariableString(sysvar::OSC::ID,buf,20);
  snprintf(id,20,"%s", buf);
  write("Id is %s",id);
  strncpy(c1,":SBUS1:CAN:TRIGger:PATTern:ID Parameter1\n",200);
  str_replace_regex(c1,"Parameter1",id);
  strncpy(cmd,c1,200);
  write("%s",cmd);
  SendTcpData(cmd,PCS_Socket);
}
void OSC_ID_Result()
{
  Rcv_Begin=1;
  Rcv_Size=0;
  SendTcpData(":SBUS1:CAN:TRIGger:PATTern:ID?\n",PCS_Socket);
}
