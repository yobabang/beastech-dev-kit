  char cmd[100]="";
  long res;
  float iv;
  double Curr;
  Curr=@this;
  if(Curr>20)
    iv=20;
  else
    iv=Curr;
  strncpy(c1,"CURR:LIM Parameter1, (@1)\n",100);
  snprintf(Current,10,"%.2f", iv);
