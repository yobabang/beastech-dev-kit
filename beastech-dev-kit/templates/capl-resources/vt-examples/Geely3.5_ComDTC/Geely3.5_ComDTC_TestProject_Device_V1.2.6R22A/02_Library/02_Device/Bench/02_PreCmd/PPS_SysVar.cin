on sysvar_update sysvar::PPS::PPS_PowerSet
{
  char c1[100]="";
  char c2[100]="";
  char Voltage[10]="";
  char Current[10]="";
  char cmd[100]="";
  long res;
  float iv,ic;
  double Volt;
  double Curr;
  Volt=@this[0];
  Curr=@this[1];
  if(Volt>30)
    iv=30;
  else
    iv=Volt;
//  if(Curr>3)
//    ic=3;
  if(Curr>20)
    ic=20;
  else
    ic=Curr;
  strncpy(c1,"VOLT Parameter1, (@2)\n",100);
  strncpy(c2,"CURR Parameter2, (@2)\n",100);
  snprintf(Voltage,10,"%.2f", iv);
  snprintf(Current,10,"%.2f", ic);
  str_replace_regex(c1,"Parameter1",Voltage);
  str_replace_regex(c2,"Parameter2",Current);
  strncpy(cmd,c2,100);
  SendTcpData(cmd,PPS_Socket);
//  testWaitForTimeout(100);
  strncpy(cmd,c1,100);
  SendTcpData(cmd,PPS_Socket);
}


