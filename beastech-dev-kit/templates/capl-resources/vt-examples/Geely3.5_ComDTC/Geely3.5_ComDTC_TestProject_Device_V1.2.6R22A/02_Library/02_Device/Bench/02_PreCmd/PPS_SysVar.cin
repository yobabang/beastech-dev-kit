on sysvar_update sysvar::PPS::PPS_ShowVoltage
{
  switch (@sysvar::PPS::PPS_ShowVoltage[0])
  {
    case 1:
  sysvar::VTS::M1_Out1::AvgVoltage.SetTransferCycle(@sysvar::PPS::PPS_ShowVoltage[1]);

      break;
    case 2:
  sysvar::VTS::M1_Out2::AvgVoltage.SetTransferCycle(@sysvar::PPS::PPS_ShowVoltage[1]);

      break;
    default:
      testStepFail("Fail","Command fail -> Unknown command");
      break;
  }
}
