on sysvar_update sysvar::PPS::PPS_Shift_OutputStsSet
{
  if(@this==1)
    @sysvar::PreCmd::Agilennt_PPS_PreCmd::Agilent_Offset_PPS_OnOff=1;
  else
    @sysvar::PreCmd::Agilennt_PPS_PreCmd::Agilent_Offset_PPS_OnOff=0;
}

