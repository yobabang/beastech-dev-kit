on sysvar_update sysvar::PPS::PPS_Shift_PowerSet
{
  char c1[100]="";
  char c2[100]="";
  char Voltage[10]="";
  char Current[10]="";
  char cmd[100]="";
  long res;
  float iv,ic;
  double Volt;
  double Curr;
  Volt=@this[0];
  Curr=@this[1];
  if((Volt>6))
    iv=6;
  else
    iv=Volt;
  if(Curr>5)
    ic=5;
  else
    ic=Curr;
  writeToLog("Voltage = %f Current Limit = %f",iv,ic);
  strncpy(c1,"VOLT Parameter1, (@1)\n",100);
  strncpy(c2,"CURR:LIM Parameter2, (@1)\n",100);
  snprintf(Voltage,10,"%.2f", iv);
  snprintf(Current,10,"%.2f", ic);
  str_replace_regex(c1,"Parameter1",Voltage);
  str_replace_regex(c2,"Parameter2",Current); 
  strncpy(cmd,c2,100);
  SendTcpData(cmd,PPS_Socket);
//  testWaitForTimeout(100);
  strncpy(cmd,c1,100);
  SendTcpData(cmd,PPS_Socket);
}


void PPS_VoltageSet(float Volt)
{
  char c1[100]="";
  char Voltage[10]="";
  char cmd[100]="";
  long res;
  float iv;
  if(Volt>30)
    iv=30;
  else
    iv=Volt;
  strncpy(c1,"VOLT Parameter1, (@2)\n",100);
  snprintf(Voltage,10,"%.2f", iv);
  str_replace_regex(c1,"Parameter1",Voltage);
  strncpy(cmd,c1,100);
  SendTcpData(cmd,PPS_Socket);
}

