on sysvar_update sysvar::PPS::PPS_Shift_VoltageSet
{
  char c1[100]="";
  char Voltage[10]="";
  char cmd[100]="";
  long res;
  float iv;
  double Volt;
  Volt=@this;
  if(Volt>30)
    iv=30;
  else
    iv=Volt;
  
  strncpy(c1,"VOLT Parameter1, (@1)\n",100);
  snprintf(Voltage,10,"%.2f", iv);
  str_replace_regex(c1,"Parameter1",Voltage);
  strncpy(cmd,c1,100);
  SendTcpData(cmd,PPS_Socket);
}
