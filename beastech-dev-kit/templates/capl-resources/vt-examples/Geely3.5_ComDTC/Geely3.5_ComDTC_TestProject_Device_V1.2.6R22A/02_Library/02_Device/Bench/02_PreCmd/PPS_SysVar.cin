on sysvar_update sysvar::PPS::PPS_VoltageMeasure
{
  double Volt;
  @sysvar::PreCmd::Agilennt_PPS_PreCmd::Agilent_PPS_VOLTAGE_MEAS=1;
//  TestWaitForTimeout(500);
  write ("TIME %f",timenow()/100.0);
  strtod(PPS_RecvData,Volt);
  @sysvar::PPS::PPS_VoltageMeasure_Value=Volt;
//  teststep("Info","Current:%fV",Volt);
//  write ("Volt = %f",Volt);
//  return(Volt);
}

