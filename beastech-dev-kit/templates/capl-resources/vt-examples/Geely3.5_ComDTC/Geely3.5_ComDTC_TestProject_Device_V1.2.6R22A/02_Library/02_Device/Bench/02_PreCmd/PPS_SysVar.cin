on sysvar_update sysvar::PPS::PPS_InitConfig
{
  @sysvar::PPS::PPS_OutputStsSet=0;//OFF
  @sysvar::PPS::PPS_Shift_OutputStsSet=0;//OFF
  @sysvarMember::PPS::PPS_PowerSet[0]=13.8;//Volt
  @sysvarMember::PPS::PPS_PowerSet[1]=20;//Curr
  @sysvar::PPS::PPS_Shift_PowerSet[0]=0;//Volt
  @sysvar::PPS::PPS_Shift_PowerSet[1]=5;//Curr
  testWaitForTimeout(3000);
  @sysvar::PPS::PPS_OutputStsSet=1;//ON
  @sysvar::PPS::PPS_Shift_OutputStsSet=0;//OFF

}

