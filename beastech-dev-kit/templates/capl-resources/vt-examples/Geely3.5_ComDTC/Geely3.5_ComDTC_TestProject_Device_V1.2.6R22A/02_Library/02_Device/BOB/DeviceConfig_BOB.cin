void AllDeviceInit()
{
  BOBReset();
  
}

void FRBusFaultSet(enum FRFaultType fault)
{
  switch(fault)
  {
    case BP_ShortTo_BM:
      BP2BM(T_on);
      break;
      
    case BP_BAT:
      
      break;
      
    case BP_GND:
      CANH2G(T_on);
      break;
      
    case BM_BAT:
      break;
      
    case BM_GND:
      break;
      
    case BP_Open:
      
      break;
      
    case BM_Open:
      break;
      
    
    Default:
      testStepFail("Fail","Set fail -> Unknown type of VH6501_CANBusFaultSet!");
      break;
  }
}
void FRBusFaultReset()
{
  AllDeviceInit();
  testWaitForTimeout(100);
  resetFlexRayCCEx(gresumFrmChnl_FR,1,50,180,60,"");
  TRC();
  SimVehBat(0x82);
}

void TestWaitForCurInRange(float current,long time)
{
  testStepWarning("Warning","Can't get current by BOB")
  testWaitForTimeout(time);
}

float GetVolt()
{
  float volt[1];
  VH1150_VoltageGet(volt);
  return volt[0];
}