/// <UDSonLIN>
void LINBusFaultSet(enum LinFaultType fault)
{
  switch(fault)
  {
    case LIN_BAT:
      LIN2BAT(T_on);
      break;
      
    case LIN_GND:
      LIN2GND(T_on);
      break;
  }
}
