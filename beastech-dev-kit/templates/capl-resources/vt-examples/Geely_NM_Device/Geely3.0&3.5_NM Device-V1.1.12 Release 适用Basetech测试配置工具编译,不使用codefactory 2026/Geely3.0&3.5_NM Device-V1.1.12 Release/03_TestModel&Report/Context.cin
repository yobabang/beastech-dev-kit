/// <ForDevice/Wakeup>
void Wakeup(int testBus, int index)
{
  int i;
  i=testBus;
  if(TestECU[i].CanBeSleepinPower>0)
  {    
    if(TestECU[i].SupportNetworkWakeup>0)
      NetworkWakeup(i,0);
    else if(TestECU[i].SupportHardwareWakeup>0)
      HardwareWakeup(i,0);
    else if(MasterChannel>=0)
    {
      if(TestECU[i].NMDB.PNCGW!=NonePNCGW)
      {
        PresetMasterChannel(5);
        MasterChannelStart(1);
        MasterChannelRequestPN(AllPN,1,SwitchOn);
      }
      else
      {
        PresetMasterChannel(5);
        MasterChannelStart(1);
        MasterChannelRequestPN(AllPN,1,SwitchOn);      
        {
          CANSetPN(AllPN); 
          CANSetNMFrame(i,gSimCanNm,gSimCanNm&0xff,0x40);
          CANSwitchNMSim(SwitchOn,MixedSend);
        }
      }
    }
  }
  
}

/// <ForDevice/Wakeup>
void Sleep(int testBus, int index)
{
  int i;
  i=testBus;
  if(TestECU[i].CanBeSleepinPower>0)
  {
    if(TestECU[i].SupportNetworkWakeup>0)
      NetworkRelease(i,0);
    else if(TestECU[i].SupportHardwareWakeup>0)
      HardwareRelease(i,0);
    else if(MasterChannel>=0)
    {
      MasterChannelRequestPN(AllPN,1,SwitchOff);
      if(TestECU[i].NMDB.PNCGW==NonePNCGW)
      {
        {
          CANSwitchNMSim(SwitchOff,NormalSend);
        }
      }
    }
  }
}

/// <ForDevice/Stress>
void CANStressDeviceIn(int testBus)
{	
  int i;
  i=TestECU[testBus].Channel;
  gStressSeq=testBus;

  testWaitForTimeout(500);
}

/// <ForDevice/Stress>
int DisturbContinue()
{    
  int res;
  
  dword msg_id;
  int i,j;
  msg_id=0x7ff;
  i=gStressSeq;
  for(j=0;j<TestECU[i].APPDB.APPNum;j++)
  {
    if(TestECU[i].APPDB.APPID[j].cycle==0)
      continue;
    if(msg_id>TestECU[i].APPDB.APPID[j].id)
      msg_id=TestECU[i].APPDB.APPID[j].id;
  }
  testStep("Step","Continue disturb message %#X",msg_id);
  res=canConfigureBusOff(TestECU[i].Channel,msg_id,1);	
	
  return res;
}

/// <ForDevice/Stress>
void DisturbContinueReset()
{    
  
  dword msg_id;
  int i,j;
  msg_id=0x7ff;
  i=gStressSeq;
  for(j=0;j<TestECU[i].APPDB.APPNum;j++)
  {
    if(TestECU[i].APPDB.APPID[j].cycle==0)
      continue;
    if(msg_id>TestECU[i].APPDB.APPID[j].id)
      msg_id=TestECU[i].APPDB.APPID[j].id;
  }
  testStep("Step","Stop disturb message %#X",msg_id);
  canConfigureBusOff(TestECU[i].Channel,msg_id,0);

	
}

