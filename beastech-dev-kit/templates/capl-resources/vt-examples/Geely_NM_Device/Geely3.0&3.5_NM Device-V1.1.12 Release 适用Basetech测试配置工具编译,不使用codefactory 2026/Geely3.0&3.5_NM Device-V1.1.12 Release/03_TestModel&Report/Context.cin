/// <ForDevice/Diagnose>
void StopDiag()
{
  if(DiagType==cETH_VGM)
  {
    kl15(T_off);
    DoIP_CloseConnection();
  }
  cancelTimer(NMCyc2);	
  if(IfUse3E80>0)
    cancelTimer(t_TesterPresent);
}

/// <ForDevice/Diagnose>
void PreStartDiag ()
{
  int i,j;
  int res;
  
  res=0;
  
  if(DiagType==cETH_VGM)
  {
    kl15(T_on);
    res=1;
  }
  if(MasterChannel>=0)
  {
    
  }
  if(DiagType==cCAN || DiagType==cCANFD)
  {
    if(IfCANBusStart[DiagChannel]==0)
    {
      CANSetPN2(AllPN); 
      SimNMmsg2.msgChannel=DiagChannel;
      SimNMmsg2.id=gSimCanNm;
      SimNMmsg2.dlc=8;
      SimNMmsg2.byte(cCanNmPduNidPosition)=gSimCanNm&0xff;
      SimNMmsg2.byte(cCanNmPduCbvPosition)=0x40;
      CANSwitchNMSim2(SwitchOn,PeriodSend,cCanNmImmediateNmCycleTime);
      IfCANBusStart[DiagChannel]=1;
    }
  }
  if(res>0)
    testWaitForTimeout(10000);
}

