testfunction TestContext_Init()
{
  int i;
  int res;
  int k;
  long j;
  testWaitForTimeout(100);
  getlocaltime(tmnow);
  for(k=0;k<9;k++)
  {
    tmstart[k]=tmnow[k];
  }
  snprintf(tim,50,"..\\07_Log&Report\\Report&Log_%d-%d-%d_%d-%d-%d\\",tmstart[5]+1900,tmstart[4]+1,tmstart[3],tmstart[2],tmstart[1],tmstart[0]);
  snprintf(reportname,100,"%s%s_NM_report",tim,ExcelInfor[0].ECUName);
  testReportFileName(reportname);
  setTimerCyclic(gTimer,2000);
  
  CANSetChannelInit();
  VariablesInit();
  WriteOnline();
  

	VH1150_InitConfig();
	testWaitForTimeout(100);

  SetBatteryVoltage(VoltageNormal);
  testWaitForTimeout(100);
  kl31(T_on);
  testWaitForTimeout(500);
  if(IfNeedUMActive>0)
  {
    InitUM();    
  }
  if(IfNeedBattU>0)
      InitBattU();
  PowerPrecondition(NoPower);
  
}

testfunction TestContext_End()
{  
  testWaitForTimeout(tCommon2);
  stopLogging();

  VH1150_Close();

  testWaitForTimeout(100);
	///删除stop();使脚本可直接在canoe中设置压力测试次数
  /// stop();
}

/// <ForDevice/Stress>
void CANBusFault(enum BusFaultType type)
{
	switch (type)
	{
		case H2L:
			testStep("Step","Short CANH to CANL");
  DisturbContinue();

		break;
		case reset_short:
			testStep("Step","Remove bus short");
  DisturbContinueReset();

		break;
	default:
	      testStepFail("Fail","Command fail -> Unknown command");
	      break;
	}
}

/// <ForDevice/Diagnose>
void ToDiagBus()
{
  long aa,bb;
  char theDiagBus[NameLong];
  strncpy(theDiagBus,PrintPhyChannel[DiagChannel],NameLong);
  SetBusContext(getBusNameContext(theDiagBus));

  TP_init();  
  testWaitForTimeout(gWaitForDiag);
  CAN_TP_CreatConnection(aa,bb,RequestID_CAN,ResponseID_CAN,0x7ff,theDiagBus);
  
  if(DiagType==cETH || DiagType==cETH_VGM)
    testWaitForTimeout(10000);
  if(IfUse3E80>0)
    setTimerCyclic(t_TesterPresent,2000);
}

