/// <ForDevice/Init>
void VariablesInit()
{
  int i,j;
  gTimeGoToSleep=gTimeGoToSleep+gTimeSleepInterval;
  gSwtichImmediateNmTransmission=SwitchOff;
  ImmediateNmTransmission=0;
  gFrameOnWhichChannel=0;
  gAnyRxComOnChannel=0;
  gIntervalFrameOnBus=0;
}

/// <ForDevice/power>
void PowerPrecondition(enum ePowerSwitch index)
{
  int i;
  switch(index)
  {
    case PowerSupply: 
      kl15(T_off);
      testWaitForTimeout(200);
      cancelTimer(timerSimAPP);
      cancelTimer(timerSimAPPinBurst);
      cancelTimer(ActiveNmCyc);
      cancelTimer(timer_SimNmBurst);
      cancelTimer(NMCyc2);
      cancelTimer(NMCyc3);
      StopUM();
      StopBattU();
      CANReset();
      for(i=0;i<gBusNum;i++)
        IfCANBusStart[i]=0;
      KL30(T_off); 
      testWaitForTimeout(1000);
      KL30(T_on);
      testWaitForTimeout(5000);//PEPS=30, other=10
      break;
    case NoPower:       
      kl15(T_off);
      testWaitForTimeout(200);
      cancelTimer(timerSimAPP);
      cancelTimer(timerSimAPPinBurst);
      cancelTimer(ActiveNmCyc);
      cancelTimer(timer_SimNmBurst);
      cancelTimer(NMCyc2);
      cancelTimer(NMCyc3);
      StopUM();
      StopBattU();
      CANReset();
      for(i=0;i<gBusNum;i++)
        IfCANBusStart[i]=0;
      KL30(T_off);
      testWaitForTimeout(TAfterRun+1);       
      break;
     default:
      testStepFail("OR","Fail--> over range of command PowerPrecondition with index=%d",index);
      break;
  } 
}

