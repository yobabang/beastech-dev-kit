/// <ForDevice/MasterChannel>
void MasterChannelRequestPN(enum ePNRquest r, int PN, enum eSwitch pState)
{
  if(MasterChannel>=0 && MasterChannel<TestNum)
  {
    if(TestECU[MasterChannel].BusType==cCAN || TestECU[MasterChannel].BusType==cCANFD)
    {
      switch(r)
      {
        case AllPN:
          CANSetPN2(AllPN); 
          CANSetNMFrame2(MasterChannel,gSimCanNm,gSimCanNm&0xff,0x40);
          CANSwitchNMSim2(pState,PeriodSend,cCanNmMsgCycleTime/4);
          break;
        case NoPN:
          CANSetPN2(NoPN); 
          CANSetNMFrame2(MasterChannel,gSimCanNm,gSimCanNm&0xff,0x40);
          CANSwitchNMSim2(pState,PeriodSend,cCanNmMsgCycleTime/4);
          break;
        case OnePN:
          CANOnlyWritePN2(PN); 
          CANSetNMFrame2(MasterChannel,gSimCanNm,gSimCanNm&0xff,0x40);
          CANSwitchNMSim2(pState,PeriodSend,cCanNmMsgCycleTime/4);
          break;
        default:
          testStepFail("OR","Fail--> over range of command MasterChannelRequestPN with PNRequest=%s on CAN",r.name());
          break;
          
      }
    }
  }
}

/// <ForDevice/MasterChannel>
void MasterChannelStop()
{
