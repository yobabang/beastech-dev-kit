/// <ForDevice/Wakeup>
void NetworkWakeup(int testBus, int index)
{
  int i;
  i=testBus;
  write("NetworkWakeup.i=%d, type=%s",i,TestECU[i].BusType.name());
  if(TestECU[i].BusType==cCAN | TestECU[i].BusType==cCANFD)
  {
    CANSetPN(AllPN); 
    CANSetNMFrame(i,gSimCanNm,gSimCanNm&0xff,0x40);
    CANSwitchNMSim(SwitchOn,MixedSend);
  }
}

/// <ForDevice/Wakeup>
void NetworkRelease(int testBus, int index)
{
  int i;
  i=testBus;
  if(TestECU[i].BusType==cCAN | TestECU[i].BusType==cCANFD)
  {
    CANSwitchNMSim(SwitchOff,NormalSend);
  }
}

