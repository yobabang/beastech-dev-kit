/// <ForDevice/MasterChannel>
void MasterChannelSwitch(enum eSwitch pState)
{
  CANSwitchNMSim2(pState,PeriodSend,cCanNmMsgCycleTime/4);
}

/// <ForDevice/UM&Batt>
void InitUM()
{
  int i;
  for(i=0;i<TestNum;i++)
  {
    if(TestECU[i].IfOnBus!=Yes)
      continue;
    if(IfNeedUMActive<=0)
      continue;
    if(strncmp(TestECU[i].BusName,VehModMngtGlbSafe[0].cluster,NameLong)==0)
    {
        CanUM.msgChannel=GetUsedChannel(i);
        CanUM.id=VehModMngtGlbSafe[0].slotID;
        CanUM.dlc=VehModMngtGlbSafe[0].dlc;
        if(TestECU[i].BusType==cCANFD)
          CanUM.FDF=1;
        else
          CanUM.FDF=0;
        if(IfNeedUMActive>0)
          IfNeedUMActive=TestECU[i].Channel;
    }
  }
}
/// <ForDevice/UM&Batt>
void InitBattU()
{
  int i;
  for(i=0;i<TestNum;i++)
  {
    if(TestECU[i].IfOnBus!=Yes)
      continue;
    if(IfNeedBattU<=0)
      continue;
    if(strncmp(TestECU[i].BusName,VehModMngtGlbSafe[1].cluster,NameLong)==0)
    {
	    CanBattU.msgChannel=GetUsedChannel(i);
	    CanBattU.id=VehModMngtGlbSafe[1].slotID;
	    CanBattU.dlc=VehModMngtGlbSafe[1].dlc;
	    if(TestECU[i].BusType==cCANFD)
	      CanBattU.FDF=1;
	    else
	      CanBattU.FDF=0;
	    if(IfNeedBattU>0)
	      IfNeedBattU=TestECU[i].Channel;
    }
  }
}

/// <ForDevice/UM&Batt>
void StartUM()
{
  int j;
  if(IfNeedUMActive>0)
  {
    StartUMActive=1;
    for(j = 2; j < VehModMngtGlbSafe[0].sigNum; j++)
    {
      VehModMngtGlbSafe[0].e2eSignalList[j].sigValue=0x0;
    }
    VehModMngtGlbSafe[0].e2eSignalList[2].sigValue=gCMNrmlValue;//CarMode
    VehModMngtGlbSafe[0].e2eSignalList[7].sigValue=0;//PwEi
    VehModMngtGlbSafe[0].e2eSignalList[9].sigValue=gUMActValue;//UsgMode
    gUMCounter=0;
    setTimerCyclic(t_UsgMode,0,50);
  }
}

/// <ForDevice/UM&Batt>
void StopUM()
{
  StartUMActive=-1;
  cancelTimer(t_UsgMode);
}
/// <ForDevice/UM&Batt>
void StartBattU()
{
  int j;
  if(IfNeedBattU>0)
  {
    StartBattU=1;
    for(j = 0; j < VehModMngtGlbSafe[1].sigNum; j++)
    {
      VehModMngtGlbSafe[1].e2eSignalList[j].sigValue=0x0;
    }
    VehModMngtGlbSafe[1].e2eSignalList[0].sigValue=gVehBatVotg;
    VehModMngtGlbSafe[1].e2eSignalList[1].sigValue=gVehBatQf;
    setTimerCyclic(t_BattU,0,50);
  }
}

/// <ForDevice/UM&Batt>
void StopBattU()
{
  if(IfNeedBattU>0)
  {
    StartBattU=-1;
    cancelTimer(t_BattU);
  }
}
