variables
{

}

on sysvar_update sysvar::DeviceControl::PMM::Command::InitConfig
{
  testSupplyTextEvent("PMM_InitConfig");
}

on sysvar_update sysvar::DeviceControl::PMM::Command::REMOTE_MODE
{
