}

on sysvar_update sysvar::DeviceControl::PMM::Command::RESistance_MEAS
{
  PMM_ResistanceMeasure();
}

on sysvar_update sysvar::DeviceControl::PMM::Command::VOLTage_MEAS
{
  PMM_VoltageMeasure();
}