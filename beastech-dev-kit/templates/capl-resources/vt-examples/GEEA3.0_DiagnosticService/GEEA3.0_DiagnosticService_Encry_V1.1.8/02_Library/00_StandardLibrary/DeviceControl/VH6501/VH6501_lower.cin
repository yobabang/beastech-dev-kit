void VH6501_CANBusFaultSet(enum VH6501_FaultType FaultType)
{  
  write("[VH6501]FaultType = [%s]",FaultType.name());
  switch(FaultType)
  {
    case CANH_ShortTo_CANL://CAN_H和CAN_L短接
      @sysvar::CANDisturbanceInterface1::Resistors::CANh_CANl::Value=0;
      testStep("Info","[VH6501.CAN]Set CAN bus fault: CANH short to CANL!");
      break;
      
    case CANH_BAT://CAN_H和电源短接
      @sysvar::CANDisturbanceInterface1::Resistors::CANh_S::Mode=1;
      @sysvar::CANDisturbanceInterface1::Resistors::CANh_S::Value=0;
      write("Set CAN bus fault: CANH short to battery!");
      write("Mode=%d,value=%d",@sysvar::CANDisturbanceInterface1::Resistors::CANh_S::Mode,@sysvar::CANDisturbanceInterface1::Resistors::CANh_S::Value=0);
      break;
      
    case CANH_GND://CAN_H和地短接
      @sysvar::CANDisturbanceInterface1::Resistors::CANh_S::Mode=0;
      @sysvar::CANDisturbanceInterface1::Resistors::CANh_S::Value=0;
      testStep("Step","Set CAN bus fault: CANH short to GND!");
      break;
      
    case CANL_BAT://CAN_L和电源短接
      @sysvar::CANDisturbanceInterface1::Resistors::CANl_S::Mode=1;
      @sysvar::CANDisturbanceInterface1::Resistors::CANl_S::Value=0;
      testStep("Step","Set CAN bus fault: CANL short to battery!");
      break;
      
    case CANL_GND://CAN_L和地短接
      @sysvar::CANDisturbanceInterface1::Resistors::CANl_S::Mode=0;
      @sysvar::CANDisturbanceInterface1::Resistors::CANl_S::Value=0;
      testStep("Step","Set CAN bus fault: CANL short to GND!");
      break;
      
    case CANH_Swap_CANL://CAN_H和CAN_L互换
      @sysvar::CANDisturbanceInterface1::Switches::CANh_CANl_Swap::Value=1;
      testStep("Step","Set CAN bus fault: CANH and CANL swap!");
      break;
      
    case CANH_Open://CAN_H和CAN_L互换
//      @sysvar::CANDisturbanceInterface1::Switches::CANh_CANl_Swap::Value=1;
      testStep("Step","Set CAN bus fault: CANH Open!");
      break;
      
    case CANL_Open://CAN_H和CAN_L互换
//      @sysvar::CANDisturbanceInterface1::Switches::CANh_CANl_Swap::Value=1;
      testStep("Step","Set CAN bus fault: CANH Open!");
      break;
    
    Default:
      testStepFail("Fail","Set fail -> Unknown type of VH6501_CANBusFaultSet!");
      break;
  }
}

void VH6501_CapacitanceSet(enum VH6501_FaultType Type, long capacitance)//设置电容,值为capacitance，单位pF
{
  switch(Type)
  {
    case CANH_ShortTo_CANL://CANH和CANL之间的电容值
      @sysvar::CANDisturbanceInterface1::Capacitors::CANh_CANl::Value=capacitance;
      testStep("Context","Capacitance value: CAN_H to CAN_L is %d pf!",capacitance);
      break;
//    case CANH_GND:
//      
//      testStep("Context","Capacitance value: CAN_H to GND is %d pf!",capacitance);
//      break;
//    case CANH_BAT:
//      
//      testStep("Context","Capacitance value: CAN_H to Battery is %d pf!",capacitance);
//      break;
//    case CANL_GND:
//      
//      testStep("Context","Capacitance value: CAN_L to GND is %d pf!",capacitance);
//      break;
//    case CANL_BAT:
//      
//      testStep("Context","Capacitance value: CAN_L to Battery is %d pf!",capacitance);
