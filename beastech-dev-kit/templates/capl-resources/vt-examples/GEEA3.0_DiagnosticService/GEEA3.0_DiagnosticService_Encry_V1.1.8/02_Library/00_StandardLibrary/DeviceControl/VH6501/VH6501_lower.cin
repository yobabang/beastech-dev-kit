//发送报文0x001，DLC=8，数据场全为0xAA，包含位填充
//对数据场靠后的一个显性位，从最后一个TQ开始往前翻转，翻转TQ数目为BtlNumber
void VH6501_SamplePointTestTriggerSet_CANFD(long BtlNumber) 
{
  CanDisturbanceSequence     sequence;
  CanDisturbanceFrameTrigger   frameTrigger;
  message *                triggerMessage;
  long                         validityMask;
  long                       result;
  long                       segmentCount;  
  int i;
  
  sequence.Clear(); //清除序列
  
  //输入序列至VH6501寄存器
   sequence.AppendToSequence(Num0fTq_Arb*5, 'd');
   sequence.AppendToSequence(Num0fTq_Arb, 'R');
   sequence.AppendToSequence(Num0fTq_Arb*5, 'd');
   sequence.AppendToSequence(Num0fTq_Arb, 'R');
   sequence.AppendToSequence(Num0fTq_Arb, 'd'); 
   sequence.AppendToSequence(Num0fTq_Arb, 'R');//SOF+ID :0 0000S00000S01
  
   sequence.AppendToSequence(Num0fTq_Arb*2-BtlNumber, 'd');//r1:00
   sequence.AppendToSequence(BtlNumber, 'R');//IDE:0
  
   sequence.AppendToSequence(Num0fTq_Arb, 'R');//FDF:1
  
   sequence.AppendToSequence(Num0fTq_Arb, 'd');//r0:0
  
   sequence.AppendToSequence(Num0fTq_Arb*0.75+80*0.4, 'R');//BRS:1  320*0.75+80*0.25
   sequence.AppendToSequence(Num0fTq_data, 'd');//esi:0    
   sequence.AppendToSequence(Num0fTq_data, 'R');//DLC:1 
   sequence.AppendToSequence(Num0fTq_data*3,'d');//DLC:000
  
  for(i=1;i<=31;i++)  //data: 101010...
  {
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');
  }
   sequence.AppendToSequence(Num0fTq_data - BtlNumber, 'R');
   sequence.AppendToSequence(Num0fTq_data + BtlNumber, 'd');
  ///数据场截止
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
  
   sequence.AppendToSequence(Num0fTq_data*2, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
  
   sequence.AppendToSequence(Num0fTq_data*2, 'R');
   sequence.AppendToSequence(Num0fTq_data*3, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data*2, 'd');//
   sequence.AppendToSequence(Num0fTq_data*2, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data*2, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'r');
   sequence.AppendToSequence(Num0fTq_data, 'd');
  //CRC截止//1(FSB)0110[Stuffcount]1(FSB)1000 1(FSB)0011 0(FSB)1010 1(FSB) 1010 1(FSB) 0
  //CRC=1 0000 0111 0101 0100=0x10754
   sequence.AppendToSequence(Num0fTq_data*0.6+320*0.25, 'r');//CRC DEL
   sequence.AppendToSequence(Num0fTq_Arb*2, 'd');//ACK 
   sequence.AppendToSequence(Num0fTq_Arb, 'r');//ACK DEL
   sequence.AppendToSequence(Num0fTq_Arb*7, 'r');//EOF:

   segmentCount = sequence.segmentCount;

   testWaitForTimeout(1);//
  
    if(segmentCount == 102)//寄存器序列数目核对
    {
//      validityMask=@sysvar::CanDisturbance::Enums::ValidityMaskFlags::IDBase;
      frameTrigger.SetMessage(triggerMessage, DeviceID, validityMask);
      frameTrigger.TriggerFieldType =@sysvar::CanDisturbance::Enums::FieldType::EndOfFrame;
      frameTrigger.TriggerFieldOffset=10;//收到触发条件，偏差后触发,此值为20，调试时为任意一帧EOF完成后30us（15bit）发出序列
                                         //即触发时间为EOF第2位结束（算上延迟）
                                            //注意：如果控制器报文处于burst发送，必定出现错误帧！
      result = canDisturbanceTriggerEnable(DeviceID, frameTrigger, sequence);//发送序列至总线
      if(result == 1)
      {
        write("Trigger is successful！");
      }
      else
      {
        testStepfail("Fail","Disturbance fail -> Enable trigger error, Result =%d", result);
      }
    }
    else
    {
      testStepfail("Fail","Device fail -> segmentCount=%d is wrong,expect count is 102!",segmentCount);
    }
}

//发送报文0x001，DLC=8，数据场全为0x55，包含位填充
//对数据场靠后的一个显性位，从最后一个TQ开始往前翻转，翻转TQ数目为BtlNumber
void VH6501_SamplePointTestTriggerSet_NIO_CANFD(long BtlNumber) 
{
  CanDisturbanceSequence     sequence;
  CanDisturbanceFrameTrigger   frameTrigger;
  message *                triggerMessage;
  long                         validityMask;
  long                       result;
  long                       segmentCount;  
  int i;
  
  sequence.Clear(); //清除序列
  
  //输入序列至VH6501寄存器
   sequence.AppendToSequence(Num0fTq_Arb*5, 'd');
   sequence.AppendToSequence(Num0fTq_Arb, 'R');
   sequence.AppendToSequence(Num0fTq_Arb*5, 'd');
   sequence.AppendToSequence(Num0fTq_Arb, 'R');
   sequence.AppendToSequence(Num0fTq_Arb, 'd'); 
   sequence.AppendToSequence(Num0fTq_Arb, 'R');//SOF+ID :0 0000S00000S01
  
//   sequence.AppendToSequence(Num0fTq_Arb*2-BtlNumber, 'd');//r1:00
//   sequence.AppendToSequence(BtlNumber, 'R');//IDE:0
   sequence.AppendToSequence(Num0fTq_Arb, 'd');//RRS:0
   sequence.AppendToSequence(Num0fTq_Arb, 'd');//IDE:0
   sequence.AppendToSequence(Num0fTq_Arb, 'R');//FDF:1
  
   sequence.AppendToSequence(Num0fTq_Arb, 'd');//res:0
  
   sequence.AppendToSequence(Num0fTq_Arb*0.75+80*0.4, 'R');//BRS:1  320*0.75+80*0.25
   sequence.AppendToSequence(Num0fTq_data, 'd');//esi:0    
   sequence.AppendToSequence(Num0fTq_data, 'R');//DLC:1 
   sequence.AppendToSequence(Num0fTq_data*3,'d');//DLC:000
  
    for(i=1;i<=31;i++)  //data: 0101010101...
    {
     sequence.AppendToSequence(Num0fTq_data, 'd');
     sequence.AppendToSequence(Num0fTq_data, 'R');
    }
   sequence.AppendToSequence(Num0fTq_data - BtlNumber, 'd');
   sequence.AppendToSequence(Num0fTq_data + BtlNumber, 'R');
  ///数据场截止
   sequence.AppendToSequence(Num0fTq_data*2, 'd');
   sequence.AppendToSequence(Num0fTq_data*2, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data*4, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'R');
   sequence.AppendToSequence(Num0fTq_data, 'd');//
   sequence.AppendToSequence(Num0fTq_data*2, 'R');
   sequence.AppendToSequence(Num0fTq_data*3, 'd');//
   sequence.AppendToSequence(Num0fTq_data, 'r');
   sequence.AppendToSequence(Num0fTq_data, 'd');
  //CRC截止//0x00b50//0 0000 1011 0101 0000//0(FSB)0110[Stuffcount] 1(FSB)0000 1(FSB)0101 0(FSB)1010 1(FSB)1000 1(FSB)0
  
   sequence.AppendToSequence(Num0fTq_data*0.6+320*0.25, 'r');//CRC DEL
   sequence.AppendToSequence(Num0fTq_Arb*2, 'd');//ACK 
   sequence.AppendToSequence(Num0fTq_Arb, 'r');//ACK DEL
   sequence.AppendToSequence(Num0fTq_Arb*7, 'r');//EOF:

   segmentCount = sequence.segmentCount;

   testWaitForTimeout(1);//
  
    if(segmentCount == 101)//寄存器序列数目核对
    {
//      validityMask=@sysvar::CanDisturbance::Enums::ValidityMaskFlags::IDBase;
      frameTrigger.SetMessage(triggerMessage, DeviceID, validityMask);
      frameTrigger.TriggerFieldType =@sysvar::CanDisturbance::Enums::FieldType::EndOfFrame;
      frameTrigger.TriggerFieldOffset=10;//收到触发条件，偏差后触发,此值为20，调试时为任意一帧EOF完成后30us（15bit）发出序列
                                         //即触发时间为EOF第2位结束（算上延迟）
                                            //注意：如果控制器报文处于burst发送，必定出现错误帧！
      result = canDisturbanceTriggerEnable(DeviceID, frameTrigger, sequence);//发送序列至总线
      if(result == 1)
      {
        write("Trigger is successful！11111111111111111111111111111111111111");
      }
      else
      {
        testStepfail("Fail","Disturbance fail -> Enable trigger error, Result =%d", result);
      }
    }
    else
    {
      testStepfail("Fail","Device fail -> segmentCount=%d is wrong,expect count is 102!",segmentCount);
    }
}
