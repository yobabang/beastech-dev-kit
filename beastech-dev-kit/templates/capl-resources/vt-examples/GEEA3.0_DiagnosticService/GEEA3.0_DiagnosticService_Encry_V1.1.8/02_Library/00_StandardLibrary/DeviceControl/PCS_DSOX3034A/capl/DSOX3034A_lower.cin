void OSC_CAN_THResholds()
{
  SendTcpData(":MEASure:SOURce CHANnel1\n");
  SendTcpData(":MEASure:DEFine THResholds,PERCent,90,50,10\n");
  SendTcpData(":MEASure:SOURce CHANnel2\n");
  SendTcpData(":MEASure:DEFine THResholds,PERCent,90,50,10\n");
  SendTcpData(":MEASure:SOURce MATH\n");
  SendTcpData(":MEASure:DEFine THResholds,PERCent,90,50,10\n");
}

void OSC_LIN_THResholds()
{
  SendTcpData(":MEASure:SOURce CHANnel3\n");
  SendTcpData(":MEASure:DEFine THResholds,PERCent,60,50,40\n");
}

void OSC_Cursor_Channel1()
{
  SendTcpData(":MARKer:X1Y1source CHANnel1\n");
}

void OSC_Cursor_Channel3()
{
  SendTcpData(":MARKer:X1Y1source CHANnel3\n");
}

void OSC_Cursor_Xdelta()
{
  double result;
  
  SendTcpData(":MARKer:XDELta?\n");
  testWaitForTimeout(100);
  SendTcpData(":Measure:TDELta\n");
  testWaitForTimeout(100);
  //SendTcpData(":MARKer:MODE Measurement\n");
  SendTcpData(":DISPlay:SIDebar CURSors\n");
  
  testWaitForTimeout(100);
  strtod(PCS_RecvData,result);
  //write("%5.9f",result);
  
  sysSetVariableFloat(sysvar::DeviceControl::PCS::Cursors::CursorValue,result);
}

void OSC_Cursor_Ydelta()
{
  SendTcpData(":MARKer:YDELta?\n");
}


void OSC_Meas_Add()
{
  char CMD[100];
  char source[20],type[20];
  Rcv_Begin=1;
  Rcv_Size=0;
   
  sysGetVariableString(sysvar::DeviceControl::DSOX3034A::Parameters::Meas_Type,type,elcount(type));
  sysGetVariableString(sysvar::DeviceControl::DSOX3034A::Parameters::Meas_Sour,source,elcount(source));
  snprintf(CMD,elcount(CMD),":MEASure:%s %s\n",type,source);
  WRITE(CMD);
  SendTcpData(CMD);
}

void OSC_SBUS_Display(int n)
{
  char cmd[100];
  snprintf(cmd,elcount(cmd),":SBUS%d:DISPlay 1\n",n);
  SendTcpData(cmd);
}

void OSC_SBUS_Mode(char mode[])
{
  char cmd[100];
  int n;
  n=@sysvar::DeviceControl::PCS::Parameter::Serial::Display;
  snprintf(cmd,elcount(cmd),":SBUS%d:MODE %s\n",n,mode);
  SendTcpData(cmd);
}

void OSC_SBUS_Source(char source[])
{
  char cmd[100],mode[100];
  int n;
  sysGetVariableString(sysvar::DeviceControl::PCS::Parameter::Serial::Mode,mode,elcount(mode));
  n=@sysvar::DeviceControl::PCS::Parameter::Serial::Display;
  snprintf(cmd,elcount(cmd),":SBUS%d:%s:SOURce %s\n",n,mode,source);
  SendTcpData(cmd);
}

void OSC_SBUS_setThreshold(float Threshold)
{
  char cmd[100];
  snprintf(cmd,elcount(cmd),":TRIGger:EDGE:LEVel %5.2f \n",Threshold);
  SendTcpData(cmd);
}

void OSC_Trigger_Type(char mode[])
{
  char cmd[100];
  snprintf(cmd,elcount(cmd),":TRIGger:MODE %s\n",mode);
  SendTcpData(cmd);
}

void OSC_Trigger_Position(char Position[])
{
  char cmd[100],Type[100];
  sysGetVariableString(sysvar::DeviceControl::PCS::Parameter::Trigger::Type,Type,elcount(Type));
  
  if(strncmp(Type,"SBUS",4)==0)
  {
    char sbusType[10];
    sysGetVariableString(sysvar::DeviceControl::PCS::Parameter::Serial::Mode,sbusType,elcount(sbusType));
    snprintf(cmd,elcount(cmd),":%s:%s:TRIGger %s\n",Type,sbusType,Position);
  }
  SendTcpData(cmd);
}

void OSC_Trigger_setID(char id[])
{
  char c1[200]="";
  char cmd[200]="";
  long res;
  char buf[20]; 
  char Type[100],sbusType[10];  
  
  sysGetVariableString(sysvar::DeviceControl::PCS::Parameter::BusType,sbusType,elcount(sbusType));
  sysGetVariableString(sysvar::DeviceControl::PCS::Parameter::TriggerID,buf,20);
  snprintf(id,20,"0x%s", buf);
  //write("Id is %s",id);
  strncpy(c1,":SBUS1:CAN:TRIGger:PATTern:ID \"Parameter1\"\n",200);
  str_replace_regex(c1,"Parameter1",id);
//  str_replace_regex(c1,"SBUS1",Type);
//  str_replace_regex(c1,"CAN",sbusType);
  strncpy(cmd,c1,200);
  if(strncmp(sbusType,"LIN",3)==0)
  {
    snprintf(cmd,elcount(cmd),":SBUS1:LIN:TRIGger:ID \"%s\"\n",id);
  }
  SendTcpData(cmd);
}

void OSC_Channel_setDisplay(int status[])
{
  char cmd[100];
  int i;
  for(i=0;i<elcount(status);i++)
  {
    if(status[i]==0)
      snprintf(cmd,elcount(cmd),":CHANnel%d:DISPlay 0\n",i+1);
    else
      snprintf(cmd,elcount(cmd),":CHANnel%d:DISPlay 1\n",i+1);
    SendTcpData(cmd);
  }
}


void OSC_Channel_setScale(float status[])
{
  char cmd[100];
  int i;
  for(i=0;i<elcount(status);i++)
  {
    snprintf(cmd,elcount(cmd),":CHANnel%d:SCALe %5.3fV\n",i+1,status[i]);
    SendTcpData(cmd);
  }
}

void OSC_Channel_setOffset(float status[])
{
  char cmd[100];
  int i;
  for(i=0;i<elcount(status);i++)
  {
    snprintf(cmd,elcount(cmd),":CHANnel%d:OFFSet %5.3fV\n",i+1,status[i]);
    SendTcpData(cmd);
  }
}

