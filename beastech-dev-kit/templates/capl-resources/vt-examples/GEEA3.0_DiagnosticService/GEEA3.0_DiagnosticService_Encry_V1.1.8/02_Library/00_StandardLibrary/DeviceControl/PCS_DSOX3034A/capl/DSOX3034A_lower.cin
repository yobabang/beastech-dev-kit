void OSC_LIN_Init()
{
  SendTcpData(":RUN\n");
  testWaitForTimeout(10);
  SendTcpData(":CHANnel1:SCALe 5V\n");
  SendTcpData("CHANnel1:OFFSet 1\n");
  SendTcpData(":CHANnel1:DISPlay 1\n");
  SendTcpData(":CHANnel2:DISPlay 0\n");
  SendTcpData(":CHANnel3:DISPlay 0\n");
  SendTcpData(":CHANnel4:DISPlay 0\n");
  SendTcpData(":FUNCtion:DISPlay 0\n");
  SendTcpData(":TIMebase:SCALe 0.0002\n");
  SendTcpData(":TIMebase:POSition 0\n");
  SendTcpData(":TRIGger:SWEep AUTO\n");
}

//初始化
void OSC_initSerialCAN()
{
  OSC_SetTimebasePosition(0);
  testWaitForTimeout(10);
  SendTcpData(":TIMebase:DELay 0.000000\n");
  testWaitForTimeout(10);
  SendTcpData(":SBUS1:DISPlay 1\n");
  testWaitForTimeout(5);
  SendTcpData(":SBUS1:MODE CAN\n");
  testWaitForTimeout(5);
  SendTcpData(":SBUS1:CAN:SOURce Channel1\n");
  testWaitForTimeout(5);
  SendTcpData(":TRIGger:EDGE:LEVel 3.0 \n");
  testWaitForTimeout(5);
  SendTcpData(":TRIGger:MODE SBUS1\n");
  testWaitForTimeout(5);
  SendTcpData(":SBUS1:CAN:TRIGger IDData\n");
  testWaitForTimeout(5);
  SendTcpData(":MEASure:WINDow AUTO\n");
  testWaitForTimeout(5);
  SendTcpData(":FUNCtion:OPERation SUBTract\n");
  testWaitForTimeout(5);
  
//  SendTcpData(":SBUS1:CAN:TRIGger SOF\n");
//  testWaitForTimeout(10);
  SendTcpData(":TIMebase:DELay 0.000050\n");
  testWaitForTimeout(10);
  
}

void OSC_Reset()
{
  SendTcpData("*RST\n");
}

void Save_Picture()
{
  char path[512];
  sysGetVariableString(sysvar::DeviceControl::PCS::Parameter::PicPath,path,elcount(path));
  Rcv_Begin=1;
  Rcv_Size=0;
  SendTcpData(":DISPlay:DATA? PNG\n");
  testWaitForTimeout(10000);
  write("示波器保存数据，大小：%d",Rcv_Size);
  dllpicConvert(Rcv_Size,PCS_RecvData,path);
}

void OSC_Singel_Trigger()
{
  SendTcpData(":SINGle\n");
}


void OSC_IDTrigger()
{
  char c1[200]="";
  char id[20]="";
  char cmd[200]="";
  long res;
  char buf[20];
  sysGetVariableString(sysvar::DeviceControl::PCS::Parameter::TriggerID,buf,20);
  snprintf(id,20,"0x%s", buf);
  write("Id is %s",id);
  strncpy(c1,":SBUS1:CAN:TRIGger:PATTern:ID \"Parameter1\"\n",200);
  str_replace_regex(c1,"Parameter1",id);
  strncpy(cmd,c1,200);
  SendTcpData(cmd);
}

void OSC_Meas_Clear()
{
  SendTcpData(":MEASure:CLEar\n");
}


