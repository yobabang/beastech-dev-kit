  dword PCS_Socket ;
  char Rcv_Begin = 1;
  long Rcv_Size = 0;
  char PCS_RecvData[400000] = "";
}

void SendTcpData(char cmd[])
{
  strncpy(PCS_SendData,cmd,100);
  
  @sysvar::DeviceControl::IPClient::SendEvent::TCPHandle = @sysvar::DeviceControl::IPClient::Sockets::PCS_Socket;//使用的socket
  sysSetVariableString(sysvar::DeviceControl::IPClient::SendEvent::SendData, PCS_SendData);//发送的数据
  write("[PCS]SendTcpData:%s",PCS_SendData);
  @sysvar::DeviceControl::IPClient::SendEvent::TCPSend = 1;//发送数据, 触发事件
}

void OSC_InitConfig()
{
  sysSetVariableString(sysvar::DeviceControl::DeviceList::PCS,DeviceName);
  SendTcpData("*CLS\n");
  SendTcpData(":RUN\n");
  SendTcpData(":TRIGger:EDGE:LEVel 3.10 \n"); 

}

void OSC_CAN_Init()
{
  SendTcpData(":RUN\n");
  testWaitForTimeout(10);
  SendTcpData(":CHANnel1:SCALe 1V\n");
  testWaitForTimeout(10);
  SendTcpData(":CHANnel2:SCALe 1V\n");
  testWaitForTimeout(10);
  SendTcpData(":SBUS1:MODE CAN\n");
  testWaitForTimeout(10);
  SendTcpData("CHANnel1:OFFSet 1\n");
  testWaitForTimeout(10);
  SendTcpData("CHANnel2:OFFSet 1\n");
  testWaitForTimeout(10);
  SendTcpData(":CHANnel1:DISPlay 1\n");
  testWaitForTimeout(10);
  SendTcpData(":CHANnel2:DISPlay 1\n");
  testWaitForTimeout(10);
  SendTcpData(":CHANnel3:DISPlay 0\n");
  testWaitForTimeout(10);
  SendTcpData(":CHANnel4:DISPlay 0\n");
  testWaitForTimeout(10);
  SendTcpData(":TIMebase:SCALe 0.000002\n");
  testWaitForTimeout(10);
  SendTcpData(":TIMebase:POSition 0\n");
  testWaitForTimeout(10);
  SendTcpData(":TRIGger:SWEep NORMAL\n");
  testWaitForTimeout(10);
  SendTcpData(":TRIGger:MODE EDGE\n");
  testWaitForTimeout(10);
  SendTcpData(":TRIGger:EDGE:SLOPe POSitive\n");
  testWaitForTimeout(10);
  SendTcpData(":TRIGger:EDGE:SOURce CHAN1 \n");
  testWaitForTimeout(10);
  SendTcpData(":TRIGger:EDGE:LEVel 3.1 \n");
  testWaitForTimeout(10);
  SendTcpData(":FUNCtion:DISPlay 1\n");
  testWaitForTimeout(10);
  SendTcpData(":FUNCtion:SOURCE1 CHANnel1\n");
  testWaitForTimeout(10);
  SendTcpData(":FUNCtion:SOURCE2 CHANnel2\n");
  testWaitForTimeout(10);
  SendTcpData(":FUNCtion:OPERation SUBTract\n");
  testWaitForTimeout(10);
  SendTcpData(":FUNCtion:SCALe 1V\n");
  testWaitForTimeout(10);
  SendTcpData(":FUNCtion:OFFSet 3\n");
  testWaitForTimeout(10);
}

