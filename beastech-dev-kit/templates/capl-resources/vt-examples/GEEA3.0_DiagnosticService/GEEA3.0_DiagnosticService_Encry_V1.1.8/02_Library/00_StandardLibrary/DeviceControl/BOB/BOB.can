void BusBreak(enum T_mode sw)
{
  if(sw==T_on)
  {
    msg.byte(0)=0x01;
    msg.byte(1)=0x03;
    msg.byte(2)=0x03;
  }
  else
  {
    msg.byte(0)=0x01;
    msg.byte(1)=0x00;
    msg.byte(2)=0x03;
  }
  
  output(msg);
//  testStep("Step","Bus Break= %d [0=off,1=on]",sw);
}
