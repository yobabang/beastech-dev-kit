/*@!Encoding:936*/

includes
{
  #include "onSysvar_KL.cin"
}

variables
{
  message CAN2.0x2 msg={dlc=8};
}


void BOBReset()
{
  msg.dlc=8;
  msg.byte(0)=0x5;
  output(msg);
}


void KL30(enum T_mode sw)
{
  if(sw==T_on)
  {
    msg.byte(0)=0x04;
    msg.byte(1)=0x00;
    msg.byte(2)=0x01;
  }
  else
  {
    msg.byte(0)=0x4;
    msg.byte(1)=0x01;
    msg.byte(2)=0x01;
  }
  output(msg);
//  testStep("Step","KL30 = %d [0=off,1=on]",sw);
}

