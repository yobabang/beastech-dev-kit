void CAN_TP_Release()
{
	CanTpCloseConnection(CAN_handlefun);
	CanTpCloseConnection(CAN_connHandle);
}

void CAN_TP_CreatConnection(long PhyHandle,long FuncHandle,dword InputReqID,dword InputResID,dword InputFuncReqID)
{
  FuncHandle = CAN_TP_Fun_Config(InputFuncReqID,InputResID);
	PhyHandle = CAN_TP_Config(InputReqID,InputResID);
}


void CAN_TP_SetPadding(long paddingValue)
{
  CanTpSetPadding(CAN_connHandle, paddingValue);
}

void CAN_TP_SetTransportParameters(int AS,int AR,int BS,int BR,int CS,int CR,int BlockSize,int ST)
{
	CAN_TP_AS = AS;
	CAN_TP_AR = AR;
	CAN_TP_BS = BS;
	CAN_TP_BR = BR;
	CAN_TP_CS = CS;
	CAN_TP_CR = CR;
	CAN_TP_BlockSize = BlockSize;
	CAN_TP_STmin = ST;
}
long CAN_TP_Config(dword SoutcesID,dword TargetID )
{
	int DiagMode=0;
	int AddressingMode=0;

	CAN_connHandle =CanTpCreateConnection(DiagMode);   //配置诊断模式 0
  if(@Diagnostic::CAN_FDFlag==1)
  {
    CanTpSetMaxCANFDFrameLength(CAN_connHandle,@Diagnostic::CAN_FDFrameLength);
    gTP_TX_DL_CANFD = @Diagnostic::CAN_FDFrameLength;
    CanTpSetBitRateSwitch(CAN_connHandle, BRSbitSwitch);
    CanTpFI_Enable(CAN_connHandle);
  }
	CanTpSetTxIdentifier(CAN_connHandle, SoutcesID);   //发送ID
	CanTpSetRxIdentifier(CAN_connHandle, TargetID);    //目标ID
	CanTpUseFlowControlFrames(CAN_connHandle, 1);     //使用流控制
//  CanTpSetFlowControlDelay( connHandle, 50);   //流控制延迟发送
	CanTpSetSTmin(CAN_connHandle, CAN_TP_STmin);  //流控制的时间间隔
	CanTpSetBlockSize( CAN_connHandle, CAN_TP_BlockSize);   //流控制的包数
	CanTpSetAddressType(CAN_connHandle, AddressingMode);  //Set the addressing type, where 1 indicates functional, 0 physical.
  CanTpSetPadding(CAN_connHandle,gPaddingValue);

 
	CanTpSetTimeoutAs(CAN_connHandle,CAN_TP_AS);//These timeouts specify the maximum time between giving a CAN frame to the transceiver and the confirmation of the sending of the frame on the bus
	CanTpSetTimeoutAr(CAN_connHandle,CAN_TP_AR);//
	CanTpSetTimeBr(CAN_connHandle,CAN_TP_BR);//This value determines the time until the next Flow Control Frame is sent.
	CanTpSetTimeoutBs(CAN_connHandle,CAN_TP_BS);//This timeout defines how long the transmitter waits for a Flow Control Frame
	CanTpSetTimeCs(CAN_connHandle,CAN_TP_CS);   //This value determines the time when the transmitter sends the next Consecutive Frame.
	CanTpSetTimeoutCr(CAN_connHandle,CAN_TP_CR);  //This timeout defines how long the receiver waits for a Consecutive Frame.
	return CAN_connHandle;
}

long CAN_TP_Fun_Config(dword SoutcesID,dword TargetID )
{
	int DiagMode=0;
//  int BlockSize=0;
//  int STmin=0x14;
	int AddressingMode=1;
//  int N_AS=25;
//  int N_AR=25;
//  int N_BS=75;
//  int N_BR=10;
//  int N_CS=20;
//  int N_CR=150;

	CAN_handlefun =CanTpCreateConnection(0);
  if(@Diagnostic::CAN_FDFlag==1)
  {
    CanTpSetMaxCANFDFrameLength(CAN_handlefun,@Diagnostic::CAN_FDFrameLength);
    CanTpSetBitRateSwitch(CAN_handlefun, @Diagnostic::CAN_FDbitRateSwitch);
    CanTpFI_Enable(CAN_handlefun);
  }
	CanTpSetTxIdentifier(CAN_handlefun, SoutcesID);   //发送ID
	CanTpSetRxIdentifier(CAN_handlefun, TargetID);    //目标ID
	CanTpUseFlowControlFrames(CAN_handlefun, 0);     //使用流控制
//  CanTpSetFlowControlDelay( handlefun, 50);   //流控制延迟发送
  CanTpSetPadding(CAN_handlefun,gPaddingValue);

	CanTpSetSTmin(CAN_handlefun, CAN_TP_STmin);
	CanTpSetBlockSize(CAN_handlefun, CAN_TP_BlockSize);
	CanTpSetAddressType(CAN_handlefun, AddressingMode);
  
	CanTpSetTimeoutAs(CAN_handlefun,CAN_TP_AS);//These timeouts specify the maximum time between giving a CAN frame to the transceiver and the confirmation of the sending of the frame on the bus
	CanTpSetTimeoutAr(CAN_handlefun,CAN_TP_AR);//
	CanTpSetTimeBr(CAN_handlefun,CAN_TP_BR);//This value determines the time until the next Flow Control Frame is sent.
	CanTpSetTimeoutBs(CAN_handlefun,CAN_TP_BS);//This timeout defines how long the transmitter waits for a Flow Control Frame
	CanTpSetTimeCs(CAN_handlefun,CAN_TP_CS);   //This value determines the time when the transmitter sends the next Consecutive Frame.
	CanTpSetTimeoutCr(CAN_handlefun,CAN_TP_CR);  //This timeout defines how long the receiver waits for a Consecutive Frame.
	return CAN_handlefun;
}

void CanTp_ErrorInd( long connHandle, long error)
{
  char buffer[100];

  if(error != 5)
  {
  	if(gBusFlag == 1)
  	{
  		write( "Error %d for connection %d", error, connHandle);
  //		testStep("TP","Error %d for connection %d", error, connHandle);
      snprintf(buffer,elcount(buffer),"Error %d for connection %d", error, connHandle);
      sysSetVariableString( sysvar::Diagnostic::ErrorMessage,buffer);
  	}

  	if(gBusFlag == 2)
  	{
  		write( "CANTP_Err:Error %d for connection %d", error, connHandle);
  //		testStep("TP","Error %d for connection %d", error, connHandle);
      snprintf(buffer,elcount(buffer),"Error %d for connection %d", error, connHandle);
      sysSetVariableString( sysvar::Diagnostic::ErrorMessage,buffer);
  	}
  }
}

int CAN_TP_Send(byte Data[],enum AddressMode Mode)
{
	if(Mode==0)
		CanTpSendData(CAN_connHandle,Data,elcount(Data));//
	else
		CanTpSendData(CAN_handlefun,Data,elcount(Data));//
	return 1;
}

int CAN_TP_Send(byte Data[],int length,enum AddressMode Mode)
{
	if(length>elcount(Data))
	{
		if(Mode==0)
			CanTpSendData(CAN_connHandle,Data,elcount(Data));//
		else
			CanTpSendData(CAN_handlefun,Data,elcount(Data));//
		write("Worning tp send data size small than given length");
	}
	else
	{
		if(Mode==0)
			CanTpSendData(CAN_connHandle,Data,length);//
		else
			CanTpSendData(CAN_handlefun,Data,length);//
	}
	return 1;
}

void CanTp_ReceptionInd( long InputHandle, byte data[])
{
  char buffer[100];
  if(@Diagnostic::Queue_EnableFlag==1)
  {
    @Diagnostic::Queue_ResExist=1;
    if(data[0]==0x7F&&data[2]==0x78)
    {
      @Diagnostic::Queue_NRC78Flag=1;
      NRC78Num++;
      TP_T1 = timeNowFloat()/100000;
      TP_T2 = timeNowFloat()/100000;
      if(NRC78Num!=1)
      {
        TP_T3 = timeNowFloat()/100000;
        if((TP_T3-TP_T2)>8)
        {
          snprintf(buffer,elcount(buffer),"NRC78 Check Timeout");
          sysSetVariableString( sysvar::Diagnostic::ErrorMessage,buffer);
          NRC78Num=0;
          @Diagnostic::Queue_NRC78CheckResult=1;
          @Diagnostic::Queue_NRC78Flag=0;
        }
        else if((TP_T3-TP_T2)>5)
        {
          snprintf(buffer,elcount(buffer),"NRC78 Timeout");
          sysSetVariableString( sysvar::Diagnostic::ErrorMessage,buffer);
        }
        else
        {
          TP_T2 = timeNowFloat()/100000;
          TP_T4 = timeNowFloat()/100000;
          if((TP_T4-TP_T1)>60)
          {
            snprintf(buffer,elcount(buffer),"P4 TimeOut");
            sysSetVariableString( sysvar::Diagnostic::ErrorMessage,buffer);
            NRC78Num=0;
            @Diagnostic::Queue_NRC78CheckResult=0;
            @Diagnostic::Queue_NRC78Flag=0;
          }
        }
      }
    }
    else
    {
      if(@Diagnostic::Queue_NRC78Flag==1)
      {
        @Diagnostic::Queue_NRC78Flag=0;
        @Diagnostic::Queue_NRC78CheckResult=2;
        NRC78Num=0;
      }
      
    	gTpRxLength=elcount(data);
      sysSetVariableData(sysvar::Diagnostic::Receive_Data,data,gTpRxLength);
      @Diagnostic::Receive_DataLength=gTpRxLength;
      @Diagnostic::Queue_DRQ_R=1;
//      write("111111111111111");
    }
  }
  else
  {
  	gTpRxLength=elcount(data);
    sysSetVariableData(sysvar::Diagnostic::Receive_Data,data,gTpRxLength);
    @Diagnostic::Receive_DataLength=gTpRxLength;
  }
  
	if(InputHandle!=CAN_handlefun)
	{
      @Diagnostic::Receive_ConAll=1;
//  		write( "TP:Connection %d Received %d byte ..." , InputHandle,elcount(data));
	}
}


