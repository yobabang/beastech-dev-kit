variables
{
	//  int SoutcesID,TargetID,DiagMode,BlockSize,STmin,AddressingMode,N_AS,N_AR,N_BS,N_BR,N_CS,N_CR;
	//SoutcesID:源物理地址，//TargetID：目标地址；//DiagMode：诊断模式 //BlockSize：流控分包数
	//STmin：流控分包时间间隔 //AddressingMode：寻址模式  //N_AS,N_BS,N_BR,N_CS,N_CR：  时间参数
	long  CAN_handlefun;
	long  CAN_connHandle;
  long gCANHandle1;
	long gCANFuncHandle1;
	int  gCAN_RequestID = 0x734;
	int  gCAN_ResponseID = 0x634;
	int  gCAN_FuncRequestID = 0x7FF;
//	dword   CAN_TP_PhyRequestID  = 0x700;
//	dword   CAN_TP_FuncRequestID = 0x7DF;
//	dword   CAN_TP_ResponseID    = 0x600;

	int   CAN_TP_AS = 25;
	int   CAN_TP_AR = 25;
	int   CAN_TP_BS = 75;
	int   CAN_TP_BR = 10;
	int   CAN_TP_CS = 20;
	int   CAN_TP_CR = 150;
	int   CAN_TP_BlockSize = 0;
	int   CAN_TP_STmin = 0x14;
	int   gFC_WaitReceived;

	msTimer CAN_TP_TesterPresentTimer,CANFD_TP_TesterPresentTimer;
	//msTimer RandomTesterPresent;
	message 0x000 CAN_TP_TesterPresentFrame = {dlc = 8,byte(0) = 0x02,byte(1) = 0x3E,byte(2) = 0x80};
  message 0x000 CANFD_TP_TesterPresentFrame0 = {brs=0,fdf=1,dlc = 8,byte(0) = 0x02,byte(1) = 0x3E,byte(2) = 0x80};
  message 0x000 CANFD_TP_TesterPresentFrame1 = {brs=1,fdf=1,dlc = 8,byte(0) = 0x02,byte(1) = 0x3E,byte(2) = 0x80};
  //
  int    gBusFlag = 1;//CAN:1 CANFD:2 LIN:3 FlexRay:4 Ethernet:5
  enum   AddressMode {PHYSICAL = 0,FUNCTIONAL = 1};
  int    gNRC78Flag = 0;
  byte   gTpRxData[65535];
  dword  gTpRxLength;
  int gUDS_P2Client = 150;
	int gUDS_P2ClientDelay = 5000;
	int gUDS_P6Client = 500;
	int gUDS_P6ClientDelay = 5000;

	int gUDS_S3Client ;
	int gUDS_S3Server = 5000;
  enum   ResponseState {TIMEOUT,POS,NEG};
  enum   TP_Switch {TP_ON = 1,TP_OFF = 0};
  enum   Bus_Type {TP_CAN = 1,TP_CANFD = 2,TP_LIN = 3,TP_FLEXRAY = 4,TP_ETHERNET = 5};
  const int    gTPWaitTimeForP2 = 3000;
  
  int gAPPFlag;
  int gNMFlag;
  int BRSbitSwitch;
  byte gPaddingValue=0xAA;
//  float TP_T1,TP_T2,TesTime;
//  msTimer TPinitdelay;
  byte NRC78Num=0;
  float TP_T1,TP_T2,TP_T3,TP_T4;
  byte QueueFirstCycle=0;

  /* 20240812: For Send Con */
  long  gIndex_Of_SN;   // Index of SN
  long  gIndex_Of_SN_0; // Index of SN_0
  long  gCount_Of_SN_0; // Count of SN_0
  long  gFlag_MultiFrame;
  long  gTP_TX_DL_CAN = 8;
  long  gTP_TX_DL_CANFD;
}
on message *
{
   if((this.id == gCAN_ResponseID)&&(((this.byte(0)&0xF0) == 0)||((this.byte(0)&0xF0) == 0x10)))
  {
    testSupplyTextEvent("CANTPreciveFirstData");
    @Diagnostic::Receive_ConFirst=1;
    @Diagnostic::CAN_FirstData_Time=timeNowFloat()/100000.0;
  }
  /* 物理寻址 */
  if(this.id == gCAN_RequestID)
  { 
    if(gFlag_MultiFrame == 1) 
    {
      if((this.byte(0) & 0xFF) == 0x20) { gCount_Of_SN_0++; }
      if((gCount_Of_SN_0 == gIndex_Of_SN_0) && ((this.byte(0) & 0x0F) == gIndex_Of_SN)) { @Diagnostic::Receive_ConAll = 0; @Diagnostic::Receive_ConFirst = 0; @Diagnostic::Send_Con = 1; }
    }
    else { @Diagnostic::Receive_ConAll = 0; @Diagnostic::Receive_ConFirst = 0; @Diagnostic::Send_Con = 1; }
  }
  /* 功能寻址 */
  else if(this.id == gCAN_FuncRequestID)
  { if(this.byte(0) == 0x02 && this.byte(1) == 0x3E && this.byte(2) == 0x80) { return; } else { @Diagnostic::Receive_ConAll = 0; @Diagnostic::Receive_ConFirst = 0; @Diagnostic::Send_Con = 1; } }
}

on timer CAN_TP_TesterPresentTimer
{
	output(CAN_TP_TesterPresentFrame);
//	write("Send TesterPresent");
}
on timer CANFD_TP_TesterPresentTimer
{
  if(BRSbitSwitch==1)
	  output(CANFD_TP_TesterPresentFrame1);
  else if(BRSbitSwitch==0)
    output(CANFD_TP_TesterPresentFrame0);
//	write("Send TesterPresent");
}

