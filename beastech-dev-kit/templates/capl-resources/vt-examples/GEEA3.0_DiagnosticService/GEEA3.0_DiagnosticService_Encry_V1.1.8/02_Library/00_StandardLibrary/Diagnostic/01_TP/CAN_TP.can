on sysvar_update Diagnostic::TP_TesterPresentSet
{
  byte i;
  
  if(@Diagnostic::CAN_FDFlag==1)
  {
    if(@this==1)
  	{
  		setTimerCyclic(CANFD_TP_TesterPresentTimer,gUDS_S3Client);

  	}
  	else if(@this==0)
  	{
  		cancelTimer(CANFD_TP_TesterPresentTimer);
  	}  
  }
  else 
  {
    if(@this==1)
  	{
  		setTimerCyclic(CAN_TP_TesterPresentTimer,gUDS_S3Client);
  	}
  	else if(@this==0)
  	{
  		cancelTimer(CAN_TP_TesterPresentTimer);
  	} 
  }
}
/// <TPparameterInit>
on sysvar_update Diagnostic::CAN_TPparameterInit
{
  byte i=0;
  
//  byte data1[3]={0x02,0x10,0x03};
  CAN_TP_AS = @Diagnostic::CAN_TP_AS;
	CAN_TP_AR = @Diagnostic::CAN_TP_AR;
	CAN_TP_BS = @Diagnostic::CAN_TP_BS;
	CAN_TP_BR = @Diagnostic::CAN_TP_BR;
	CAN_TP_CS = @Diagnostic::CAN_TP_CS;
	CAN_TP_CR = @Diagnostic::CAN_TP_CR;
	CAN_TP_BlockSize = @Diagnostic::CAN_BlockSize;
	CAN_TP_STmin = @Diagnostic::CAN_STmin;
  
  gCAN_RequestID=@Diagnostic::CAN_RequestID;
  gCAN_ResponseID=@Diagnostic::CAN_ResponseID;
  gCAN_FuncRequestID=@Diagnostic::CAN_FunctionalID;
  gUDS_S3Client=@Diagnostic::S3Client;
  BRSbitSwitch=@Diagnostic::CAN_FDbitRateSwitch;
  gPaddingValue=@Diagnostic::CAN_Padding;
  
  CAN_TP_CreatConnection(gCANHandle1,gCANFuncHandle1,gCAN_RequestID,gCAN_ResponseID,gCAN_FuncRequestID);
  CAN_TP_TesterPresentFrame.id=gCAN_FuncRequestID;
  CANFD_TP_TesterPresentFrame0.id=gCAN_FuncRequestID;
  CANFD_TP_TesterPresentFrame1.id=gCAN_FuncRequestID;
  for(i=3;i<8;i++)
  {
    CAN_TP_TesterPresentFrame.byte(i)=gPaddingValue;
    CANFD_TP_TesterPresentFrame0.byte(i)=gPaddingValue;
    CANFD_TP_TesterPresentFrame1.byte(i)=gPaddingValue;
  }
}
on sysvar_update Diagnostic::Send_Flag
{
  byte tempdata[65535],ResponseData[65535];
  byte tempAddressmode;
  long Requestlength,Responselength;
  
  if(@this==1)
  { 
    tempAddressmode=@Diagnostic::AddressingMode;
    Requestlength=elcount(sysvar::Diagnostic::Send_Data);
    sysGetVariableData(sysvar::Diagnostic::Send_Data,tempdata,Requestlength);
    
    gCount_Of_SN_0 = 0;
    if(@Diagnostic::CAN_FDFlag == 0) // CAN
    {
      if(Requestlength > (gTP_TX_DL_CAN - 1)) // 多帧处理
      {
        long temp1,temp2;
        gFlag_MultiFrame = 1;
        
        temp1 = (Requestlength - (gTP_TX_DL_CAN - 2)) % (gTP_TX_DL_CAN - 1);
        if(temp1 == 0) { temp2 = (Requestlength - (gTP_TX_DL_CAN - 2))/(gTP_TX_DL_CAN - 1); }
        else           { temp2 = (Requestlength - (gTP_TX_DL_CAN - 2))/(gTP_TX_DL_CAN - 1) + 1; }
        gIndex_Of_SN   = temp2 % 16;
        gIndex_Of_SN_0 = temp2 / 16;
      }
      else { gFlag_MultiFrame = 0; }
    }
    else // CANFD
    {
      long temp1,temp2;
      
      if(Requestlength <= 4095) // CANFD Mode1
      {
        if(Requestlength > (gTP_TX_DL_CANFD - 2)) // 多帧处理
        {
          gFlag_MultiFrame = 1;
          
          temp1 = (Requestlength - (gTP_TX_DL_CANFD - 2)) % (gTP_TX_DL_CANFD - 1);
          if(temp1 == 0) { temp2 = (Requestlength - (gTP_TX_DL_CANFD - 2))/(gTP_TX_DL_CANFD - 1); }
          else           { temp2 = (Requestlength - (gTP_TX_DL_CANFD - 2))/(gTP_TX_DL_CANFD - 1) + 1; }
          gIndex_Of_SN   = temp2 % 16;
          gIndex_Of_SN_0 = temp2 / 16;
        }
        else { gFlag_MultiFrame = 0; }
      }
      else                     //  CANFD Mode2
      {
        gFlag_MultiFrame = 1;
        
        temp1 = (Requestlength - (gTP_TX_DL_CANFD - 6)) % (gTP_TX_DL_CANFD - 1);
        if(temp1 == 0) { temp2 = (Requestlength - (gTP_TX_DL_CANFD - 6))/(gTP_TX_DL_CANFD - 1); }
        else           { temp2 = (Requestlength - (gTP_TX_DL_CANFD - 6))/(gTP_TX_DL_CANFD - 1) + 1; }
        gIndex_Of_SN   = temp2 % 16;
        gIndex_Of_SN_0 = temp2 / 16;
      }
    }
    
    if(tempAddressmode==0)
      CAN_TP_Send(tempdata,Requestlength,PHYSICAL);
    else if(tempAddressmode==1)
      CAN_TP_Send(tempdata,Requestlength,FUNCTIONAL);
  }
}
on sysvar_update Diagnostic::CAN_SendSmallBufferDataLen
{
  byte tempdata[65535],ResponseData[65535];
  byte tempAddressmode;
  long Requestlength,Responselength;
  
  tempAddressmode=@Diagnostic::AddressingMode;
  Requestlength=elcount(sysvar::Diagnostic::Send_Data);
  sysGetVariableData(sysvar::Diagnostic::Send_Data,tempdata,Requestlength);
  
    if(tempAddressmode==0)
      CanTpSmallBufferSend(CAN_connHandle,Requestlength,tempdata,@this);
    else if(tempAddressmode==1)
      CanTpSmallBufferSend(CAN_handlefun,Requestlength,tempdata,@this);
  
}

on sysvar_update Diagnostic::ReleaseConnection
{
  CAN_TP_Release();
}

void MainTest()
{
  while(1)
  {
    testWaitForTimeout(10000);
  }
}