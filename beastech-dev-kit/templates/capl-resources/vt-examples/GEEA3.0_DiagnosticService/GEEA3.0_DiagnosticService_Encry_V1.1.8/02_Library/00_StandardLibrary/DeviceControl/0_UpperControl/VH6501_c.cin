void VH6501_DisturbRTR(dword ID, long time)
{
  char IdBuff[10];
  snprintf(IdBuff,10,"%02x",ID);
  VH6501_RTRDisturbance(IdBuff,time);
}

void VH6501_SamplePointTestTriggerSet(long InvertTqNum)
{
  @sysvar::DeviceControl::VH6501::Parameters::Sampling_DisturbTqNum=InvertTqNum;
  @sysvar::DeviceControl::VH6501::Parameters::Datafield = 0;//0:0xAA;1:0x55
  @sysvar::DeviceControl::VH6501::Command::Sampling_Trigger++;
}

void VH6501_SamplePointTestTriggerSet(long InvertTqNum,int isTestArbSampling)
{
  @sysvar::DeviceControl::VH6501::Parameters::Sampling_DisturbTqNum=InvertTqNum;
  @sysvar::DeviceControl::VH6501::Parameters::isTestArbSampling=isTestArbSampling;//0:testData(BRS=1),1:testArb
  @sysvar::DeviceControl::VH6501::Parameters::Datafield=1;//0:0xAA;1:0x55
  @sysvar::DeviceControl::VH6501::Command::Sampling_Trigger++;
}