void CANTPTestParameterInit(dword ReqID,dword ResID,dword FunReqID,int AS,int AR,int BS,int BR,int CS,int CR,int BlockSize,int STmin)
{
  gTPTResponseID = ResID;
  gTPTRequestID = ReqID;
  gTPTFuncRequestID = FunReqID;
  gN_As = AS;
  gN_Ar = AR;
  gN_Bs = BS;
  gN_Br = BR;
  gN_Cs = CS;
  gN_Cr = CR;
  gBS   = BlockSize;
  gSTmin = STmin;
  gFCSTmin = STmin;
  
  gTp_Message.id           = gTPTRequestID;
  gRequestMultiFrame.id    = gTPTRequestID;
  gRequestSingleFrame.id   = gTPTRequestID;
  gSingleFrame.id          = gTPTRequestID;
  gFirstFrame.id           = gTPTRequestID;
  gConsecutiveFrame.id     = gTPTRequestID;
  gFlowControlFrame.id     = gTPTRequestID;
  gFlowControlFrame1.id    = gTPTRequestID;
  
  gTE_Message.id           = gTPTFuncRequestID;
}