/*@!Encoding:936*/

variables
{
  mstimer t_TeSim, t_FCSim;
  
  message 0x000 gTp_Message;
  message 0x000 gRequestMultiFrame   ={dlc=8};
  message 0x000 gRequestSingleFrame  ={dlc=8};
  message 0x000 gSingleFrame         ={dlc=8,byte(0)=0x00};
  message 0x000 gFirstFrame          ={dlc=8,byte(0)=0x10};
  message 0x000 gConsecutiveFrame    ={dlc=8,byte(0)=0x20};
  message 0x000 gFlowControlFrame    ={dlc=8,byte(0)=0x30,byte(1)=0x02,byte(2)=0x00};
  message 0x000 gFlowControlFrame1   ={dlc=8,byte(0)=0x30,byte(1)=0x02,byte(2)=0x00};
  message 0x000 gTE_Message          ={dlc=8,byte(0)=0x02,byte(1)=0x3e,byte(2)=0x80};
  message 0x000 gTR;
  mstimer t5,t4,t6;
  message 0x001 interframe={dlc=8,byte(0)=0xFF,byte(1)=0xFF,byte(2)=0xFF,byte(3)=0xFF,byte(4)=0xFF,byte(5)=0xFF,byte(6)=0xFF,byte(7)=0xFF};
  
  byte gReqMultiFrame[8]={0x03,0x22,0xF1,0x93,0xAA,0xAA,0xAA,0xAA};
  byte gReqSingleFrame[8]={0x02,0x10,0x01,0xAA,0xAA,0xAA,0xAA,0xAA};
  byte gSendSingleFrame[8]={0x03,0x22,0xF1,0x8C,0xAA,0xAA,0xAA,0xAA};
  byte gSendMultiFrame1[6]={0x22,0x01,0x02,0x03,0x04,0x05};//FF
  byte gSendMultiFrame2[7]={0x06,0x07,0x08,0x09,0x0A,0x0B,0x0C};//CF
  byte gSendMultiFrame3[7]={0x0D,0x0E,0x0F,0x10,0x11,0x12,0x13};//CF
  byte gSendMultiFrame4[7]={0x14,0x15,0x16,0x17,0x18,0x19,0x1A};//CF
  byte gSendMultiFrame5[7]={0x1B,0x1C,0x1D,0x1E,0x1F,0x20,0x21};//CF
  byte gSendMultiFrame6[7]={0x22,0xAA,0xAA,0xAA,0xAA,0xAA,0xAA};//CF
  
  dword gTPTResponseID;
  dword gTPTRequestID;
  dword gTPTFuncRequestID;
  byte  gCurrentFrameType;
  byte  gReceivedData[8];
  int   gNumberOfCFReceived;
  int   gNumberCounter;
  int   gTP_NRC78_Flag;
  enum  FrameType {SF, FF, CF, FC, UF};
  enum  FlowStateType {CTS = 0x00,WAIT = 0X01,OVFLOW = 0x02};
  byte  gSF_DL;
  byte  gFF_DL;
  byte  gBS;
  byte  gSTmin;
  byte  gFCSTmin;
  int   gN_As;
  int   gN_Ar;
  int   gN_Bs;
  int   gN_Br;
  int   gN_Cs;
  int   gN_Cr;
  
  int TIMERFLAG = 0;
  int TIMERFLAG1 = 0;
}

on timer t_TeSim
{
  output(gTE_Message);//send the tester present period=10ms
 // Sim_TE(SV_on,10);
}
on timer t_FCSim
{
  output(gFlowControlFrame1); 
 // setTimerCyclic(FCSim,10);
}

