void Tp_SendMessage(byte Data[],int Len,dword id)
{ //将数组中的数据一位一位地装入到CAN帧的数据位
 
  int i; 
  gTp_Message.id =  id;
  
  if (Len > 8)
  {
    testStepWarning("Tp_SendMessage","Len cannot > 8, dlc set to 8");
    gTp_Message.dlc = 8;
  }
  else
  {
     gTp_Message.dlc = Len; 
  }
  
  for(i=0;i<Len;i++)
  {
    gTp_Message.byte(i) = Data[i];
  }
  output(gTp_Message);
}

int RequestSingleFrame()
{ 
  byte Data1[8]={0x02,0x10,0x01,0xAA,0xAA,0xAA,0xAA,0xAA};
  int i;

  for(i=0 ; i<8; i++)
  {
    gRequestSingleFrame.byte(i) = gReqSingleFrame[i];
  }
  output(gRequestSingleFrame);
  
  return 2;
}

void RequestMultiFrame()
{ 
  int i;

  for(i=0 ; i<8; i++)
  {
    gRequestMultiFrame.byte(i) = gReqMultiFrame[i];
  }
  output(gRequestMultiFrame);
}

int AllCFReceivedConfirm()
{
  long res, NumberOfCFComputed, NumberOfCFNeedUpdate;
  NumberOfCFComputed = -1;
  if((gFF_DL-6)%7>0)
   NumberOfCFComputed = (gFF_DL-6)/7 + 1;
  else
   NumberOfCFComputed = (gFF_DL-6)/7;
  
  for(NumberOfCFNeedUpdate=0 ; ; )
  { 
    //SendFlowControl(CTS,1,0);
    testWaitForTimeout(gN_Cr);
    if(gNumberOfCFReceived > NumberOfCFNeedUpdate)
    {
      NumberOfCFNeedUpdate = gNumberOfCFReceived; 
    }  
    else
      break;
  }
  testStep ("Inf","NumberOfCFComputed = %d, NumberOfCFReceived = %d",NumberOfCFComputed,gNumberOfCFReceived);
  if(gNumberOfCFReceived == NumberOfCFComputed)
  {
    Diag_SetReqCheckResult(1,8,RESULT_PASS,"Recive all CFs with the exact amount.");
    return 2;
  }
    
  else if(gNumberOfCFReceived > NumberOfCFComputed)
  {
    Diag_SetReqCheckResult(1,16,RESULT_FAIL,"Recive more CFs than expected."); 
    return 1;
  }
  else
  {
    Diag_SetReqCheckResult(1,16,RESULT_FAIL,"Recive less CFs than expected"); 
    return -1;
  }        
}

void CheckNRC78(message* TR) //判断是否为NRC78
{
  int i;
  int Res;
  
  gTP_NRC78_Flag = 0;
  gTPTResponseID=gCAN_ResponseID;
  for(i=0;i<1;)
  {
    if ( TR.byte(1)==0x7F && TR.byte(3)==0x78)
     {
        testJoinMessageEvent(gTPTResponseID);
        if(testWaitForAnyJoinedEvent(2000)>0)
        {
          testGetWaitEventMsgData(TR);
        }
        else
        {
          teststepfail("Fail","Dut don't response during P2* Server");
          break;
        }
        gTP_NRC78_Flag = 1;
     }
    else
      break;
  }
}

int CheckSingleFrameMessage(message* TpRes)//测试SF帧
{ 
  if(TpRes.dlc == 8 && ((TpRes.byte(0)&0xF0) == 0x00 ))
  { 
    Diag_SetReqCheckResult(0,0,RESULT_PASS,"ECU responses a SF");
    return 2;
  }   
  else
  {
    Diag_SetReqCheckResult(1,8,RESULT_FAIL,"ECU doesn't response a SF"); 
    testStepFail("Chk","ECU doesn'tresponse a FF");
    return 1;
  }   
}

int CheckFirstFrameMessage(message* TpRes)//测试FF帧
{ 
  if(TpRes.dlc == 8 && ((TpRes.byte(0)&0xF0) == 0x10 ))
  { 
    Diag_SetReqCheckResult(0,0,RESULT_PASS,"ECU responses a FF"); 
    return 2;
  }   
  else
  {
    Diag_SetReqCheckResult(1,8,RESULT_FAIL,"ECU doesn'tresponse a FF"); 
    testStepFail("Chk","ECU doesn'tresponse a FF");
    return 1;
  }   
}

long CheckConsecutiveFrameMessage(message* TpRes)//测试CF帧
{ 
  if(TpRes.dlc == 8 && ((TpRes.byte(0)&0xF0) == 0x20 ))
  { 
     Diag_SetReqCheckResult(0,0,RESULT_PASS,"ECU responses a CF");
     return 2;
  }   
  else
  {
    Diag_SetReqCheckResult(1,10,RESULT_FAIL,"ECU doesn'tresponse a CF");
    return 1;
  }   
}

int CheckCFPadding(int msgdlc_1)
{ 
  int msgtpd;
  int i;
  msgtpd = (msgdlc_1 - 6)%7;//最后一帧填充的字节数
  
  if(msgtpd==0)
    msgtpd=7;
  
  for(i=7;i>msgtpd;i--)
  {
    if(gReceivedData[i]!=0xAA)
      Diag_SetReqCheckResult(6,4,RESULT_FAIL,"The padding of CF is right");
      return 1;
  }
  Diag_SetReqCheckResult(0,0,RESULT_PASS,"The padding of CF is right");
  return 2;
    
}
long CheckResponse_3EInterference(message* TpRes,int service)
{
   if(TpRes.dlc==8 && (TpRes.byte(0)&0xFF) == 0x03&&TpRes.byte(1)==0x7F&TpRes.byte(2)==service)//==优先级高于&
  {
    if( TpRes.byte(4)==0xAA && TpRes.byte(5)==0xAA && TpRes.byte(6)==0xAA && TpRes.byte(7)==0xAA )
     {
      testStepPass("Chk","Response message is correct");
      return 1;
      }
      
    else
     {
     testStepFail("Chk","The padding of Response message is not correct");
     return -1;
     }
  }
  else  
  {
    testStepFail("Chk","Response message is not correct");
    return -1;
  }
}

