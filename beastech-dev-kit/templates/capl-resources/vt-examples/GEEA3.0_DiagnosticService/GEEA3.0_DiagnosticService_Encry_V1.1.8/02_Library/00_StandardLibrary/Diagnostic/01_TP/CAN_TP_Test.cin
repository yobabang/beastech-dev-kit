dword GetMessageLength(byte High,byte Low)
{ 
  return ((High&0x0f)<<8) + Low; 
}

int SendFirstFrame( dword FF_DL ,byte Data[])
{ 
  int i;
  
  gFirstFrame.byte(0) = 0x10  + (FF_DL>>8);
  gFirstFrame.byte(1) = FF_DL & 0x0FF;
  if ( FF_DL >= 8 && FF_DL <=0xFFF )
  {
    ;
  }
  else
  {
    testStepWarning("Warning","FF_DL should >= 8, <=0xFFF");
    //return 1;
    //return 2;
  }
  if (elCount(Data) > 6)
  {
    testStepWarning("Warning","Number of Bytes > 6, send error");
    i = 6;
    return 1;
  }
  else
  {
    i = elCount(Data); 
  }
  for( ; i>=1; i--)
  {
    gFirstFrame.byte(i+1) = Data[i-1];
  }
  output(gFirstFrame);
  return 2;
}

int CheckFlowControlMessage(message* TpRes)//测试流控帧FC
{
  if(TpRes.dlc==8 && (TpRes.byte(0)&0xF0) == 0x30)//==优先级高于&
  {
    if( TpRes.byte(3)==0xAA && TpRes.byte(4)==0xAA && TpRes.byte(5)==0xAA && TpRes.byte(6)==0xAA && TpRes.byte(7)==0xAA )
     {
      if(TpRes.byte(1)!=00)
      {
        Diag_SetReqCheckResult(6,3,RESULT_FAIL,"The parameter 'BS' of FC is not corrcet"); 
        return 1;
      }
      
      if(TpRes.byte(2)==gFCSTmin)
      { 
        gSTmin=TpRes.byte(2);
        return 2;
      }
      else
      {
        Diag_SetReqCheckResult(6,2,RESULT_FAIL,"The parameter 'STmin' of FC is not corrcet");  
        return 1;
      }
    }            
    else
     {
      Diag_SetReqCheckResult(6,4,RESULT_FAIL,"The padding of FC is not correct");  
      return 1;
     }
  }
  else  
  {
    Diag_SetReqCheckResult(1,2,RESULT_FAIL,"The ECU doesn't send FC");  
    return 0;
  }
}

int SendConsecutiveFrame( byte SN ,byte Data[])
{ 
  int i;
  if (SN > 0x0f)
  {
    Diag_SetReqCheckResult(6,5,RESULT_FAIL,"SN cannot > 0x0f, SN set to 0");  
    SN = 0;
    return 1;
  }
  else
  {
     ; 
  }
  gConsecutiveFrame.byte(0)=0x20 + SN;
  
  if (elCount(Data) > 7)
  {
    Diag_SetReqCheckResult(0,0,RESULT_WARNING,"Number of Bytes cannot > 7, send error");  
    i = 7;
    return 1;
  }
  else
  {
     i = elCount(Data); 
  }
  for( ;i >= 1; i--)
  {
    gConsecutiveFrame.byte(i) = Data[i-1];
  }
  output(gConsecutiveFrame);
  return 2;
}

void SendSingleFrame( byte SF_DL ,byte Data[])
{ 
  int i;
  if (SF_DL>=0 && SF_DL <=7  )
  {
    ;
  }
  else
  {
    testStepWarning("SendSingleFrame","SF_DL should >= 0, <=7");
  }
  gSingleFrame.byte(0)=0x00 + SF_DL;
  
  if (elCount(Data) > 7)
  {
    testStepWarning("SendSingleFrame","Number of Bytes > 7, send 7 bytes");
    i = 7;
  }
  else
  {
    i = elCount(Data); 
  }
  for( ; i>=1; i--)
  {
    gSingleFrame.byte(i) = Data[i-1];
  }
  output(gSingleFrame);
}

void SendFlowControl( enum FlowStateType fcs,byte BS,byte STmin)
{ 
  gFlowControlFrame.byte(0)=0x30+fcs;
  gFlowControlFrame.byte(1)=BS;
  gFlowControlFrame.byte(2)=STmin;
  output(gFlowControlFrame);
}

