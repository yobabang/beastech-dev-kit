/*@!Encoding:936*/
//办事处机柜的环境配置板卡底层
includes
{

}

variables
{
  byte ENV_SendData[13] = {0x08,0x00,0x00,0x00,0xAA,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00} ;
}

void SendTcpData_BYTE()
{
  @sysvar::DeviceControl::IPClient::SendEvent::TCPHandle = @sysvar::DeviceControl::IPClient::Sockets::ETH_CAN0_Socket;//使用的socket
  sysSetVariableData(sysvar::DeviceControl::IPClient::SendEvent::SendDataByte, ENV_SendData, elcount(ENV_SendData));//发送的数据
  @sysvar::DeviceControl::IPClient::SendEvent::TCPSend_Byte = elcount(ENV_SendData);//发送数据的长度，也是触发的事件
}

void ENV_Reset()
{
  ENV_SendData[5] = 0xff;
  ENV_SendData[6] = 0x00;
  ENV_SendData[7] = 0x00;
  ENV_SendData[8] = 0x00;
  ENV_SendData[9] = 0x00;
  ENV_SendData[10] = 0x00;
  SendTcpData_BYTE();
}

void ENV_Circuit1()
{
  ENV_SendData[5] = 0x0A;
  ENV_SendData[6] = 0x00;
  ENV_SendData[7] = 0x00;
  ENV_SendData[8] = 0x00;
  ENV_SendData[9] = 0x00;
  ENV_SendData[10] = 0x00;
  SendTcpData_BYTE();
  write("inf");
}

void ENV_Circuit2()
{
  ENV_SendData[5] = 0x0A;
  ENV_SendData[6] = 0x00;
  ENV_SendData[7] = 0x00;
  ENV_SendData[8] = 0x00;
  ENV_SendData[9] = 0x00;
  ENV_SendData[10] = 0x00;
  SendTcpData_BYTE();
  testWaitForTimeout(100);
  ENV_SendData[5] = 0x0B;
  ENV_SendData[6] = 0x00;
  ENV_SendData[7] = 0x00;
  ENV_SendData[8] = 0x00;
  ENV_SendData[9] = 0x00;
  ENV_SendData[10] = 0x00;
  SendTcpData_BYTE();
}

