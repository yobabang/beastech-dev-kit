  ENV_SendData[10] = 0x00;
  SendTcpData_BYTE();
}

void Non_Terminal_MaxLoad_No_Rx()
{
  ENV_SendData[5] = 0x00;
  ENV_SendData[6] = 0x02;
  ENV_SendData[7] = 0x00;
  ENV_SendData[8] = 0x02;
  ENV_SendData[9] = 0x02;
  ENV_SendData[10] = 0x10;
  SendTcpData_BYTE();
}

void Non_Terminal_MaxLoad_Rx()
{
  ENV_SendData[5] = 0x00;
  ENV_SendData[6] = 0x02;
  ENV_SendData[7] = 0x0A;
  ENV_SendData[8] = 0x02;
  ENV_SendData[9] = 0x02;
  ENV_SendData[10] = 0x10;
  SendTcpData_BYTE();
}

