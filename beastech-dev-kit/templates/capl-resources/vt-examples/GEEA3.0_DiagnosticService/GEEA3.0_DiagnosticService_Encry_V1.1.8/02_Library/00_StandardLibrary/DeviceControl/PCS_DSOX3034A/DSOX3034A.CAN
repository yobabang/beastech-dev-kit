  SendTcpData(":MEASure:FALLtime CHANnel2\n");
  testWaitForTimeout(10);
  SendTcpData(":MEASure:FALLtime CHANnel1\n");
  testWaitForTimeout(10);
  SendTcpData(":MEASure:RISetime CHANnel2\n");
  testWaitForTimeout(10);
