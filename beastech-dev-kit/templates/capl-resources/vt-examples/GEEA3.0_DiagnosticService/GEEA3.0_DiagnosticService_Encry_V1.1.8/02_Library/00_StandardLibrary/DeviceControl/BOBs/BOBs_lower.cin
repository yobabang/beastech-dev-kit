}

void SendTcpData_BYTE()
{
  @sysvar::DeviceControl::IPClient::SendEvent::TCPHandle = @sysvar::DeviceControl::IPClient::Sockets::ETH_CAN1_Socket;//使用的socket
  sysSetVariableData(sysvar::DeviceControl::IPClient::SendEvent::SendDataByte, BOB_SendData, elcount(BOB_SendData));//发送的数据
  @sysvar::DeviceControl::IPClient::SendEvent::TCPSend_Byte = elcount(BOB_SendData);//发送数据的长度，也是触发的事件
}

void ALL_BOB_Reset()
{
  BOB_SendData[0] =0x08;
  BOB_SendData[1] =0x00;
  BOB_SendData[2] =0x00;
  BOB_SendData[3] =0x07;
  BOB_SendData[4] =0xfe;
  BOB_SendData[5] =0x01;
  BOB_SendData[6] =0x00;
  BOB_SendData[7] =0x00;
  BOB_SendData[8] =0x00;
  BOB_SendData[9] =0x00;
  BOB_SendData[10] =0x00;
  BOB_SendData[11] =0x00;
  BOB_SendData[12] =0x00;
  SendTcpData_BYTE();
}

void BOB_Ctr(dword BOB_ID,enum OperName opername)//
{
  BOB_SendData[3] =(byte)(BOB_ID>>8);
  BOB_SendData[4] =(byte)BOB_ID;
  BOB_SendData[5] = (byte)(OperCmd[opername]>>56);
  BOB_SendData[6] = (byte)(OperCmd[opername]>>48);
  BOB_SendData[7] = (byte)(OperCmd[opername]>>40);
  SendTcpData_BYTE();
}



