/// <TRC>
void StopTRC()
{
  char sigStr[500]="";
  
  gTimeCnt=0;
  cancelTimer(t_TimeCnt);
  testStep("","");
  testStep("Info","Stop simulation of TRC SignalGroups %s",sigStr);
}

void ParameterOfSigGroupsInit()
{
  int  i;
  int  errflag = 0;
  long returnValue; 
  char info[200] = "未找到工程中包含以下网段信息，请注意添加：\n\n"; //用于存储错误错误信息
  
  if(gTestTypeFlag == 1)
  {
    if(CLUSTER_NUM_CAN != 0) //说明需要仿真报文至CAN总线，判断工程中是否能找到相应的网段信息
    {
      for(i=0;i<CLUSTER_NUM_CAN;i++)
      {
        if(getBusNameContext(gClusterName[i]) == 0) //未找到相关的网段信息
        {
          snprintf(info,elcount(info),"%s%s\n",info,gClusterName[i]);
          errflag = 1;
        }
      }
    }
    
    if(errflag == 1) //弹窗提示测试人员添加仿真网段，并确认是否继续执行测试
    {
      snprintf(info,elcount(info),"%s\n\n请确认是否继续执行测试！！！\n\nYes: 继续执行测试（可能会导致信号仿真功能失效）\nNo : 停止测试，添加网段信息后重新执行测试",info);
      returnValue = testWaitForTesterConfirmation(info);
      if(returnValue == 1)
      {
        testStepWarning("",info);
        testStepWarning("","测试人员确认继续执行测试！！！");
      }
      else { testStepWarning("","测试人员确认不继续执行测试，测试终止！！！"); stop(); }
    }
  }
}




