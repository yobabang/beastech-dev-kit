includes
{
  #pragma library("..\04_DLL\GenSAKey2.dll") //用于生成安全访问的Seed and Key
}

variables
{
  enum SeedState {AllZero=0,NotAllZero=1,CheckRandom=2};
  enum Sim_Switch {Sim_on = 0x01,Sim_off = 0x00,Sim_cut = 0x02};
  float gTimeTCPDisCnct,gTimeTCPCnct;
  int gTCPCnctFlag; 
  int gECUInitTimeCheckFlag = 0;
  dword gTolerateTimeForTCPConnect = 60000;////偏离后建立TCP的时间
  dword gTolerateTimeForDiagInit = 1000;////TCP建立后诊断使能时间
  dword gTolerateTimeForSYNMessage = 60000;////等待SYN报文时间
  dword gConnectionSocket;
  //22服务参数
  int  PreLenth;
  byte PreData[5120];//用来写入读取到的数据
  byte TestData[5120];
  
  //19服务的参数
  byte AvailiableMask=0xFF;//DTC有效掩码
  byte   supdtc[3000];
  int Ndtc=0;
  int NdtcSD=0;
  
  int gnum_of_snapshot_record_num;

  struct DTC
  {
  byte DTCNumber[3];
  byte DTCStatus;
  };

  struct DTC DTCNEW[2000];
  struct DTC recdtc[2000];
  struct DTC TestDtc[2];
  
  struct DTCSnapshotData
  {
    byte DTCNumber[3];
    byte DTCSnapshotRecordNum;
  };
  struct DTCSnapshotData DTCSnapshotDataREC[1000];

  
  dword  testdtc[2];

  //28服务
  enum e_CommunicationControl {DEAPP,DENM,DEALL,DENONE};
  int gReceiveID=0,gFlagApp=0,gFlagNM=0,gNMID=0,gAppID=0;
  int gfalg_app_message_received,gflag_nm_message_received;
  int subnetComConTestingFlag=0;
  int subnetComConTestingChannel=0;
  
  //23 3D
  int Flag_Ser_0x23_For0x24=0;
	int Flag_Ser_0x3D_For0x24=0;
  
  int  Rss1;//中间参量 
  
  //29服务
  enum e_AuthenticateState {Deauthenticated,Authenticated};
  enum e_SecDiagFunConfig {Disable,UnidirectionalAuthen,BidirectionalAuthen};
  //29服务
  
  //TP Message
  message 0x0 TP_FirstFrame={dlc=8,byte(0)=0x10,byte(1)=0x08,byte(2)=0x13};
  message 0x0 TP_FC_CTS={dlc=8,byte(0)=0x30,byte(1)=0x00,byte(2)=0x7F};
  message 0x0 TP_CF1={dlc=8,byte(0)=0x21};
  msTimer SendF186;
  message 0x0 msgF186={dlc=8,byte(0)=0x03,byte(1)=0x22,byte(2)=0xf1,byte(3)=0x86};
  
  /* 20240827 */
  int   gflag_check_ecu_init_time;
}
on timer SendF186
{
  output(msgF186);
}

on message *
{
  int ReceiveID;
  
  if(this.dir==rx&&this.SIMULATED==0)  
  {
    if(subnetComConTestingFlag==0)
    {
      if((this.id<0x500)&&(this.id>0)||(this.id<0x600)&&(this.id>0x53F))
      {
        gFlagApp=1;
        gfalg_app_message_received = 1;
        testSupplyTextEvent("CANAPPmessageReceived");
  //      write("APPID:%x CAN:%x",this.id,this.can);
      }
      else if((this.id<=0x53F)&&(this.id>=0x500))//更正NM报文的ID范围
      {
        gFlagNM=1;
        gflag_nm_message_received = 1;
        testSupplyTextEvent("CANNMmessageReceived");
  //      write("NMID:%x CAN:%x",this.id,this.can);
      }
    }
    else
    {
      if(this.can==subnetComConTestingChannel)
      {
        if((this.id<0x500)&&(this.id>0)||(this.id<0x600)&&(this.id>0x53F))
        {
          gFlagApp=1;
          gfalg_app_message_received = 1;
          testSupplyTextEvent("CANAPPmessageReceived");
    //      write("APPID:%x CAN:%x",this.id,this.can);
        }
        else if((this.id<=0x53F)&&(this.id>=0x500))//更正NM报文的ID范围
        {
          gFlagNM=1;
          gflag_nm_message_received = 1;
          testSupplyTextEvent("CANNMmessageReceived");
    //      write("NMID:%x CAN:%x",this.id,this.can);
        }
      }
    }
  }
}

//Geely
void PID27_Parameters_Seeds_Chk()
{
	int i;
	if(gTpRxData[0]!=0x67)
	{
		testStepFail("Chk","Not expect response");
		return;
	}
	CmpPID(seedTemp,gSeedArray,Fail);
	for( i = 0; i < elCount(gSeedArray); i++ )
	{
		seedTemp[i] = gSeedArray[i];
	}
}

void PID27_Parameters_Seeds_Chk_Sameseed()
{
	int i;
	if(gTpRxData[0]!=0x67)
	{
		testStepFail("Chk","Not expect response");
		return;
	}
	CmpPID(seedTemp,gSeedArray,Pass);
	for( i = 0; i < elCount(gSeedArray); i++ )
	{
		seedTemp[i] = gSeedArray[i];
	}
}

void PID27_Parameters_Seeds_Chk(enum SeedState State,byte SeedArray[])
{
	int i;
  int SeedFlag=0;
  
  SeedFlag=0;
  if(gRss!=POS)
    return;
	if(gTpRxData[0]!=0x67)
	{
		testStepFail("UDS_Fun","Not expect response");
		return;
	}
  if(State==AllZero)
  {
    SeedFlag=0;
    write("Flag is %d",SeedFlag);
    for(i=0; i<elCount(SeedArray); i++)
    {
      write("seedarray %d is %02x",i,SeedArray[i]);
      if(SeedArray[i]!=0)
        SeedFlag=1;
    }
    write("Flag is %d",SeedFlag);
    if(SeedFlag==1)
    {
      testStepFail("UDS_Fun","The seed is not all zero");
    }
    else
    {
      testStepPass("UDS_Fun","The seed is all zero");
    }
  }
  else if(State==NotAllZero)
  {
    for(i=0; i<elCount(SeedArray); i++)
    {
      if(SeedArray[i]!=0)
        SeedFlag=1;
    }
    if(SeedFlag==1)
    {
      testStepPass("UDS_Fun","The seed is not all zero");
    }
    else
    {
      testStepFail("UDS_Fun","The seed is all zero");
    }
  }
  else if(State==CheckRandom)
  {
  	CmpPID(seedTemp,SeedArray,Fail);
  	for( i = 0; i < elCount(SeedArray); i++ )
  	{
  		seedTemp[i] = SeedArray[i];
  	}
  }
}
