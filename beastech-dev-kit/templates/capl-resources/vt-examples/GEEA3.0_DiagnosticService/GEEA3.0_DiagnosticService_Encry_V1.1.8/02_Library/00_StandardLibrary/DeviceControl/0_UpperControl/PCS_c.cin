/*@!Encoding:936*/
/*
PCS接口调用步骤：
1.调用初始化接口，配置示波器参数
2.触发波形，设置时基（缩放、移动）
3.Add Measure 选择添加测量接口
4.Result 选择测试结果接口
5.调用保存图片log接口
*/
variables
{
  enum PCS_Measure_Type{DEBUG=0,BUSVOLTAGE,COMMVOLT,BITTIME,EDGETIME};
//  enum e_PCS_Location{PCS_Arb = 0, PCS_Data = 1}; 
}

/// <c_AddMeasure>
void PCS_BusVoltageMeasure()
{    
  @sysvar::DeviceControl::PCS::Command::MEAS_TYPE=BUSVOLTAGE;
  @sysvar::DeviceControl::PCS::Command::Measure=1;
}

/// <c_AddMeasure>
void PCS_CommVoltMeasure()
{ 
  @sysvar::DeviceControl::PCS::Command::MEAS_TYPE=COMMVOLT;
  @sysvar::DeviceControl::PCS::Command::Measure=1;
}

/// <d_Result/Query>
float PCS_MeasureResultQuery(Char Type[],char Source[])
{
  testWaitForTimeout(200);
  
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::Meas_Type,Type);
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::Meas_Sour,Source);
  @sysvar::DeviceControl::PCS::Command::MeasResult_Query++;
  testWaitForSysVar(sysvar::DeviceControl::PCS::Parameter::Meas_Result,5000);
  return @sysvar::DeviceControl::PCS::Parameter::Meas_Result;
}

/// <d_Result>
void PCS_BusVoltageResult(float& BitVoltage_CANH_Dom,float& BitVoltage_CANH_Res,float& BitVoltage_CANL_Res,float& BitVoltage_CANL_Dom,float& BitVoltage_Diff_Dom,float& BitVoltage_Diff_Res)
{
  BitVoltage_CANH_Dom= PCS_MeasureResultQuery("Vtop","Channel1");
  BitVoltage_CANH_Res= PCS_MeasureResultQuery("Vbase","Channel1");
  BitVoltage_CANL_Res= PCS_MeasureResultQuery("Vtop","Channel2");
  BitVoltage_CANL_Dom= PCS_MeasureResultQuery("Vbase","Channel2");
  BitVoltage_Diff_Dom= PCS_MeasureResultQuery("Vtop","MATH");
  BitVoltage_Diff_Res= PCS_MeasureResultQuery("Vbase","MATH");  
}

/// <d_Result>
void PCS_CommVoltResult(float& BitVoltage_Comm_Dom,float& BitVoltage_Comm_Res)
{
  BitVoltage_Comm_Dom= PCS_MeasureResultQuery("Vtop","MATH");
  BitVoltage_Comm_Res= PCS_MeasureResultQuery("Vbase","MATH");  
}

/// <c_AddMeasure>
void PCS_BitLengthMeasure()
{
  @sysvar::DeviceControl::PCS::Command::MEAS_TYPE=BITTIME;
  @sysvar::DeviceControl::PCS::Command::Measure=1;
}

/// <d_Result>
float PCS_BitLengthResult(int isDataField,int isBRS)
{
  float bitlength,Ntime;
  Ntime = PCS_XCursorQuery();
  if(Ntime != 0)
  {
    if(isDataField == 1 && (isBRS > 0))
      bitlength = Ntime/(_round( Ntime /0.0000005) );//单位为ns
    else
      bitlength = Ntime/(_round( Ntime /0.000002) );
  }
  else
    teststepwarning("","未捕捉到上升沿，请检查");
  return bitlength * 1000000000;//ns
}

/// <c_AddMeasure>
void PCS_BusEdgeTimeMeasure()
{ 
  @sysvar::DeviceControl::PCS::Command::MEAS_TYPE=EDGETIME;
  @sysvar::DeviceControl::PCS::Command::Measure=1;
}

/// <d_Result>
void PCS_BusEdgeTimeResult(float& FallTime_CANH,float& RiseTime_CANH,float& FallTime_CANL,float& RiseTime_CANL,float& FallTime_CANDiff,float& RiseTime_CANDiff)
{
  FallTime_CANH= PCS_MeasureResultQuery("falltime","Channel1")*1000000000;
  RiseTime_CANH= PCS_MeasureResultQuery("risetime","Channel1")*1000000000;
  FallTime_CANL= PCS_MeasureResultQuery("falltime","Channel2")*1000000000;
  RiseTime_CANL= PCS_MeasureResultQuery("risetime","Channel2")*1000000000;
  FallTime_CANDiff= PCS_MeasureResultQuery("falltime","MATH")*1000000000;
  RiseTime_CANDiff= PCS_MeasureResultQuery("risetime","MATH")*1000000000;  
}

