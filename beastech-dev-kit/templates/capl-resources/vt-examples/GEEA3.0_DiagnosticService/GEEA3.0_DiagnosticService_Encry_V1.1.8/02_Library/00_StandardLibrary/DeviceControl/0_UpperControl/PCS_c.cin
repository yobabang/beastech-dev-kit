/// <a_Configure>
void PCS_setTriggerID()//任意ID触发
{
  char TriggerID[256];
  
  snprintf(TriggerID,elcount(TriggerID),"XXX");
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::TriggerID,TriggerID);
}

/// <a_Configure>
void PCS_setTriggerID(dword ID)//特定ID触发
{
  char TriggerID[256];
  char IdBuff[10];
  
  snprintf(IdBuff,elcount(IdBuff),"%02x",ID);
  snprintf(TriggerID,elcount(TriggerID),IdBuff);
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::TriggerID,TriggerID);
}

/// <b_Trigger>
void PCS_Trigger_All()
{
  PCS_setTriggerID();
  @sysvar::DeviceControl::PCS::Command::ID_Trigger++;
}

/// <b_Trigger>
void PCS_Trigger_ID(dword ID)
{
  PCS_setTriggerID(ID);
  @sysvar::DeviceControl::PCS::Command::ID_Trigger++;
}

/// <a_Configure>
void PCS_PreTestConfig(char bustype[],int isDataField,int isBRSEnable)
{
  PCS_SetTimebase(isDataField,isBRSEnable);
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::BusType,bustype);
  @sysvar::DeviceControl::PCS::Command::initSerial = 1;
  testWaitForTimeout(2000);
}



