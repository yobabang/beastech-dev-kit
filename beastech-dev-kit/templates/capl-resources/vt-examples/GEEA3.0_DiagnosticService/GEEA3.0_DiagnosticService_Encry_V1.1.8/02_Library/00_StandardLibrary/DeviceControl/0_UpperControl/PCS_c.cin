/// <d_Result/Query>
float PCS_XCursorQuery()
{
  float result;
  @sysvar::DeviceControl::PCS::Cursors::XCursor++;
  testWaitForTimeout(200);
  result = sysGetVariableFloat("DeviceControl::PCS::Cursors","CursorValue");
  return result;
}

/// <d_Result/Query>
float PCS_YCursorQuery()
{
  float result;
  @sysvar::DeviceControl::PCS::Cursors::YCursor++;
  testWaitForTimeout(200);
  result = sysGetVariableFloat("DeviceControl::PCS::Cursors","CursorValue");
  return result;
}

//示波器一般可以设置窗口大小和偏移，可根据使用者需要修改
/// <a_Configure>
void PCS_SetTimebase(int isDataField,int isBRSEnable)
{
  
    if(isDataField == 1 && (isBRSEnable > 0))//CANFD数据场,BRS=1,2M
    {
        @sysvar::DeviceControl::PCS::Timebase::Scale=0.0000005;//500ns
        @sysvar::DeviceControl::PCS::Timebase::position=0.0000005 * 30;/*将波形向右移动30位，使数据场占据屏幕；一格是4位*/
    }
    else//500k
    {
      if(isDataField == 1 && isBRSEnable == 0)//CAN数据场，/canfd数据场且BRS=0
      {
        @sysvar::DeviceControl::PCS::Timebase::Scale=0.000002;//2us
        @sysvar::DeviceControl::PCS::Timebase::position=0.000002 * 30;/*将波形向右移动30位，使数据场占据屏幕；一格是1位*/
      }
      else//CAN(FD)仲裁场
      {
        @sysvar::DeviceControl::PCS::Timebase::Scale=0.000005;
        @sysvar::DeviceControl::PCS::Timebase::position=-0.000002 * 10;/*将波形向右移动10位，使仲裁场占据屏幕；一格是2.5位,移动4格*/
      }    
    }
}

/// <e_SavePicture>
void PCS_SavePicture(char PicPath[],char PicName[])
{
  char path[256];
  char picpath[512];
  char userFileName[512],relFileName[512];
  char fileNameRel2Xml[512];
  teststep("OSC_SavePicture","");
  snprintf(picpath,elcount(picpath),"%s\\%s",PicPath,PicName);
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::PicPath,picpath);
  write("[picturepath]:%s",PicPath);
  write("[picturefilepath]:%s",picpath);
  testWaitForTimeout(10);
  @sysvar::DeviceControl::PCS::Command::SavePicture = 1;
  testWaitForTimeout(11000);
  testReportAddImage(PicName,picpath);
}

