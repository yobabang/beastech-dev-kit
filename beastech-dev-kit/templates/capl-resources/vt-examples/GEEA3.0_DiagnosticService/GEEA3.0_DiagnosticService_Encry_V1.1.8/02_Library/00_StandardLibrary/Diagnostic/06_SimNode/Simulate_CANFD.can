  snprintf(gDLLName, 400, "%s\\02_Library\\04_SecurityHandle\\GenerateKeyExImpl.dll", cfgPath);
  write("dll name is %s",gDLLName);
  
  memcpy(Challenge8Byte,SeedArray,3);
  memcpy_off(Challenge8Byte,3,FixedBytes,0,5);
  
