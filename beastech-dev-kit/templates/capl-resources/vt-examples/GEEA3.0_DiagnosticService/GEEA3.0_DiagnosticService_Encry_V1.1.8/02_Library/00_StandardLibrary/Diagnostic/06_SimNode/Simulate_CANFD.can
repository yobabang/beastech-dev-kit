//    PosRes[76] = 0x00;
//    PosResLength=77;
//    CanTpSendData(CAN_connHandle,PosRes,PosResLength);
//    
//    
//    return;  
//  }
    else if(ReceiveLength > 21)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断最小长度
  
  DataIdentifer = ((ReceiveData[1]<<8)+ReceiveData[2]);
  //判断DID
  switch(DataIdentifer)
  {
    case 0xF186:
    {
      PosResLength = 4;
      PosRes[1] = 0xF1;
      PosRes[2] = 0x86;
      PosRes[3] = gCurrentSession;
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xD01C:
    {
      if(gCurrentSession == PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x22);
        break;
      }
      else
      {
        SendNegativeResponse(0x31);
        break;
      }
    }
    case 0xF1A0://控制器诊断数据库版本信息
    {
      PosResLength = 11;
      PosRes[1] = 0xF1;
      PosRes[2] = 0xA0;
      for(i=0;i<8;i++)
      {
        PosRes[i+3] = gECUDiagnosticDatabasePN[i];
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xF1AA://控制器硬件版本信息
    {
      PosResLength = 11;
      PosRes[1] = 0xF1;
      PosRes[2] = 0xAA;
      for(i=0;i<8;i++)
      {
        PosRes[i+3] = gECUHardwareNumber[i];
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xF1A2://控制器SBL版本信息
    {
      if((gCurrentSession != PROGRAMMINGSESSION)||(gSBLActived != 1))
      {
        SendNegativeResponse(0x31);
        break;
      }
      PosResLength = 11;
      PosRes[1] = 0xF1;
      PosRes[2] = 0xA2;
      for(i=0;i<8;i++)
      {
        PosRes[i+3] = gECUHardwareNumber[i];
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xF1AB://控制器版本信息
    {
      PosResLength = 11;
      PosRes[1] = 0xF1;
      PosRes[2] = 0xAB;
      for(i=0;i<8;i++)
      {
        PosRes[i+3] = gECUDeliveryAssemblyPartNumberGeely[i];
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xF18C://控制器SN版本信息
    {
      PosResLength = 7;
      PosRes[1] = 0xF1;
      PosRes[2] = 0x8C;
      for(i=0;i<8;i++)
      {
        PosRes[i+3] = gECUSerialNumber[i];
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xF1AE://控制器软件版本信息
    {
      if(gCurrentSession == PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x31);
        break;
      }
      PosResLength = gECUSoftwareNumberLength;
      PosRes[1] = 0xF1;
      PosRes[2] = 0xAE;
      for(i=0;i<gECUSoftwareNumberLength;i++)
      {
        PosRes[i+3] = gECUSoftwareNumber[i];
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength+3);
      break;
    }
    case 0xF1A5://控制器BootLoader版本信息
    {
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x31);
        break;
      }
      PosResLength = 11;
      PosRes[1] = 0xF1;
      PosRes[2] = 0xA5;
      for(i=0;i<8;i++)
      {
        PosRes[i+3] = gECUBootNumber[i];
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xED20://控制器综合信息
    {
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        PosResLength = 8+8+8+4+gECUSoftwareNumberLength+3;
        PosRes[1] = 0xED;
        PosRes[2] = 0x20;
        for(i=0;i<(PosResLength-3);i++)
        {
          if(i<8)
          {
            PosRes[i+3] = gECUDiagnosticDatabasePN[i];
          }
          else if(i<16)
          {
            PosRes[i+3] = gECUHardwareNumber[i-8];
          }
          else if(i<24)
          {
            PosRes[i+3] = gECUDeliveryAssemblyPartNumberGeely[i-16];
          }
          else if(i<28)
          {
            PosRes[i+3] = gECUSerialNumber[i-24];
          }
          else
          {
            PosRes[i+3] = gECUSoftwareNumber[i-28];
          }
        }
        CanTpSendData(CAN_connHandle,PosRes,PosResLength);
        break;
      }
      else
      {
        PosResLength = 39;
        PosRes[1] = 0xED;
        PosRes[2] = 0x20;
        for(i=0;i<(PosResLength-3);i++)
        {
          if(i<8)
          {
            PosRes[i+3] = gECUDiagnosticDatabasePN[i];
          }
          else if(i<16)
          {
            PosRes[i+3] = gECUHardwareNumber[i-8];
          }
          else if(i<24)
          {
            PosRes[i+3] = gECUDeliveryAssemblyPartNumberGeely[i-16];
          }
          else if(i<28)
          {
            PosRes[i+3] = gECUSerialNumber[i-24];
          }
          else
          {
            PosRes[i+3] = gECUBootNumber[i-28];
          }
        }
        CanTpSendData(CAN_connHandle,PosRes,PosResLength);
        break;
      }
    }
    default :
    {
      SendNegativeResponse(0x31);
      break;
    }
  }
  //判断子功能
  
}

void HandleService_0x31(byte ReceiveData[],dword ReceiveLength)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  byte PosRes[100];
  int  PosResLength;
  
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  
  dword DataIdentifer;
  int  i;
  
  PosRes[0] = 0x71;
  //判断最小长度
  if(ReceiveLength <= 3)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断最小长度
  
  SuppressPosRspMsgIndicationBit = ReceiveData[1]>>7;
  Subfunction = (ReceiveData[1]&0x7F);
  
  DataIdentifer = ((ReceiveData[2]<<8)+ReceiveData[3]);
  //判断DID
  switch(DataIdentifer)
  {
    case 0x0212://验证签名
    {
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x31);
        break;
      }
      if(gCurrentState != BootLevelUnlocked)
      {
        SendNegativeResponse(0x33);
        return;
      }
      //判断最大长度
      if(ReceiveLength != 260)
      {
        SendNegativeResponse(0x13);
        return;  
      }
      //判断最大长度
      PosResLength = 6;
      PosRes[1] = Subfunction;
      PosRes[2] = ReceiveData[2];
      PosRes[3] = ReceiveData[3];
      PosRes[4] = 0x10;
      if(ReceiveData[4] == 0x02)
      {
        PosRes[5] = 0x01;
        gCompleteFlag = 0;
      }
      else
      {
        PosRes[5] = 0x00;
        if(ReceiveData[4] == 0x01)
        {
          gCompleteFlag = 1;
          gComppatiable = 0;
          //gFlag_ECUAPP = 2;
        }
        else
        {
          gCompleteFlag = 1;
          gComppatiable = 1;
          //gFlag_ECUAPP = 1;
        }
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0x0301://激活SBL
    {
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x31);
        break;
      }
      if(gCurrentState != BootLevelUnlocked)
      {
        SendNegativeResponse(0x33);
        return;
      }
      //判断最大长度
      if(ReceiveLength != 8)
      {
        SendNegativeResponse(0x13);
        return;  
      }
      //判断最大长度
      PosResLength = 5;
      PosRes[1] = Subfunction;
      PosRes[2] = ReceiveData[2];
      PosRes[3] = ReceiveData[3];
      PosRes[4] = 0x10;
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      gSBLActived = 1;
      break;
    }
    case 0x0206://进入编程模式条件检查
    {
      if(gCurrentSession == PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x31);
        break;
      }
      //判断最大长度
      if(ReceiveLength != 4)
      {
        SendNegativeResponse(0x13);
        return;  
      }
      //判断最大长度
      PosResLength = 6;
      PosRes[1] = Subfunction;
      PosRes[2] = ReceiveData[2];
      PosRes[3] = ReceiveData[3];
      PosRes[4] = 0x10;
      PosRes[5] = 0x01;
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    case 0xFF00://擦除信息
    {
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x31);
        break;
      }
      //判断最大长度
      if(ReceiveLength != 12)
      {
        SendNegativeResponse(0x13);
        return;  
      }
      //判断最大长度
      PosResLength = 5;
      PosRes[1] = Subfunction;
      PosRes[2] = ReceiveData[2];
      PosRes[3] = ReceiveData[3];
      PosRes[4] = 0x10;
      PosRes[5] = 0x01;
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      gFlag_ECUAPP = 0;
      gCompleteFlag = 0;
      gComppatiable = 0;
      break;
    }
    case 0x0205://完整性一致性校验
    {
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x31);
        break;
      }
      //判断最大长度
      if(ReceiveLength != 4)
      {
        SendNegativeResponse(0x13);
        return;  
      }
      if(gCompleteFlag == 0)
      {
        gFlag_ECUAPP = 0;
      }
      else if(gComppatiable == 0)
      {
        gFlag_ECUAPP = 2;
      }
      else
      {
        gFlag_ECUAPP = 1;
      }
      //判断最大长度
      PosResLength = 9;
      PosRes[1] = Subfunction;
      PosRes[2] = ReceiveData[2];
      PosRes[3] = ReceiveData[3];
      PosRes[4] = 0x10;
      PosRes[5] = 0x00;
      PosRes[6] = 0x00;
      PosRes[7] = 0x00;
      if(gFlag_ECUAPP == 1)
      {
        PosRes[8] = 0x00;
      }
      else if(gFlag_ECUAPP == 0)
      {
        PosRes[8] = 0x05;
      }
      else if(gFlag_ECUAPP == 2)
      {
        PosRes[8] = 0x02;
      }
      CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      break;
    }
    default:
    {
      SendNegativeResponse(0x31);
      break;
    }
  }
  //判断子功能
  
}

void HandleService_0x27(byte ReceiveData[],dword ReceiveLength)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  byte PosRes[6] = {0x67,0x00,0x00,0x00,0x01,0xF4};
  int  PosResLength;
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  
  int  CompareFlag;
  int  i;
  
  
  //判断长度
  if(ReceiveLength <= 1)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断长度
  
  SuppressPosRspMsgIndicationBit = ReceiveData[1]>>7;
  Subfunction = (ReceiveData[1]&0x7F);
  
  //判断子功能
  switch(Subfunction)
  {
    case 0x01:
    {
      if(ReceiveLength != 2)
      {
        SendNegativeResponse(0x13);
        break;
      }
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x7E);
        break;
      }
      if(gFailAttemptCounterLelve_0x01 == gFailCounterMax)
      {
        SendNegativeResponse(0x37);
        break;
      }
      PosResLength = gNumverOfSeed + 2;
      PosRes[1] = 0x01;
      if(gCurrentState == BootLevelUnlocked)
      {
        for(i = 0;i<gNumverOfSeed;i++)
        {
          PosRes[i+2] = 0;
        }
      }
      else
      {
        for(i = 0;i<gNumverOfSeed;i++)
        {
          PosRes[i+2] = random(256);
          gSeedArray[i] = PosRes[i+2];
        }
        gFlag_SeedRequest_Level0x01 = 1;
      }
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      }
      break;
    }
    case 0x02:
    {
      if(ReceiveLength != (gNumverOfSeed + 2))
      {
        SendNegativeResponse(0x13);
        
        //在进入2702判断后，即对种子请求状态做清除
        gFlag_SeedRequest_Level0x01 = 0;
        gFlag_SeedRequest_Level0x05 = 0;
        break;
      }
      if(gCurrentSession != PROGRAMMINGSESSION)
      {
        SendNegativeResponse(0x7E);
        //在进入2702判断后，即对种子请求状态做清除
        gFlag_SeedRequest_Level0x01 = 0;
        gFlag_SeedRequest_Level0x05 = 0;
        break;
      }
      if(gFlag_SeedRequest_Level0x01 != 1)
      {
        SendNegativeResponse(0x24);
        break;
      }
      //在进入2702判断后，即对种子请求状态做清除
      gFlag_SeedRequest_Level0x01 = 0;
      gFlag_SeedRequest_Level0x05 = 0;
      GenerateKey(gSeedArray,gKeyArray,gNumverOfSeed,0x01,gECUFixBytes_L1);
      CompareFlag = 0;
      for(i=0;i<gNumverOfSeed;i++)
      {
        if(gKeyArray[i] != ReceiveData[i+2])
        {
          CompareFlag = 1;
        }
      }
      if(CompareFlag == 1)
      {
        gFailAttemptCounterLelve_0x01++;
        if(gFailAttemptCounterLelve_0x01<gFailCounterMax)
        {
          SendNegativeResponse(0x35);
          break;
        }
        else
        {
          SendNegativeResponse(0x36);
          setTimer(DelatTimer_Level0x01,gDelayTimerTimeoutTime);
          break;
        }
      }
      else
      {
      PosResLength = 2;
      PosRes[1] = 0x02;
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      }
      gFailAttemptCounterLelve_0x01 = 0;
      gCurrentState = BootLevelUnlocked;
      }
      break;
    }
    case 0x05:
    {
      if(ReceiveLength != 2)
      {
        SendNegativeResponse(0x13);
        break;
      }
      if(gCurrentSession != EXTENDEDSESSION)
      {
        SendNegativeResponse(0x7E);
        break;
      }
      if(gFailAttemptCounterLelve_0x05 == gFailCounterMax)
      {
        SendNegativeResponse(0x37);
        break;
      }
      PosResLength = gNumverOfSeed + 2;
      PosRes[1] = 0x05;
      if(gCurrentState == WriteLevelUnlocked)
      {
        for(i = 0;i<gNumverOfSeed;i++)
        {
          PosRes[i+2] = 0;
        }
      }
      else
      {
        for(i = 0;i<gNumverOfSeed;i++)
        {
          PosRes[i+2] = random(256);
          gSeedArray[i] = PosRes[i+2];
        }
        gFlag_SeedRequest_Level0x05 = 1;
      }
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      }
      break;
    }
    case 0x06:
    {
      if(ReceiveLength != (gNumverOfSeed + 2))
      {
        SendNegativeResponse(0x13);
        
        //在进入2702判断后，即对种子请求状态做清除
        gFlag_SeedRequest_Level0x01 = 0;
        gFlag_SeedRequest_Level0x05 = 0;
        break;
      }
      if(gCurrentSession != EXTENDEDSESSION)
      {
        SendNegativeResponse(0x7E);
        //在进入2702判断后，即对种子请求状态做清除
        gFlag_SeedRequest_Level0x01 = 0;
        gFlag_SeedRequest_Level0x05 = 0;
        break;
      }
      if(gFlag_SeedRequest_Level0x05 != 1)
      {
        SendNegativeResponse(0x24);
        break;
      }
      //在进入2702判断后，即对种子请求状态做清除
      gFlag_SeedRequest_Level0x01 = 0;
      gFlag_SeedRequest_Level0x05 = 0;
      GenerateKey(gSeedArray,gKeyArray,gNumverOfSeed,0x05,gECUFixBytes_L5);
      CompareFlag = 0;
      for(i=0;i<gNumverOfSeed;i++)
      {
        if(gKeyArray[i] != ReceiveData[i+2])
        {
          CompareFlag = 1;
        }
      }
      if(CompareFlag == 1)
      {
        gFailAttemptCounterLelve_0x05++;
        if(gFailAttemptCounterLelve_0x05<gFailCounterMax)
        {
          SendNegativeResponse(0x35);
          break;
        }
        else
        {
          SendNegativeResponse(0x36);
          setTimer(DelatTimer_Level0x05,gDelayTimerTimeoutTime);
          break;
        }
      }
      else
      {
      PosResLength = 2;
      PosRes[1] = 0x06;
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,PosResLength);
      }
      gFailAttemptCounterLelve_0x05 = 0;
      gCurrentState = WriteLevelUnlocked;
      }
      break;
    }
    default :
    {
        SendNegativeResponse(0x12);
      break;
    }
  }
  //判断子功能
  
}

void HandleService_0x3E(byte ReceiveData[],dword ReceiveLength)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  byte PosRes[2] = {0x7E,0x00};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  
  
  //判断长度
  if(ReceiveLength != 2)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断长度
  
  SuppressPosRspMsgIndicationBit = ReceiveData[1]>>7;
  Subfunction = (ReceiveData[1]&0x7F);
  
  //判断子功能
  switch(Subfunction)
  {
    case 0x00:
    {
      PosRes[1] = 0x00;
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,2);
      }
      break;
    }
    default :
    {
      SendNegativeResponse(0x12);
      break;
    }
  }
  //判断子功能
  
}

void HandleService_0x11(byte ReceiveData[],dword ReceiveLength)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  byte PosRes[2] = {0x51,0x00};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  
  
  //判断长度
  if(ReceiveLength != 2)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断长度
  
  SuppressPosRspMsgIndicationBit = ReceiveData[1]>>7;
  Subfunction = (ReceiveData[1]&0x7F);
  
  //判断子功能
  switch(Subfunction)
  {
    case 0x01:
    {
      PosRes[1] = 0x01;
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,2);
      }
      if(gFlag_ECUAPP == 1)
      { 
        gCurrentSession = DEFAULTSESSION;
      }
      else
      {
        gCurrentSession = PROGRAMMINGSESSION;
      }
      break;
    }
    default :
    {
      SendNegativeResponse(0x12);
      break;
    }
  }
  //判断子功能
  
}

void HandleService_0x19(byte ReceiveData[],dword ReceiveLength)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  byte PosRes[3] = {0x59,0x00,0x00};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  
  
  //判断长度
  if(ReceiveLength <= 2)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  
  if(gFlag_ECUAPP != 1)
  {
     SendNegativeResponse(0x11);
     return;
  }
  //判断长度
  
  SuppressPosRspMsgIndicationBit = ReceiveData[1]>>7;
  Subfunction = (ReceiveData[1]&0x7F);
  
  //判断子功能
  switch(Subfunction)
  {
    case 0x02:
    {
      if(ReceiveLength != 3)
      {
        SendNegativeResponse(0x13);
        return;  
      }
      PosRes[1] = 0x02;
      PosRes[2] = 0xFF;
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,3);
      }
      break;
    }
    default :
    {
      SendNegativeResponse(0x12);
      break;
    }
  }
  //判断子功能
  
}

void HandleService_0x14(byte ReceiveData[],dword ReceiveLength)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  byte PosRes[1] = {0x54};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  
  if(gFlag_ECUAPP != 1)
  {
     SendNegativeResponse(0x11);
     return;
  }
  //判断长度
  if(ReceiveLength != 4)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断长度
  
  CanTpSendData(CAN_connHandle,PosRes,1);
  
}

void HandleService_0x34(byte ReceiveData[],dword ReceiveLength)
{
  byte PosRes[4] = {0x74,0x20,0x0F,0xFF};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  int  i;
  
  //判断当前会话
  if(gCurrentSession != PROGRAMMINGSESSION)
  {
    SendNegativeResponse(0x7E);
    return;
  }
  //判断当前会话
  //判断解锁状态
  if(gCurrentState != BootLevelUnlocked)
  {
    SendNegativeResponse(0x33);
    return;
  }
  //判断解锁状态
  //判断长度
  if(ReceiveLength != (gAddressFormat + gLengthFormat + 3))
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断长度
  
  SuppressPosRspMsgIndicationBit = ReceiveData[1]>>7;
  Subfunction = (ReceiveData[1]&0x7F);
  
  //检查地址及长度
  
  //检查地址及长度
  
  //检查是否擦除
  
  //检查是否擦除
  
  //获取下载长度
  gDwonloadLength = 0;
  for(i=0;i<gLengthFormat;i++)
  {
    gDwonloadLength = gDwonloadLength + (ReceiveData[3+gAddressFormat+i]<<((gLengthFormat-1-i)*8));
  } 
  //获取下载长度
  
  PosRes[2] = gMaxNumberOfBlockLenth>>8;
  PosRes[3] = gMaxNumberOfBlockLenth&0xFF;
  
  gFlag_StartDownload = 1;
  gFlag_FinishDownload = 0;
  gCounter = 1;
  CanTpSendData(CAN_connHandle,PosRes,4);
  
}

void HandleService_0x36(byte ReceiveData[],dword ReceiveLength)
{
  byte PosRes[2] = {0x76,0x00};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  dword i;
  int  flag;
  
  //判断当前会话
  if(gCurrentSession != PROGRAMMINGSESSION)
  {
    SendNegativeResponse(0x7E);
    return;
  }
  //判断当前会话
  //判断解锁状态
  if(gCurrentState != BootLevelUnlocked)
  {
    SendNegativeResponse(0x33);
    return;
  }
  //判断解锁状态
  
  //判断长度
  if(ReceiveLength <=2)
  {
    SendNegativeResponse(0x13);
    return;
  }
  //判断长度
  
  //判断下载顺序
  if(gFlag_StartDownload != 1)
  {
    SendNegativeResponse(0x24);
    return;
  }
  //判断下载顺序
  
  //判断计数器
  if(ReceiveData[1] !=gCounter)
  {
    if(ReceiveData[1] != (gCounter - 1))
    {
      SendNegativeResponse(0x73);
      return;
    }
    else//重复传输相同数据，则直接回复肯定响应
    {
      if(ReceiveLength != (gTempSaveLength + 2))
      {
        SendNegativeResponse(0x73);
        return;
      }
      else
      {
        flag = 0;
        for(i=0;i<gTempSaveLength;i++)
        {
          if(ReceiveData[i+2] != gTempSaveData[i])
          {
            flag = 1;
            break;
          }
        }
        if(flag == 1)
        {
          SendNegativeResponse(0x73);
          return;
        }
        else
        {
          PosRes[1] = ReceiveData[1];
          CanTpSendData(CAN_connHandle,PosRes,2);
          return;
        }
      }
    }
  }
  else
  {
    gCounter++;
    if(gCounter>0xFF)
    {
      gCounter = 0;
    }
  }
  //判断计数器
  
  gTempSaveLength = ReceiveLength - 2;
  for(i = 0;i<gTempSaveLength;i++)
  {
    gTempSaveData[i] = ReceiveData[i+2];
  }
  gDwonloadLength = gDwonloadLength-gTempSaveLength;
  if(gDwonloadLength<0)//下载了超过34服务传输的数据，响应NRC70
  {
    SendNegativeResponse(0x70);
    return;
  }
  else if(gDwonloadLength == 0)
  {
    gFlag_FinishDownload = 1;
  }
  
  PosRes[1] = ReceiveData[1];
  CanTpSendData(CAN_connHandle,PosRes,2);
  
}

void HandleService_0x37(byte ReceiveData[],dword ReceiveLength)
{
  byte PosRes[1] = {0x77};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  int  i;
  
  //判断当前会话
  if(gCurrentSession != PROGRAMMINGSESSION)
  {
    SendNegativeResponse(0x7E);
    return;
  }
  //判断当前会话
  //判断解锁状态
  if(gCurrentState != BootLevelUnlocked)
  {
    SendNegativeResponse(0x33);
    return;
  }
  //判断解锁状态
  //判断长度
  if(ReceiveLength != 1)
  {
    SendNegativeResponse(0x13);
    return;  
  }
  //判断长度
  
  //判断下载顺序
  if(gFlag_FinishDownload != 1)
  {
    SendNegativeResponse(0x24);
    return;
  }
  //判断下载顺序
  
  gFlag_StartDownload = 0;
  gFlag_FinishDownload = 0;
  CanTpSendData(CAN_connHandle,PosRes,1);
  
}
/**************服务处理****************/

/**************获取诊断数据的中断****************/
//物理寻址请求
void CanTp_ReceptionInd( long InputHandle, byte data[])
{
	gTpRxLength=elcount(data);
	memcpy( gTpRxData, data, gTpRxLength);
  gCurrentReqMode = PHYSICAL;
  if(gTpRxLength > 0)
  {
  write("Receive physical request %02x",gTpRxData[0]);
  if(gCurrentSession != DEFAULTSESSION)
  {
    setTimer(S3ServerTimer,gS3ServerTimerTimeoutTime);
  }
  
  ServiceHandle(gTpRxData,gTpRxLength);
  
  }
}

//功能寻址请求
on message gCAN_TP_FuncRequestID
{
  int i;
  
  if(this.dir == rx)
  {
  if(this.byte(0) == 0)
  {
    if(this.FDF == 1)
    {
      gTpRxLength = this.byte(1);
    }
    else
    {
      gTpRxLength = 0;
    }
  }
  else
  {
    gTpRxLength = this.byte(0);
    for(i=0;i<gTpRxLength;i++)
    {
      gTpRxData[i] = this.byte(i+1);
    }
  }
  gCurrentReqMode = FUNCTIONAL;
  if(gTpRxLength > 0)
  {
  write("Receive functional request %02x",gTpRxData[0]);
  if(gCurrentSession != DEFAULTSESSION)
  {
    setTimer(S3ServerTimer,gS3ServerTimerTimeoutTime);
  }
  ServiceHandle(gTpRxData,gTpRxLength);
  }
  
  }
}
/**************获取诊断数据的中断****************/

/***********************初始化函数*************************/
long CAN_TP_Config(dword SoutcesID,dword TargetID )
{
	int DiagMode=0;
	int AddressingMode=0;

  write("Create physical connection");
	CAN_connHandle =CanTpCreateConnection( DiagMode);   //配置诊断模式 0
	CanTpSetTxIdentifier(CAN_connHandle, SoutcesID);   //发送ID
	CanTpSetRxIdentifier(CAN_connHandle, TargetID);    //目标ID
	CanTpUseFlowControlFrames(CAN_connHandle, 1);     //使用流控制
//  CanTpSetFlowControlDelay( connHandle, 50);   //流控制延迟发送
	CanTpSetSTmin(CAN_connHandle, CAN_TP_STmin);  //流控制的时间间隔
	CanTpSetBlockSize( CAN_connHandle, CAN_TP_BlockSize);   //流控制的包数
	CanTpSetAddressType(CAN_connHandle, AddressingMode);  //Set the addressing type, where 1 indicates functional, 0 physical.
  CanTpSetMaxCANFDFrameLength(CAN_connHandle,64);
	CanTpSetTimeoutAs(CAN_connHandle,CAN_TP_AS);//These timeouts specify the maximum time between giving a CAN frame to the transceiver and the confirmation of the sending of the frame on the bus
	CanTpSetTimeoutAr(CAN_connHandle,CAN_TP_AR);//
	CanTpSetTimeBr(CAN_connHandle,CAN_TP_BR);//This value determines the time until the next Flow Control Frame is sent.
	CanTpSetTimeoutBs(CAN_connHandle,CAN_TP_BS);//This timeout defines how long the transmitter waits for a Flow Control Frame
	CanTpSetTimeCs(CAN_connHandle,CAN_TP_CS);   //This value determines the time when the transmitter sends the next Consecutive Frame.
	CanTpSetTimeoutCr(CAN_connHandle,CAN_TP_CR);  //This timeout defines how long the receiver waits for a Consecutive Frame.
  CanTpSetPadding(CAN_connHandle,gPaddingByte);
	return CAN_connHandle;
}

on start
{
  dword gHandle;
    
  gHandle = registerCAPLDLL();

//	SKDLL_Init(gHandle);
  
  gSBLActived = 0;
  
  write("Initial diagnostic!");
  CAN_TP_Config(gCAN_TP_PhyRequestID,gCAN_TP_ResponseID);
  
  if(gFlag_ECUAPP == 1)
  { 
    gCurrentSession = DEFAULTSESSION;
  }
  else
  {
    gCurrentSession = PROGRAMMINGSESSION;
  }
}
