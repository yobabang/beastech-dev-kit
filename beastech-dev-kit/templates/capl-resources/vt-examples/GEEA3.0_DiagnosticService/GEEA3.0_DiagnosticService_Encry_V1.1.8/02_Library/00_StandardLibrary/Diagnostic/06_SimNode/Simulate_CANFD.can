//  #pragma library("osek_tp_New.dll") //用于生成安全访问的Seed and Key
  
}

variables
{
  //ECU信息参数
  int   gECUSN = 1;//用来作为索引数据库的ECU唯一标识
  int   gFlag_ECUAPP = 1;//用来表示应用程序是否有效
  int   gCompleteFlag = 1;
  int   gComppatiable = 1;
  int   gSBLActived = 0;
  
  
  //Diagnostic Session Layer
  dword gTpRxLength; //接收诊断数据的长度
  byte  gTpRxData[65535]; //接收诊断数据的数组
  long  CAN_connHandle;//物理请求的连接句柄
  
  //TP层参数
  dword   gCAN_TP_PhyRequestID  = 0x630;
	const dword   gCAN_TP_FuncRequestID = 0x7FF;
	dword   gCAN_TP_ResponseID    = 0x730;

	int   CAN_TP_AS = 25;
	int   CAN_TP_AR = 25;
	int   CAN_TP_BS = 75;
	int   CAN_TP_BR = 10;
	int   CAN_TP_CS = 20;
	int   CAN_TP_CR = 150;
	int   CAN_TP_BlockSize = 0;
	int   CAN_TP_STmin = 0x00;
	int   gFC_WaitReceived;
  //TP层参数
  
  //状态控制参数
  msTimer S3ServerTimer;
  msTimer DelatTimer_Level0x01;
  msTimer DelatTimer_Level0x05;
  int  gS3ServerTimerTimeoutTime = 5000;
  int  gP2ClientAPP = 50;
  int  gP2ClientBOOT = 25;
  int  gP2StarClient = 5000;
  int  gDelayTimerTimeoutTime = 10000;
  int  gNumverOfSeed = 4;//种子字节数
  int  gFailCounterMax = 2;//允许的最大错误计数器值
  int  gFailAttemptCounterLelve_0x01;
  int  gFailAttemptCounterLelve_0x05;
  int  gFlag_SeedRequest_Level0x01;
  int  gFlag_SeedRequest_Level0x05;
  byte gSeedArray[4];//存储种子值
  byte gKeyArray[4];//存储密钥值
  enum e_DiagMode {PHYSICAL = 0x01,FUNCTIONAL = 0X02};
  enum e_DiagMode gCurrentReqMode;
  enum e_DiagSession {DEFAULTSESSION=0x01,PROGRAMMINGSESSION=0x02,EXTENDEDSESSION=0x03,SAFETYSESSION=0x04};//会话模式
  enum e_DiagSession gCurrentSession;//当前会话模式
  enum e_DiagSecurityState {NoLevelUnlocked = 0x00,WriteLevelUnlocked = 0x05,BootLevelUnlocked = 0x01};
  enum e_DiagSecurityState gCurrentState;//当前解锁状态
  int  gAddressFormat = 4;//控制器使用的下载地址字节长度
  int  gLengthFormat = 4;//控制器使用的下载长度字节长度
  int  gDataFormatIdentifier;//控制器使用的数据类型
  dword  gMaxNumberOfBlockLenth = 0xFFF;//控制器支持的最大块长度
  int  gFlag_StartDownload;
  int  gFlag_FinishDownload;
  int  gCounter;
  dword gDwonloadLength;
  byte gTempSaveData[65535];
  dword gTempSaveLength; 
  //状态控制参数
  
  //控制器存储信息
  byte gECUFixBytes_L1[5] = {0xFF,0xFF,0xFF,0xFF,0xFF};
  byte gECUFixBytes_L5[5] = {0xFF,0xFF,0xFF,0xFF,0xFF};
  byte gECUHardwareNumber[8] = {0x88,0x92,0x35,0x74,0x55,0x20,0x20,0x41};
  byte gECUBootNumber[8] = {0x88,0x92,0x35,0x74,0x55,0x20,0x20,0x41};
  byte gECUDiagnosticDatabasePN[8] = {0x88,0x92,0x35,0x74,0x55,0x20,0x20,0x41};
  byte gECUDeliveryAssemblyPartNumberGeely[8] = {0x88,0x92,0x35,0x74,0x55,0x20,0x20,0x41};
  byte gECUSerialNumber[4] = {0x88,0x92,0x35,0x74};
  byte gECUSoftwareNumber[17] = {0x02,0x88,0x94,0x27,0x31,0x98,0x20,0x20,0x42,0x88,0x94,0x27,0x32,0x71,0x20,0x20,0x42};
  int  gECUSoftwareNumberLength = 17;
  byte gPaddingByte = 0xAA;
  
}

on timer S3ServerTimer
{
  if(gFlag_ECUAPP == 1)
  { 
    gCurrentSession = DEFAULTSESSION;
  }
  else
  {
    gCurrentSession = PROGRAMMINGSESSION;
  }
}

on timer DelatTimer_Level0x01
{
  gFailAttemptCounterLelve_0x01 = gFailCounterMax -1;
}

on timer DelatTimer_Level0x05
{
  gFailAttemptCounterLelve_0x05 = gFailCounterMax -1;
}

void ChangeSession(enum e_DiagSession TargetSession)
{
  gCurrentSession = TargetSession;
  if(gCurrentSession != DEFAULTSESSION)
  {
    setTimer(S3ServerTimer,gS3ServerTimerTimeoutTime);
  }
  
  if(gCurrentSession != PROGRAMMINGSESSION)
  {
    gSBLActived = 0;
  }
  gCurrentState = NoLevelUnlocked;
  
  //在切换会话后，即对种子请求状态做清除
  gFlag_SeedRequest_Level0x01 = 0;
  gFlag_SeedRequest_Level0x05 = 0;
  
  //在切换会话后，即对所有下载参数做复位
  gFlag_StartDownload = 0;
  gFlag_FinishDownload = 0;
  gCounter = 0;
  gDwonloadLength = 0;
  gTempSaveLength = 0;
}

/**************服务处理****************/
ServiceHandle(byte ReceiveData[],dword ReceiveLength)
{
  switch(ReceiveData[0])
  {
    case 0x10:
    {
      HandleService_0x10(ReceiveData,ReceiveLength);
      break;
    }
    case 0x11:
    {
      HandleService_0x11(ReceiveData,ReceiveLength);
      break;
    }
    case 0x22:
    {
      HandleService_0x22(ReceiveData,ReceiveLength);
      break;
    }
    case 0x27:
    {
      HandleService_0x27(ReceiveData,ReceiveLength);
      break;
    }
    case 0x19:
    {
      HandleService_0x19(ReceiveData,ReceiveLength);
      break;
    }
    case 0x14:
    {
      HandleService_0x14(ReceiveData,ReceiveLength);
      break;
    }
    case 0x3E:
    {
      HandleService_0x3E(ReceiveData,ReceiveLength);
      break;
    }
    case 0x34:
    {
      HandleService_0x34(ReceiveData,ReceiveLength);
      break;
    }
    case 0x36:
    {
      HandleService_0x36(ReceiveData,ReceiveLength);
      break;
    }
    case 0x37:
    {
      HandleService_0x37(ReceiveData,ReceiveLength);
      break;
    }
    case 0x31:
    {
      HandleService_0x31(ReceiveData,ReceiveLength);
      break;
    }
    default :
    {
      if(gCurrentReqMode != FUNCTIONAL)
      {
        SendNegativeResponse(0x11);
      }
      break;
    }
  }
}

void SendNegativeResponse(int code)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  
  NRC[1] = gTpRxData[0];
  NRC[2] = code;
  if(gCurrentReqMode != FUNCTIONAL)
  {
    CanTpSendData(CAN_connHandle,NRC,3);
  }
  else
  {
    if((code == 0x11)||(code == 0x12)||(code == 0x31)||(code == 0x7E)||(code == 0x7F))
    {
      
    }
    else
    {
      CanTpSendData(CAN_connHandle,NRC,3);
    }
  }
}

void HandleService_0x10(byte ReceiveData[],dword ReceiveLength)
{
  byte NRC[3] = {0x7F,0x00,0x00};
  byte PosRes[6] = {0x50,0x00,0x00,0x00,0x01,0xF4};
  int  SuppressPosRspMsgIndicationBit;
  int  Subfunction;
  
  
  //判断长度
  if((ReceiveLength <= 1)||(ReceiveLength > 2))
  {
    SendNegativeResponse(0x13);
    return;   
  }
  //判断长度
  
  SuppressPosRspMsgIndicationBit = ReceiveData[1]>>7;
  Subfunction = (ReceiveData[1]&0x7F);
  
  //判断子功能
  switch(Subfunction)
  {
    case 0x01:
    {
      PosRes[1] = 0x01;
      PosRes[2] = (gP2ClientAPP>>8);
      PosRes[3] = gP2ClientAPP&0xFF;
      PosRes[4] = ((gP2StarClient/10)>>8);
      PosRes[5] = ((gP2StarClient/10)&0xFF);
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,6);
      }
      ChangeSession(DEFAULTSESSION);
      break;
    }
    case 0x02:
    {
      PosRes[1] = 0x02;
      PosRes[2] = (gP2ClientBOOT>>8);
      PosRes[3] = gP2ClientBOOT&0xFF;
      PosRes[4] = ((gP2StarClient/10)>>8);
      PosRes[5] = ((gP2StarClient/10)&0xFF);
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,6);
      }
      ChangeSession(PROGRAMMINGSESSION);
      break;
    }
    case 0x03:
    {
      if(gCurrentSession == PROGRAMMINGSESSION)
      {
         SendNegativeResponse(0x7E);
         break;
      }
      PosRes[1] = 0x03;
      PosRes[2] = (gP2ClientAPP>>8);
      PosRes[3] = gP2ClientAPP&0xFF;
      PosRes[4] = ((gP2StarClient/10)>>8);
      PosRes[5] = ((gP2StarClient/10)&0xFF);
      if(SuppressPosRspMsgIndicationBit == 0)
      {
        CanTpSendData(CAN_connHandle,PosRes,6);
      }
      ChangeSession(EXTENDEDSESSION);
      break;
    }
    default :
    {
      SendNegativeResponse(0x12);
      break;
    }
  }
  //判断子功能
  
}

