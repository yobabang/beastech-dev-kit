/*以下函数没有实际功能意义，供参考*/
void PSRB_Relay(int relayNum, enum e_PSRB_Status status)
{
  switch(relayNum)
  {
    case 1:
      @sysvar::DeviceControl::PSRB::Relay1 = status;
      break;
    case 2:
      @sysvar::DeviceControl::PSRB::Relay2 = status;
      break;
    case 3:
      @sysvar::DeviceControl::PSRB::Relay3 = status;
      break;
    case 4:
      @sysvar::DeviceControl::PSRB::Relay4 = status;
      break;
    case 5:
      @sysvar::DeviceControl::PSRB::Relay5 = status;
      break;
    case 6:
      @sysvar::DeviceControl::PSRB::Relay1 = status;
      break;
    case 7:
      @sysvar::DeviceControl::PSRB::Relay7 = status;
      break;
    case 8:
      @sysvar::DeviceControl::PSRB::Relay8 = status;
      break;
    case 9:
      @sysvar::DeviceControl::PSRB::Relay9 = status;
      break;
    case 10:
      @sysvar::DeviceControl::PSRB::Relay10 = status;
      break;
    case 11:
      @sysvar::DeviceControl::PSRB::Relay11 = status;
      break;
    case 12:
      @sysvar::DeviceControl::PSRB::Relay12 = status;
      break;
    default:
      break;
  }
}