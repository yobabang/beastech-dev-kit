//地漂电源切入
void PSRB_GroundOffset_In()
{
  PSRB_Relay(10,PSRB_DisConnect);
  testWaitForTimeout(100);
  PSRB_Relay(11,PSRB_Connect);
  testWaitForTimeout(100);
  PSRB_Relay(9,PSRB_DisConnect);
  testWaitForTimeout(100);
}

//地漂电源切出
void PSRB_GroundOffset_Out()
{
  PSRB_Relay(10,PSRB_DisConnect);
  testWaitForTimeout(100);
  PSRB_Relay(11,PSRB_DisConnect);
  testWaitForTimeout(100);
  PSRB_Relay(9,PSRB_DisConnect);
  testWaitForTimeout(100);
}

