/// <TPInit>
void ETH_TP_Init()
{
  long Count;
  
  Count = 0;
  
  if(@Diagnostic::ETH_NodeType == 2 || (@Diagnostic::ETH_AnnouncementMessageReceived == 0))
  {
    sysSetVariableString( sysvar::Diagnostic::ETH_TesterIPAddress,gTesterIpv4Address);
    sysSetVariableString( sysvar::Diagnostic::ETH_VehicleIPAddress, gECUIpv4Address);
  }
  @Diagnostic::ETH_Enable=1;
  
  @Diagnostic::ETH_TesterLogicAddress=gTesterLogicAddress;
  @Diagnostic::ETH_FunctionalLogicAddress=gFunctionalLogicAddress;
  if(EthNodeTypeNow==EdgeNode)
    @Diagnostic::ETH_NodeType=1;
  else if(EthNodeTypeNow==InternalNode)
    @Diagnostic::ETH_NodeType=2;
  
  
  sysSetVariableString( sysvar::Diagnostic::ETH_ETHNetMask,gNetmask);
  @Diagnostic::S3Client=gS3Client;
  testWaitForTimeout(2);
  
  /* 边缘节点判断车辆声明报文 */
  if(@Diagnostic::ETH_NodeType == 1)
  {
    while(@Diagnostic::ETH_AnnouncementMessageReceived == 0)
    {
      testWaitForTimeout(100);
      Count++;
      if(Count%10 == 0) { @Diagnostic::ETH_SendVehicleAnnouncementRequest = 1; }
      if(Count >= 200) { testStepWarning("ETH_TP_Init","@Diagnostic::ETH_AnnouncementMessageReceived == 0"); break; }
    }
  }
  @Diagnostic::ETH_TPparameterInit=1;
  
  Count = 0;
  while(@Diagnostic::ETH_TCPConnectionStatus == 0)
  {
    testWaitForTimeout(1000);
    Count++;
    if(Count >= gTimeForTCPConnect/1000) { testStepFail("ETH_TP_Init","@Diagnostic::ETH_TCPConnectionStatus = 0"); stop(); }
  }
}
/// <ECU_Response>
enum ResponseState ETH_ECU_Response(int P2,int CheckService)
{
  long Responselength;
//  write("p2=%d %f",P2,P2);
//  write("FLAG=%d,p2app=%d,p2boot=%d",SessionFlag,gP2Client_APP,gP2Client_BOOT);
	if(P2 != gP2StarClientDelay)
	{
		gNRC78Flag = 0;
	}
  if(P2 != gP2StarClientDelay)
  {
  	if(testWaitForTextEvent("ETHTPreciveData",gP2ClientDelay)==0)
  		return TIMEOUT;
    TP_T2 = timeNowFloat()/10000;
    TesTime = (TP_T2-TP_T1)*100;
//    write("real=%f expect=%f",TesTime,P2);
//    write("real=%d expect=%d",TesTime,P2);
    if(TesTime>P2)
    {
      if(WaringOrErrorFlag==1)
      {
        testStepWarning("TP","ECU P2Server timeout,real P2 is %fms,expect P2 is %dms",TesTime,P2);
      }
      else
      {
        testStepFail("TP","ECU P2Server timeout,real P2 is %fms,expect P2 is %dms",TesTime,P2);
      }
      
    }
  }
  else
  {
    if(testWaitForTextEvent("ETHTPreciveData",gP2StarClientDelay)>0)
     {
      TP_T5 = timeNowFloat()/10000;
      P2startime=(TP_T5-TP_T4)*100;
      if(P2startime>gP2StarClient)
        testStepFail("TP","ECU P2*Server timeout,real P2* is %fms,expect P2* is %dms",P2startime,gP2StarClient);
      else if(P2startime<(gP2StarClient*0.3) && gTpRxData[0] == 0x7F && gTpRxData[1] == CheckService && gTpRxData[2] == 0x78)
        testStepFail("TP","ECU P2*Server expect between 0.3*P2*ServerMax and ServerMax,real P2* is %fms,expect P2* is %dms",P2startime,gP2StarClient);
     }
     else
      return TIMEOUT;
  }
  Responselength=@Diagnostic::Receive_DataLength;
  gTpRxLength=Responselength;
  sysGetVariableData(sysvar::Diagnostic::Receive_Data,gTpRxData,Responselength);
	if(gTpRxData[0]==0x7f)
	{
		switch(gTpRxData[2])
		{
  		case 0x78:
        if((CheckService != gTpRxData[1])&&(CheckService != 0x00))
        {
          testStepFail("Chk","The ECU responds to the NRC78 with unexpected service 0x%02x for the service 0x%02x",gTpRxData[1],CheckService);
        }
        TP_T4 = timeNowFloat()/10000;
  			gNRC78Flag = 1;
        if(NRC78AllowFlag!=1)
        {
          testStepFail("Chk","The NRC78 is not allowed when the UDS service is 0x%02x.",CheckService);
        } 
  			return ETH_ECU_Response(gP2StarClientDelay,CheckService);
  		case 0x22:
  			break;
  		default:
  			break;
		}
		return NEG;
	}
	else
  {
    if(gNRC78Flag==1)
    {
      TP_T3=timeNowFloat()/10000;
      P4time=(TP_T3-TP_T1)*100;
      if(P4time>gP4Client)
        testStepFail("Chk","ECU P4Server timeout,expect P4 is %fms,and actual P4 is %fms!",gP4Client,P4time);
    }
		return POS;
  }
}

/// <ECU_Response>
enum ResponseState LIN_ECU_Response(int P2,int CheckService)
{
  long Responselength;
  
	if(P2 != gP2StarClientDelay)
	{
		gNRC78Flag = 0;
	}
  if(P2 != gP2StarClientDelay)
  {
  	if(testWaitForTextEvent("LINTPFirstCFrecived",gP2ClientDelay)==0)
  		return TIMEOUT;
    TP_T2 = timeNowFloat()/10000;
    TesTime = (TP_T2-TP_T1)*100;
    if(TesTime>P2)
    {
      if(WaringOrErrorFlag==1)
      {
        testStepWarning("TP","ECU P2Server timeout,real P2 is %fms,expect P2 is %dms",TesTime,P2);
      }
      else
      {
        testStepFail("TP","ECU P2Server timeout,real P2 is %fms,expect P2 is %dms",TesTime,P2);
      }
    }
  }
  else
  {
    if(testWaitForTextEvent("LINTPFirstCFrecived",gP2StarClientDelay)>0)
     {
      TP_T5 = timeNowFloat()/10000;
      P2startime=(TP_T5-TP_T4)*100;
      if(P2startime>gP2StarClient)
      testStepFail("TP","ECU P2*Server timeout,real P2* is %fms,expect P2* is %dms",P2startime,gP2StarClient);
      else if(P2startime<(gP2StarClient*0.3) && gTpRxData[0] == 0x7F && gTpRxData[1] == CheckService && gTpRxData[2] == 0x78)
        testStepFail("TP","ECU P2*Server expect between 0.3*P2*ServerMax and ServerMax,real P2* is %fms,expect P2* is %dms",P2startime,gP2StarClient);
     }
    else
     return TIMEOUT;
  }
	if(testWaitForTextEvent("LINTPreciveData",gUDS_P6Client)==0)
	{
		testStep("TP","LIN_TP:Don't receive complete data");
		return TIMEOUT;
	}

  Responselength=@Diagnostic::Receive_DataLength;
  gTpRxLength=Responselength;
  sysGetVariableData(sysvar::Diagnostic::Receive_Data,gTpRxData,Responselength);
	if(gTpRxData[0]==0x7f)
	{
		switch(gTpRxData[2])
		{
		case 0x78:
      if((CheckService != gTpRxData[1])&&(CheckService != 0x00))
      {
        testStepFail("Chk","The ECU responds to the NRC78 with unexpected service 0x%02x for the service 0x%02x",gTpRxData[1],CheckService);
      }
			gNRC78Flag = 1;
      
      if(NRC78AllowFlag!=1)
      {
        testStepFail("Chk","The NRC78 is not allowed when the UDS service is 0x%02x.",CheckService);
      }
      TP_T4 = timeNowFloat()/10000;
			return LIN_ECU_Response(gP2StarClientDelay,CheckService);
		default:
			break;
		}
		return NEG;
	}
	else
  {
    if(gNRC78Flag==1)
    {
      TP_T3=timeNowFloat()/10000;
      P4time=(TP_T3-TP_T1)*100;
      if(P4time>gP4Client)
        testStepFail("Chk","ECU P4Server timeout,expect P4 is %fms,and actual P4 is %fms!",gP4Client,P4time);
    }
		return POS;
  }
}
void P4ServerInit(byte Data[])
{
//  byte ServiceID;
  byte SubFunction;
  word DataID;
  int DataLength; 
  byte ServiceMatchFlag=0;
  byte SubFunctionMatchFlag=0;
  byte IDMatchFlag=0;
  int i=0,j=0,k=0;// i=Level 1 cycle,j=Level 2 cycle,k=Level 3 cycle.
  
  ServiceMatchFlag=0;
  SubFunctionMatchFlag=0;
  IDMatchFlag=0;
  
  DataLength=elcount(Data);
  ServiceIDNow = Data[0];

  for(i=0;i<ServiceNum;i++)
  {
    if(ServiceIDNow==P4ServerTime[i].ServiceID)
    {
      if(P4ServerTime[i].SupportNRC78Flag==0)
      {
        NRC78AllowFlag=0;
        break;
      }
      else if(P4ServerTime[i].SupportNRC78Flag==1)
      {
        NRC78AllowFlag=1;
        if(P4ServerTime[i].SubFunctionSeparate==0xFF)
        {
          if(P4ServerTime[i].DataIDSeparateNum>0)
          {
            if(DataLength>=4)
            {
              DataID = Data[2] << 8 | Data[3];
              if((P4ServerTime[j].DataIDSeparateNum=0)||P4ServerTime[j].DataIDSeparateNum>100)
              {
                gP4Client=P4DefaultValue*1.2;
                write("1  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                return;
              }
              for(j=0;j<P4ServerTime[i].DataIDSeparateNum;j++)
              {
                if(P4ServerTime[i].DataIDForSepP4[j].Data==DataID)
                {
                  if(P4ServerTime[i].DataIDForSepP4[j].SeparateValue!=0)
                  {
                    gP4Client=P4ServerTime[i].DataIDForSepP4[j].SeparateValue*1.2;
                    IDMatchFlag=1;
                  }
                  else
                  {
                    gP4Client=P4DefaultValue*1.2;
                    write("2  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                    return;
                  }
                }
                else if((j==P4ServerTime[i].DataIDSeparateNum)&&(IDMatchFlag!=1))
                {
                  if(P4ServerTime[i].DefaultValue!=0)
                  {
                    gP4Client=P4ServerTime[i].DefaultValue*1.2;
                    return;
                  }
                  else
                  {
                    gP4Client=P4DefaultValue*1.2;
                    write("3  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                    return;
                  }
                }
                else 
                  continue;
              }              
            }
            else
            {
              gP4Client=P4DefaultValue*1.2;
              write("4  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
              return;
            }
          }
          else
          {
            if(P4ServerTime[i].DefaultValue!=0)
            {
              gP4Client=P4ServerTime[i].DefaultValue*1.2;
              return;
            }
            else
            {
              gP4Client=P4DefaultValue*1.2;
              write("5  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
              return;
            }
          }
        }
        else //find mantchd subfunction
        {
          if(DataLength>=2)
          {
            SubFunction = Data[1];
            for(j=0;j<ServiceNum;j++)
            {
              if((P4ServerTime[j].ServiceID==ServiceIDNow)&&(P4ServerTime[j].SubFunctionSeparate==SubFunction))
              {
                SubFunctionMatchFlag=1;
                if(P4ServerTime[j].DataIDSeparateNum>0)
                {
                  if(DataLength>=4)
                  {
                    DataID = Data[2] << 8 | Data[3];
                    if((P4ServerTime[j].DataIDSeparateNum=0)||P4ServerTime[j].DataIDSeparateNum>100)
                    {
                      gP4Client=P4DefaultValue*1.2;
                      write("6  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                      return;
                    }
                    for(k=0;k<P4ServerTime[j].DataIDSeparateNum;k++)
                    {
                      if(P4ServerTime[j].DataIDForSepP4[k].Data==DataID)
                      {
                        if(P4ServerTime[j].DataIDForSepP4[k].SeparateValue!=0)
                        {
                          gP4Client=P4ServerTime[j].DataIDForSepP4[k].SeparateValue*1.2;
                          IDMatchFlag=1;
                        }
                        else
                        {
                          gP4Client=P4DefaultValue*1.2;
                          write("7  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                          return;
                        }
                      }
                      else if((j==P4ServerTime[j].DataIDSeparateNum)&&(IDMatchFlag!=1))
                      {
                        if(P4ServerTime[j].DefaultValue!=0)
                        {
                          gP4Client=P4ServerTime[j].DefaultValue*1.2;
                          return;
                        }
                        else
                        {
                          gP4Client=P4DefaultValue*1.2;
                          write("8  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                          return;
                        }
                      }
                      else 
                        continue;
                    }              
                  }
                  else
                  {
                    gP4Client=P4DefaultValue*1.2;
                    write("9  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                    return;
                  }
                }
                else
                {
                  if(P4ServerTime[j].DefaultValue!=0)
                  {
                    gP4Client=P4ServerTime[j].DefaultValue*1.2;
                    return;
                  }
                  else
                  {
                    gP4Client=P4DefaultValue*1.2;
                    write("10  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                    return;
                  }
                }
              }
              else if((j==(ServiceNum-1))&&(SubFunctionMatchFlag!=1))
              {
                gP4Client=P4DefaultValue*1.2;
                write("11  there is not a legal or Clearly defined request_,The p4 value is set to default value--%dms",P4DefaultValue);
                return;
              }
              else
                continue;
            }
              
          }
          else 
          {
            gP4Client=P4DefaultValue*1.2;
            write("12  there is not a legal or Clearly defined request,The p4 value is set to default value--%dms",P4DefaultValue);
            return;
          }
        } 
      }
      else
      {
        NRC78AllowFlag=1;
        gP4Client=P4DefaultValue*1.2;
        write("13  there is not a legal or Clearly defined request,The p4 value is set to default value--%dms",P4DefaultValue);
        return;
      }
    }
    else if((i==(ServiceNum-1)&&(ServiceMatchFlag!=1)))
    {
      NRC78AllowFlag=1;
      gP4Client=P4DefaultValue*1.2;
      write("14  there is not a legal or Clearly defined request,The p4 value is set to default value--%dms",P4DefaultValue);
      return;
    }
    else
      continue;
  }
}
void GeelyParameterParsing()
{
  char ECUinfoPath[400];
  char gAbsPath[400];
  int i=0;
//  char tempstring[100];
  getAbsFilePath("",gAbsPath,500);
  snprintf(ECUinfoPath,500,"%s\\01_Input\\",gAbsPath);
  setFilePath(ECUinfoPath,2);//初始化ini文件地址
  
  if(strncmp(BusType,"CAN",10) == 0)
  {
    writeProfileString("ECUinfo", "BusType",BusType,"DiagParameter.ini");
    writeProfileint("ECUinfo", "CAN_RequestID",0x700+(ECUAddress_Temp&0x00FF),"DiagParameter.ini");
    writeProfileint("ECUinfo", "CAN_ResponseID",0x600+(ECUAddress_Temp&0x00FF),"DiagParameter.ini");
  }
  else if(strncmp(BusType,"CANFD",10) == 0)
  {
    writeProfileString("ECUinfo", "BusType",BusType,"DiagParameter.ini");
    writeProfileint("ECUinfo", "CAN_RequestID",0x700+(ECUAddress_Temp&0x00FF),"DiagParameter.ini");
    writeProfileint("ECUinfo", "CAN_ResponseID",0x600+(ECUAddress_Temp&0x00FF),"DiagParameter.ini");
  }
  else if(strncmp(BusType,"LIN",10) == 0)
  {
    writeProfileString("ECUinfo", "BusType",BusType,"DiagParameter.ini");
    writeProfileint("ECUinfo", "LIN_TP_NAD",ECUAddress_Temp&0xFF,"DiagParameter.ini");
  }
  else if(strncmp(BusType,"ETH_InternalNode",10) == 0)
  {
    writeProfileString("ECUinfo", "BusType","Ethernet","DiagParameter.ini");
    writeProfileString("ECUinfo", "EthNodeType","InternalNode","DiagParameter.ini");
    writeProfileint("ECUinfo", "ECULogicAddress",ECUAddress_Temp,"DiagParameter.ini");
    
//    for(i=0;i<elcount(gSpecificDUTInfo);i++)
//    {
//      if(ECUAddress_Temp == gSpecificDUTInfo[i].LogicAddress)
//      {
//        writeProfileString("ECUinfo", "ECUIpv4Address",gSpecificDUTInfo[i].IPv4Address,"DiagParameter.ini");
//        break;
//      }
//      else if(i==elcount(gSpecificDUTInfo)-1)
//      {
//        writeProfileString("ECUinfo", "ECUIpv4Address","0","DiagParameter.ini");
//      }
//    }
  }
  else if(strncmp(BusType,"ETH_EdgeNode",10) == 0)
  {
    writeProfileString("ECUinfo", "BusType","Ethernet","DiagParameter.ini");
    writeProfileString("ECUinfo", "EthNodeType","EdgeNode","DiagParameter.ini");
    writeProfileint("ECUinfo", "ECULogicAddress",ECUAddress_Temp,"DiagParameter.ini");
  }
}