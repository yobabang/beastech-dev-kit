  float  gETH_t1,gETH_t2;      //Used to calculate send and receive time 
  

  int gP2ClientDelay=2000;
  int gP2StarClientDelay=7000;
  int gP6ClientDelay=5000;
  enum Session{others=0,APP=1,BOOT=2};
  enum Session SessionFlag = APP;

  
  long gSlaveResponseTableIndex=1;
