on start
{
  char IpAddress[16];
  dword result;
  
  dword gHandle;
  long  cyclesocket;
    
  gHandle = registerCAPLDLL();
	SKDLL_Init(gHandle);
  
  write("TCAM Simulation: Initial diagnostic!");
  
  //setBusContext(GetBusNameContext( "VGMDHU"));
  
  gCurrentSession = DEFAULTSESSION;
  gCurrentECUState = APP;
  
  //建立TCP连接
  diagnosticsocket = TcpOpen(0x112012C6, 13400);
  if (diagnosticsocket != ~0)
  {
    result = TcpConnect( diagnosticsocket, 0x012012C6, 13400 );
    if ( result == -1)
    {
      result = IpGetLastSocketError(diagnosticsocket);
      if ( result != 10035)
      {
        writeLineEx( 1, 3, "TCAM Simulation:  [ TcpConnect for client failed with error %d ]", result );
      }
    }
    else
    {
      writeLineEx(1, 3, "TCAM Simulation:  [ TcpConnect error %d ]", result);
    };
  }
  else
  {
    writeLineEx(1, 3, "TCAM Simulation:  [ TcpOpen: FAILED. ]");
    writeLineEx(1, 3, "IpGetLastError: %d", IpGetLastError());
  }
  //建立TCP连接 
  
  setTimerCyclic(T_TCPConnectRequest,100);
  
}

on timer T_TCPConnectRequest
{
  dword result;
  
  ethSetLinkStatus(gEthPort,1);
  
  if(gFlag_TCPConnect == 0)
  {
    diagnosticsocket = TcpOpen(0x112012C6, 13400);
    if (diagnosticsocket != ~0)
    {
      result = TcpConnect( diagnosticsocket, 0x012012C6, 13400 );
      if ( result == -1)
      {
        result = IpGetLastSocketError(diagnosticsocket);
        if ( result != 10035)
        {
          writeLineEx( 1, 3, "TCAM Simulation:  [ TcpConnect for client failed with error %d ]", result );
        }
      }
      else
      {
        writeLineEx(1, 3, "TCAM Simulation:  [ TcpConnect error %d ]", result);
      };
    }
    else
    {
      writeLineEx(1, 3, "TCAM Simulation:  [ TcpOpen: FAILED. ]");
      writeLineEx(1, 3, "IpGetLastError: %d", IpGetLastError());
    }
  }
  else { cancelTimer(T_TCPConnectRequest); }
}

on timer T_UDSHandle
{
  ServiceHandle(gTpRxData,gTpRxLength);
}


on timer S3ServerTimer
{
  ChangeSession(DEFAULTSESSION);
}

on timer T_Disconnect
{
  ethSetLinkStatus(gEthPort,0);
    
  setTimer(T_Reset,gPowerResetTime);
}

on timer T_Reset
{
  dword result;
  
  ethSetLinkStatus(gEthPort,1);
  //建立TCP连接
  diagnosticsocket = TcpOpen(0x112012C6, 13400);
  if (diagnosticsocket != ~0)
  {
    result = TcpConnect( diagnosticsocket, 0x012012C6, 13400 );
    if ( result == -1)
    {
      result = IpGetLastSocketError(diagnosticsocket);
      if ( result != 10035)
      {
        writeLineEx( 1, 3, "TCAM Simulation:  [ TcpConnect for client failed with error %d ]", result );
      }
    }
    else
    {
      writeLineEx(1, 3, "TCAM Simulation:  [ TcpConnect error %d ]", result);
    };
  }
  else
  {
    writeLineEx(1, 3, "TCAM Simulation:  [ TcpOpen: FAILED. ]");
    writeLineEx(1, 3, "IpGetLastError: %d", IpGetLastError());
  }
  //建立TCP连接  
}

on timer DelatTimer_Level0x01
{
  gFailAttemptCounterLelve_0x01 = gFailCounterMax -1;
}

on timer DelatTimer_Level0x05
{
  gFailAttemptCounterLelve_0x05 = gFailCounterMax -1;
}

void OnTcpSend(dword socket, long result, char buffer[], dword size)
{
  if (socket != ~0)
  {
    // sending data complete.
    If (result != 0)
    {
      writeLineEx(1, 3, "TCAM Simulation: OnTcpSend error: %d", result);
    }
  }
  else
  {
    writelineex(0, 2, "TCAM Simulation: OnTcpSend called for socket 0x%X", socket);
  }
}

dword GetPortForUDP(dword OPID)
{
  dword port;
  
  switch(OPID)
  {
    case 0x0B22:
      port = 50171;
      break;
    case 0x0B10:
      port = 50171;
      break;
  }
  
  return port;
}

void OnTcpConnect( dword Socket, long Result)
{
  if ( diagnosticsocket != Socket)
  {
    Writelineex(0, 2, "TCAM Simulation: OnTcpConnect Called For Unknown Socket 0x%X", Socket);
    return;
  }
  if (0 != Result)
  {
    IpGetLastSocketErrorAsString( Socket, gIpLastErrStr, elcount( gIpLastErrStr));
    Writelineex(0, 2, "TCAM Simulation: OnTcpConnect Error (%d): %s", IpGetLastSocketError(Socket), gIpLastErrStr);
    return;
  }
  else
  {
    Writelineex(0, 1, "TCAM Simulation: Successfully Connected To Server");
    TcpDataRx(Socket);
    
    gFlag_TCPConnect = 1;
  }
}

void OnTcpClose(dword socket, long result)
{
  TcpClose(socket);
  
  ethSetLinkStatus(gEthPort,0);
  gFlag_TCPConnect = 0;
  
  setTimerCyclic(T_TCPConnectRequest,100);
  
////  setTimer(T_Reset,gPowerResetTime);
}

