/// <a.PPS&PSRB>
On sysvar sysvar::Panel::PPS::settingVoltage
{
  PPS_SetVoltage(@sysvar::Panel::PPS::settingVoltage);
}
/// <a.PPS&PSRB>
On sysvar sysvar::Panel::PPS::settingCurrent
{
  //PPS_SetCurrent(@sysvar::Panel::PPS::settingCurrent);
}

/// <a.PPS&PSRB>
On sysvar sysvar::Panel::PPS::output
{
  if(@sysvar::Panel::PPS::output==0)
  {
    OutputCnt=!OutputCnt;
  }
  
  if(OutputCnt==1)
  {
    PPS_Output(1);
    setControlBackColor("ZEEKR_Panel","Main Power Output",makeRGB(255,0,0)); 
  }
  else if(OutputCnt==0)
  {
    PPS_Output(0);
    setControlBackColor("ZEEKR_Panel","Main Power Output",makeRGB(220,220,220));
  }
}

/// <a.PPS&PSRB>
On sysvar sysvar::Panel::SPPS::settingVoltage
{
  SPPS_SetVoltage(@sysvar::Panel::SPPS::settingVoltage);
}
/// <a.PPS&PSRB>
On sysvar sysvar::Panel::SPPS::settingCurrent
{
  //SPPS_SetCurrent(@sysvar::Panel::SPPS::settingCurrent);
}


/// <a.PPS&PSRB>
On sysvar sysvar::Panel::SPPS::output
{
  if(@sysvar::Panel::SPPS::output==0)
  {
    OutputOffsetCnt=!OutputOffsetCnt;
  }

  if(OutputOffsetCnt==1)
  {
    SPPS_Output(1);
    setControlBackColor("ZEEKR_Panel","Offset Power Output",makeRGB(255,0,0));
  }
  else if(OutputOffsetCnt==0)
  {
    SPPS_Output(0);
    setControlBackColor("ZEEKR_Panel","Offset Power Output",makeRGB(220,220,220));
  }
}

/// <a.PPS&PSRB>
on sysvar sysvar::Panel::PSRB::Relay1
{
  if(@this==1)
  {
    PSRB_Relay(1,PSRB_DisConnect); 
  }
  else
  {
    PSRB_Relay(1,PSRB_Connect);  
  } 
}

