/////////////////////CTR/////////////////////////////////////////////
void Update_Op(long index)
{
  switch(index)
  {
    case 1:
      //Set_Env();
      break;
    case 2:
      //PMM_RESistance_Data_Recv();
      break;
    default:break;
  }
}

void Panel_Cmd()
{
   long index = 0;
    testJoinTextEvent("ENV_Set_Env"); //1
    testJoinTextEvent("PMM_RESistance_Data_Recv");//2
    index = testWaitForAnyJoinedEvent(1000000);
    Update_Op(index );
}