void OSC_Trigger_ByCANID(char ID[])
{
  testWaitForTimeout(100);
  OSC_SetTimebasePosition(0);
  testWaitForTimeout(100);
  OSC_SBUS_Display(1);
  testWaitForTimeout(5);
  OSC_SBUS_Mode("CAN");
  testWaitForTimeout(5);
  testWaitForTimeout(5);
  OSC_Trigger_Type("SBUS1");
  testWaitForTimeout(5);
  OSC_Trigger_Position("IDData");
}
