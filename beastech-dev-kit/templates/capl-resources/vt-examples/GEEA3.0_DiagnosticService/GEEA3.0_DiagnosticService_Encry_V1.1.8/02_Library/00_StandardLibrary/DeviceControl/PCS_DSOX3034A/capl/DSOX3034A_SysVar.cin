double PCS_ReceiveDataStg(char Src[])
{
  char SelFront[100]="<Res scr=\"PCS\" pyid=\"-\"><!\\[CDATA\\[";
  char SelBack[100]="\\]\\]></Res>";
  char SubSrc_String[100]="";
  double SubSrc_Double;
  str_replace_regex(Src,SelFront,"");
//  testWaitForTimeout(10);
  str_replace_regex(Src,SelBack,"");
//  testWaitForTimeout(10);
  strncpy(SubSrc_String,Src,strlen(Src)-3);
  str_replace_regex(SubSrc_String,"E","e");
//  testWaitForTimeout(10);
  strtod(SubSrc_String,SubSrc_Double);
  return(SubSrc_Double);
}




void OSC_MeasureAdd(Char Type[],char Source[])
{
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::Meas_Type,Type);
  sysSetVariableString(sysvar::DeviceControl::PCS::Parameter::Meas_Sour,Source);
  OSC_Meas_Add();
  testWaitForTimeout(100);
}

void OSC_setChannelScale(int ChannelNo, float scale)
{
  int i;
  float status[4];

  scalebuff[ChannelNo-1]=scale;
  for(i=0;i<elcount(status);i++)
  {
    status[i]=scalebuff[i];
  }
  OSC_Channel_setScale(status);
}

void OSC_setChannelDisplay(int ChannelNo, int isDisplay)
{
  int i;
  int status[4];
  
  Displaybuff[ChannelNo-1]=isDisplay;
  for(i=0;i<elcount(status);i++)
  {
    status[i]=Displaybuff[i];
  }
  OSC_Channel_setDisplay(status);
}

void OSC_setChannelOffset(int ChannelNo, float offset)
{
  int i;
  float status[4];

  offsetbuff[ChannelNo-1]=offset;
  for(i=0;i<elcount(status);i++)
  {
    status[i]=offsetbuff[i];
  }
  OSC_Channel_setOffset(status);
}

