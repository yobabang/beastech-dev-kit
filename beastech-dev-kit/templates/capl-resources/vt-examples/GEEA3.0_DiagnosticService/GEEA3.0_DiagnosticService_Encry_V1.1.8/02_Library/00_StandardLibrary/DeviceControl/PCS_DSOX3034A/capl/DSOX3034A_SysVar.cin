On sysvar_update sysvar::DeviceControl::IPClient::Sockets::PCS_Socket
{
  if(@this > 0)
  {
    PCS_Socket=@this;
    
    OSC_InitConfig();
  }
}

ON sysvar_update sysvar::DeviceControl::IPClient::RcvEvent::TcpRecData
{
  LONG LEN,index;
  byte data[99999];
  for(index = 0;index < elcount(PCS_RecvData);index++)
  {
    PCS_RecvData[index] = 0;
  }
  if(@sysvar::DeviceControl::IPClient::RcvEvent::Socket != PCS_Socket)
    return;
  sysGetVariableData(THIS,data,LEN);
  Rcv_Size = LEN;
  for(index = 0;index < LEN;index++)
  {
    PCS_RecvData[index] = data[index];
    //write("PCS_RecvData[%d]:0x%x",index,PCS_RecvData[index]);
  }
}


