void ETH_TP_Release()
{
  DoIP_CloseConnection();
  tcpClose(gConnectionSocket);
//////  tcpClose(gListenSocket);
}

//Used to receive data from DoIP connection
Void DoIP_DataInd( byte buffer[], dword count, dword address, dword senderAddress) 
{
  if(address==gECULogicAddress)
  {
    sysSetVariableData(sysvar::Diagnostic::Receive_Data,buffer,count);
    @Diagnostic::Receive_DataLength=count;
    @Diagnostic::Receive_ConAll=1;
    
    TestSupplyTextEvent("ETHTPreciveData");
    write( "Received %d byte  %x ..." , elcount(buffer), buffer[0]);
  }
}

//Used to confirm data transition from DoIP connection
void DoIP_DataCon( dword count)
{
  TestSupplyTextEvent("ETHSendDiagMessage");
  @Diagnostic::Send_Con=1;
}
void _DoIP_MessageAcknowledgeInd( word payloadType, long code, word testerAddress, word ecuAddress)
{
//  TestSupplyTextEvent("ETHSendDiagMessage");
  @Diagnostic::Send_DoipAckReceved=1;
  @Diagnostic::Send_Con=1;
}
