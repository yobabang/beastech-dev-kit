    }
    else
    {
      if(EthNodeTypeNow == EdgeNode)
      {
        DoIP_DataReq( Data, length, gETH_FunctionalLogicAddress, gETH_TesterLogicAddress);
      }
      else
      {
        SendTcpData( Data, length, gETH_FunctionalLogicAddress, gETH_TesterLogicAddress);
      }
