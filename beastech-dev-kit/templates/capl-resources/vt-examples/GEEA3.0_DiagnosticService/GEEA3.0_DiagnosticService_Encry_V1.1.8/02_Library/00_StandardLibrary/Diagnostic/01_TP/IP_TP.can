	dword  gTesterLogicAddress = 0x0E80;
	dword  gECULogicAddress=0x1011;
	dword   gFunctionalLogicAddress = 0x1FFF;
	char gTesterIpv4Address[400] = "";
  char gECUIpv4Address[400] = "";
	char   gNetmask[400] = "";
