  return result;  
}

void SendTcpData(byte buffer[], long size,dword vehicleAddress, dword testerAddress)
{
  byte TCPData[70000];
  dword i,j;
//  long result;
//  char errorbuffer[100],errormsgbuffer[100];

  
  TCPData[0]= 0x02;
  TCPData[1]= 0xFD;
  TCPData[2]= 0x80;
  TCPData[3]= 0x01;
  TCPData[4]= size+4>>24;
  TCPData[5]= size+4>>16;
  TCPData[6]= size+4>>8;
  TCPData[7]= size+4&0xFF;
  TCPData[8]= testerAddress>>8;
  TCPData[9]= testerAddress&0xFF;
  TCPData[10]= vehicleAddress>>8;
  TCPData[11]= vehicleAddress&0xFF;
  gTpTxLength=size+12;

//  write("ETHTP:TpTxLength=%d ",gTpTxLength);
  for(i=0;i<size;i++)
  {
    TCPData[i+12]=buffer[i];
  }
  
  if(gflag_multi_chip_handle == 1) 
  { 
    if(gflag_address_mode_change == 1) { TCPData[10]= 0x1F; TCPData[11]= 0xFF; }
    

      gIpLastErr = TCPSend(gConnectionSocket, TCPData, gTpTxLength); 

      if(0x1FFF != vehicleAddress) 
      { 
        TCPData[10]= second_logical_address >> 8; 
        TCPData[11]= second_logical_address & 0xFF; 
      }
      TCPSend(second_socket, TCPData, gTpTxLength);

  }
  else 
  { 
     gIpLastErr = TCPSend(gConnectionSocket, TCPData, gTpTxLength); 
  }
  
//  write("ETHTP:TCPSendData:0x%lx,0x%lx,0x%lx,0x%lx,  elcount(TCPData)=%d ",TCPData[12],TCPData[13],TCPData[14],TCPData[15],elcount(TCPData));
  
//////  if (0 != TCPSend(gConnectionSocket, TCPData, gTpTxLength))
//////  {
//////    gIpLastErr = IpGetLastSocketError( gConnectionSocket);
//////
//////    if ( WSA_IO_PENDING != gIpLastErr)
//////    {
//      IpGetLastSocketErrorAsString( gConnectionSocket, gIpLastErrStr, elcount( gIpLastErrStr));
//////
//////      writelineex( 0, 2, "ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);
//////    }
//////  }
//////  else
//////  {
//////    writelineex( 0, 1, "ETHTP:Tcp data sent successfully!");
//////  }


  if (gIpLastErr == 0)
  {
    // sending took place immediately.
    // => OnTcpSend is NOT called.
////////    write("ETHTP:Tcp data sent successfully!");
//    TestSupplyTextEvent("ETHSendDiagMessage");
  }
  else
  {
    if (gIpLastErr == -1)
    {
      gIpLastErr = IpGetLastSocketError(gConnectionSocket);
      if (gIpLastErr == 997)
      {
        // sending is done asynchronously.
        // => OnTcpSend is called when done sending.
////////        writelineex( 0, 1, "ETHTP:Tcp data sent successfully!");  
//        TestSupplyTextEvent("ETHSendDiagMessage");
      }
      else
      {
        IpGetLastSocketErrorAsString( gConnectionSocket, gIpLastErrStr, elcount( gIpLastErrStr));
        writeLineEx( 1, 3, "ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);   
        snprintf(errorbuffer,elcount(errorbuffer),"ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);
        sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);
       
      }
    }
    else
    {
//////////        IpGetLastSocketErrorAsString( gConnectionSocket, gIpLastErrStr, elcount( gIpLastErrStr));
//////////        writeLineEx( 1, 3, "ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);   
//////////        snprintf(errorbuffer,elcount(errorbuffer),"ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);
//////////        sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);
    }
  }
}

void SendTcpDatasmall2(byte buffer[], long size,dword vehicleAddress, dword testerAddress)
{
  byte TCPData[65536];
  dword i;
//  long result;
  
  TCPData[0]= 0x02;
  TCPData[1]= 0xFD;
  TCPData[2]= 0x80;
  TCPData[3]= 0x01;
  TCPData[4]= (size+2)>>24;
  TCPData[5]= (size+2)>>16;
  TCPData[6]= (size+2)>>8;
  TCPData[7]= (size+2)&0xFF;
  TCPData[8]= testerAddress>>8;
  TCPData[9]= testerAddress&0xFF;
  TCPData[10]= vehicleAddress>>8;
  TCPData[11]= vehicleAddress&0xFF;
  gTpTxLength=size+12;

//  write("ETHTP:TpTxLength=%d ",gTpTxLength);
  for(i=0;i<size;i++)
  {
    TCPData[i+12]=buffer[i];
  }
//  write("ETHTP:TCPSendData:0x%lx,0x%lx,0x%lx,0x%lx,  elcount(TCPData)=%d ",TCPData[12],TCPData[13],TCPData[14],TCPData[15],elcount(TCPData));
  
//  if (0 != TCPSend(gConnectionSocket, TCPData, gTpTxLength))
//  {
//    gIpLastErr = IpGetLastSocketError( gConnectionSocket);
//
//    if ( WSA_IO_PENDING != gIpLastErr)
//    {
//      IpGetLastSocketErrorAsString( gConnectionSocket, gIpLastErrStr, elcount( gIpLastErrStr));
//
//      writelineex( 0, 2, "ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);
//    }
//  }
//  else
//  {
//    writelineex( 0, 1, "ETHTP:Tcp data sent successfully!");
//  }
  
   gIpLastErr=TCPSend(gConnectionSocket, TCPData, gTpTxLength);
 
  if (gIpLastErr == 0)
  {
    // sending took place immediately.
    // => OnTcpSend is NOT called.
////////    write("ETHTP:Tcp data sent successfully!");
//    TestSupplyTextEvent("ETHSendDiagMessage");
  }
  else
  {
    if (gIpLastErr == -1)
    {
      gIpLastErr = IpGetLastSocketError(gConnectionSocket);
      if (gIpLastErr == 997)
      {
        // sending is done asynchronously.
        // => OnTcpSend is called when done sending.
////////        writelineex( 0, 1, "ETHTP:Tcp data sent successfully!");        
      }
      else
      {
        IpGetLastSocketErrorAsString( gConnectionSocket, gIpLastErrStr, elcount( gIpLastErrStr));
        writeLineEx( 1, 3, "ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);   
        snprintf(errorbuffer,elcount(errorbuffer),"ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);
        sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);
      }
    }
    else
    {
      IpGetLastSocketErrorAsString( gConnectionSocket, gIpLastErrStr, elcount( gIpLastErrStr));
      writeLineEx( 1, 3, "ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);   
      snprintf(errorbuffer,elcount(errorbuffer),"ETHTP_Err:Tcp send error (%d): %s", gIpLastErr, gIpLastErrStr);
      sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);
    }
  }
}

int ETH_TP_Send(byte Data[],enum AddressMode Mode)
{
  int  a;
  long EventHandle1;
  
  
  ETHSendFlag = 0;
  if(Mode==PHYSICAL)
  {
    if(EthNodeTypeNow == EdgeNode)
    {
      DoIP_DataReq( Data, elCount(Data), gETH_ECULogicAddress, gETH_TesterLogicAddress);
//      DoIP_TCPSend(0x02,0x8001, payload, 6);
    }
    else
    {
      SendTcpData( Data, elCount(Data), gETH_ECULogicAddress, gETH_TesterLogicAddress);
    }
//    if(testWaitForTextEvent("ETHSendDiagMessage",500) == 1)
//    {
//      write("Ethernet data send successfully!");
//    }
//    gETH_t1=timenow()/100.0;
//    TP_T1 = timeNowFloat()/10000;
  }
  else
  {
    if(EthNodeTypeNow == EdgeNode)
    {
      DoIP_DataReq( Data, elCount(Data), gETH_FunctionalLogicAddress, gETH_TesterLogicAddress);
    }

    else
    {
      SendTcpData( Data, elCount(Data), gETH_FunctionalLogicAddress, gETH_TesterLogicAddress);
    }
//    if(testWaitForTextEvent("ETHSendDiagMessage",500) == 1)
//    {
//      write("Ethernet data send successfully!");
//    }
////    gETH_t1=timenow()/100.0;
//    TP_T1 = timeNowFloat()/10000;
  }
  return 1;
}

