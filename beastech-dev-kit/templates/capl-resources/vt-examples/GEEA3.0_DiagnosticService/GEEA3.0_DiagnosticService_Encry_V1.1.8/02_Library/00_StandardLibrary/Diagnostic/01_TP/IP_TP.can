void MainTest()
{
  gUDP_Socket = udpOpen(0,13400);
  
  while(1)
  {
    if(EthNodeTypeNow == EdgeNode && ConnectToEthernetCommand==1 && AnnouncementReceivedFlag==1)
    {
      ETH_TP_SetTransportParameters(gECULogicAddress,gTesterLogicAddress,gFunctionalLogicAddress,gTesterIpv4Address,gECUIpv4Address,gNetmask);
      ConnectToEthernetCommand=0;
    }
    else if(EthNodeTypeNow == InternalNode && ConnectToEthernetCommand==1)
    {
      int i = 0;
      if(i == 0) { Server_Listen(); }
      ETH_TP_SetTransportParameters(gECULogicAddress,gTesterLogicAddress,gFunctionalLogicAddress,gTesterIpv4Address,gECUIpv4Address,gNetmask);
      i = 1;
      ConnectToEthernetCommand=0;
    }
    testWaitForTimeout(100);
  }
}
