{
  int a;
  long EventHandle1;
  ETHSendFlag = 0;
  
  if(length>elcount(Data))
  {
    if(Mode==PHYSICAL)
    {
      if(EthNodeTypeNow == EdgeNode)
      {
        DoIP_DataReq( Data, elcount(Data), gETH_ECULogicAddress, gETH_TesterLogicAddress);
      }
      else
      {
        SendTcpData( Data, elcount(Data), gETH_ECULogicAddress, gETH_TesterLogicAddress);
      }
