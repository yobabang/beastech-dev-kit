  dword TCPSegmentIndex = 0;       // TCP数据段计数
  byte  TcpRecvData[10][2000]; // 存储每个TCP数据段的数据，最大存储 10*1500
  dword TcpRecvDataLength;
  dword MultiTCPSegmentFlag,MultiTCPSegmentLength;
  
