on preStart
{  

}

on timer gmstimer_creattcp_for_doipdll
{
  if(1 == @Diagnostic::ETH_AnnouncementMessageReceived) { @Diagnostic::ETH_TPparameterInit = 1; cancelTimer(gmstimer_creattcp_for_doipdll); }
}

on timer gmstimer_closetcp_for_linkdown
{
  tcpAbort(gConnectionSocket);
}

on timer ETH_ServerListen
{

}

on timer ETH_TP_TesterPresentTimer
{
  byte Data[2] = {0x3E,0x80};
  byte payload[6]={0x0E,0x80,0x1F,0xFF,0x3E,0x80};
  
//  SID3E_TesterPresent(FUNCTIONAL,SPRMIB_TRUE);
  if(EthNodeTypeNow==EdgeNode)
  {
    DoIP_TCPSend(0x02,0x8001, payload, 6);
  }
  else
  {
    ETH_TP_Send(Data,FUNCTIONAL);
  }
  
  
  //SendTcpData( Data, elcount(Data), gETH_FunctionalLogicAddress, gETH_TesterLogicAddress); 
}
on sysvar_update Diagnostic::ETH_TPparameterInit
{
  gECULogicAddress=@Diagnostic::ETH_ECULogicAddress;
  gTesterLogicAddress=@Diagnostic::ETH_TesterLogicAddress;
  gFunctionalLogicAddress=@Diagnostic::ETH_FunctionalLogicAddress;
  if(@Diagnostic::ETH_NodeType==1)
    EthNodeTypeNow=EdgeNode;
  else if(@Diagnostic::ETH_NodeType==2)
    EthNodeTypeNow=InternalNode;
  
  sysGetVariableString( sysvar::Diagnostic::ETH_TesterIPAddress,gTesterIpv4Address,elcount(gTesterIpv4Address));
  sysGetVariableString( sysvar::Diagnostic::ETH_VehicleIPAddress, gECUIpv4Address,elcount(gECUIpv4Address));
  sysGetVariableString( sysvar::Diagnostic::ETH_ETHNetMask,gNetmask,  elcount(gNetmask));

  
  gUDS_S3Client=@Diagnostic::S3Client;
  
  ConnectToEthernetCommand=1;
}

on sysvar_update Diagnostic::Send_Flag
{
  byte tempAddressmode;
  
  
  if(@this==1)
  { 
    tempAddressmode=@Diagnostic::AddressingMode;
    Requestlength=elcount(sysvar::Diagnostic::Send_Data);
    sysGetVariableData(sysvar::Diagnostic::Send_Data,Senddata,Requestlength);
    if(tempAddressmode==0)
      ETH_TP_Send(Senddata,Requestlength,PHYSICAL);
    else if(tempAddressmode==1)
      ETH_TP_Send(Senddata,Requestlength,FUNCTIONAL);
  }
}

on sysvar_update Diagnostic::TP_TesterPresentSet
{
  if(@this==1)
	{
		setTimerCyclic(ETH_TP_TesterPresentTimer,gUDS_S3Client);
	}
	else if(@this==0)
	{
		cancelTimer(ETH_TP_TesterPresentTimer);
	}  
}

on sysvar_update Diagnostic::ETH_SendVehicleAnnouncementRequest
{
  if(@this==1)
	{
		Send_VehicleAnnouncementRequest(); 
	}
}

