void _DoIP_VehicleConnectedInd()
{
  @Diagnostic::ETH_TCPConnectionStatus = 1;
  @Diagnostic::ETH_TimeTCPReconnect = timeNow()/100.0;
  write( "Vehicle connected.");
}
void DoIP_ErrorInd( int error)
{
  switch(error)
  {
    case 0:
      writelineex( 0, 2, "No vehicle responded to the identification request");
      break;
    case 1:
      writelineex( 0, 2, "Connection to vehicle failed");
      break;
    case 2:
      writelineex( 0, 2, "Routing Activation failed ");
      break;
    case 3:
      writelineex( 0, 2, "A negative ACK Code was received for a Diagnostic Message ");
      break;
    case 4:
      writelineex( 0, 2, "No Ack for diagnostics message received  ");
      break;
    case 5:
      writelineex( 0, 2, "A Generic DoIP header negative acknowledge was received ");
      break;
    default:
      writelineex( 0, 2, "Reserved ");
      break;
  }
}

void _DoIP_ConnectionClosedInd( long reason)
{
  @Diagnostic::ETH_TCPConnectionStatus = 0;
  @Diagnostic::ETH_TimeTCPDisconnect = timeNow()/100.0;
  write( "ConnectionClosedInd( %d)", reason);
}

//Used to init ETH
void ETH_TP_SetTransportParameters(dword ECULogicAddress,dword TesterLogicAddress,dword FunctionalLogicAddress,char TesterIPAddress[],char VehicleIPAddress[],char ETHNetMask[])
{
  dword result;
  dword interfaceIndex;
  
  gETH_TesterLogicAddress=TesterLogicAddress;
  //ETH_RawECULogicAddress=ECULogicAddress;
  gETH_ECULogicAddress = ECULogicAddress;
  gETH_FunctionalLogicAddress = FunctionalLogicAddress;
//  gETH_TesterIPv4Address = ipGetAddressAsNumber(TesterIPAddress);
//  gETH_VehicleIPv4Address = ipGetAddressAsNumber(VehicleIPAddress);
  gETH_netmask = ipGetAddressAsNumber(ETHNetMask);
  
  gIPAddressForECU=addresstrans(gIPAddressForECU,VehicleIPAddress);
  gIPAddressForTester=addresstrans(gIPAddressForTester,TesterIPAddress);
  
  interfaceIndex = 1;
  
//  result= ipAddAdapterAddress(interfaceIndex, gIPAddressForTester, gETH_netmask);
  
//  if( result != 0 )
//  {
//    write( "IpAddAdapterAddress failed, error code %d, last error %d", result, IpGetLastError());
//  }

  if(EthNodeTypeNow == EdgeNode)
  {
    if(gETH_EdgeNodeLogicAddress == 0 &&  gETH_EdgeNodeLogicAddress_UserDefine!= @Diagnostic::ETH_ECULogicAddress) { gETH_EdgeNodeLogicAddress = gETH_EdgeNodeLogicAddress_UserDefine; }
    write("Initial DoIP!");
    DoIP_SetProtocol(gDoIP_ProtocolVersion);   //1: Draft version (2010)
    DoIP_SetLocalIPaddress(TesterIPAddress);
    DoIP_SetVehicleAddress(VehicleIPAddress);
    DoIP_SetTesterLogicalAddress( gETH_TesterLogicAddress);
    DoIP_SetVehicleLogicalAddress( gETH_EdgeNodeLogicAddress);
    DoIP_SetBroadcastIPaddress("255.255.255.255"); 
    DoIP_SetVehicleTcpPort(13400);
    DoIP_SetVehicleUdpPort(13400);
    DoIP_SetReconnectInterval( 200, 100);
    DoIP_SetReconnectDelay(ECUIniTime); 
    DoIP_ConfigureRoutingActivationRequest(1,0x00,0x00000000);
    DoIP_SetDiagnosticMessageTimeout(2000);
    DoIP_SetIdentificationRequestVIN( "VECT0RVEH1CLE1234");
    DoIP_ConnectToVehicle();
//    write("TesterIPAddress=%s",TesterIPAddress);
//    write("VehicleIPAddress=%s",VehicleIPAddress);
//    write("gETH_TesterLogicAddress=%x",gETH_TesterLogicAddress);
//    write("gETH_ECULogicAddress=%x",gETH_ECULogicAddress);
    gETH_ECULogicAddress = @Diagnostic::ETH_ECULogicAddress;
  }
  else
  {
    Waitforcnnected(gMaxTimeToWaitForTCPConnected);
  }
}

void Waitforcnnected(dword timeoutime)
{
  testWaitForTextEvent("TCPConnected",timeoutime);
}

//Used to set MAC for the tester
void ETH_TP_SetTesterMAC(byte MAC[])
{
  gMACAddressForTester[0] = MAC[0];
  gMACAddressForTester[1] = MAC[1];
  gMACAddressForTester[2] = MAC[2];
  gMACAddressForTester[3] = MAC[3];
  gMACAddressForTester[4] = MAC[4];
  gMACAddressForTester[5] = MAC[5];
}

void Server_Listen()
{
  long Result1;
  int i;
  
  write("listening ...");
  gListenSocket = TcpOpen( 0, 13400 );//建立一个TCP Socket
  if(gListenSocket!=~0)
  {
    write("built TCP socket success ");
  }
  else
    write("built TCP socket fail");
    // Begin listening on TCP port.
  TcpListen(gListenSocket);// listen for incoming connection requests
  if (IpGetLastError() != 0)//判断监听TCP Socket是否成功
  {
    // if UdpSocket::Open fails, we print a message to the write window
    write( "ETHTP_Err:<%BASE_FILE_NAME%> TcpSocket::Open failed with result %d", IpGetLastError() );
  }
  else
    write("ETHTP:listen success");

}


//
// Callback OnTcpListen is called on incomming connect request.
//
void OnTcpConnect( dword Socket, long Result)
{
  if (0 != Result)
  {
    IpGetLastSocketErrorAsString( Socket, gIpLastErrStr, elcount( gIpLastErrStr));
    Writelineex(0, 2, "OnTcpConnect Error (%d): %s", IpGetLastSocketError(Socket), gIpLastErrStr);
    snprintf(errorbuffer,elcount(errorbuffer),"OnTcpConnect Error (%d): %s", IpGetLastSocketError(Socket), gIpLastErrStr);
    sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);
    return;
  }
}

