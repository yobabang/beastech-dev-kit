variables
{
  //new add-10-14
  float gTimeTCPDisCnct,gTimeTCPCnct;
  int gTCPCnctFlag; 
  int gECUInitTimeCheckFlag = 0;
  dword gTolerateTimeForTCPConnect = 60000;////偏离后建立TCP的时间
  dword gTolerateTimeForDiagInit = 1000;////TCP建立后诊断使能时间
  dword gTolerateTimeForSYNMessage = 60000;////等待SYN报文时间
  dword gECUIniTime=5000;
//  float TCPConnectionRecordTime1=0,TCPConnectionRecordTime2=0;
  
  dword   gETH_EdgeNodeLogicAddress;
  dword   gETH_TesterLogicAddress ;
  dword   gETH_ECULogicAddress ;
  dword   gETH_FunctionalLogicAddress;
//  dword   gETH_VehicleIPv4Address;
