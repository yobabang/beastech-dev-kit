void OnTcpListen( dword socket, long result)
{
  dword gOtherConnection;
  int i,j;
  char ipaddressstring[20];
  dword addressesCount;
  dword temp_socket;
  dword temp_ipv4address;
  
  write("ETHTP:listen success2  %d    %f",result,timeNow()/100000.0);

  if (result == 0)
  {
    temp_socket = TcpAccept(socket);
    temp_ipv4address = TcpGetRemoteAddress(temp_socket);
    
    if (temp_ipv4address == IpGetAddressAsNumber(first_ip))
    {
      first_socket=temp_socket;
      gConnectionSocket=temp_socket;
      tcpReceive(gConnectionSocket, gTcpRxBuffer, elcount(gTcpRxBuffer) );
      
      if(gflag_wait_for_multi_tcp_socket ==0)
      {
           
           
           @Diagnostic::ETH_TimeTCPReconnect = timeNow()/100.0;
           testSupplyTextEvent("TCPConnected");
           @Diagnostic::ETH_TCPConnectionStatus=1;
           @Diagnostic::ETH_TCPReconnection = 1;
           gFlag_TCPConnected = 1;
           
        
      }
      
    }
    else if(temp_ipv4address == IpGetAddressAsNumber(second_ip))
    {
       
       second_socket=temp_socket;
      
    }
    if(gflag_wait_for_multi_tcp_socket ==1)
    {
       if(first_socket!=0 && second_socket!=0)
      {
          @Diagnostic::ETH_TimeTCPReconnect = timeNow()/100.0;
           testSupplyTextEvent("TCPConnected");
           @Diagnostic::ETH_TCPConnectionStatus=1;
           @Diagnostic::ETH_TCPReconnection = 1;
           gFlag_TCPConnected = 1;
        
      }
       
    }
    
  }
    
 
}
/********************************************************
This function is used to set receive data to the confirmed TCP connection
 *********************************************************/
void SetSendTCPConnection()
{
  int i;
  for(i=0;i<gTCPConnectionNum;i++)
  {
    write("now check num is %d and state is %d and add is %x",i,gConSoc[i].State,swapDWord(gConSoc[i].gSocAdd));
    if(gConSoc[i].State == 1)
    {
      if(gIPAddressForECU == swapDWord(gConSoc[i].gSocAdd))
      {
        write("Successfully get IP and it is %x",gConSoc[i].gSocAdd);
        gConnectionSocket =gConSoc[i].gConSocHandle;
        tcpReceive(gConSoc[i].gConSocHandle, gTcpRxBuffer, elcount(gTcpRxBuffer) );
        testSupplyTextEvent("TCPConnected");
        @Diagnostic::ETH_TCPConnectionStatus=1;
        gFlag_TCPConnected = 1;
        
        sysSetVariableString( sysvar::Diagnostic::ETH_TesterIPAddress,gTesterIpv4Address);
        sysSetVariableString( sysvar::Diagnostic::ETH_VehicleIPAddress, gECUIpv4Address);
      }
    }
  }
}

