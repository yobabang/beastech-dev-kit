        DoIP_DataReq( Data, elcount(Data), gETH_FunctionalLogicAddress, gETH_TesterLogicAddress);
      }
      else
      {
        SendTcpData( Data, elcount(Data), gETH_FunctionalLogicAddress, gETH_TesterLogicAddress);
      }
//     if(testWaitForTextEvent("ETHSendDiagMessage",500) == 1)
//  {
//    write("Ethernet data send successfully!");
//  }
//////      gETH_t1=timenow()/100.0;
//    TP_T1 = timeNowFloat()/10000;
    }
    write("ETHTP:Warning tp send data size small than given length");
  }
  else
  {
    if(Mode==0)
    {
      if(EthNodeTypeNow == EdgeNode)
      {
        DoIP_DataReq( Data, length, gETH_ECULogicAddress, gETH_TesterLogicAddress);
      }
      else
      {
        SendTcpData( Data, length, gETH_ECULogicAddress, gETH_TesterLogicAddress);
      }
//      if(testWaitForTextEvent("ETHSendDiagMessage",500) == 1)
//      {
//        write("Ethernet data send successfully!");
//      }
////      gETH_t1=timenow()/100.0;
