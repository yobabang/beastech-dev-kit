dword addresstrans(dword b,char ipv4[])
{
  dword a;
  a=IpGetAddressAsNumber(ipv4);
  b=((a&0xFF)<<24)+((a&0xff00)<<8)+((a&0xff0000)>>8)+((a&0xff000000)>>24);
  return b;
}

void Send_VehicleAnnouncementRequest()
{
  byte DoIPMessage[65535];
  
  DoIPMessage[0] = 0xFF;
  DoIPMessage[1] = 0x00;
  DoIPMessage[2] = 0x00;
  DoIPMessage[3] = 0x01;
  UdpSendTo(gUDP_Socket, 0xFFFFFFFF, 13400, DoIPMessage,8);
}

/* 取同网段的IP地址 */
void IP_GetAddressWithinSameCluster(char dst[],char scr[])
{
  char[10] address[long];
  long pos_dot[long];
  long offset;
  offset = 0;

  while(1)
  {
    long index;
    index = pos_dot.size();
    pos_dot[index] = strstr_off(scr,offset,".");
    if(pos_dot[index] < 0)
      break;
    offset = pos_dot[index] + 1;
  }
  
  for(long index : pos_dot)
  {
    if(index == 0)
      substr_cpy(address[index],scr,0,pos_dot[index],elcount(scr));
    else
      substr_cpy(address[index],scr,pos_dot[index-1] + 1,pos_dot[index] - pos_dot[index-1] - 1,elcount(scr));
  }
  
  /* 改变最后一个字节 */
  if(atol( address[3]) != 254)
    snprintf(address[3],elcount(address[3]),"%d",atol( address[3]) + 1 );
  else
    snprintf(address[3],elcount(address[3]),"%d",atol( address[3]) - 1 );
  snprintf(dst,elcount(dst),"%s.%s.%s.%s",address[0],address[1],address[2],address[3]);
  
  address.clear();
  pos_dot.clear();
}

