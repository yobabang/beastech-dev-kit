on ethernetStatus *
{
  if(this.status == 0) 
  { 
    int i;
//    for(i=0;i<elcount(gecu_ipv4_logical_address_info);i++)
//    { 
//      if(gConSoc[i].State == 1) 
//      { 
//        gConSoc[i].gTimeTCPDisconnect = timeNow()/100.0; 
//      }
//    }
    if(@Diagnostic::ETH_TCPConnectionStatus == 1) 
    { 
      @Diagnostic::ETH_TimeTCPDisconnect = timeNow()/100.0; 
    }
    @Diagnostic::ETH_AnnouncementMessageReceived = 0;
    cancelTimer(ETH_TP_TesterPresentTimer);
    ETH_TP_Release();
    @Diagnostic::ETH_TCPConnectionStatus = 0; 
    @Diagnostic::ETH_TCPReconnection = 0;
  }
  else 
  { 
    int flag = 1;
    if(flag == 0)
    {
      if(1 == @Diagnostic::ETH_NodeType) 
      { 
        setTimerCyclic(gmstimer_creattcp_for_doipdll,10); 
      }
      else if(2 == @Diagnostic::ETH_NodeType) 
      { 
        setTimer(gmstimer_closetcp_for_linkdown,gtime_closetcp_for_linkdown); 
      }
    }
    flag = 0;
  }
}

