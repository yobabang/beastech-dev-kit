long FindDoIP_AnnouncementOnPacket(ethernetPacket * myPacket)
{
  char ipaddressstring[20];
  dword addressesCount;
  
  if(myPacket.doip.IsAvailable() && myPacket.doip.byte(0) == gDoIP_ProtocolVersion && (myPacket.doip.byte(1) == (0xFF-gDoIP_ProtocolVersion)) && swapWord(myPacket.doip.word(2)) == 4 )/* DoIP车辆声明触发 */
  {
    long logicAddress;
    
    logicAddress = swapWord(myPacket.doip.word(25)); 
    
    ipGetAddressAsString(myPacket.ipv4.source,gECUIpv4Address,elcount(gECUIpv4Address));
    write("onDoIPUDPPacketReceived：scrip = %s, logic address = %04X",gECUIpv4Address,logicAddress);
    
    gETH_EdgeNodeLogicAddress = logicAddress;
    //@Diagnostic::ETH_ECULogicAddress = logicAddress;//石太佳 20250417 注释掉此行，这里不能修改ECU 逻辑地址
    {
      char TestIpAddress_str[20];
      dword TestIpAddress_dword;
      
      TestIpAddress_dword = ipGetAddressAsNumber(TestIpAddress_str);
      
      IP_GetAddressWithinSameCluster(TestIpAddress_str,gECUIpv4Address);
      if( TestIpAddress_dword != ipGetAddressAsNumber(TestIpAddress_str))
      {
        ipAddAdapterAddress(1,ipGetAddressAsNumber(TestIpAddress_str),ipGetAddressAsNumber("255.255.0.0"));
      }
      
      sysSetVariableString( sysvar::Diagnostic::ETH_TesterIPAddress,TestIpAddress_str);
      sysSetVariableString( sysvar::Diagnostic::ETH_VehicleIPAddress, gECUIpv4Address);
    }
    
    
    
    @Diagnostic::ETH_AnnouncementMessageReceived = 1;
    AnnouncementReceivedFlag=1;
  }
  return 1;
}

//Used to get received data by TCP connection
long TcpRecv( dword socket)
{
  int result = 0;
  int i;
  
  
  result = TcpReceive( socket,TcpRecvData[TCPSegmentIndex],elCount(TcpRecvData[TCPSegmentIndex]));
  
  if ( 0 != result)
  {
    gIpLastErr = IpGetLastSocketError( socket);

    if ( WSA_IO_PENDING != gIpLastErr)
    {
      IpGetLastSocketErrorAsString( socket, gIpLastErrStr, elcount( gIpLastErrStr));

      writelineex( 0, 2, "ETHTP_Err:TcpReceive error (%d): %s", gIpLastErr, gIpLastErrStr);
      
      snprintf(errorbuffer,elcount(errorbuffer),"ETHTP_Err:TcpReceive error (%d): %s", gIpLastErr, gIpLastErrStr);
      sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);     
    }
  }
  write("receive TCP data byte[0]=%x",TcpRecvData[TCPSegmentIndex][0]);
  /* 0x8001: DiagnosticMessage(完整的诊断响应或响应的第一个TCP数据段) */
  if((TcpRecvData[TCPSegmentIndex][0] == gDoIP_ProtocolVersion)&&(TcpRecvData[TCPSegmentIndex][1] == 0xFF-gDoIP_ProtocolVersion)&&(TcpRecvData[TCPSegmentIndex][2] == 0x80)&&(TcpRecvData[TCPSegmentIndex][3] == 0x01))
  {
    gTpRxLength = (TcpRecvData[TCPSegmentIndex][4]<<24)|(TcpRecvData[TCPSegmentIndex][5]<<16)|(TcpRecvData[TCPSegmentIndex][6]<<8)|(TcpRecvData[TCPSegmentIndex][7]);
    gTpRxLength = gTpRxLength - 4;
////////    for(i=0;i<gTpRxLength;i++)  { gTpRxData[i] = TcpRecvData[TCPSegmentIndex][i+12]; } //接收第一个数据段数据
    memcpy_off(gTpRxData,0,TcpRecvData[TCPSegmentIndex],12,TCPSegmentLength);
    if(TCPSegmentLength < gTpRxLength + 12)     // 当前TCP段数据长度小于DoIP包的长度，说明DoIP包在TCP层分段
    {
      MultiTCPSegmentFlag = 1;  //TCP分段标志
      MultiTCPSegmentLength = TCPSegmentLength - 12;  //获取的诊断响应的总长度
      return 1;
    }
    else                                        // 当前TCP段数据长度不小于DoIP包的长度，说明DoIP包在TCP层未分段
    {
      TestSupplyTextEvent("ETHTPreciveData");
      sysSetVariableData(sysvar::Diagnostic::Receive_Data,gTpRxData,gTpRxLength);
      @Diagnostic::Receive_DataLength = gTpRxLength;
      @Diagnostic::Receive_ConAll = 1;
////////      write( "ETHTP:Received TpRxLength=%d byte : 0x%02X 0x%02X 0x%02X 0x%02X  ..." , gTpRxLength, gTpRxData[0], gTpRxData[1], gTpRxData[2], gTpRxData[3]);
    }
  }
  /*  */
  if(MultiTCPSegmentFlag == 1) //需要对分段数据进行处理
  {
////////    for(i=0;i<TCPSegmentLength;i++) { gTpRxData[MultiTCPSegmentLength + i] = TcpRecvData[i]; }
    memcpy_off(gTpRxData,MultiTCPSegmentLength,TcpRecvData[TCPSegmentIndex],0,TCPSegmentLength);
    MultiTCPSegmentLength = MultiTCPSegmentLength + TCPSegmentLength;
    if(MultiTCPSegmentLength >= gTpRxLength) 
    { 
      MultiTCPSegmentFlag = 0; 
      TCPSegmentIndex = 0;
      TestSupplyTextEvent("ETHTPreciveData");
      sysSetVariableData(sysvar::Diagnostic::Receive_Data,gTpRxData,gTpRxLength);
      @Diagnostic::Receive_DataLength=gTpRxLength;
      @Diagnostic::Receive_ConAll=1;
////////      write( "ETHTP:Received TpRxLength=%d byte : 0x%02X 0x%02X 0x%02X 0x%02X  ..." , gTpRxLength, gTpRxData[0], gTpRxData[1], gTpRxData[2], gTpRxData[3]);
    }
  }
  /* TCP分段处理完成后重置标志位 */
  if(MultiTCPSegmentFlag == 0) { MultiTCPSegmentLength = 0;  TCPSegmentLength = 0; } 
  
//////  20240414_yangjing: 新增TCP粘包处理机制
  
  
  
  
  
  
  
//////  20240413_yangjing: 新增TCP分段处理机制，此部分注释
//////  result = TcpReceive( socket, gTcpRxBuffer, elcount(gTcpRxBuffer));
//////
//////  if ( 0 != result)
//////  {
//////    gIpLastErr = IpGetLastSocketError( socket);
//////
//////    if ( WSA_IO_PENDING != gIpLastErr)
//////    {
//////      IpGetLastSocketErrorAsString( socket, gIpLastErrStr, elcount( gIpLastErrStr));
//////
//////      writelineex( 0, 2, "ETHTP_Err:TcpReceive error (%d): %s", gIpLastErr, gIpLastErrStr);
//////      
//////      snprintf(errorbuffer,elcount(errorbuffer),"ETHTP_Err:TcpReceive error (%d): %s", gIpLastErr, gIpLastErrStr);
//////      sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);     
//////    }
//////  }
//////  
//////  gTpRxLength = (gTcpRxBuffer[4]<<24)|(gTcpRxBuffer[5]<<16)|(gTcpRxBuffer[6]<<8)|(gTcpRxBuffer[7]);
//////  gTpRxLength = gTpRxLength-4;
//////  if((gTcpRxBuffer[0]==0x02)&&(gTcpRxBuffer[1]==0xFD)&&(gTcpRxBuffer[2]==0x80)&&(gTcpRxBuffer[3]==0x01))
//////  {
//////    for(i=0;i<=gTpRxLength;i++)
