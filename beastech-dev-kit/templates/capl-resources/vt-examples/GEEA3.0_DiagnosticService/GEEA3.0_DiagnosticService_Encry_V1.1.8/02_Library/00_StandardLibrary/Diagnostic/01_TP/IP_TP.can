  enum   ResponseState {TIMEOUT,POS,NEG};
  enum   TP_Switch {TP_ON = 1,TP_OFF = 0};
  enum   Bus_Type {TP_CAN = 1,TP_CANFD = 2,TP_LIN = 3,TP_FLEXRAY = 4,TP_ETHERNET = 5};
  enum   AddressMode {PHYSICAL = 0,FUNCTIONAL = 1};
