  msTimer ETH_ServerListen;
  msTimer ETH_TP_TesterPresentTimer;
  const long  WSA_IO_PENDING =  997;
  
  int ETHSendFlag = 0;
  
  struct ConnectionSocket
  {
    dword gConSocHandle;
    dword gSocAdd;
    dword gLogicalAddress;
    dword gSocIndex;
    int   State;
    float gTimeTCPDisconnect;
    float gTimeTCPReconnect;
    byte  gSocketData[65535];
