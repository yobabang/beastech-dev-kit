void OnTcpReceive( dword socket, long result, dword address, dword port, byte buffer[], dword size)
{
  char  addressString[64] = "";
  char  AddressString[64] = "";
  char Data[1024]="";
//////  write("99999999999999999999999999999999   gConnectionSocket = %d; socket = %d  %f",gConnectionSocket,socket,timeNow()/100000.0);
  if ( gConnectionSocket == socket)
  {
    if(MultiTCPSegmentFlag == 1) { TCPSegmentIndex++; }
    memcpy(TcpRecvData[TCPSegmentIndex],buffer,size);
    TCPSegmentLength = size;
    TcpRecv( socket);
  }

  if (0 != result)
  {
    IpGetLastSocketErrorAsString( socket, gIpLastErrStr, elcount( gIpLastErrStr));
    writelineex( 0, 2, "OnTcpReceive error (%d): %s", IpGetLastSocketError( socket), gIpLastErrStr);
    snprintf(errorbuffer,elcount(errorbuffer),"OnTcpReceive error (%d): %s", IpGetLastSocketError( socket), gIpLastErrStr);
    sysSetVariableString( sysvar::Diagnostic::ErrorMessage,errorbuffer);
    return;
  }
}

