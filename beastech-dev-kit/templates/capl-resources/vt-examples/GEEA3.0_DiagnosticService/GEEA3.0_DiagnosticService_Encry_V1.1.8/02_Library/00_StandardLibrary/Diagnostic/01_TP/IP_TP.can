  dword   gTpTxLength;          //Used to save dala lenth
  dword   gListenSocket;        //Used to identify the current listen
  dword   gConnectionSocket;    //Used to identify the current tcp connection
  char    gRxBuffer[65536];     //Used to save data to be received
  dword   gConnectionECUAddress;    //Used to identify the current tcp connection

  char    gIpLastErrStr[1024]  = "";//Used to save error information  
  byte    gTcpRxBuffer[8192];   //Used to save TCP receive data
  int     gIpLastErr           = 0;//Used to save last error code
