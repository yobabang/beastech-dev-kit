void SID22_ReadDataByIdentifier(byte PID[],enum AddressMode Mode)
{
	byte SID22[3];
	SID22[0]=0x22;
	SID22[1]=PID[0];
	SID22[2]=PID[1];
	TP_Send(SID22, Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID22,elCount(SID22));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID22,elCount(SID22));
		}
	}
}

void SID22_ReadDataByIdentifier(long PID,enum AddressMode Mode)
{
	byte SID22[3];
	SID22[0]=0x22;
	SID22[1]=PID>>8;
	SID22[2]=PID&0xFF;
	TP_Send(SID22, Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID22,elCount(SID22));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID22,elCount(SID22));
		}
	}
}

