void SID19_Sub04_ReportDTCSnapshotRecordByDTCNumber(Byte DTC[],Byte DTCSnapshotRecordNumber,enum AddressMode Mode)
{
	byte SID19[6];
	SID19[0]=0x19;
	SID19[1]=0x04;
	SID19[2]=DTC[0];
	SID19[3]=DTC[1];
	SID19[4]=DTC[2];
	SID19[5]=DTCSnapshotRecordNumber;
	TP_Send(SID19,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID19,elCount(SID19));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID19,elCount(SID19));
		}
	}
}
