void SID2A_ReadDataByPeriodicIdentifier(enum e_TransmissionMode TMode,byte PID[],enum AddressMode Mode)
{
	byte SID2A[20];
	int  i;
	SID2A[0]=0x2A;
	SID2A[1]=TMode;
	for(i=0; i<elCount(PID); i++)
		SID2A[i+2]=PID[i];
	TP_Send(SID2A,elCount(PID)+2,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID2A,elCount(SID2A));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID2A,elCount(SID2A));
		}
	}
}

void SID2A_ReadDataByPeriodicIdentifier_Stop(enum AddressMode Mode)
{
	byte SID2A[2];
	SID2A[0]=0x2A;
	SID2A[1]=0x04;
	TP_Send(SID2A,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID2A,elCount(SID2A));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID2A,elCount(SID2A));
		}
	}
}

