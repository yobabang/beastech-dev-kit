int CheckCurrentSession(byte expectSession,enum AddressMode Mode,int reqGroup,int reqNum)
{
	int result;
	byte SID22_F186[3]= {0x22,0xf1,0x86};
  teststep("UDS","Send Request[22 F1 86]");
	TP_Send(SID22_F186,Mode);
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x22);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x22);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x22);
    }
  }
	switch(gRss)
	{
	case POS:
    PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
		if(expectSession==gTpRxData[3])
		{
			if(gUDS_DescriptionExistFlag == 1)
			{
				if(gUDS_LanguageSet == 0)
				{
					testStepPass("UDS","Current Session [0x%2x]",gTpRxData[3]);
				}
				else
				{
					testStepPass("UDS","当前会话 [0x%2x]",gTpRxData[3]);
				}
			}
			result = 2;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Unexpected session 0x%02x when request current session",gTpRxData[3]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求当前会话时响应当前会话为 0x%02x",gTpRxData[3]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			result = -1;
		}
		break;
	case TIMEOUT:
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"Timeout no response recived when request current session");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"请求当前会话模式时控制器超时未响应");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		result = 1;
		break;
	default:
    PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"Timeout negative response 0x%02x recived when request current session",gTpRxData[2]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"请求当前会话时控制器响应否定响应 0x%02x",gTpRxData[2]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		result = 1;
		break;
	}

	return result;
}


void PrintPID(char stepTile[],char Info[],byte Data[],int len)
{
	int i;
	char PrintData[102400];
	for(i=0; i<len; i++)
	{
		if((Data[i]>>4)<10)
			PrintData[i*3]=((Data[i]>>4)+0x30);
		else
			PrintData[i*3]=((Data[i]>>4)+0x37);
		if((Data[i]&0x0F)<10)
			PrintData[i*3+1]=((Data[i]&0x0F)+0x30);
		else
			PrintData[i*3+1]=((Data[i]&0x0F)+0x37);
		PrintData[i*3+2]=0x20;
	}
	PrintData[len*3]='\0';
	testStep(stepTile,"%s [%s]",Info,PrintData);
}

int CheckRxLength(dword length)
{
	if(gTpRxLength>length)
	{
		return 1;
	}
	else if(gTpRxLength==length)
	{
		return 2;
	}
	else
	{
		return -1;
	}
}

dword GetRxLength()
{
	dword lenth;

	lenth = gTpRxLength;
	return lenth;
}

int CompareByte(byte Data1[],byte Data2[],dword lenth)
{
	int Flag;
	dword RealLenth;
	int i;
	Flag = 2;
	RealLenth = elCount(Data1);
	if(RealLenth>elCount(Data2))
	{
		RealLenth = elCount(Data2);
	}
	if(RealLenth>lenth)
	{
		for(i = 0; i<lenth; i++)
		{
			if(Data1[i] != Data2[i])
			{

				Flag = 0;
			}
		}
	}
	else
	{
		for(i = 0; i<RealLenth; i++)
		{
			if(Data1[i] != Data2[i])
			{
				Flag = 0;
			}
		}
	}

	return Flag;


}

void GetReceivedData(byte InputData[])
{
	int GRDa;

	if(gTpRxLength>elcount(InputData))
	{
		for(GRDa = 0; GRDa <elcount(InputData); GRDa++)
		{
			InputData[GRDa] = gTpRxData[GRDa];
		}
		testStepWarning("","Can't get all the received data,please use larger data receiver");
	}
	else
	{
		for(GRDa = 0; GRDa <gTpRxLength; GRDa++)
		{
			InputData[GRDa] = gTpRxData[GRDa];
		}
	}
}

void GetReceivedData(byte InputData[],dword StartPos,dword lenth)
{
	dword GRDa;

	if(gTpRxLength>=(lenth+StartPos))
	{
		for(GRDa = StartPos; GRDa <lenth+StartPos; GRDa++)
		{
			InputData[GRDa-StartPos] = gTpRxData[GRDa];
		}
	}
	else
	{
		for(GRDa = StartPos; GRDa <(gTpRxLength-StartPos); GRDa++)
		{
			InputData[GRDa-StartPos] = gTpRxData[GRDa];
		}
	}
}

void NRC_Info(byte nrc)
{
	switch(nrc)
	{
	case 0x11:
		testStep("NRC","Get NRC(0x%2x) serviceNotSupported",nrc);
		break;
	case 0x12:
		testStep("NRC","Get NRC(0x%2x) subFunctionNotSupported",nrc);
		break;
	case 0x13:
		testStep("NRC","Get NRC(0x%2x) incorrectMessageLength",nrc);
		break;
	case 0x14:
		testStep("NRC","Get NRC(0x%2x) responseTooLong",nrc);
		break;
	case 0x22:
		testStep("NRC","Get NRC(0x%2x) conditionsNotCorrect",nrc);
		break;
	case 0x24:
		testStep("NRC","Get NRC(0x%2x) requestSequenceError",nrc);
		break;
	case 0x31:
		testStep("NRC","Get NRC(0x%2x) requestOutOfRange",nrc);
		break;
	case 0x33:
		testStep("NRC","Get NRC(0x%2x) securityAccessDenied",nrc);
		break;
	case 0x35:
		testStep("NRC","Get NRC(0x%2x) invalidKey",nrc);
		break;
	case 0x36:
		testStep("NRC","Get NRC(0x%2x) exceedNumberOfAttempts",nrc);
		break;
	case 0x37:
		testStep("NRC","Get NRC(0x%2x) requiredTimeDelayNotExpired",nrc);
		break;
	case 0x70:
		testStep("NRC","Get NRC(0x%2x) uploadDownloadNotAccepted",nrc);
		break;
	case 0x71:
		testStep("NRC","Get NRC(0x%2x) transferDataSuspended",nrc);
		break;
	case 0x72:
		testStep("NRC","Get NRC(0x%2x) generalProgrammingFailure",nrc);
		break;
	case 0x73:
		testStep("NRC","Get NRC(0x%2x) wrongBlockSequenceCounter",nrc);
		break;
	case 0x78:
		testStep("NRC","Get NRC(0x%2x) requestCorrectlyReceived-ResponsePending",nrc);
		break;
	case 0x7e:
		testStep("NRC","Get NRC(0x%2x) subfunctionNotSupportinActiveSession-ResponsePending",nrc);
		break;
	case 0x7f:
		testStep("NRC","Get NRC(0x%2x) serviceNotSupportedInActiveSession",nrc);
		break;
	case 0x83:
		testStep("NRC","Get NRC(0x%2x) engineIsRunning",nrc);
		break;
	case 0x84:
		testStep("NRC","Get NRC(0x%2x) engineIsNotRunning",nrc);
		break;
	case 0x85:
		testStep("NRC","Get NRC(0x%2x) engineRunTimeTooLow",nrc);
		break;
	case 0x92:
		testStep("NRC","Get NRC(0x%2x) voltageTooHigh",nrc);
		break;
	case 0x93:
		testStep("NRC","Get NRC(0x%2x) voltageTooLow",nrc);
		break;
	default:
		testStepFail("NRC","Get NRC(0x%2x) Undefined Reason",nrc);
		break;
	}
}


