			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0xAF",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对AF服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0xEF)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0xAF",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对AF服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=0x06)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect subfunction 0x%02x to the request of service 0xAF",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对AF服务回复了非预期的子功能0x%02x",gTpRxData[1]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if((DTC[0]!=gTpRxData[2])||(DTC[1]!=gTpRxData[3])||(DTC[2]!=gTpRxData[4]))
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect DTC 0x%02x 0x%02x 0x%02x to the request of service 0xAF 06",gTpRxData[2],gTpRxData[3],gTpRxData[4]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对AF服务响应了错误的DTC： 0x%02x 0x%02x 0x%02x",gTpRxData[2],gTpRxData[3],gTpRxData[4]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}


void SID2F_IOControl(byte PID[],byte inputOutputControlParameter,byte ControlState[],byte CSLength,byte ControlEnableMaskRecord[],byte CEMLength,enum AddressMode Mode)
{
	int i,length;
	byte SID2F[30000];
	SID2F[0]=0x2F;
	SID2F[1]=PID[0];
	SID2F[2]=PID[1];
	SID2F[3]=inputOutputControlParameter;
	for(i=0; i<CSLength; i++)
	{
		SID2F[i+4]=ControlState[i];
	}
	for(i=0; i<CEMLength; i++)
	{
		SID2F[i+4+CSLength]=ControlEnableMaskRecord[i];
	}
  
	length=4+CSLength+CEMLength;

	TP_Send(SID2F,length,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID2F,length);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID2F,length);
		}
	}
}

void SID2F_IOControl(byte PID[],byte ControlOptionRecord[],enum AddressMode Mode)
{
	int i,length;
	byte SID2F[30000];
	SID2F[0]=0x2F;
	SID2F[1]=PID[0];
	SID2F[2]=PID[1];
	SID2F[3]=0x03;
	for(i=0; i<elcount(ControlOptionRecord); i++)
	{
		SID2F[i+4]=ControlOptionRecord[i];
	}
	length=4+elCount(ControlOptionRecord);

	TP_Send(SID2F,length,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID2F,length);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID2F,length);
		}
	}
}

void SID2F_IOControl(byte PID[],enum e_InputOutputControlParameter IOParameter,enum AddressMode Mode)
{
	int i;
	byte SID2F[4];
	SID2F[0]=0x2F;
	SID2F[1]=PID[0];
	SID2F[2]=PID[1];
	SID2F[3]=IOParameter;
	TP_Send(SID2F, Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID2F,elCount(SID2F));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID2F,elCount(SID2F));
		}
	}
}

void SID2F_IOControl(byte PID[],enum e_InputOutputControlParameter IOParameter,int Length)
{
	int i,len,j;
	byte SID2F[30000];
  len=4+Length;
	SID2F[0]=0x2F;
	SID2F[1]=PID[0];
	SID2F[2]=PID[1];
	SID2F[3]=IOParameter;
  
  if(len==4)
  {
    
  }
  else
  {
    for(j=4;j<len;j++)
    {
      SID2F[j]=0x00;
    }
  }
  
	TP_Send(SID2F,len, PHYSICAL);
  if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID2F,elCount(SID2F));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID2F,elCount(SID2F));
		}
	}
}

