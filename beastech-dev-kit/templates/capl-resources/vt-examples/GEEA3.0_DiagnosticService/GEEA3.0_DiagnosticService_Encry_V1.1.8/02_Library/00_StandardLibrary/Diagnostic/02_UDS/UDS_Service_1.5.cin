			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS_Ser","Neg.Response: ",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","否定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

int CheckNegResponse(byte ExpectNRC[],int PosFlag,int NonFlag,int reqGroup,int reqNum)
{
	int i;
	int NRCFlag=0;
  NRCFlag=0;
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x00);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x00);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x00);
    }
  }
	if(gRss!=NEG)
	{
		if(gRss==TIMEOUT)
		{
			if(NonFlag==0)
			{
				if(gUDS_LanguageSet == 0)
				{
					snprintf(gDiagResultDescription,4000,"Timeout no response recived");
				}
				else
				{
					snprintf(gDiagResultDescription,4000,"请求超时，控制器未回复响应");
				}
				Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
				return -1;
			}
			else
			{
				if(gUDS_DescriptionExistFlag == 1)
				{
					if(gUDS_LanguageSet == 0)
					{
						PrintPID("UDS_Ser","No response: ",gTpRxData,gTpRxLength);
					}
					else
					{
						PrintPID("UDS","无响应",gTpRxData,gTpRxLength);
					}
				}
				return 2;
			}

		}
		else
		{
			if(PosFlag==0)
			{
				if(gUDS_LanguageSet == 0)
				{
					snprintf(gDiagResultDescription,4000,"Get Pos.Response 0x%02x",gTpRxData[0]);
				}
				else
				{
					snprintf(gDiagResultDescription,4000,"得到了肯定响应 0x%02x",gTpRxData[0]);
				}
				Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
				return 1;
			}
			else
			{
				if(gUDS_DescriptionExistFlag == 1)
				{
					if(gUDS_LanguageSet == 0)
					{
						PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
					}
					else
					{
						PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
					}
				}
				return 2;
			}
		}
	}
	for(i=0; i<elCount(ExpectNRC); i++)
	{
		if(ExpectNRC[i]==gTpRxData[2])
			NRCFlag=1;
	}
	if(NRCFlag==1)
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS_Ser","Neg.Response: ",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","否定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
	else
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"Get uncepected Nr.Response 0x%02x instead of 0x%2x or  ...",gTpRxData[2],ExpectNRC[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"期望否定响应 0x%02x,实际得到了否定响应 0x%02x",ExpectNRC[0],gTpRxData[2]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
}

