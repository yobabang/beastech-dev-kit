{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x36);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x36);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x36);
    }
  }
	if(gBusFlag != 4)
	{
		if(gRss!=POS)
		{
			if(gRss==TIMEOUT)
			{
				if(gUDS_LanguageSet == 0)
				{
					snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x36");
				}
				else
				{
					snprintf(gDiagResultDescription,4000,"请求超时，控制器对36服务未回复响应");
				}
				Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
				return -1;
			}
			else
			{
				if(gUDS_LanguageSet == 0)
				{
					snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x36",gTpRxData[2]);
				}
				else
				{
					snprintf(gDiagResultDescription,4000,"ECU对36服务回复了负响应0x%02x",gTpRxData[2]);
				}
				Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
				return -1;
			}
		}
		if(gTpRxData[0]!=0x76)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x36",gTpRxData[0]);
