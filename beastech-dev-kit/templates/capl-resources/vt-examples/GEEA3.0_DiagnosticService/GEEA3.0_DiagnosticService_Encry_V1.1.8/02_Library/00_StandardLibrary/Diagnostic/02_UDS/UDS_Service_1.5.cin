				snprintf(gDiagResultDescription,4000,"ECU对36服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return 1;
		}
		if(gTpRxData[1]!=Counter)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Wrong block sequence counter 0x%02x",gTpRxData[1]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU响应了错误的Counter值",gTpRxData[1]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return 1;
		}
		if(2!=gTpRxLength)
		{
			if(gUDS_LanguageSet == 0)
			{
