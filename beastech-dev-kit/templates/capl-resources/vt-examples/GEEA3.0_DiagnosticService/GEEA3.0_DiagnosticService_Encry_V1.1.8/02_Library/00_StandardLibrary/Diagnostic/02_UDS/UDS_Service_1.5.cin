void SID2E_WriteDataByIdentifier(byte PID[],byte RawData[],enum AddressMode Mode)
{
	byte SID2E[4096];
	int  i;
	SID2E[0]=0x2E;
	SID2E[1]=PID[0];
	SID2E[2]=PID[1];
	for(i=0; i<elCount(RawData); i++)
		SID2E[i+3]=RawData[i];
	TP_Send(SID2E,elCount(RawData)+3,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID2E,elCount(RawData)+3);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID2E,elCount(RawData)+3);
		}
	}
}

