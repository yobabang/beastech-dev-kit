includes
{

}

variables
{
	/*
	*函数返回值说明
	1.请求发送函数：无返回值
	2.响应检查函数：int类型返回值
	函数执行成功 = 2
	函数执行失败，低风险 = 1
	函数执行失败，高风险 = -1

	*报告输出说明
	1.对于不做判断的打印内容，可通过参数gUDS_DescriptionExistFlag进行判断是否打印
	2.对于判断为Fail的打印内容，不可配置，必须打印在报告中
	3.对于判断为Pass的打印内容，可通过参数gUDS_DescriptionExistFlag进行判断是否打印
	4.打印时，统一使用“UDS”作为本文件输出的描述
	*/

	//文件输出设置参数
	int gUDS_DescriptionExistFlag = 1;
	int gUDS_LanguageSet = 0;//English = 0;Chinese = 1
	//文件输出设置参数

	//TimingParameters
//	int gUDS_P2Client = 150;
	int gUDS_P2ClientDelay = 5000;
	int gUDS_P6Client = 1000;
	int gUDS_P6ClientDelay = 5000;

	int gUDS_S3Client = 2000;
	int gUDS_S3Server = 5000;
	//TimingParameters

	int gRss;//用以表示收到响应的类型（肯定响应/否定响应/无响应)
	//enum AddressMode {physical,functional};
	enum e_SPRMIB {SPRMIB_TRUE=0x01,SPRMIB_FALSE=0x00};//用以区分肯定响应抑制位是否悬置
	//Service0x10
	enum e_DiagSession {DEFAULTSESSION=0x01,PROGRAMMINGSESSION=0x02,EXTENDEDSESSION=0x03,SAFETYSESSION=0x04,OTASESSION=0x40};//用以切换会话模式
	//Service0x11
	enum e_ResetType {HARDRESET=0x01,SOFTRESET=0x03};//用以区分复位类型
	//int gUnlockflag;
	//Service0x28
	enum e_CommunicationType {NormalCommunicationMessage=0x01,NetworkManagementMessage=0x02,NCMAndNMM=0x03};//用以区分报文类型
	//Service0x2A
	enum e_TransmissionMode {SendAtSlowRate=0x01,SendAtMediumRate=0x02,SendAtFastRate=0x03,StopSending=0x04};

	//Service0x2F
	enum e_InputOutputControlParameter {ReturnControlToECU=0x00,ResetToDefault=0x01,FreezeCurrentState=0x02,ShortTermAdjustment = 0x03};
	//Service0x31
	//enum e_RoutineStatusRecord {CorrectResult=0x00,IncerectResult=0x01};
	enum e_RoutineControlType {StartRoutine=0x01,StopRoutine=0x02,RequestRoutineResult=0x03};
	//Service0x3E

	//Service0x34
	dword gMaxNumberOfBlockLenth;
	//Service0x36
	int gCounter;
	//Service0x37
	int gTransferResponseParameterRecord;
}


void SetUDSDescriptionInReport(int ExistFlag)
{
	gUDS_DescriptionExistFlag = ExistFlag;
	if(gUDS_LanguageSet == 0)
	{
		if(ExistFlag == 1)
		{
			testStep("UDS","Open the description in test report");
		}
		else
		{
			testStep("UDS","Close the description in test report");
		}
	}
	else
	{
		if(ExistFlag == 1)
		{
			testStep("UDS","打开报告描述添加功能");
		}
		else
		{
			testStep("UDS","关闭报告描述添加功能");
		}
	}
}

void SetUDSLanguageInReport(int LanguageFlag)
{
	gUDS_LanguageSet = LanguageFlag;
	if(gUDS_LanguageSet == 0)
	{
		testStep("UDS","Set the report language to English");
	}
	else
	{
		testStep("UDS","设置报告语言为中文");
	}
}

void UDS_ParametersSet(dword P2C_APP,dword P2C_BOOT,dword P2CD,dword P6C,dword P6CD,dword S3C,dword S3S)
{
//	gUDS_P2Client = P2C;
	gUDS_P2ClientDelay = P2CD;
	gUDS_P6Client = P6C;
	gUDS_P6ClientDelay = P6CD;
	gUDS_S3Client = S3C;
	gUDS_S3Server = S3S;
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
//			testStep("UDS","Parameters configuration:\n  P2Client_APP is %dms\n P2Client_BOOT is %dms\n  P2*Client is %dms\n P4Client is %dms\n   P6Client is %dms\n   S3Client is %dms",gP2Client_APP,gP2Client_BOOT,gP2StarClient,gP4Client,gUDS_P6Client,gUDS_S3Client);
		}
		else
		{
//			testStep("UDS","参数设置:\n  P2Client_APP is %dms\n P2Client_BOOT is %dms\n  P2*Client = %dms\n  P4Client = %dms\n  P6Client = %dms\n S3Client = %dms ",gP2Client_APP,gP2Client_BOOT,gP2StarClient,gP4Client,gUDS_P6Client,gUDS_S3Client);
		}
	}
}



void SID10_DiagnosticSessionControl(int Subfunction,enum AddressMode Mode,enum e_SPRMIB Response)
{
	byte SID10[2];
	SID10[0]=0x10;
	if(Response==0)
		SID10[1]=Subfunction;
	else
		SID10[1]=Subfunction+0x80;

	TP_Send(SID10,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Send Request",SID10,elCount(SID10));
		}
		else
		{
			PrintPID("UDS","发送请求",SID10,elCount(SID10));
		}
	}
}

int CheckPosResponse_SID10(byte Subfunction,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x10);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x10);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x10);
    }
  }

	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service0x10");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对10服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
			return 1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x10",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对10服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
			return -1;
		}
	}

	if(gTpRxData[0]!=0x50)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x10",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对10服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
		return -1;
	}
	else if(gTpRxData[1]!=Subfunction)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect subfunction 0x%02x to the request of service 0x10",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对10服务回复了非预期的子功能0x%02x",gTpRxData[1]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
		return 1;
	}
	else if(gTpRxLength!=0x06)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU response lenth is wrong to the request of service 0x10");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对10服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}


int CheckPosResponse_SID10(byte Subfunction,int P2Server,int P2ServerDelay,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x10);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x10);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x10);
    }
  }

	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x10");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对10服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
			return 1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x10",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对10服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
			return -1;
		}
	}

	if(gTpRxData[0]!=0x50)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x10",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对10服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
		}
		else
		{
			PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
		return -1;
	}
	else if(gTpRxData[1]!=Subfunction)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect subfunction 0x%02x to the request of service 0x10",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对10服务回复了非预期的子功能0x%02x",gTpRxData[1]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
		return 1;
	}
	else if(gTpRxLength!=0x06)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU response lenth is wrong to the request of service 0x10");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对10服务回复了错误的长度");
		}
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
		}
		else
		{
			PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
		return 1;
	}
	else if((((gTpRxData[2]<<8)|gTpRxData[3])!=P2Server)||(((gTpRxData[4]<<8)|gTpRxData[5])!=P2ServerDelay))
	{
		if(((gTpRxData[2]<<8)|gTpRxData[3])!=P2Server)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU response parameter P2 is wrong to the request of service 0x10 , expect value is %d",P2Server);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对10服务响应的参数P2与期望值不一致，期望值为%dms",P2Server);
			}
		}
		if(((gTpRxData[4]<<8)|gTpRxData[5])!=P2ServerDelay)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU response parameter P2* is wrong to the request of service 0x10 , expect value is %d",P2ServerDelay);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对10服务响应的参数P2*与期望值不一致，期望值为%dms",P2ServerDelay*10);
			}
		}
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
		}
		else
		{
			PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
		}
    Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription,"UDS");
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

void SID11_ECUReset(int Subfunction,enum AddressMode Mode,enum e_SPRMIB Supress)
{
	byte SID11[2];
	SID11[0]=0x11;
	if(Supress==0)
		SID11[1]=Subfunction;
	else
		SID11[1]=Subfunction+0x80;

	TP_Send(SID11,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Send Request",SID11,elCount(SID11));
		}
		else
		{
			PrintPID("UDS","发送请求",SID11,elCount(SID11));
		}
	}
}

int CheckPosResponse_SID11(int Subfunction,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x11);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x11);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x11);
    }
  }

	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service0x11");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对11服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,2,RESULT_FAIL,gDiagResultDescription);
			return 0;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x11",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对11服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x51)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x11",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对11服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=Subfunction)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect subfunction 0x%02x to the request of service 0x11",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对11服务回复了非预期的子功能0x%02x",gTpRxData[1]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(0x02!=gTpRxLength)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU response lenth is wrong to the request of service 0x11");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对11服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

int CheckPosResponse_SID11(byte Subfunction,int powerDownTime,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x11);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x11);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x11);
    }
  }

	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service0x11");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对11服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,2,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x11",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对11服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x51)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x11",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对11服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(0x04!=Subfunction)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive subfunction 0x%02x to the request of service 0x11",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对11服务回复了非预期的子功能0x%02x",gTpRxData[1]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(0x03!=gTpRxLength)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU response lenth is wrong to the request of service 0x11");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对11服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(powerDownTime!=gTpRxData[2])
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU power down time is not correct");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU响应了错误的Power down time");
		}

		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}


void SID27_SecurityAccess_RequestSeed(int level,enum AddressMode Mode)
{
	byte SID27[2];
	int  i;
	int  SecurityLevel;

	SID27[0]=0x27;
	SID27[1]=level;
	SecurityLevel=level;
	TP_Send(SID27,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID27, elCount(SID27));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID27, elCount(SID27));
		}
	}
}

void SID27_SecurityAccess_SendKey(int level,byte KeyArray[],enum AddressMode Mode)
{
	byte SID27[34];
	int  k;
	long ActualSize[1];
	byte ChallengeByte[32];
	int  SecurityLevel;
  
  SID27[0] = 0x27;
  SID27[1] = level+1;
  
  memcpy(ChallengeByte,gSeedArray,gSeedLength);
  for(k=0;k<NumOfSecurityLv;k++)
  {
    if(SELevel[k].SElevel==level)
    {
      memcpy_off(ChallengeByte,gSeedLength,SELevel[k].SEconstant,0,gConstLength);
    }
  }
  for(k=0; k<gSeedLength+gConstLength; k++)
	{
		write("ChallengeByte[%d]:0x%02x",k,ChallengeByte[k]);
	}
  
	write("DLLName:%s",DLLName);
  if(AlgorithmVersion_3Seed == 1)
  {
    SKDLL_GenKeyEx(ChallengeByte,gSeedLength+gConstLength,1,"",KeyArray,gSeedLength,ActualSize,DLLName);
  }
  else
  {
    SeedParameter(ChallengeByte,gSeedLength+gConstLength,1);
    GenerateKeyExOpt(KeyArray,gSeedLength,DLLName);
  }
  testWaitForTimeout(5);
  for(k=0;k<gSeedLength;k++) { SID27[2+k]=KeyArray[k]; }
 
	TP_Send(SID27,gSeedLength+2,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID27, gSeedLength+2);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID27, gSeedLength+2);
		}
	}
}

int CheckPosResponse_SID27_ReqSeed(int level,byte SeedArray[],int ByteNumOfSeed,int reqGroup,int reqNum )
{
	int i;
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x27);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x27);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x27);
    }
  }
	if(gRss==POS)
		for(i=0; i<elcount(SeedArray); i++)
			SeedArray[i]=gTpRxData[i+2];
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x27");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对27服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x27",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对27服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x67)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x27",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对27服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=level)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect subfunction 0x%02x to the request of service 0x27",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对27服务回复了非预期的子功能0x%02x",gTpRxData[1]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxLength!=ByteNumOfSeed+2)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x27");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对27服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

