void SID29_Authentication_verifyCertificateUnidirectional(byte communicationConfiguration,word lengthOfCertificateClient,byte certificateClient[],word lengthOfChallengeClient,enum AddressMode Mode)
{
	byte SID29[2048];
	int  i;
	SID29[0]=0x29;
  SID29[1]=0x01;
  SID29[2]=communicationConfiguration;
  SID29[3]=lengthOfCertificateClient>>8;
  SID29[4]=lengthOfCertificateClient;
	for(i=0; i<lengthOfCertificateClient; i++)
  {
 		SID29[i+5]=certificateClient[i];
//    Teststep("","SID29[%d+5]=%x",i,certificateClient[i]);
  }

  testWaitForTimeout(1);
  SID29[i+5]=0;
  SID29[i+6]=0;


//  write("=================%x",SID29[i+5]);
//  write("=================%x",SID29[i+6]);
//  write("=================%x",SID29[i+7]);
//  PrintPID("UDS","Cert: ",certificateClient,lengthOfCertificateClient);
	TP_Send(SID29,lengthOfCertificateClient+7,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID29,lengthOfCertificateClient+7);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID29,lengthOfCertificateClient+7);
		}
	}
}

int CheckPosResponse_SID29_verifyCertificateUnidirectional(byte authenticationReturnParameter,word lengthOfChallengeServer,byte challengeServer[],word lengthOfEphemeralPublicKeyServer,int reqGroup,int reqNum)
{
  int i=0;

	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x29);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x29);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x29);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x29");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对29服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x29",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对29服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x69)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x29",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对29服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if((7+lengthOfChallengeServer)!=gTpRxLength)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x29");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对29服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
    if(gTpRxData[1]!=1)
    {
      TeststepFail("Fail","Dut response subfunction error,expect:%x,real:%x",1,gTpRxData[1]);
    }
    if(gTpRxData[2]!=authenticationReturnParameter)
    {
      TeststepFail("Fail","Dut response authenticationReturnParameter error,expect:%x,real:%x",authenticationReturnParameter,gTpRxData[2]);
    }
    if(((gTpRxData[3]>>8)+gTpRxData[4]) !=lengthOfChallengeServer)
    {
      TeststepFail("Fail","Dut response lengthOfChallengeServer error,expect:%x,real:%x",lengthOfChallengeServer,((gTpRxData[3]>>8)+gTpRxData[4]));
    }
    for(i=0;i<lengthOfChallengeServer;i++)
    {
      challengeServer[i]=gTpRxData[5+i];
    }
		}
		return 2;
	}
}
void SID29_Authentication_proofOfOwnership(word lengthOfProofOfOwnershipClient,byte proofOfOwnershipClient[],word lengthOfEphemeralPublicKeyClient,enum AddressMode Mode)
{
	byte SID29[2048];
	int  i;
	SID29[0]=0x29;
  SID29[1]=0x03;
  SID29[2]=lengthOfProofOfOwnershipClient>>8;
  SID29[3]=lengthOfProofOfOwnershipClient;
	for(i=0; i<lengthOfProofOfOwnershipClient; i++)
		SID29[i+4]=proofOfOwnershipClient[i];
