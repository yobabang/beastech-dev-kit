int CheckNotNegResponse(int exceptNRC,int reqGroup,int reqNum)
{
  if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x29);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x29);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x29);
    }
  }
  
	if(gRss!=NEG)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout No Response Received!");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"超时无响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return 1;
		}
		else
		{
      if(gUDS_DescriptionExistFlag == 1)
  		{
  			if(gUDS_LanguageSet == 0)
  			{
  				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
  			}
  			else
  			{
  				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
  			}
  		}
  		return 2;
		}
	}
	if(exceptNRC == gTpRxData[2])
	{
		PrintPID("Chk","Neg.Response: ",gTpRxData,gTpRxLength);
		testStepFail("Chk","Doesn't Expect NegativeResponseCode 0x%2x",gTpRxData[2]);
    if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"Doesn't Expect NegativeResponseCode 0x%2X",gTpRxData[2]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"非预期的否定响应0x%02X",gTpRxData[2]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
    return 1;
	}
  else 
  {
    if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","否定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
  }
  return 2;
}

