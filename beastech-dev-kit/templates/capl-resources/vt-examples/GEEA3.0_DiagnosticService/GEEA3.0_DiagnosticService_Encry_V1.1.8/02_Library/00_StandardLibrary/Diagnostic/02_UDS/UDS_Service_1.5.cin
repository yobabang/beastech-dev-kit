    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x19);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x19");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对19服务未回复响应");
			}
			testStepFail("CHK",gDiagResultDescription);
			return -1;
		}
		else
		{
      PrintPID("UDS","Response",gTpRxData,gTpRxLength);
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x19",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对19服务回复了负响应0x%02x",gTpRxData[2]);
			}
			testStepFail("CHK",gDiagResultDescription);
			return -1;
		}
	}
  PrintPID("UDS","Response",gTpRxData,gTpRxLength);
	if(gTpRxData[0]!=0x59)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x19",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对19服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		testStepFail("CHK",gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=0x55)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect subfunction 0x%02x to the request of service 0x19",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对19服务回复了非预期的子功能0x%02x",gTpRxData[1]);
		}
		testStepFail("CHK",gDiagResultDescription);
		return 1;
	}
  
  if(gTpRxData[2]!=group)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect FunctionalGroupIdentifier 0x%02x to the request of service 0x19",gTpRxData[2]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对19服务响应了非预期的有效FunctionalGroupIdentifier%02x",gTpRxData[2]);
		}
		testStepFail("CHK",gDiagResultDescription);
		return 1;
	}
  
	if(gTpRxData[3]!=AvaliableMask)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect Avaliable Mask 0x%02x to the request of service 0x19",gTpRxData[2]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对19服务响应了非预期的有效掩码%02x",gTpRxData[2]);
		}
		testStepFail("CHK",gDiagResultDescription);
		return 1;
	}
  
  if(gTpRxData[4]!=0x04 && gTpRxData[4]!=0x02)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect DTCFormatIdentifier 0x%02x to the request of service 0x19",gTpRxData[2]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对19服务响应了非预期的有效DTCFormatIdentifier %02x",gTpRxData[2]);
		}
		testStepFail("CHK",gDiagResultDescription);
		return 1;
	}
  teststep("","gTpRxLength=%d",gTpRxLength);
	if((gTpRxLength-5)%4 != 0)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x19");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对19服务回复了错误的长度");
		}
		testStepFail("CHK",gDiagResultDescription);
		return 1;
	}
	else
	{
