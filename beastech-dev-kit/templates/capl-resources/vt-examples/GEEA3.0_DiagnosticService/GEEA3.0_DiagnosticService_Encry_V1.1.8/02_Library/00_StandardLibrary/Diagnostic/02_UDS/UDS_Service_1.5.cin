int CheckPosResponse_SID22(byte PID[],int ExpectLength,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x22);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x22);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x22);
    }
  }

	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives no response to supported DID %02x %02x of service 22",PID[0],PID[1]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对22服务如下DID未回复响应 ：%02x %02x",PID[0],PID[1]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x22",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"控制器对22服务如下DID回复了负响应%02x ：%02x %02x",gTpRxData[2],PID[0],PID[1]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x62)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x22",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对22服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=PID[0] || gTpRxData[2]!=PID[1])
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives posotive response, but the response DID is wrong");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对22服务回复了错误的DID");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(ExpectLength!=gTpRxLength-3)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x22");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对22服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

int CheckPosResponse_SID22(long PID,int ExpectLength,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x22);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x22);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x22);
    }
  }

	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives no response to supported DID 0x%04X of service 22",PID);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对22服务如下DID未回复响应 ：0x%04X",PID);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x22",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"控制器对22服务如下DID回复了负响应%02x ：0x%04X",gTpRxData[2],PID);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x62)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x22",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对22服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if((gTpRxData[1]!=PID>>8) || (gTpRxData[2]!=PID&0xFF))
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives posotive response, but the response DID is wrong");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对22服务回复了错误的DID");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(ExpectLength!=gTpRxLength-3)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x22");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对22服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

