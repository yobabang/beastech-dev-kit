int CheckNonResponse(int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x00);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x00);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x00);
    }
  }
	if(gRss!=TIMEOUT)
	{
		if(gRss==NEG)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Expect No response received but get Neg.Response 0x%02x",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"期望无响应但得到了否定响应 0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return 1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Expect No response received but get Pos.Response 0x%02x",gTpRxData[0]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"期望无响应但的到了肯定响应 0x%02x",gTpRxData[0]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return 0;
		}
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				testStep("UDS_Ser","No Response ");
			}
			else
			{
				testStep("UDS","无响应");
			}
		}
		return 2;
	}
}

