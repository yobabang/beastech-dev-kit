Void SID38_RequestFileTransfer(int modeOfOperation,byte filePathAndNameLength[],int filePathAndName,int dataFormatIdentifier,byte fileSizeparameterLength[],byte fileSizeUncompressed[],byte filesizeCompressed[],enum AddressMode Mode)
{
	byte SID38[12];
	SID38[0]  = 0x38;
	SID38[1]  = modeOfOperation;
	SID38[2]  = filePathAndNameLength[0];
	SID38[3]  = filePathAndNameLength[1];
	SID38[4]  = filePathAndName;
	SID38[5]  = dataFormatIdentifier;
	SID38[6]  = fileSizeparameterLength[0];
	SID38[7]  = fileSizeparameterLength[1];
	SID38[8]  = fileSizeUncompressed[0];
	SID38[9]  = fileSizeUncompressed[1];
	SID38[10] = filesizeCompressed[0];
	SID38[11] = filesizeCompressed[1];
	TP_Send(SID38,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID38,elCount(SID38));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID38,elCount(SID38));
		}
	}
}

