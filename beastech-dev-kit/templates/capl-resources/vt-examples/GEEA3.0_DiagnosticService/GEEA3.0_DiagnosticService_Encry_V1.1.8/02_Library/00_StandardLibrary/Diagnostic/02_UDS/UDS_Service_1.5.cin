void SID28_CommunicationControl(byte Subfunction,enum e_CommunicationType CommType,enum AddressMode Mode,enum e_SPRMIB Supress)
{
	byte SID28[3];
	SID28[0]=0x28;
	if(Supress==0)
		SID28[1]=Subfunction;
	else
		SID28[1]=Subfunction+0x80;
	SID28[2]=CommType;
	TP_Send(SID28,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID28,elCount(SID28));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID28,elCount(SID28));
		}
	}
}
void SID28_CommunicationControl(byte Subfunction,byte CommType,enum AddressMode Mode,enum e_SPRMIB Supress)
{
	byte SID28[3];
	SID28[0]=0x28;
	if(Supress==0)
		SID28[1]=Subfunction;
	else
		SID28[1]=Subfunction+0x80;
	SID28[2]=CommType;
	TP_Send(SID28,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID28,elCount(SID28));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID28,elCount(SID28));
		}
	}
}

void SID28_CommunicationControl(byte Subfunction,enum e_CommunicationType CommType, byte NodeIdentificationNumber[],enum AddressMode Mode,enum e_SPRMIB Supress)
{
	byte SID28[5];
	SID28[0]=0x28;
	if(Supress==0)
		SID28[1]=Subfunction;
	else
		SID28[1]=Subfunction+0x80;
  SID28[2]=CommType;
	SID28[3]=NodeIdentificationNumber[0];
  SID28[4]=NodeIdentificationNumber[1];
  
	TP_Send(SID28,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID28,elCount(SID28));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID28,elCount(SID28));
		}
	}
}

