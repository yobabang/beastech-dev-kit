int CheckPosResponse_SID22(byte PID[])
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x22);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x22);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x22);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				TestStep("UDS","ECU gives no response to supported DID %02x %02x of service 22",PID[0],PID[1]);
			}
			else
			{
				TestStep("UDS","请求超时，控制器对22服务如下DID未回复响应 ：%02x %02x",PID[0],PID[1]);
			}
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				TestStep("UDS","ECU gives negative response 0x%02x to the request of service 0x22",gTpRxData[2]);
			}
			else
			{
				TestStep("UDS","控制器对22服务如下DID回复了负响应%02x ：%02x %02x",gTpRxData[2],PID[0],PID[1]);
			}
			return -1;
		}
	}
	if(gTpRxData[0]!=0x62)
	{
		if(gUDS_LanguageSet == 0)
		{
			TestStep("UDS","ECU gives unexpect positive response service ID 0x%02x to the request of service 0x22",gTpRxData[0]);
		}
		else
		{
			TestStep("UDS","ECU对22服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		return 1;
	}
	if(gTpRxData[1]!=PID[0] || gTpRxData[2]!=PID[1])
	{
		if(gUDS_LanguageSet == 0)
		{
			TestStep("UDS","ECU gives posotive response, but the response DID is wrong");
		}
		else
		{
			TestStep("UDS","ECU对22服务回复了错误的DID");
		}
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				TestStep("UDS","Pos.Response");
			}
			else
			{
				TestStep("UDS","肯定响应");
			}
		}
		return 2;
	}
}

Void SID23_ReadMemoryByAdress(byte addressAndLengthFormatIdentifier,byte MemoryAddress[],byte MemorySize[],enum AddressMode Mode)
{
	int i,length;
	byte SID23[15];
	int  LenthOfADD;
	int  LenthOfSize;
	SID23[0]=0x23;
	SID23[1]=addressAndLengthFormatIdentifier;
	LenthOfSize=addressAndLengthFormatIdentifier>>4;
	LenthOfADD=addressAndLengthFormatIdentifier&0x0F;
	for(i=0; i<LenthOfADD; i++)
		SID23[i+2]=MemoryAddress[i];
	for(i=0; i<LenthOfSize; i++)
		SID23[i+2+LenthOfADD]=MemorySize[i];
	TP_Send(SID23,LenthOfADD+LenthOfSize+2,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID23,LenthOfADD+LenthOfSize+2);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID23,LenthOfADD+LenthOfSize+2);
		}
	}
}

int CheckPosResponse_SID23(int ExpectLength,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x23);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x23);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x23);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x23");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对23服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x23",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对23服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x63)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x23",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对23服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else if(ExpectLength!=gTpRxLength-1)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x23");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对23服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

