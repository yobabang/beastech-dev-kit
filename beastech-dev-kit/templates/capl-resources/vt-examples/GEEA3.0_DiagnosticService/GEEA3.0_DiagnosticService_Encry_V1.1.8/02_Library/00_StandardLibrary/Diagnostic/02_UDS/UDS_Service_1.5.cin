int CheckPosResponse(byte SID,int ExpectLength,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,SID);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,SID);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,SID);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service %02x",SID);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对%02x服务未回复响应",SID);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service %02x",gTpRxData[2],SID);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对%02x服务回复了负响应0x%02x",SID,gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=(SID+0x40))
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service %02x",gTpRxData[0],SID);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对%02x服务回复了非预期的肯定响应0x%02x",SID,gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(ExpectLength!=gTpRxLength)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service %02x",SID);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对%02x服务回复了错误的长度",SID);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}


