				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x19",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对19服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
