		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x3E",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对3E服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x7E)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x3E",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对3E服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else if(gTpRxLength!=2)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x3E");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对3E服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

void SID85_ControlDTCSetting(byte Subfunction,char DTC[],enum AddressMode Mode,enum e_SPRMIB Supress)
{
	byte SID85[10];
	int  i;

	SID85[0]=0x85;
	if(Supress==0)
		SID85[1]=Subfunction;
	else
		SID85[1]=Subfunction+0x80;
	for(i=0; i<elCount(DTC); i++)
		SID85[i+2]=DTC[i];
	TP_Send(SID85,elCount(DTC),Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID85,elCount(SID85));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID85,elCount(SID85));
		}
	}
}

void SID85_ControlDTCSetting(byte Subfunction,enum AddressMode Mode,enum e_SPRMIB Supress)
{
	byte SID85[2];
	SID85[0]=0x85;
	if(Supress==0)
		SID85[1]=Subfunction;
	else
		SID85[1]=Subfunction+0x80;
	TP_Send(SID85,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID85,elCount(SID85));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID85,elCount(SID85));
		}
	}
}

