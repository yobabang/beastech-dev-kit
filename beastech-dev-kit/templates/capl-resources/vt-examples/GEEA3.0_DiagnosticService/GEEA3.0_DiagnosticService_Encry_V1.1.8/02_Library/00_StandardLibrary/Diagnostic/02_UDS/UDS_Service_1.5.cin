		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[2]!=AvaliableMask)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect Avaliable Mask 0x%02x to the request of service 0x19",gTpRxData[2]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对19服务响应了非预期的有效掩码%02x",gTpRxData[2]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[3]!=DTCFormatIdentifer)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect DTC format identifer 0x%02x to the request of service 0x19",gTpRxData[3]);
