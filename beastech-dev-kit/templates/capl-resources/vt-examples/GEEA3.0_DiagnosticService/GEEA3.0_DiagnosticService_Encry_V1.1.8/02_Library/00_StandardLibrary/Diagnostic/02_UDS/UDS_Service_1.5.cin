int CheckPosResponse_SID2F(byte inputOutputControlParameter,byte PID[],int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x2F);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x2F);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x2F);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x2F");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对2F服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x2F",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对2F服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x6F)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x2F",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对2F服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=PID[0] &&gTpRxData[2]!=PID[1])
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives posotive response, but the response DID is wrong");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对2F服务回复了错误的DID");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[3]!=inputOutputControlParameter)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives posotive response, but the response DID is wrong");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对2F服务回复了错误的inputOutputControlParameter");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

