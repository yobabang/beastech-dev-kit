void SID31_RoutineControl(enum e_RoutineControlType RoutineType,byte RoutineIdentifier[],byte RoutineControlOptionRecord[],int RecordLenth,enum AddressMode Mode,enum e_SPRMIB Supress)
{
	int i,length;
	byte SID31[1000];
	SID31[0]=0x31;
  if(Supress==0)
		SID31[1]=RoutineType;
	else
		SID31[1]=RoutineType+0x80;

	SID31[2]=RoutineIdentifier[0];
	SID31[3]=RoutineIdentifier[1];
	for(i=0; i<RecordLenth; i++)
	{
		SID31[i+4]=RoutineControlOptionRecord[i];
	}
	length=4+RecordLenth;
	TP_Send(SID31,length,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
      if(length<30)
      {
			  PrintPID("UDS","Request ",SID31,length);
      }
      else
      {
        PrintPID("UDS","Request ",SID31,30);
      }
		}
		else
		{
      if(length<30)
      {
			  PrintPID("UDS","发送请求 ",SID31,length);
      }
      else
      {
			  PrintPID("UDS","发送请求 ",SID31,30);
      }
		}
	}
}

