int CheckPosOrNegResponse(int expectNRC,int reqGroup,int reqNum)
{
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x00);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x00);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x00);
    }
  }
	if(gRss!=NEG)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Expect Nr.Response 0x%02X but Timeout no response recived",expectNRC);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"期望否定响应 0x%02X 但控制器未回复响应",expectNRC);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Expect Nr.Response 0x%02x or Pos.Response, get Pos.Response 0x%02x",expectNRC,gTpRxData[0]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"期望否定响应 0x%02x 或者正响应， 但得到了肯定响应 0x%02x",expectNRC,gTpRxData[0]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_PASS,gDiagResultDescription);
			return 2;
		}
	}
	if(expectNRC != gTpRxData[2])
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"Expect Nr.Response 0x%02x but get Nr.Response 0x%02x",expectNRC,gTpRxData[2]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"期望否定响应 0x%02x 但得到了否定响应 0x%02x",expectNRC,gTpRxData[2]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS_Ser","Neg.Response: ",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","否定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}

