void SID34_RequestDownload(int dataFormatIdentifier,byte addressAndLengthFormatIdentifier,byte memoryaddress[],byte memorysize[],enum AddressMode Mode)
{
	byte SID34[11];
	int  i,Size,Address;
	SID34[0]  = 0x34;
	SID34[1]  = dataFormatIdentifier;
	SID34[2]  = addressAndLengthFormatIdentifier;
	Size=addressAndLengthFormatIdentifier>>4;
	Address=addressAndLengthFormatIdentifier&0x0F;
	/////MemoryAddress//////
	for(i=0; i<Address; i++)
		SID34[i+3]  = memoryaddress[i];
	/////MemorySize/////////
	for(i=0; i<Size; i++)
		SID34[i+3+Address]  = memorysize[i];
	TP_Send(SID34,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID34,elCount(SID34));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID34,elCount(SID34));
		}
	}
}


int CheckPosResponse_SID34_RequestDownload(byte lengthFormatIdentifier,int reqGroup,int reqNum)
{
	int MaxNumberOfBlockLenth;
  int tempLength,j;
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x34);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x34);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x34);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x34");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对34服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x34",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对34服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x74)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x34",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对34服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=lengthFormatIdentifier)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lengthFormatIdentifier 0x%02x in the request of service 0x34",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对34服务响应了错误的lengthFormatIdentifier",gTpRxData[1]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
  tempLength = gTpRxData[1]>>4;
	if((tempLength + 2)!=gTpRxLength)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x34");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对34服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
    gMaxNumberOfBlockLenth = 0;
    for(j=0;j<tempLength;j++)
    {
      gMaxNumberOfBlockLenth = gMaxNumberOfBlockLenth + (gTpRxData[j+2]<<(8*(tempLength-1-j)));
    }
		gMaxNumberOfBlockLenth = gMaxNumberOfBlockLenth - 2;
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}


