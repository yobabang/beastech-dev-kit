void SID36_TransferData(byte Data[],long length,int Counter,enum AddressMode Mode)
{
	byte SID36[65536];
	dword n;
	SID36[0]=0x36;
	SID36[1]=Counter;
	//testStep("Chk 0x36","Transfer data. Send Counter=%d,SID36[1]=%d",Counter,SID36[1]);
	for(n=0; n<length; n++)
	{
		SID36[n+2]=Data[n];
	}

	if(gBusFlag != 4)
	{
		TP_Send(SID36,length+2,Mode);
	}

	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID36,20);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID36,20);
		}
	}
}

void SID36_TransferData(int Counter,enum AddressMode Mode)
{
	byte SID36[2];
	SID36[0]=0x36;
	SID36[1]=Counter;
	TP_Send(SID36,2,Mode);
	//writeLineEx(4,1,"%s-%f: Send $36 data",timeBuf,(timeNow()/100000.0));
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID36,elCount(SID36));
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID36,elCount(SID36));
		}
	}
}

