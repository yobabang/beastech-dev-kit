			snprintf(gDiagResultDescription,4000,"ECU对31服务回复了错误的例程类型");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if((gTpRxData[2]!=RoutineIdentifier[0]) || (gTpRxData[3]!=RoutineIdentifier[1]))
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives posotive response, but the response RoutineIdentifer is wrong");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对31服务回复了错误的例程标识符");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}


	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
		}
		else
		{
			PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
		}
	}
	return 2;

}

int CheckPosResponse_SID31(enum e_RoutineControlType RoutineType,byte RoutineIdentifier[],byte RoutineControlOptionRecord[],int RecordLenth,int reqGroup,int reqNum)
{
	int i;
	if((gBusFlag == 1)||(gBusFlag == 2)||(gBusFlag == 3)||(gBusFlag == 4)||(gBusFlag == 5))
  {
    if(SessionFlag==APP)
    {
      gRss=ECU_Response(gP2Client_APP,0x31);
    }
    else if(SessionFlag==BOOT)
    {
      gRss=ECU_Response(gP2Client_BOOT,0x31);
    }
    else
    {
       gRss=ECU_Response(gP2Client_APP,0x31);
    }
  }
	if(gRss!=POS)
	{
		if(gRss==TIMEOUT)
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"Timeout no response recived when request service 0x31");
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"请求超时，控制器对31服务未回复响应");
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
		else
		{
			if(gUDS_LanguageSet == 0)
			{
				snprintf(gDiagResultDescription,4000,"ECU gives negative response 0x%02x to the request of service 0x31",gTpRxData[2]);
			}
			else
			{
				snprintf(gDiagResultDescription,4000,"ECU对31服务回复了负响应0x%02x",gTpRxData[2]);
			}
			Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
			return -1;
		}
	}
	if(gTpRxData[0]!=0x71)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect positive response service ID 0x%02x to the request of service 0x31",gTpRxData[0]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对31服务回复了非预期的肯定响应0x%02x",gTpRxData[0]);
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(gTpRxData[1]!=RoutineType)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpected routine type 0x%02x to the service 0x31",gTpRxData[1]);
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对31服务回复了错误的例程类型");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if((gTpRxData[2]!=RoutineIdentifier[0]) || (gTpRxData[3]!=RoutineIdentifier[1]))
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives posotive response, but the response RoutineIdentifer is wrong");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对31服务回复了错误的例程标识符");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	if(RecordLenth+4!=gTpRxLength)
	{
		if(gUDS_LanguageSet == 0)
		{
			snprintf(gDiagResultDescription,4000,"ECU gives unexpect lenth to the request of service 0x31");
		}
		else
		{
			snprintf(gDiagResultDescription,4000,"ECU对31服务回复了错误的长度");
		}
		Diag_SetReqCheckResult(reqGroup,reqNum,RESULT_FAIL,gDiagResultDescription);
		return 1;
	}
	else
	{
		for(i=0; i<RecordLenth; i++)
		{
			RoutineControlOptionRecord[i] = gTpRxData[i+4];
		}
		if(gUDS_DescriptionExistFlag == 1)
		{
			if(gUDS_LanguageSet == 0)
			{
				PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
			}
			else
			{
				PrintPID("UDS","肯定响应",gTpRxData,gTpRxLength);
			}
		}
		return 2;
	}
}



void SID3D_WriteMemoryByAdress_14(byte MemoryAddress[],byte MemorySize[],byte dataRecord[],enum AddressMode Mode)
{
	int i,length;
	byte SID3D[100];
	SID3D[0]=0x3D;
	SID3D[1]=0x14;
	SID3D[2]=MemoryAddress[0];
	SID3D[3]=MemoryAddress[1];
	SID3D[4]=MemoryAddress[2];
	SID3D[5]=MemoryAddress[3];
	SID3D[6]=MemorySize[0];
	for(i=0; i<elcount(dataRecord); i++)
	{
		SID3D[i+7]=dataRecord[i];
	}
	length=7+elCount(dataRecord);

	TP_Send(SID3D,length,Mode);
	if(gUDS_DescriptionExistFlag == 1)
	{
		if(gUDS_LanguageSet == 0)
		{
			PrintPID("UDS","Request ",SID3D,length);
		}
		else
		{
			PrintPID("UDS","发送请求 ",SID3D,length);
		}
	}
}

