variables
{
  message CAN1.0x53E NMMessage = {dlc=8,byte(0)=0x3E,byte(1)=0x40,byte(2)=0xFF,byte(3)=0xFF,byte(4)=0xFF,byte(5)=0xFF,byte(6)=0xFF,byte(7)=0xFF};
  message CAN1.0x53E NMMessage_Repeat = {dlc=8,byte(0)=0x3E,byte(1)=0x41,byte(2)=0xFF,byte(3)=0xFF,byte(4)=0xFF,byte(5)=0xFF,byte(6)=0xFF,byte(7)=0xFF};
  msTimer NMMes;
}

on timer NMMes
{
  output(NMMessage);
}
on preStop
{
  reportParsing();
}
