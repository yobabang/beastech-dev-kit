void Precondition()
{
  ResetStepIndex();//重置测试步骤的step编号
  
	testStep("Pre","Verify the current session is default session");
  testWaitForTimeout(100);
	SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
	CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
//////  testWaitForTimeout(ECUIniTime+3000);
  testWaitForTimeout(TestStepIntervalTime);
  CheckCurrentSession(0x01,PHYSICAL,0,0); 
	
  testWaitForTimeout(1000);
  
  TP_TesterPresentSet(TP_ON);
  
  testWaitForTimeout(1000);
}

void PostCondition()
{
  testStep("","");
  testWaitForTimeout(TestStepIntervalTime);
  testStep("Post","Verify the current session is default session");
  
	SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
	CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  if(SessionFlag == BOOT) { ECUinitHandle(0); SessionFlag = APP; }
  
  testWaitForTimeout(ECUIniTime);
  CheckCurrentSession(0x01,PHYSICAL,0,0); 
  
  TP_TesterPresentSet(TP_OFF);
  stopLogging();
}
void WakeupECU(enum T_mode sw)
{
  if(gBusFlag != 3)
  {
    if(sw==T_on)
    {
      setTimerCyclic(NMMes,20);
      testWaitForTimeout(1000);
      
      cancelTimer(NMMes);
      
      setTimerCyclic(NMMes,1000);
    }
    else
    {
      cancelTimer(NMMes);
    } 
  }
}
