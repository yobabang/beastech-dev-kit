  stop();
}

void reportParsing()
{
  char ReportPath[1500];
  char AbsPath[1500];
  char ToolPath[3000];
  
  getAbsFilePath("",AbsPath,1500);
  snprintf(ToolPath,1500,"%s02_Library\\00_StandardLibrary\\Common\\main.exe",AbsPath);
  snprintf(ReportPath,1500,"%s.html",reportName);
  
  sysExec(ToolPath,ReportPath);
}
