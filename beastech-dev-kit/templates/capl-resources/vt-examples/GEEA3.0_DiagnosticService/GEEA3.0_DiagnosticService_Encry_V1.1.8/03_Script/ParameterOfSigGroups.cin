  struct e2eSignal
  {
    char sigName[100];//信号名称
    int sigLength;//长度
    int startBit;//起始位
    qword sigValue;//初始值
    long sigUsed;//测试用途标识
    int sigValue_Fulfilled;//满足要求的值
    int sigValue_NotFulfilled;//不满足要求的值
  };
  
  struct EthPacketInfo
  {
    char srcMac[20];//arxml无此信息
    char dstMac[20];//arxml无此信息
    char srcIp[20];
    char dstIp[20];
    word srcPort;
    word dstPort;
    word vid;
    byte ttl;//SWRS需求组播TTL为1
  };

  struct e2eSigGroup
  {
    char sigGroupName[100];//信号组名称
    int dataId;//data id 信息
    int E2ELength; //数据长度
    int uBit;// update bit
    int ubValue;//默认值1
    int sigNum;//信号个数
    int pduStartBit;//
    struct e2eSignal e2eSignalList[100];
    int aliveCnt;
    int chks;
    int cntErrFlg;
    int chksErrFlg;
    byte nrc;
  };
  struct e2eFrame
  {
    char frName[100];//帧名
    char cluster[100];//组
    char busType[100];//总线类型
    int fdFlg;//是否为CAN FD
