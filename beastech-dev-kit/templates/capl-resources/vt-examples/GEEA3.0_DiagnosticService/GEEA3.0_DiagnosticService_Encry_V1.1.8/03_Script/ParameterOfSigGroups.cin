    int msgCyc;//信号帧发送周期
    dword msgDataLgth;//信号帧长度
    struct e2eSigGroup e2eSigGroupList[100];//信号组的结构体
    int simFrFlg;
    int simFrImtFlg;
    struct EthPacketInfo ethInfo; 
  };

