/// <PBL_GeneralTest>
testcase Unsupported_Diagnostic_Service_Test_Physical_ProgrammingSession()
{
  int i,j;
  byte TestSD_service[1]= {0x00};
  byte ExpectNRC[2]={0x11,0x7F};
  int Flag;
  int StartService;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351027_Unsupported_Diagnostic_Service_Test_Physical_ProgrammingSession",400);
  testCaseDescription("To ensure that no other services is implemented than those in configured list.");
  testCaseTitle("1351027","Unsupported_Diagnostic_Service_Test_Physical_ProgrammingSession");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  if(Flag_OBDNode == 1)
    StartService = 0x10;
  else
    StartService = 0x00;
  
  for(i=StartService; i<=0xFF; i++)
  {
    Flag = 0;
    
    if(i==0x10)
    {
      TestStep("Let SV=%02x",StartService);
    }
    else
    {
      TestStep("If SV<0xFF add 1 to SV and jump to Step 2",TestStepIntervalTime,2);
    }
    TestStep("If SV equals a service from configured list jump to Step 4",TestStepIntervalTime,4);
    for(j=0;j<service_PBL_Num;j++)
    {
      if(service_PBL[j] == i)
        Flag = 1;
    }
    if(Flag == 1)
      continue;
    TestStep("Request unsupported service",TestStepIntervalTime);
    TestSD_service[0]=i;
    TPSendRawMessage(TestSD_service,PHYSICAL);
    CheckNegResponse(ExpectNRC,0,0,0,0);
    testWaitForTimeout(100);
  }
  TestStep("Verify ProgrammmingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
