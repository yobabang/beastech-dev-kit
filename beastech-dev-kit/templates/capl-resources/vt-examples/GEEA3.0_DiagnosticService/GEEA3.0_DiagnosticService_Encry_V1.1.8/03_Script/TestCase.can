//          {
//            tem2 = answer[g+1]- 0x57;
//          }
//          
//          Para[g/2] = (tem1<<4)+tem2;
//        }
//      }
    }
    
    if(IODID[i].SecuLevel!=0xFF)
      {
        
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(IODID[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(IODID[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(IODID[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(IODID[i].SecuLevel,0,0);
      
      }
//
    if(IODID[i].Flag_Ser03==1)
    {
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,ControlOptionRecord,0,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
      
      TestStep("Short term adjustment",TestStepIntervalTime);
      SID2F_IOControl(PID,0x03,ControlOptionRecord,NumOfLenth,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x03,PID,0,0);
      
      TestStep("Short term adjustment",TestStepIntervalTime);
      SID2F_IOControl(PID,0x03,ControlOptionRecord,NumOfLenth,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x03,PID,0,0);
      
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,ControlOptionRecord,0,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
    }
    
    if(IODID[i].Flag_Ser02==1)
    {
      TestStep("freeze current state",TestStepIntervalTime);
      SID2F_IOControl(PID,0x02,ControlOptionRecord,0,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x02,PID,0,0);
      
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,ControlOptionRecord,0,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
    }
  }

  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
//2F
  
  
//31
  for(i=0;i<NumOfRoutine_Sub0x01;i++)//遍历所有例程
  {
    if(Routine_Sub0x01[i].AuthenticationFlag != 1)
    {
      continue;
    }
    if(Routine_Sub0x01[i].Flag_Ser03 != 1)
    {
      continue;
    }
    if(Routine_Sub0x01[i].routinetype == 1)//筛选所有例程类型为1的例程
    {
      tem1 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }  
      }
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      if( (gRss==NEG) && (gTpRxData[2]==0x22))
      {
        TestStepWarning("warning","Received NRC0x22 for Service 0x31,test next RID");
        continue;
      }
      testWaitForTimeout(2000);
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem1 == 1)
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      }
      
    }
    else if(Routine_Sub0x01[i].routinetype == 2)//筛选所有例程类型为2的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }

      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);

      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);
  
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x22)
      {
        TestStepWarning("Chk","No 0x22 maybe routine has finished executing");
      }
      testWaitForTimeout(Routine_Sub0x01[i].runtime+10);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }

      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
      }
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
    }
    else if(Routine_Sub0x01[i].routinetype == 3)//筛选所有例程类型为3的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }
      } 
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x32)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem1 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }     
    }
  }
  
  TestStep("Transition from defaultSession(0x01) to programmingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
