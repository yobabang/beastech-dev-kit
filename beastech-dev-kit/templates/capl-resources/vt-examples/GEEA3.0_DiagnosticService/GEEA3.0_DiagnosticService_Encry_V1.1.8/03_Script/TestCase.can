    CheckCommunication(DENONE,0);
    TestStep(":");
    SID28_CommunicationControl(SFOf28[0],NCMAndNMM,FUNCTIONAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[0],0,0);
    CheckCommunication(DENONE,0);
    TestStep(":");
    SID28_CommunicationControl(SFOf28[1],NormalCommunicationMessage,FUNCTIONAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[1],0,0);
    CheckCommunication(DEAPP,0);
    TestStep(":");
    SID28_CommunicationControl(SFOf28[3],NCMAndNMM,FUNCTIONAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[3],0,0);
    CheckCommunication(DEAPP,0);
    TestStep(":");
    SID28_CommunicationControl(SFOf28[2],NormalCommunicationMessage,FUNCTIONAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[2],0,0);
    CheckCommunication(DENONE,0);
    TestStep(":");
    SID28_CommunicationControl(SFOf28[0],NCMAndNMM,FUNCTIONAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[0],0,0);
    CheckCommunication(DENONE,0);
  }
  if(TestSubnetCommunicationControlFlag==1)
  {
    subnetComConTestingFlag=1;
    if(gFlagNM==0)
    {
      for(i=0;i<elcount(GEEA30_E245);i++)
      {
        if(GEEA30_E245[i].canChannelNumber!=0)
        {
          Teststep("INF","=======================Now testing %s subnet communicationControl function=======================",GEEA30_E245[i].network);
          subnetComConTestingChannel=GEEA30_E245[i].canChannelNumber;
          CommType=(GEEA30_E245[i].value<<4)|0x3;
          SID28_CommunicationControl(SFOf28[3],CommType,FUNCTIONAL,SPRMIB_FALSE);
          CheckPosResponse_SID28(SFOf28[3],0,0);
          CheckCommunication(DEAPP,0);
          
          SID28_CommunicationControl(SFOf28[0],CommType,FUNCTIONAL,SPRMIB_FALSE);
          CheckPosResponse_SID28(SFOf28[0],0,0);
          CheckCommunication(DENONE,0);
          
          testWaitForTimeout(5000);
          SID28_CommunicationControl(SFOf28[3],CommType,FUNCTIONAL,SPRMIB_TRUE);
          CheckPosResponse_SID28(SFOf28[3],0,0);
          CheckCommunication(DEAPP,0);
          
          SID28_CommunicationControl(SFOf28[0],CommType,FUNCTIONAL,SPRMIB_TRUE);
          CheckPosResponse_SID28(SFOf28[0],0,0);
          CheckCommunication(DENONE,0);
          
          testWaitForTimeout(5000);
        }
      }
    }
    else
    {
      for(i=0;i<elcount(GEEA30_E245);i++)
      {
        if(GEEA30_E245[i].canChannelNumber!=0)
        {
          Teststep("INF","=======================Now testing %s subnet communicationControl function=======================",GEEA30_E245[i].network);
          subnetComConTestingChannel=GEEA30_E245[i].canChannelNumber;
          CommType=(GEEA30_E245[i].value<<4)|0x3;
          SID28_CommunicationControl(SFOf28[3],CommType,FUNCTIONAL,SPRMIB_FALSE);
          CheckPosResponse_SID28(SFOf28[3],0,0);
          CheckCommunication(DEALL,0);
          
          SID28_CommunicationControl(SFOf28[0],CommType,FUNCTIONAL,SPRMIB_FALSE);
          CheckPosResponse_SID28(SFOf28[0],0,0);
          CheckCommunication(DENONE,0);
          
          testWaitForTimeout(5000);
          SID28_CommunicationControl(SFOf28[3],CommType,FUNCTIONAL,SPRMIB_TRUE);
          CheckPosResponse_SID28(SFOf28[3],0,0);
          CheckCommunication(DEALL,0);
          
          SID28_CommunicationControl(SFOf28[0],CommType,FUNCTIONAL,SPRMIB_TRUE);
          CheckPosResponse_SID28(SFOf28[0],0,0);
          CheckCommunication(DENONE,0);
          
          testWaitForTimeout(5000);
        }
      }
    }
    subnetComConTestingFlag=0;
  }
  
  TestStep("Verify extendedSession(0x03)",TestStepIntervalTime);
  CheckCurrentSession(expectSession[2],FUNCTIONAL,0,0);
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
