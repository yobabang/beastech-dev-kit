  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to programmingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify programmingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  SessionFlag=APP;
  
  TestStep("Transition from programmingSession(0x02) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x03) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x03) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x03) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  
  TestStep("Transition from extendedDiagnosticSession(0x03) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep(":Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to extendedDiagnosticSession(0x03) is not allowed",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckNonResponse(0,0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  SessionFlag=APP;

  TestStep("Transition from ProgrammingSession(0x02) to DefaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from DefaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  
  TestStep("Transition from extendedDiagnosticSession(0x03) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  SessionFlag=APP;
  
  TestStep("Transition from ProgrammingSession(0x02) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from DefaultSession(0x01) to DefaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from DefaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x01) to DefaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  
  gflag_check_ecu_init_time = 0;
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
/// <APP_CommonServiceTest>
testcase Sercice_0x11_Valid_Physical_DefaultSession_Supported()
{
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350870_Sercice_0x11_Valid_Physical_DefaultSession_Supported_R2",400);
  testCaseDescription("The intent of this test is to verify that the service ECUReset(0x11) and its subfunction is functioning correctly in defaultSession");
  testCaseTitle("1350870","Sercice_0x11_Valid_Physical_DefaultSession_Supported");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  gflag_check_ecu_init_time = 1;
  
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  //SID11_ECUReset(HardReset,SPRMIB_False,PHYSICAL);
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  
  TestStep("Verify defaultSession, the ECU shall return to defaultSession after hardReset.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  //SID11_ECUReset(HardReset,SPRMIB_True,PHYSICAL);
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  
  gflag_check_ecu_init_time = 0;
  /******************************以上为测试步骤*********************************/
  Postcondition();
}
/// <APP_CommonServiceTest>
testcase Sercice_0x11_Valid_Functional_DefaultSession_Supported()
{
  char logPath[400] = "";
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350871_Sercice_0x11_Valid_Functional_DefaultSession_Supported_R2",400);
  testCaseDescription("The intent of this test is to verify that the service ECUReset(0x11) and its subfunction is functioning correctly in defaultSession"); 
  testCaseTitle("1350871","Sercice_0x11_Valid_Functional_DefaultSession_Supported");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  gflag_check_ecu_init_time = 1;
  
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  SID11_ECUReset(HARDRESET,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession, the ECU shall return to defaultSession after hardReset.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  SID11_ECUReset(HARDRESET,FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
