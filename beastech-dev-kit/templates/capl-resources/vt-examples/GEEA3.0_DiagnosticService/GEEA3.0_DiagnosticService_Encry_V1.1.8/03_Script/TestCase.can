  TestStep("Verify extendedSession(0x03)",TestStepIntervalTime);
  CheckCurrentSession(expectSession[2],PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
/// <APP_CommonServiceTest>
testcase Service_0x28_Func_Function()
{
  byte expectSession[4]={0x01,0x02,0x03,0x04};
  byte SFOf28[4]={0x00,0x01,0x02,0x03};
  byte t28[3]={0x28,0x00,0x01};
  byte expectNRC[1]={0x31};
  byte CommType=0;
  int i=0,j=0;
  char logName[400] = "";
  char info[1024];
  strncat(logName,"1088539_Service_0x28_Func_Function",400);
  testCaseTitle("1088539","Service_0x28_Func_Function");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/

  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedsession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  TestStep("Verify extendedSession(0x03)",TestStepIntervalTime);
  CheckCurrentSession(expectSession[2],FUNCTIONAL,0,0);
  
  gFlagNM=0;
  output(NMMessage_Repeat);Teststep("INF","out put NM repeat request message");
  testwaitfortimeout(3000);
  if(gFlagNM==1)
  {
    TestStep("ECU support NM message",TestStepIntervalTime);
    
    SID28_CommunicationControl(SFOf28[1],NormalCommunicationMessage,FUNCTIONAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[1],0,0);
