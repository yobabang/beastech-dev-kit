      if(IODID[i].AuthenticationFlag != 1)
      {
        CheckPosResponse(0x2F,0,0);
      }
      else
      {
        CheckNegResponse(0x34,0,0);
      }
    }
    
    if(IODID[i].Flag_Ser02==1)
    {
      TestStep("freeze current state",TestStepIntervalTime);
      SID2F_IOControl(PID,0x02,ControlOptionRecord,0,ControlEnableMaskRecord,0,PHYSICAL);
      if(IODID[i].AuthenticationFlag != 1)
      {
        CheckPosResponse(0x2F,0,0);
      }
      else
      {
        CheckNegResponse(0x34,0,0);
      }
      
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,ControlOptionRecord,0,ControlEnableMaskRecord,0,PHYSICAL);
      if(IODID[i].AuthenticationFlag != 1)
      {
        CheckPosResponse(0x2F,0,0);
      }
      else
      {
        CheckNegResponse(0x34,0,0);
      }
    }
  }
//2F
  
  
//31
  for(i=0;i<NumOfRoutine_Sub0x01;i++)//遍历所有例程
  {
    if(Routine_Sub0x01[i].Flag_Ser03 != 1)
    {
      continue;
    }
    
    if(checkAuthenticateState(Deauthenticated)!=2)
    {
      
    }
    else
    {
      AuthenticationFullSeq(testerCertName);
    }
    
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    if(Routine_Sub0x01[i].SecuLevel!=0xFF)
    {

      
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
    }
    
    Deauthenticate();
    
    if(Routine_Sub0x01[i].routinetype == 1)//筛选所有例程类型为1的例程
    {
      tem1 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
