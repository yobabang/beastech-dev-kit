/// <APP_CommonServiceTest>
testcase Service_0x28_Phy_PositiveResponse()
{
  byte expectSession[3]={0x01,0x02,0x03};
  byte SFOf28[4] = {0x00,0x01,0x02,0x03};
  int i=0,j=0;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1088261_Service_0x28_Phy_PositiveResponse",400);
  testCaseTitle("1088261","Service_0x28_Phy_PositiveResponse");
	if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  TestStep("Verify extendedSession(0x03)",TestStepIntervalTime);
  CheckCurrentSession(expectSession[2],PHYSICAL,0,0);
  
  TestStep("CommunicationControl_Request(Sub-Function= [ControlType=CT],CommunicationType=CoT,SPRMIB=FALSE)",TestStepIntervalTime);
  for(i=1;i<=3;i++)
  {
    if(i==1)
    {
      SID28_CommunicationControl(SFOf28[0],NormalCommunicationMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[0],0,0);
      SID28_CommunicationControl(SFOf28[1],NormalCommunicationMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[1],0,0);
      SID28_CommunicationControl(SFOf28[2],NormalCommunicationMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[2],0,0);
      SID28_CommunicationControl(SFOf28[3],NormalCommunicationMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[3],0,0);
    }
    if(i==2)
    {
      SID28_CommunicationControl(SFOf28[0],NetworkManagementMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[0],0,0);
      SID28_CommunicationControl(SFOf28[1],NetworkManagementMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[1],0,0);
      SID28_CommunicationControl(SFOf28[2],NetworkManagementMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[2],0,0);
      SID28_CommunicationControl(SFOf28[3],NetworkManagementMessage,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[3],0,0);
    }
    if(i==3)
    {
      SID28_CommunicationControl(SFOf28[0],NCMAndNMM,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[0],0,0);   
      SID28_CommunicationControl(SFOf28[1],NCMAndNMM,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[1],0,0);       
      SID28_CommunicationControl(SFOf28[2],NCMAndNMM,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[2],0,0);
      SID28_CommunicationControl(SFOf28[3],NCMAndNMM,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID28(SFOf28[3],0,0);
    }
  }
  TestStep("CoT>=0x04,Go to step 6",TestStepIntervalTime);
  TestStep("CT=0x00,CoT=0x01",TestStepIntervalTime);
  
  TestStep("CommunicationControl_Request(Sub-Function= [ControlType=CT],CommunicationType=CoT,SPRMIB=TRUE)",TestStepIntervalTime);
  for(i=1;i<=3;i++)
  {
    if(i==1)
    {
      SID28_CommunicationControl(SFOf28[0],NormalCommunicationMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[1],NormalCommunicationMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[2],NormalCommunicationMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[3],NormalCommunicationMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
    }
    if(i==2)
    {
      SID28_CommunicationControl(SFOf28[0],NetworkManagementMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[1],NetworkManagementMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[2],NetworkManagementMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[3],NetworkManagementMessage,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
    }
    if(i==3)
    {
      SID28_CommunicationControl(SFOf28[0],NCMAndNMM,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);   
      SID28_CommunicationControl(SFOf28[1],NCMAndNMM,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);       
      SID28_CommunicationControl(SFOf28[2],NCMAndNMM,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[3],NCMAndNMM,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
    }
  }
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
