/// <APP_GeneralTest>
testcase S3_Server_SuspensionDuringSegmentedRequestTest_Valid_Physical_ExtendedSession()
{
  long res,msgdlc,CFNum,Stmin;
  message 0x1 TpRes;
  int i=0;
  char logName[400] = "";
  char info[1024];
  byte testPreFillFlag=0;
  
  strncat(logName,"1350966_S3_Server_SuspensionDuringSegmentedRequestTest_Valid_Physical_ExtendedSession",400);
  testCaseDescription("The intent of this test is to verify that the S3Server timer in the ECU is suspended during segmented request.");
  testCaseTitle("1350966","S3_Server_SuspensionDuringSegmentedRequestTest_Valid_Physical_ExtendedSession");
  if((gBusFlag!=1)&&(gBusFlag!=2))
	{
		testStepWarning("Test","This test case only apply to the CAN or CANFD bus");
		return;
	}
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  TPMsgInit(0);
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).");
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Send MultiFrame with an unsupported diagnostic service.");
  
  CloseCANConnection();
  testStep("Chk","Send FF");
  output(TP_FirstFrame);
  
  testJoinMessageEvent(gCAN_ResponseID);
  res= testWaitForAnyJoinedEvent(1000);
  if(res>0)
  {
    testGetWaitEventMsgData(TpRes);
    CheckNRC78(TpRes);//判断收到的报文是否为NRC78
  }
  else
    testStepFail("Fail","DUT doesn't response FF during test");

  if(res>0)
  {
    testGetWaitEventMsgData(TpRes);
    if((TpRes.byte(0)&0xF0) == 0x30 )
    {
      testStepPass("Pass","Receiced FC");
      Stmin=TpRes.byte(2);
      if(Stmin<=0x7F||Stmin>=0)
      {
      }
      else
      {
        Stmin=0;
      }
    }
    else 
    {
      testStepFail("Fail","Dut don't Send a FC");
    }
  }
  testWaitForTimeout(Stmin+1);
  testStep("Chk","Wait for N_Cr Timeout*0.95, then Send CF");
  output(TP_CF1);
  OpenCANConnection();
  
  CheckNegResponse(0x11,0,0);
  
  
  
  TestStep("Wait for 4800 ms");
  testWaitForTimeout(4800);
  TestStep("Verify extendedDiagnosticSession");
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}

/// <APP_GeneralTest>
testcase VersionNumberCannotBeWritten()
{
  #pragma warning(disable: 2058)
  long res,msgdlc,CFNum,Stmin;
  message 0x1 TpRes;
  int i=0,j=0;
  char logName[400] = "";
  char info[1024];
  byte WriteDataRaw[0xFF];
  byte PID[2];
  byte gres;
  
  struct Identifier{
    word DID;
    byte sessionFlag;//1-app,2-boot,3-all
    byte dataLen[3];//0-default,1-extend,2-boot
    byte dataRecord[3][255];//0-default,1-extend,2-boot
    byte readRsult[3];//0-default,1-extend,2-boot
  };
  const int didNum=15;
  struct Identifier ECU_Identifier[didNum]={
    {0xF1A1,2,{8,8,8}},
    {0xF121,2,{7,7,7}},
    {0xF1A5,2,{8,8,8}},
    {0xF125,2,{7,7,7}},
    {0xF1AA,3,{8,8,8}},
    {0xF12A,3,{7,7,7}},
    {0xF1AB,3,{8,8,8}},
    {0xF12B,3,{7,7,7}},
    {0xF18A,3,{6,6,6}},
    {0xF18C,3,{4,4,4}},
    {0xED20,3,{8,8,8}},
    {0xEDA0,3,{9,9,9}},
    {0xF1A0,1,{8,8,8}},
    {0xF1AE,1,{9,9,9}},
    {0xF12E,1,{8,8,8}}
  };
  strncat(logName,"1351038_VersionNumberCannotBeWritten",400);
  testCaseDescription("The intent of this test is to verify that the version number can not be Written.");
  testCaseTitle("1351038","VersionNumberCannotBeWritten");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/

  //DefaultSession
  SessionFlag=APP;
  TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request Write DID:",TestStepIntervalTime);
    SID2E_WriteDataByIdentifier(PID,WriteDataRaw,ECU_Identifier[i].dataLen[0],PHYSICAL);
    gres=GetECUResponse();
    if(gres==NEG)
    {
      if(gTpRxData[2]==0x13)
      {
        PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
        testStepFail("Fail","Expect to respond NRC other than NRC0x13,but get negative response 0x13");
      }
      else
      {
        PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
        testStepPass("Pass","Get expectd response");
      }
    }
    else if(gres==POS)
    {
      PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
      testStepFail("Fail","Get unexpectd postive response");
    }
    else if(gres==TIMEOUT)
    {
      testStepFail("Fail","Timeout no response recived when request service 0x2E");
    }
  }
  //DefaultSession
  
  //ExtendedSession
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).");
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request Write DID:",TestStepIntervalTime);
    SID2E_WriteDataByIdentifier(PID,WriteDataRaw,ECU_Identifier[i].dataLen[1],PHYSICAL);
    gres=GetECUResponse();
    if(gres==NEG)
    {
      if(gTpRxData[2]==0x13)
      {
        PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
        testStepFail("Fail","Expect to respond NRC other than NRC0x13,but get negative response 0x13");
      }
      else
      {
        PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
        testStepPass("Pass","Get expectd response");
      }
    }
    else if(gres==POS)
    {
      PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
      testStepFail("Fail","Get unexpectd postive response");
    }
    else if(gres==TIMEOUT)
    {
      testStepFail("Fail","Timeout no response recived when request service 0x2E");
    }
  }
  //遍历解锁等级、遍历各DID
  for(j=0; j<NumOfSecurityLv; j++)
  {
    if(j==0)
      TestStep("Let L1 = First security level from the configured security level array from configured list. ",TestStepIntervalTime);
    else
      TestStep("Let L1 be equal to next security level",TestStepIntervalTime);
    
    if(SELevel[j].SEFlagPBL == 1)
    {
      continue;
    }
    
    Level1=SELevel[j].SElevel;
    write("Level1 is %02x",Level1);
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    //执行解锁以确保控制器的错误计数器为0
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    for(i=0;i<didNum;i++)
    {
      if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
      {
        
      }
      else   
      {
        continue;
      }
      PID[0]=ECU_Identifier[i].DID>>8;
      PID[1]=ECU_Identifier[i].DID&0xFF;
      
      TestStep("Request Write DID:",TestStepIntervalTime);
      SID2E_WriteDataByIdentifier(PID,WriteDataRaw,ECU_Identifier[i].dataLen[1],PHYSICAL);
      gres=GetECUResponse();
      if(gres==NEG)
      {
        if(gTpRxData[2]==0x13)
        {
          PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
          testStepFail("Fail","Expect to respond NRC other than NRC0x13,but get negative response 0x13");
        }
        else
        {
          PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
          testStepPass("Pass","Get expectd response");
        }
      }
      else if(gres==POS)
      {
        PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
        testStepFail("Fail","Get unexpectd postive response");
      }
      else if(gres==TIMEOUT)
      {
        testStepFail("Fail","Timeout no response recived when request service 0x2E");
      }
    }
  }
  //ExtendedSession
  
  //ProgrammingSession
  SessionFlag=BOOT;
  TestStep("Transition from extendedDiagnosticSession(0x03) to programmingSession(0x02).");
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==2||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request Write DID:",TestStepIntervalTime);
    SID2E_WriteDataByIdentifier(PID,WriteDataRaw,ECU_Identifier[i].dataLen[2],PHYSICAL);
    gres=GetECUResponse();
    if(gres==NEG)
    {
      if(gTpRxData[2]==0x13)
      {
        PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
        testStepFail("Fail","Expect to respond NRC other than NRC0x13,but get negative response 0x13");
      }
      else
      {
        PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
        testStepPass("Pass","Get expectd response");
      }
    }
    else if(gres==POS)
    {
      PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
      testStepFail("Fail","Get unexpectd postive response");
    }
    else if(gres==TIMEOUT)
    {
      testStepFail("Fail","Timeout no response recived when request service 0x2E");
    }
  }
  //遍历解锁等级、遍历各DID
  for(j=0; j<NumOfSecurityLv; j++)
  {
    if(j==0)
      TestStep("Let L1 = First security level from the configured security level array from configured list. ",TestStepIntervalTime);
    else
      TestStep("Let L1 be equal to next security level",TestStepIntervalTime);
    
    if(SELevel[j].SEFlagAPP == 1)
    {
      continue;
    }
    
    Level1=SELevel[j].SElevel;
    write("Level1 is %02x",Level1);
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    //执行解锁以确保控制器的错误计数器为0
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    for(i=0;i<didNum;i++)
    {
      if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
      {
        
      }
      else   
      {
        continue;
      }
      PID[0]=ECU_Identifier[i].DID>>8;
      PID[1]=ECU_Identifier[i].DID&0xFF;
      
      TestStep("Request Write DID:",TestStepIntervalTime);
      SID2E_WriteDataByIdentifier(PID,WriteDataRaw,ECU_Identifier[i].dataLen[2],PHYSICAL);
      gres=GetECUResponse();
      if(gres==NEG)
      {
        if(gTpRxData[2]==0x13)
        {
          PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
          testStepFail("Fail","Expect to respond NRC other than NRC0x13,but get negative response 0x13");
        }
        else
        {
          PrintPID("UDS","Neg.Response",gTpRxData,gTpRxLength);
          testStepPass("Pass","Get expectd response");
        }
      }
      else if(gres==POS)
      {
        PrintPID("UDS","Pos.Response",gTpRxData,gTpRxLength);
        testStepFail("Fail","Get unexpectd postive response");
      }
      else if(gres==TIMEOUT)
      {
        testStepFail("Fail","Timeout no response recived when request service 0x2E");
      }
    }
  }
  //ProgrammingSession
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
}

/// <APP_SecurityAccessAlgorithm>
testcase  ReadandWriteSecurityConstant_APP()
{
  int  i;
  byte DID[2];
  int support_11_19_flag=0;
  byte SecurityConstantTest[16]={0x11,0x22,0x33,0x44,0x55,0x66,0x77,0x88,0x99,0x00,0x11,0x22,0x33,0x44,0x55,0x66};
  byte notApplicableFlag=1;
  
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1023148_ReadandWriteSecurityConstant_APP",400);
  testCaseTitle("1023148","ReadandWriteSecurityConstant_APP");
  
  SetLog(logName);
  Precondition();
  
  /******************************以下为测试步骤*********************************/  
  SessionFlag=APP;
  
  for(i=0; i<NumOfSecurityLv; i++)
  {
    if(SELevel[i].SEFlagPBL == 1)
    {
      continue;
    }
    Level1=SELevel[i].SElevel;
    notApplicableFlag=0;
    
    if((Level1==0x11)||(Level1==0x19))
    {
      support_11_19_flag=1;
      if(Level1==0x11)
      {
        DID[0]=0xF1;
        DID[1]=0x0A;
      }
      else if(Level1==0x19)
      {
        DID[0]=0xF1;
        DID[1]=0x0B;
      }
      TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      
      TestStep("Verify ExtendedSession.",TestStepIntervalTime);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
      
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(Level1,0,0);
      
      TestStep("Read security constant",TestStepIntervalTime);
      SID22_ReadDataByIdentifier(DID,PHYSICAL);
      CheckNegResponse(0x31,0,0);
      
      TestStep("Write security constant",TestStepIntervalTime);
      SID2E_WriteDataByIdentifier(DID,SecurityConstantTest,PHYSICAL);
      CheckPosResponse_SID2E(DID,0,0);
      
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      
      PrintPID("Info","Execute Security access,use security constant:",SELevel[i].SEconstant,16);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
      
      memcpy_off(SELevel[i].SEconstant,0,SecurityConstantTest,0,16);
      PrintPID("Info","Execute Security access,use security constant:",SELevel[i].SEconstant,16);
      
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(Level1,0,0);
      
      TestStep("Write security constant again",TestStepIntervalTime);
      SID2E_WriteDataByIdentifier(DID,SecurityConstantTest,PHYSICAL);
      CheckNegResponse(0x22,0,0);
      
    }
    else
    {
      if((i==(NumOfSecurityLv-1))&&(notApplicableFlag==1))
      {
        testStepWarning("Warning","ECU not support Securirty access level 0x11&0x19,this test is not applicable");
      }
    }
  }
  
  if(support_11_19_flag==1)
  {
    TestStep("Verify ExtendedSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  }
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <APP_SecurityAccessAlgorithm>
testcase DelayTimerAfterFalseAttempts_APP()
{
  int i,B;
  dword t;
  int N = 2;
  float TempT1,TempT2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1023149_DelayTimerAfterFalseAttempts_APP",400);
  testCaseTitle("1023149","DelayTimerAfterFalseAttempts_APP");
  
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  for(i=0; i<NumOfSecurityLv; i++)
  {
    if(SELevel[i].SEFlagPBL == 1)
    {
      continue;
    }
    TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    Level1=SELevel[i].SElevel;    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
   //1) Test no delay after N-1 false attempts:
    for(B=0; B<N-1; B++)
    {
      TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      TestStep("Generate wrong key from response.",TestStepIntervalTime);
      gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
      
      TestStep("Send invalid key.",TestStepIntervalTime);
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
    }
    
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    //2) Test the delay timer after false attempts:
    TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    for(B=0; B<N; B++)
    {
      TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      TestStep("Generate wrong key from response.",TestStepIntervalTime);
      gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
      
      TestStep("Send invalid key.",TestStepIntervalTime);
      if(B != N-1)
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x35,0,0);
      }
      else
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x36,0,0);
      }
    }
    
    for(t=0; t<DelayTimer;)
    {
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckNegResponse(0x37,0,0);
      t = t + 1005;
      testWaitForTimeout(1005);
    }
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    TestStep("===Below steps is to verify false attempts counter shall be reset to zero after ECU reset===");
    for(B=0; B<N-1; B++)
    {
      TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      TestStep("Generate wrong key from response.",TestStepIntervalTime);
      gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
      
      TestStep("Send invalid key.",TestStepIntervalTime);
      if(B != N-1)
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x35,0,0);
      }
      else
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x36,0,0);
      }
    }
    testWaitForTimeout(50);//增加50ms延时
    SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID11(HARDRESET,0,0);

    ECUinitHandle(0);
    
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    for(B=0; B<N; B++)
    {
      TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      TestStep("Generate wrong key from response.",TestStepIntervalTime);
      gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
      
      TestStep("Send invalid key.",TestStepIntervalTime);
      if(B != N-1)
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x35,0,0);
      }
      else
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x36,0,0);
      }
    }
    
    testWaitForTimeout(DelayTimer+2000);

    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    TestStep("===Below steps is to verify Delay timer will not lost after ECU Reset===");
    
    for(B=0; B<N; B++)
    {
      TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      TestStep("Generate wrong key from response.",TestStepIntervalTime);
      gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
      
      TestStep("Send invalid key.",TestStepIntervalTime);
      if(B != N-1)
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x35,0,0);
      }
      else
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x36,0,0);
      }
    }
    testWaitForTimeout(50);//增加50ms延时
    SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID11(HARDRESET,0,0);

    ECUinitHandle(0);
    
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckNegResponse(0x37,0,0);
//    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
//    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
//    
//    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
//    CheckNegResponse(0x37,0,0);
      
    delaywithreq(DelayTimer+2000);
    
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);

    TestStep("===Below steps is to verify false attempts counter will return 0 after Delay timer time-out===");
    for(B=0; B<N; B++)
    {
      TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      TestStep("Generate wrong key from response.",TestStepIntervalTime);
      gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
      
      TestStep("Send invalid key.",TestStepIntervalTime);
      if(B != N-1)
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x35,0,0);
      }
      else
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x36,0,0);
      }
    }
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckNegResponse(0x37,0,0);
    
    delaywithreq(DelayTimer+100);
    
    for(B=0; B<N-1; B++)
    {
      TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      TestStep("Generate wrong key from response.",TestStepIntervalTime);
      gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
      
      TestStep("Send invalid key.",TestStepIntervalTime);
      if(B != N-1)
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x35,0,0);
      }
      else
      {
        SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
        CheckNegResponse(0x36,0,0);
      }
    }
    delaywithreq(DelayTimer+2000);
    
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    
  }

//  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
//  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);

  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
