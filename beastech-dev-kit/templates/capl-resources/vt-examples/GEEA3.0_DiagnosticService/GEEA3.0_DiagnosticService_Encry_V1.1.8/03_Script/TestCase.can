/// <APP_GeneralTest>
testcase ECU_Identification_Verification_Test_Physical_Allsession()
{
  #pragma warning(disable: 2058)
  int  i=0,j=0;
  byte PID[2];
  char logName[400] = "";
  char info[1024];
  struct Identifier{
    word DID;
    byte sessionFlag;//1-app,2-boot,3-all
    byte dataLen[3];//0-default,1-extend,2-boot
    byte dataRecord[3][255];//0-default,1-extend,2-boot
    byte readRsult[3];//0-default,1-extend,2-boot
  };
  const int didNum=15;
  struct Identifier ECU_Identifier[didNum]={
    {0xF1A1,2,{8,8,8}},
    {0xF121,2,{7,7,7}},
    {0xF1A5,2,{8,8,8}},
    {0xF125,2,{7,7,7}},
    {0xF1AA,3,{8,8,8}},
    {0xF12A,3,{7,7,7}},
    {0xF1AB,3,{8,8,8}},
    {0xF12B,3,{7,7,7}},
    {0xF18A,3,{6,6,6}},
    {0xF18C,3,{4,4,4}},
    {0xED20,3,{0xFF,0xFF,0xFF}},
    {0xEDA0,3,{0xFF,0xFF,0xFF}},
    {0xF1A0,1,{8,8,8}},
    {0xF1AE,1,{0xFF,0xFF,0xFF}},
    {0xF12E,1,{0XFF,0XFF,0XFF}}
  };
  int compareResult1=0;//default会话与extend会话对比结果
  int compareResult2=0;//boot与app会话对比结果
  
  char inputchar[500];
  char tempstr[5];
  byte F18A[6];
  
  strncat(logName,"1350993_ECU_Identification_Verification_Test_Physical_Allsession",400);
  testCaseDescription("ECU supports ECU mandatory identification dataidentifiers (DIDs).ECU responds with negative response code (NRC) to dataidentifiers not supported.");
  testCaseTitle("1350993","ECU_Identification_Verification_Test_Physical_Allsession");

  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/  
  
  SessionFlag=APP;

  //DefaultSession
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request DID:",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    if(ECU_Identifier[i].dataLen[0]!=0xFF)
    {
      if(CheckPosResponse_SID22(PID,ECU_Identifier[i].dataLen[0],0,0)>0)
      {
        ECU_Identifier[i].dataLen[0]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[0];j++)
        {
          ECU_Identifier[i].dataRecord[0][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[0]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[0]=0;
      }
    }
    else
    {
      if(CheckPosResponse(0x22,0,0)>0)
      {
        ECU_Identifier[i].dataLen[0]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[0];j++)
        {
          ECU_Identifier[i].dataRecord[0][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[0]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[0]=0;
      }
    }
  }
  //DefaultSession
  
  //ExtendedSession
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request DID:",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    if(ECU_Identifier[i].dataLen[1]!=0xFF)
    {
      if(CheckPosResponse_SID22(PID,ECU_Identifier[i].dataLen[1],0,0)>0)
      {
        ECU_Identifier[i].dataLen[1]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[1];j++)
        {
          ECU_Identifier[i].dataRecord[1][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[1]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[1]=0;
      }
    }
    else
    {
      if(CheckPosResponse(0x22,0,0)>0)
      {
        ECU_Identifier[i].dataLen[1]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[0];j++)
        {
          ECU_Identifier[i].dataRecord[1][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[1]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[1]=0;
      }
    }
  }
  //ExtendedSession
  
  //ProgrammingSession
  SessionFlag=BOOT;
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==2||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request DID:",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    if(ECU_Identifier[i].dataLen[2]!=0xFF)
    {
      if(CheckPosResponse_SID22(PID,ECU_Identifier[i].dataLen[2],0,0)>0)
      {
        ECU_Identifier[i].dataLen[2]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[2];j++)
        {
          ECU_Identifier[i].dataRecord[2][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[2]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[2]=0;
      }
    }
    else
    {
      if(CheckPosResponse(0x22,0,0)>0)
      {
        ECU_Identifier[i].dataLen[2]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[2];j++)
        {
          ECU_Identifier[i].dataRecord[2][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[2]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[2]=0;
      }
    }
  }
  //ProgrammingSession
  
  //Compare
  
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==3)
    {
      Teststep("Info","DID_%x_Data:",ECU_Identifier[i].DID);
      if(ECU_Identifier[i].readRsult[0]==1)
      {
        PrintPID("Info","DefaultSession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      }
      else
      {
        TestStep("Info","DefaultSession:Read Fail");
      }
      if(ECU_Identifier[i].readRsult[1]==1)
      {
        PrintPID("Info","Extend Session:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      }
      else
      {
        TestStep("Info","Extend Session:Read Fail");
      }
      if(ECU_Identifier[i].readRsult[2]==1)
      {
        PrintPID("Info","ProgramSession:",ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      }
      else
      {
        TestStep("Info","ProgramSession:Read Fail");
      }
      compareResult1=CompareByte(ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[0]);
      compareResult2=CompareByte(ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[1]);
      if(ECU_Identifier[i].DID == 0xED20 || ECU_Identifier[i].DID == 0xEDA0) //0xED20和0xEDA0特殊处理，APP和BOOT下数据需要不一致
      {
        if(compareResult1==2) { TeststepPass("Pass","The value of DID:%x are same between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID); }
        else                  { TeststepFail("Fail","The value of DID:%x are different between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID); }
        if(compareResult2==2) { TeststepFail("Fail","The value of DID:%x are same between APP and Boot :",ECU_Identifier[i].DID); }
        //else                  { TeststepPass("Fail","The value of DID:%x are different between APP and Boot :",ECU_Identifier[i].DID); }
      }
      else
      {
        if(compareResult1==2)
        {
          TeststepPass("Pass","The value of DID:%x are same between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
        }
        else
        {
          TeststepFail("Fail","The value of DID:%x are different between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
        }
        if(compareResult2==2)
        {
          TeststepPass("Pass","The value of DID:%x are same between APP and Boot :",ECU_Identifier[i].DID);
        }
        else
        {
          TeststepFail("Fail","The value of DID:%x are different between APP and Boot :",ECU_Identifier[i].DID);
        }
      }
    }
    else if(ECU_Identifier[i].sessionFlag==1)
    {
      Teststep("Info","DID_%x_Data:",ECU_Identifier[i].DID);
      if(ECU_Identifier[i].readRsult[0]==1)
      {
        PrintPID("Info","DefaultSession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      }
      else
      {
        TestStep("Info","DefaultSession:Read Fail");
      }
      if(ECU_Identifier[i].readRsult[1]==1)
      {
        PrintPID("Info","Extend Session:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      }
      else
      {
        TestStep("Info","Extend Session:Read Fail");
      }
      compareResult1=CompareByte(ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[0]);
      if(compareResult1==2)
      {
        TeststepPass("Pass","The value of DID:%x are same between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
      }
      else
      {
        TeststepFail("Fail","The value of DID:%x are different between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
      }
    }
    else if(ECU_Identifier[i].sessionFlag==2)
    {
      Teststep("Info","DID:%x is only supported in programmingsession,not need to be compared",ECU_Identifier[i].DID);
    }
  }
  //Compare

  if(strlen(F18AValue)==0)// 这里改为由strlen判断长度
  {
  	if(1==testWaitForStringInput("Please input F18A(System Supplier Identifier,HEX 格式如供应商代码123456，请先将ascii转换为16进制，输入313233343536) ExpectValue:"))
  	{
  		testGetStringInput(inputchar,elcount(inputchar));

  		str_replace(inputchar," ","");
  		str_replace(inputchar,",","");
  		str_replace(inputchar,"0x","");
  		str_replace(inputchar,"0X","");
  		str_replace(inputchar,":","");

  		if(strlen(inputchar)!=12)
  		{
        testStepFail("Error","Length of the input F18A(System Supplier Identifier) is not correct,skip check F18A Value.");
        testWaitForTesterConfirmation("Length of the input F18A(System Supplier Identifier) is not correct,skip this testcase.");
        Postcondition(); 
        return;
  		}

  		tempstr[0] = '0';
  		tempstr[1] = 'x';
      
  		for(i=0; 2*i<strlen(inputchar); i++)
  		{
  			tempstr[2] = inputchar[2*i];
  			tempstr[3] = inputchar[2*i+1];
  			tempstr[4] = 0;
  			F18A[i] = atol(tempstr);
  		}
      for(i=0;i<didNum;i++)
      {
        if(ECU_Identifier[i].DID==0xF18A)
          Break;
      }
      PrintPID("Info","F18A defaultsession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      PrintPID("Info","F18A extendsession:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      PrintPID("Info","F18A programmingsession:",ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      PrintPID("Info","F18A expected:",F18A,ECU_Identifier[i].dataLen[0]);
      
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A defaultsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A extendsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A programmingsession mismatech expected");
      }
  	}
  }
  else
  {
//  		testGetStringInput(F18AValue,elcount(F18AValue));

  		str_replace(F18AValue," ","");
  		str_replace(F18AValue,",","");
  		str_replace(F18AValue,"0x","");
  		str_replace(F18AValue,"0X","");
  		str_replace(F18AValue,":","");

  		if(strlen(F18AValue)!=12)
  		{
        testStepFail("Error","Length of the input F18A(System Supplier Identifier) is not correct,skip check F18A Value.");
//        testWaitForTesterConfirmation("Length of the input F18A(System Supplier Identifier) is not correct,skip this testcase.");
        Postcondition(); 
        return;
  		}

  		tempstr[0] = '0';
  		tempstr[1] = 'x';
      
  		for(i=0; 2*i<strlen(F18AValue); i++)
  		{
  			tempstr[2] = F18AValue[2*i];
  			tempstr[3] = F18AValue[2*i+1];
  			tempstr[4] = 0;
  			F18A[i] = atol(tempstr);
  		}
      for(i=0;i<didNum;i++)
      {
        if(ECU_Identifier[i].DID==0xF18A)
          Break;
      }
      PrintPID("Info","F18A defaultsession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      PrintPID("Info","F18A extendsession:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      PrintPID("Info","F18A programmingsession:",ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      PrintPID("Info","F18A expected:",F18A,ECU_Identifier[i].dataLen[0]);
      
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A defaultsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A extendsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A programmingsession mismatech expected");
      }
  }
  
  /******************************以上为测试步骤*********************************/
  Postcondition(); 
}
/// <APP_GeneralTest>
testcase ECU_Identification_Verification_Test_Functional_Allsession()
{
  #pragma warning(disable: 2058)
  int  i=0,j=0;
  byte PID[2];
  char logName[400] = "";
  char info[1024];
  struct Identifier{
    word DID;
    byte sessionFlag;//1-app,2-boot,3-all
    byte dataLen[3];//0-default,1-extend,2-boot
    byte dataRecord[3][255];//0-default,1-extend,2-boot
    byte readRsult[3];//0-default,1-extend,2-boot
  };
  const int didNum=15;
  struct Identifier ECU_Identifier[didNum]={
    {0xF1A1,2,{8,8,8}},
    {0xF121,2,{7,7,7}},
    {0xF1A5,2,{8,8,8}},
    {0xF125,2,{7,7,7}},
    {0xF1AA,3,{8,8,8}},
    {0xF12A,3,{7,7,7}},
    {0xF1AB,3,{8,8,8}},
    {0xF12B,3,{7,7,7}},
    {0xF18A,3,{6,6,6}},
    {0xF18C,3,{4,4,4}},
    {0xED20,3,{0xFF,0xFF,0xFF}},
    {0xEDA0,3,{0xFF,0xFF,0xFF}},
    {0xF1A0,1,{8,8,8}},
    {0xF1AE,1,{0xFF,0xFF,0xFF}},
    {0xF12E,1,{0XFF,0XFF,0XFF}}
  };
  int compareResult1=0;//default会话与extend会话对比结果
  int compareResult2=0;//boot与app会话对比结果
  char inputchar[500];
  char tempstr[5];
  byte F18A[6];
  
  strncat(logName,"1350994_ECU_ECU_Identification_Verification_Test_Functional_Allsession",400);
  testCaseDescription("ECU supports ECU mandatory identification dataidentifiers (DIDs).ECU responds with negative response code (NRC) to dataidentifiers not supported.");
  testCaseTitle("1350994","ECU_Identification_Verification_Test_Functional_Allsession");

  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/  
  
  SessionFlag=APP;

  //DefaultSession
  SID10_DiagnosticSessionControl(DEFAULTSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  CheckCurrentSession(DEFAULTSESSION,FUNCTIONAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request DID:",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    if(ECU_Identifier[i].dataLen[0]!=0xFF)
    {
      if(CheckPosResponse_SID22(PID,ECU_Identifier[i].dataLen[0],0,0)>0)
      {
        ECU_Identifier[i].dataLen[0]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[0];j++)
        {
          ECU_Identifier[i].dataRecord[0][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[0]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[0]=0;
      }
    }
    else
    {
      if(CheckPosResponse(0x22,0,0)>0)
      {
        ECU_Identifier[i].dataLen[0]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[0];j++)
        {
          ECU_Identifier[i].dataRecord[0][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[0]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[0]=0;
      }
    }
  }
  //DefaultSession
  
  //ExtendedSession
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  CheckCurrentSession(EXTENDEDSESSION,FUNCTIONAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==1||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request DID:",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    if(ECU_Identifier[i].dataLen[1]!=0xFF)
    {
      if(CheckPosResponse_SID22(PID,ECU_Identifier[i].dataLen[1],0,0)>0)
      {
        ECU_Identifier[i].dataLen[1]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[1];j++)
        {
          ECU_Identifier[i].dataRecord[1][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[1]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[1]=0;
      }
    }
    else
    {
      if(CheckPosResponse(0x22,0,0)>0)
      {
        ECU_Identifier[i].dataLen[1]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[1];j++)
        {
          ECU_Identifier[i].dataRecord[1][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[1]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[1]=0;
      }
    }
  }
  //ExtendedSession
  
  //ProgrammingSession
  SessionFlag=BOOT;
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  CheckCurrentSession(PROGRAMMINGSESSION,FUNCTIONAL,0,0);
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==2||ECU_Identifier[i].sessionFlag==3)
    {
      
    }
    else   
    {
      continue;
    }
    PID[0]=ECU_Identifier[i].DID>>8;
    PID[1]=ECU_Identifier[i].DID&0xFF;
    
    TestStep("Request DID:",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    if(ECU_Identifier[i].dataLen[2]!=0xFF)
    {
      if(CheckPosResponse_SID22(PID,ECU_Identifier[i].dataLen[2],0,0)>0)
      {
        ECU_Identifier[i].dataLen[2]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[2];j++)
        {
          ECU_Identifier[i].dataRecord[2][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[2]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[2]=0;
      }
    }
    else
    {
      if(CheckPosResponse(0x22,0,0)>0)
      {
        ECU_Identifier[i].dataLen[2]=gTpRxLength-3;
        for(j=0;j<ECU_Identifier[i].dataLen[2];j++)
        {
          ECU_Identifier[i].dataRecord[2][j]=gTpRxData[j+3];
        }
        ECU_Identifier[i].readRsult[2]=1;
      }
      else
      {
        teststepfail("Fail","Fail to read did:%x",ECU_Identifier[i].DID);
        ECU_Identifier[i].readRsult[2]=0;
      }
    }
  }
  //ProgrammingSession
  
  //Compare
  
  for(i=0;i<didNum;i++)
  {
    if(ECU_Identifier[i].sessionFlag==3)
    {
      Teststep("Info","DID_%x_Data:",ECU_Identifier[i].DID);
      if(ECU_Identifier[i].readRsult[0]==1)
      {
        PrintPID("Info","DefaultSession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      }
      else
      {
        TestStep("Info","DefaultSession:Read Fail");
      }
      if(ECU_Identifier[i].readRsult[1]==1)
      {
        PrintPID("Info","Extend Session:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      }
      else
      {
        TestStep("Info","Extend Session:Read Fail");
      }
      if(ECU_Identifier[i].readRsult[2]==1)
      {
        PrintPID("Info","ProgramSession:",ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      }
      else
      {
        TestStep("Info","ProgramSession:Read Fail");
      }
      compareResult1=CompareByte(ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[0]);
      compareResult2=CompareByte(ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[1]);
      if(ECU_Identifier[i].DID == 0xED20 || ECU_Identifier[i].DID == 0xEDA0) //0xED20和0xEDA0特殊处理，APP和BOOT下数据需要不一致
      {
        if(compareResult1==2) { TeststepPass("Pass","The value of DID:%x are same between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID); }
        else                  { TeststepFail("Fail","The value of DID:%x are different between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID); }
        if(compareResult2==2) { TeststepFail("Fail","The value of DID:%x are same between APP and Boot :",ECU_Identifier[i].DID); }
        else                  { TeststepPass("Pass","The value of DID:%x are different between APP and Boot :",ECU_Identifier[i].DID); }
      }
      else
      {
        if(compareResult1==2)
        {
          TeststepPass("Pass","The value of DID:%x are same between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
        }
        else
        {
          TeststepFail("Fail","The value of DID:%x are different between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
        }
        if(compareResult2==2)
        {
          TeststepPass("Pass","The value of DID:%x are same between APP and Boot :",ECU_Identifier[i].DID);
        }
        else
        {
          TeststepFail("Fail","The value of DID:%x are different between APP and Boot :",ECU_Identifier[i].DID);
        }
      }
    }
    else if(ECU_Identifier[i].sessionFlag==1)
    {
      Teststep("Info","DID_%x_Data:",ECU_Identifier[i].DID);
      if(ECU_Identifier[i].readRsult[0]==1)
      {
        PrintPID("Info","DefaultSession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      }
      else
      {
        TestStep("Info","DefaultSession:Read Fail");
      }
      if(ECU_Identifier[i].readRsult[1]==1)
      {
        PrintPID("Info","Extend Session:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      }
      else
      {
        TestStep("Info","Extend Session:Read Fail");
      }
      compareResult1=CompareByte(ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[0]);
      if(compareResult1==2)
      {
        TeststepPass("Pass","The value of DID:%x are same between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
      }
      else
      {
        TeststepFail("Fail","The value of DID:%x are different between DefaultSession and ExtendedSession :",ECU_Identifier[i].DID);
      }
    }
    else if(ECU_Identifier[i].sessionFlag==2)
    {
      Teststep("Info","DID:%x is only supported in programmingsession,not need to be compared",ECU_Identifier[i].DID);
    }
  }
  //Compare
  if(elCount(F18AValue)==0)
  {
  	if(1==testWaitForStringInput("Please input F18A(System Supplier Identifier) ExpectValue:"))
  	{
  		testGetStringInput(inputchar,elcount(inputchar));

  		str_replace(inputchar," ","");
  		str_replace(inputchar,",","");
  		str_replace(inputchar,"0x","");
  		str_replace(inputchar,"0X","");
  		str_replace(inputchar,":","");

  		if(strlen(inputchar)!=12)
  		{
        testStepFail("Error","Length of the input F18A(System Supplier Identifier) is not correct,skip check F18A Value.");
        testWaitForTesterConfirmation("Length of the input F18A(System Supplier Identifier) is not correct,skip this testcase.");
        Postcondition(); 
        return;
  		}

  		tempstr[0] = '0';
  		tempstr[1] = 'x';
      
  		for(i=0; 2*i<strlen(inputchar); i++)
  		{
  			tempstr[2] = inputchar[2*i];
  			tempstr[3] = inputchar[2*i+1];
  			tempstr[4] = 0;
  			F18A[i] = atol(tempstr);
  		}
      for(i=0;i<didNum;i++)
      {
        if(ECU_Identifier[i].DID==0xF18A)
          Break;
      }
      PrintPID("Info","F18A defaultsession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      PrintPID("Info","F18A extendsession:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      PrintPID("Info","F18A programmingsession:",ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      PrintPID("Info","F18A expected:",F18A,ECU_Identifier[i].dataLen[0]);
      
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A defaultsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A extendsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A programmingsession mismatech expected");
      }
  	}
  }
  else
  {
//  		testGetStringInput(F18AValue,elcount(F18AValue));

  		str_replace(F18AValue," ","");
  		str_replace(F18AValue,",","");
  		str_replace(F18AValue,"0x","");
  		str_replace(F18AValue,"0X","");
  		str_replace(F18AValue,":","");

  		if(strlen(F18AValue)!=12)
  		{
        testStepFail("Error","Length of the input F18A(System Supplier Identifier) is not correct,skip check F18A Value.");
//        testWaitForTesterConfirmation("Length of the input F18A(System Supplier Identifier) is not correct,skip this testcase.");
        Postcondition(); 
        return;
  		}

  		tempstr[0] = '0';
  		tempstr[1] = 'x';
      
  		for(i=0; 2*i<strlen(F18AValue); i++)
  		{
  			tempstr[2] = F18AValue[2*i];
  			tempstr[3] = F18AValue[2*i+1];
  			tempstr[4] = 0;
  			F18A[i] = atol(tempstr);
  		}
      for(i=0;i<didNum;i++)
      {
        if(ECU_Identifier[i].DID==0xF18A)
          Break;
      }
      PrintPID("Info","F18A defaultsession:",ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      PrintPID("Info","F18A extendsession:",ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      PrintPID("Info","F18A programmingsession:",ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      PrintPID("Info","F18A expected:",F18A,ECU_Identifier[i].dataLen[0]);
      
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[0],ECU_Identifier[i].dataLen[0]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A defaultsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[1],ECU_Identifier[i].dataLen[1]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A extendsession mismatech expected");
      }
      compareResult1=CompareByte(F18A,ECU_Identifier[i].dataRecord[2],ECU_Identifier[i].dataLen[2]);
      if(compareResult1!=2)
      {
        testStepFail("Fail","F18A programmingsession mismatech expected");
      }
  }
  /******************************以上为测试步骤*********************************/
  Postcondition(); 
}
