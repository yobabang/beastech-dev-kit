          CheckPosResponse_SID28(SFOf28[0],0,0);
          CheckCommunication(DENONE,0);
          
          testWaitForTimeout(5000);
          
          SID28_CommunicationControl(SFOf28[3],CommType,PHYSICAL,SPRMIB_TRUE);
          CheckPosResponse_SID28(SFOf28[3],0,0);
          CheckCommunication(DEAPP,0);
          
          SID28_CommunicationControl(SFOf28[0],CommType,PHYSICAL,SPRMIB_TRUE);
          CheckPosResponse_SID28(SFOf28[0],0,0);
          CheckCommunication(DENONE,0);
          
          testWaitForTimeout(5000);
        }
      }
    }
