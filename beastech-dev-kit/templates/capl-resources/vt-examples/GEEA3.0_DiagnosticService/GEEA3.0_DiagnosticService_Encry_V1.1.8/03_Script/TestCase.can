/// <Authentication_Test>
testcase Service_0x29_UnsupporrtedSubfunctionTest()
{
  char logName[400] = "";
  char info[1024];
  byte OCSP_RID[2]={0x70,0x27};
  byte tempdata[3075];
  char errorMsg[500];
  byte challenge[32]={0xAD,0x95,0x37,0xF6,0xC8,0x04,0x56,0x99,0xCE,0x04,0x19,0x88,0x68,0x83,0xB3,0xA1};
  char hashFunction[10]="SHA-256";  
//  char testerCertName[300] = "Geely3.0";
  byte testerCertByte[2000];
  dword testerCertByteLength;
  char testerCertString[4000];
  byte ownerShip[1000];
  dword ownerShipLength;
  char ownerShipString[2000];
  byte supportSubFunction[4]={0,1,3,8};
  int i=0,j=0;
  byte data[2]={0x29,00};
  byte ExpectNRC[2]={0x12,0x7E};
  byte supportFlag=0;
  
  strncat(logName,"1318673_Service_0x29_UnsupporrtedSubfunctionTest",400);
  testCaseTitle("1318673","Service_0x29_UnsupporrtedSubfunctionTest");
  
  if(gBusFlag==5&&EthNodeTypeNow==EdgeNode)
  {
    
  }
  else
  {
    testStepWarning("Warning","This test case is only applicable for ETH_Edgenode");
    return;
  }
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/

  for(i=0; i<=0xFF; i++)
  {
    for(j=0;j<elcount(supportSubFunction); j++)
    {
      if(i==supportSubFunction[j])
      {
        supportFlag=1;
        break;
      }
      else if(i==(supportSubFunction[j]+0x80))
      {
        supportFlag=1;
        break;
      }
    }
    if(supportFlag==1)
    {
      supportFlag=0;
      continue;
    }
    else
    {
      data[1]=i;
      TPSendRawMessage(data,PHYSICAL);
      CheckNegResponse(ExpectNRC,0,0,0,0);
    }
  }
  
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
}
