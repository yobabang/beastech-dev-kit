  int i,j,Flag;
  byte DID_Format[2]={0xF1,0x86};
  byte ExpectNRC[2]={0x11,0x7F};
  char logName[400] = "";
  char info[1024];
 
  strncat(logName,"1350956_Sercice_0x2C_Valid_Functional_DefaultSession_Supported",400);
  testCaseDescription("The intent of the test is to verify service dynamicallyDefinedDataIdentifier (0x2C) and its subfunctions defineByIdentifier (0x01) defineByMemoryAddress (0x02) and clearDynamicallyDefinedDataIdentifier (0x03) is supported.");
  testCaseTitle("1350956","Sercice_0x2C_Valid_Functional_DefaultSession_Supported");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  TestStep("Let Z1 Z2 = first dataidentifier from configured list",TestStepIntervalTime);
  
  TestStep("Support of subfunction defineByIdentifier",TestStepIntervalTime);
  
  TestStep("Support of one dynamicallyDefinedDataIdentifier in one request",TestStepIntervalTime);
  
  if(Flag_Ser0x2C_Sub0x01==1)
  {
    for(i=0; i<NumOfDID2C; i++)
    {
      TestStep("Dynamically Defined DataIdentifier)",TestStepIntervalTime);
      SID2C_DynamicallyDefinedDataIdentifier_Identifier(DID_0x2C[i].DID,DID_Format,1,1,PHYSICAL);//遍历DID的01子功能
      if(gRss==POS)
      {
        CheckPosResponse_SID2C_Identifier(DID_0x2C[i].DID,0,0);//检查肯定响应
        testWaitForTimeout(100);
        
        TestStep("Read out of dynamicallyDefinedDataIdentifier containing DID F1 86",TestStepIntervalTime);
        SID22_ReadDataByIdentifier(DID_0x2C[i].DID,FUNCTIONAL);//读取DID
        CheckPosResponse_SID22(DID_0x2C[i].DID,1,0,0);//检查肯定响应
        testWaitForTimeout(100);
        
        TestStep("Clear dynamicallyDefinedDataIdentiifier",TestStepIntervalTime);
        SID2C_ClearDynamicallyDefinedDataIdentifier_withDID(DID_0x2C[i].DID,FUNCTIONAL);//清除
        CheckPosResponse_SID2C_ClearwithDID(DID_0x2C[i].DID,0,0);
        testWaitForTimeout(100);
        
        TestStep("Read out of dynamicallyDefinedDataIdentifier",TestStepIntervalTime);
        SID22_ReadDataByIdentifier(DID_0x2C[i].DID,FUNCTIONAL);//读取DID
        CheckNonResponse(0,0);
        testWaitForTimeout(100);
      }
      else if(gRss==NEG)
      {
        if(CheckNegResponse(ExpectNRC,0,0,0,0)==1)
        {
          Flag=1;
        break;
          
        }
      }
    }
    if(Flag!=1)
    {
      for(i=0; i<NumOfDID2C; i++)
      {
        TestStep("Dynamically Defined DataIdentifier)",TestStepIntervalTime);
        SID2C_DynamicallyDefinedDataIdentifier_Identifier(DID_0x2C[i].DID,DID_Format,1,1,PHYSICAL);//遍历DID的01子功能
        if(gRss==POS)
        {
          CheckPosResponse_SID2C_Identifier(DID_0x2C[i].DID,0,0);//检查肯定响应
          testWaitForTimeout(100);
        }
        else if(gRss==NEG)
        {
          CheckNegResponse(ExpectNRC,0,0,0,0);
          break;
        }
      }
      
       TestStep("Clear dynamicallyDefinedDataIdentiifier",TestStepIntervalTime);
       SID2C_ClearDynamicallyDefinedDataIdentifier(PHYSICAL);//清除
       CheckPosResponse_SID2C_Clear(0,0);
       testWaitForTimeout(100);
      
      for(i=0; i<NumOfDID2C; i++)
      {
       TestStep("Read out of dynamicallyDefinedDataIdentifier",TestStepIntervalTime);
       SID22_ReadDataByIdentifier(DID_0x2C[i].DID,FUNCTIONAL);//读取DID
       CheckNonResponse(0,0);
       testWaitForTimeout(100);  
      }
    }
  }
  
  if(Flag_Ser0x2C_Sub0x02==1)
  {
    for(i=0; i<NumOfDID2C; i++)
    {
      for(j=0;j<NumOfAddSup;j++)
      {
        TestStep("Dynamically Defined DataIdentifier)",TestStepIntervalTime);
        SID2C_DynamicallyDefinedDataIdentifier_Address_14(DID_0x2C[i].DID,Add_0x14[j].Address,Add_0x14[j].AddressLenth,PHYSICAL);//遍历DID的01子功能
        if(gRss==POS)
        {
          CheckPosResponse_SID2C_Address_14(DID_0x2C[i].DID,0,0);//检查肯定响应
          testWaitForTimeout(100);
          TestStep("Read out of dynamicallyDefinedDataIdentifier",TestStepIntervalTime);
          SID22_ReadDataByIdentifier(DID_0x2C[i].DID,FUNCTIONAL);//读取DID
          CheckPosResponse_SID22(DID_0x2C[i].DID,4,0,0);//检查肯定响应
          testWaitForTimeout(100);
          TestStep("Clear dynamicallyDefinedDataIdentiifier",TestStepIntervalTime);
          SID2C_ClearDynamicallyDefinedDataIdentifier_withDID(DID_0x2C[i].DID,FUNCTIONAL);//清除
          CheckPosResponse_SID2C_ClearwithDID(DID_0x2C[i].DID,0,0);
          testWaitForTimeout(100);
          TestStep("Read out of dynamicallyDefinedDataIdentifier",TestStepIntervalTime);
          SID22_ReadDataByIdentifier(DID_0x2C[i].DID,FUNCTIONAL);//读取DID
          CheckNonResponse(0,0);
          testWaitForTimeout(100);
        }
        else if((gRss==NEG)&&(gTpRxData[2]==0x33))
        {
          continue;
        }
        else
        {
          CheckNegResponse(ExpectNRC,0,0,0,0);
          break;
        }
      }
    }
    
    for(i=0; i<NumOfDID2C; i++)
    {
      for(j=0;j<NumOfAddSup;j++)
      {
        TestStep("Dynamically Defined DataIdentifier)",TestStepIntervalTime);
        SID2C_DynamicallyDefinedDataIdentifier_Address_24(DID_0x2C[i].DID,Add_0x24[j].Address,Add_0x24[j].AddressLenth,PHYSICAL);//遍历DID的01子功能
        if(gRss==POS)
        {
          CheckPosResponse_SID2C_Address_24(DID_0x2C[i].DID,0,0);//检查肯定响应
          testWaitForTimeout(100);
          TestStep(":Read out of dynamicallyDefinedDataIdentifier",TestStepIntervalTime);
          SID22_ReadDataByIdentifier(DID_0x2C[i].DID,FUNCTIONAL);//读取DID
          CheckPosResponse_SID22(DID_0x2C[i].DID,4,0,0);//检查肯定响应
          testWaitForTimeout(100);
          TestStep("Clear dynamicallyDefinedDataIdentiifier",TestStepIntervalTime);
          SID2C_ClearDynamicallyDefinedDataIdentifier_withDID(DID_0x2C[i].DID,FUNCTIONAL);//清除
          CheckPosResponse_SID2C_ClearwithDID(DID_0x2C[i].DID,0,0);
          testWaitForTimeout(100);
          TestStep("Read out of dynamicallyDefinedDataIdentifier",TestStepIntervalTime);
          SID22_ReadDataByIdentifier(DID_0x2C[i].DID,FUNCTIONAL);//读取DID
          CheckNonResponse(0,0);
          testWaitForTimeout(100);
        }
        else if((gRss==NEG)&&(gTpRxData[2]==0x33))
        {
          continue;
        }
        else
        {
          CheckNegResponse(ExpectNRC,0,0,0,0);
          break;
        }
      }
    }
  }
  
  TestStep("Verify DefaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
