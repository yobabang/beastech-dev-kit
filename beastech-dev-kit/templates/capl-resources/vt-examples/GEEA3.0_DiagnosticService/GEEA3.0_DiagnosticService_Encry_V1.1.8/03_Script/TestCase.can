      continue;
    }
    if(Routine_Sub0x01[i].routinetype == 1)//筛选所有例程类型为1的例程
    {
      tem1 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        } 
      }
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      if( (gRss==NEG) && (gTpRxData[2]==0x22))
      {
        TestStepWarning("warning","Received NRC0x22 for Service 0x31,test next RID");
        continue;
      }
      testWaitForTimeout(2000);
      
      if(tem1 == 1)
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
      }
    }
    else if(Routine_Sub0x01[i].routinetype == 2)//筛选所有例程类型为2的例程
    {
      TestStepFail("Fail","Routine type should not be supported in default session , but RID %04x support",Routine_Sub0x01[i].DID);
    }
    else if(Routine_Sub0x01[i].routinetype == 3)//筛选所有例程类型为3的例程
    {
      TestStepFail("Fail","Routine type should not be supported in default session , but RID %04x support",Routine_Sub0x01[i].DID);
    }
    
  }
  
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
   

}
/// <APP_CommonServiceTest>
testcase Sercice_0x31_Valid_Physical_ExtendedSession_Supported_Service()
{
  byte PID[2];
  int  i,j,k;
  byte StuffByte[400];
  byte ExpectNRC[4]={0x33,0x22,0x70,0x10};
  int  NumOfLenth;
//  char Description[3000];
  char answer[100];
  byte Para[50];
  int tem1,tem2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350950_Sercice_0x31_Valid_Physical_ExtendedSession_Supported_Service",400);
  testCaseDescription("The intent is to verify that the service RoutineControl (0x31) and sub functions is supported. RoutineType on identifier will also be verified.");
  testCaseTitle("1350950","Sercice_0x31_Valid_Physical_ExtendedSession_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  TestStep("step1-Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TP_TesterPresentSet(TP_ON);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  ////判断0x31服务是否支持
  for(i=0;i<service_APP_Num;i++)
  {
    if(service_APP[i] == 0x31)
      break;
  }
  if(i==service_APP_Num)
  {
    TestStepWarning("ECU doesn't support this service , test case exit!");
    Postcondition();
     
    return;
  }
  
  for(i=0;i<NumOfRoutine_Sub0x01;i++)//遍历所有例程
  {
    if(Routine_Sub0x01[i].Flag_Ser03 != 1)
    {
      continue;
    }
    if(Routine_Sub0x01[i].routinetype == 1)//筛选所有例程类型为1的例程
    {
      tem1 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }  
      }
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      check_routine_type(1);
      if( (gRss==NEG) && (gTpRxData[2]==0x22))
      {
        TestStepWarning("warning","Received NRC0x22 for Service 0x31,test next RID");
        continue;
      }
      testWaitForTimeout(2000);
      
      if(tem1 == 1)
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        check_routine_type(1);
      }
      
    }
    else if(Routine_Sub0x01[i].routinetype == 2)//筛选所有例程类型为2的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }

      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);

      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);
  
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      check_routine_type(2);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      check_routine_type(2);
      if(gTpRxData[4]!= 0x22)
      {
        TestStepWarning("Chk","No 0x22 maybe routine has finished executing");
      }
      testWaitForTimeout(Routine_Sub0x01[i].runtime+10);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckPosOrNegResponse(0x24,0,0);//20250313 石太佳 这里修改为 NRC24 或者 正响应都可以

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
      }
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
    }
    else if(Routine_Sub0x01[i].routinetype == 3)//筛选所有例程类型为3的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }
      } 
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      check_routine_type(3);
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        check_routine_type(3);
        if(gTpRxData[4]!= 0x32)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem1 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
        check_routine_type(3);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }     
    }
  }
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}
/// <APP_CommonServiceTest>
testcase Sercice_0x31_Valid_Functional_ExtendedSession_Supported_Service()
{
  byte PID[2];
  int  i,j,k;
  byte StuffByte[400];
  byte ExpectNRC[4]={0x33,0x22,0x70,0x10};
  int  NumOfLenth;
  char Description[3000];
  char answer[100];
  byte Para[50];
  int tem1,tem2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350952_Sercice_0x31_Valid_Functional_ExtendedSession_Supported_Service",400);
  testCaseDescription("The intent is to verify that the service RoutineControl (0x31) and sub functions is supported. RoutineType on identifier will also be verified.");
  testCaseTitle("1350952","Sercice_0x31_Valid_Functional_ExtendedSession_Supported_Service");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  TestStep("step1-Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TP_TesterPresentSet(TP_ON);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  ////判断0x31服务是否支持
  for(i=0;i<service_APP_Num;i++)
  {
    if(service_APP[i] == 0x31)
      break;
  }
  if(i==service_APP_Num)
  {
    TestStepWarning("ECU doesn't support this service , test case exit!");
    Postcondition();
    return;
  }
  
  for(i=0;i<NumOfRoutine_Sub0x01;i++)//遍历所有例程
  {
    if(Routine_Sub0x01[i].Flag_Ser03 != 1)
    {
      continue;
    }
    if(Routine_Sub0x01[i].routinetype == 1)//筛选所有例程类型为1的例程
    {
      tem1 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }  
      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      if((gRss==NEG) && (gTpRxData[2]==0x22))
      {
        TestStepWarning("warning","Received NRC0x22 for Service 0x31,test next RID");
        continue;
      }
      
      testWaitForTimeout(2000);
      
      if(tem1 == 1)
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      }
    }
    else if(Routine_Sub0x01[i].routinetype == 2)//筛选所有例程类型为2的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }
      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }

      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {   
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      
      if(gTpRxData[4]!= 0x22)
      {
        TestStepWarning("Chk","No 0x22 maybe routine has finished executing");
      }
      testWaitForTimeout(Routine_Sub0x01[i].runtime+10);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Chk","Routine still not finished after running time timeout");
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
        CheckPosOrNegResponse(0x24,0,0);//这里修改为正响应 或者 NRC24都可以
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
      }
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Chk","Routine still not finished after running time timeout");
      }
    }
    else if(Routine_Sub0x01[i].routinetype == 3)//筛选所有例程类型为3的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }

      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x32)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem1 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
    }
  }
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}
