/// <Authentication_Test>
testcase Unidirectional_Authentication_Test()
{

  char logName[400] = "";
  char info[1024];
  
  byte OCSP_RID[2]={0x70,0x27};
  byte tempdata[5000];
  char errorMsg[500];
  byte challenge[32]={0xAD,0x95,0x37,0xF6,0xC8,0x04,0x56,0x99,0xCE,0x04,0x19,0x88,0x68,0x83,0xB3,0xA1};
  char hashFunction[10]="SHA-256";  
//  char testerCertName[300] = "Geely3.0";
  byte testerCertByte[2000];
  dword testerCertByteLength;
  char testerCertString[4000];
  byte ownerShip[1000];
  dword ownerShipLength;
  char ownerShipString[2000];
  dword i=0,tempI;
  
  strncat(logName,"1318670_Unidirectional_Authentication_Test",400);
  testCaseTitle("1318670","Unidirectional_Authentication_Test");
  
  if(gBusFlag==5&&EthNodeTypeNow==EdgeNode)
  {
    
  }
  else
  {
    testStepWarning("Warning","This test case is only applicable for ETH_Edgenode");
    return;
  }
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  
  checkAuthenticateState(Deauthenticated);
  
  SID29_Authentication_authenticationConfiguration(PHYSICAL);
  CheckPosResponse_SID29_authenticationConfiguration(0x2,0,0);
  
  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  
  ocspCheckSequence();
  
  SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
  CheckPosResponse_SID29_verifyCertificateUnidirectional(0x11,0x20,challenge,0,0,0);
  
  
  if(CreateOwnership(testerCertName, hashFunction, challenge, elcount(challenge), ownerShip, ownerShipLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  
  SID29_Authentication_proofOfOwnership(ownerShipLength,ownerShip,0,PHYSICAL);
  CheckPosResponse_SID29_proofOfOwnership(0x12,0,0);
  
  checkAuthenticateState(Authenticated);
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  checkAuthenticateState(Authenticated);
  
  TestStep("Transition from extendedDiagnosticSession(0x03) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  checkAuthenticateState(Authenticated);
  
  SID29_Authentication_deAuthenticate(PHYSICAL);
  CheckPosResponse_SID29_deAuthenticate(0x10,0,0);
  
  checkAuthenticateState(Deauthenticated);

  /******************************以上为测试步骤*********************************/
  Postcondition();
  
}

