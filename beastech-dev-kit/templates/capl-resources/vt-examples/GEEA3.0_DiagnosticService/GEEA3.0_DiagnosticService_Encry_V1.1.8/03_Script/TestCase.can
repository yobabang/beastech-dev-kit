  strncat(logName,"1350951_Sercice_0x31_Valid_Functional_DefaultSession_Supported_Service",400);
  testCaseDescription("The intent is to verify that the service RoutineControl (0x31) and sub functions is supported. RoutineType on identifier will also be verified.");
  testCaseTitle("1350951","Sercice_0x31_Valid_Functional_DefaultSession_Supported_Service");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
