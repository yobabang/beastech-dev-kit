/// <APP_SecurityAccessAlgorithm>
testcase DelayTimer_activated_at_every_start_APP()
{
  int i,j;
  float T3,T4,Delta;
  char logName[400] = "";
  char info[1024];
  message 0x1 TpRes;
  int counter=0;
  
  strncat(logName,"1088590_DelayTimer_activated_at_every_start_APP",400);
  testCaseTitle("1088590","DelayTimer_activated_at_every_start_APP");
  
  SetLog(logName);
  Precondition();
  
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  TPMsgInit(0);
  
  for(i=0; i<NumOfSecurityLv; i++)
  {
    if(i==0)
      TestStep("Let L1 = First security level from the configured security level array from configured list. ",TestStepIntervalTime);
    else
      TestStep("Start Test",TestStepIntervalTime);
    
    if(SELevel[i].SEFlagPBL == 1)
    {
      continue;
    }
    
    Level1=SELevel[i].SElevel;
    
    TestStep("SEInfo","SELevel1 is %02x",Level1);

    SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_TRUE);
    testWaitForTimeout(ECUIniTime);
    
    SessionFlag=BOOT;
    TestStep("Verify programmingSession",TestStepIntervalTime);
    CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
    
    TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    SessionFlag=APP;
    TestStep("ECU reset");
    if((gBusFlag==1)||(gBusFlag==2))
    {
      msgF186.id=gCAN_RequestID;
      TestStep("10ms cycle send 22 F1 86");
      T4 = timeNowFloat()/10000;
      setTimerCyclic(SendF186,10);
//      output(msgF186);

      //write("Response ID is %03x",ResponseID);
      while(counter<1000)
      {
        counter++;
        testJoinMessageEvent(gCAN_ResponseID);
        if(TestWaitForAnyJoinedEvent(10)>0)
        {
          testGetWaitEventMsgData(TpRes);
//          write("byte(1)=%x,byte(4)=%x",TpRes.byte(1),TpRes.byte(4));
          if((TpRes.byte(1)==0x62)&&(TpRes.byte(4)==0x01))
          {
            T3 = timeNowFloat()/10000;
            break;
          }
        }
      }
      cancelTimer(SendF186);
      if(counter==1000)
      {
        TestStepFail("","ECU Reset timeout");
      }
      else
      {
        Delta = (T3-T4)*100;
        TestStep("","**********\nThe ECU reset time is %f ms\n**********",Delta);
      }
      counter=0;
    }
    else
    {
      ECUinitHandle(0);
    }
    testWaitForTimeout(10);
    TestStep("Verify defaultSession.",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    
    TestStep("Transition to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    TestStep("Repet the above steps with other level again",TestStepIntervalTime);
  }
  for(i=0; i<NumOfSecurityLv; i++)
  {
    if(SELevel[i].SEFlagPBL == 1)
    {
      continue;
    }
    
    Level1=SELevel[i].SElevel;
    
    
    TestStep("SEInfo","SELevel1 is %02x",Level1);
    
    SessionFlag=APP;
    TestStep("Transition to ExtendedSession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    TestStep("Verify ExtendedSession",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
 
    
    TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
    SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID11(HARDRESET,0,0);
    
    
    SessionFlag=APP;
    TestStep("ECU reset");
    if((gBusFlag==1)||(gBusFlag==2))
    {
      msgF186.id=gCAN_RequestID;
      TestStep("10ms cycle send 22 F1 86");
      T4 = timeNowFloat()/10000;
      setTimerCyclic(SendF186,10);

      
      //write("Response ID is %03x",ResponseID);
      while(counter<1000)
      {
        counter++;
        testJoinMessageEvent(gCAN_ResponseID);
        if(TestWaitForAnyJoinedEvent(10)>0)
        {
          testGetWaitEventMsgData(TpRes);
          if((TpRes.byte(1)==0x62)&&(TpRes.byte(4)==0x01))
          {
            T3 = timeNowFloat()/10000;
            break;
          }
        }
      }
      cancelTimer(SendF186);
      if(counter==1000)
      {
        TestStepFail("","ECU Reset timeout");
      }
      else
      {
        Delta = (T3-T4)*100;
        TestStep("","**********\nThe ECU reset time is %f ms\n**********",Delta);
      }
      counter=0;
    }
    else
    {
      ECUinitHandle(0);
    }
    testWaitForTimeout(10);
    TestStep("Verify defaultSession.");
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    
    TestStep("Transition to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    
    TestStep("Repet the above steps with other level again",TestStepIntervalTime);
  }
  /******************************以上为测试步骤*********************************/
  Postcondition(); 
}

/// <PBL_SecurityAccessAlgorithm>
testcase ReadOfSecurityConstant_PBL()
{
  byte DID[2] = {0xF1,0x09};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1023154_ReadOfSecurityConstant_PBL",400);
  testCaseTitle("1023154","ReadOfSecurityConstant_PBL");
  
  
  SetLog(logName);
  Precondition();
  SessionFlag=APP;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  TestStep("Read security constant",TestStepIntervalTime);
  SID22_ReadDataByIdentifier(DID,PHYSICAL);
  CheckNegResponse(0x31,0,0);
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  Postcondition();
}
/// <PBL_SecurityAccessAlgorithm>
testcase DelayTimerAfterFalseAttempts_PBL()
{
  int i,B;
  dword t;
  int N = 2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1023155_DelayTimerAfterFalseAttempts_PBL",400);
  testCaseTitle("1023155","DelayTimerAfterFalseAttempts_PBL");
  
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;

  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  Level1=0x01;  
  testWaitForTimeout(gTimeWaitForSecuAccess);
 //1) Test no delay after N-1 false attempts:
  for(B=0; B<N-1; B++)
  {
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckNegResponse(0x35,0,0);
  }
  
  TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  TestStep("ECU unlock.",TestStepIntervalTime);
  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(Level1,0,0);
  
  //2) Test the delay timer after false attempts:
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  for(B=0; B<N; B++)
  {
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    if(B != N-1)
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
    }
    else
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x36,0,0);
    }
  }
  
  for(t=0; t<DelayTimer;)
  {
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckNegResponse(0x37,0,0);
    t = t + 1005;
    testWaitForTimeout(1005);
  }
  
  testWaitForTimeout(65);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(Level1,0,0);
  
  TestStep("===Below steps is to verify false attempts counter shall be reset to zero after ECU reset===");
  
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  for(B=0; B<N-1; B++)
  {
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    if(B != N-1)
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
    }
    else
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x36,0,0);
    }
  }
  testWaitForTimeout(50);//增加50ms延时
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);

  ECUinitHandle(0);
  
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  for(B=0; B<N; B++)
  {
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    if(B != N-1)
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
    }
    else
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x36,0,0);
    }
  }
  
  testWaitForTimeout(DelayTimer+2000);

  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(Level1,0,0);
  
  TestStep("===Below steps is to verify Delay timer will not lost after ECU Reset===");
  
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  for(B=0; B<N; B++)
  {
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    if(B != N-1)
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
    }
    else
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x36,0,0);
    }
  }
  testWaitForTimeout(50);//增加50ms延时
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);

  ECUinitHandle(0);
  
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckNegResponse(0x37,0,0);
//  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
//  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
//  
//  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
//  CheckNegResponse(0x37,0,0);
  
  delaywithreq(DelayTimer+2000);
  
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(Level1,0,0);
  
  TestStep("===Below steps is to verify false attempts counter will return 0 after Delay timer time-out===");
  
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  
  for(B=0; B<N; B++)
  {
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    if(B != N-1)
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
    }
    else
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x36,0,0);
    }
  }
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckNegResponse(0x37,0,0);
  
  delaywithreq(DelayTimer+100);
  
  for(B=0; B<N-1; B++)
  {
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    if(B != N-1)
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0);
    }
    else
    {
      SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x36,0,0);
    }
  }
  delaywithreq(DelayTimer+2000);
  
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(Level1,0,0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);

  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
