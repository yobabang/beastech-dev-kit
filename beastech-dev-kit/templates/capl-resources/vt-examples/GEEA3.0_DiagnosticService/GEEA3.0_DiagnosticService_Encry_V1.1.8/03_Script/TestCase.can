      SID2F_IOControl(PID,0x03,ControlOptionRecord,NumOfLenth,ControlEnableMaskRecord,0,PHYSICAL);
      if(IODID[i].AuthenticationFlag != 1)
      {
        CheckPosResponse(0x2F,0,0);
      }
      else
