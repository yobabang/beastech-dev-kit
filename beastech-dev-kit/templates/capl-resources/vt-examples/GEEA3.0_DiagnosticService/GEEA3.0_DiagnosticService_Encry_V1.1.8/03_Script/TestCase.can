/// <PBL_GeneralTest>
testcase ECU_Identification_Verification_Test_Physical_ProgrammingSession()
{
  dword MulDID[6]= {0xF18C,0xF121,0xF125,0xF12A,0xF12B,0xEDA0};
  int  i;
  byte PID[2];
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1022511_ECU_Identification_Verification_Test_Physical_ProgrammingSession",400);
  testCaseDescription("The intent is to verify that the ECU support mandatory Identification dataIdentifiers.");
  testCaseTitle("1022511","ECU_Identification_Verification_Test_Physical_ProgrammingSession");
  
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  for(i=0;i<6;i++)
  {
    if(i==0)
    {
      TestStep("Let Z1 Z2 = First dataIdentifier from table Mandatory DIDs in PBL, NN = data size of the identifier stated in table.",TestStepIntervalTime);
    }
    else
    {
      TestStep("Jump to Step 4 until all the dataIdentifiers in table Mandatory DIDs in PBL are tested. Let Z1 Z2 = next dataIdentifier, NN = data size of the identifier stated in table.",TestStepIntervalTime,4);
    }
    PID[0]=MulDID[i]>>8;
    PID[1]=MulDID[i]&0xFF;
    
    TestStep("Request multiple DIDs",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse(0x22,0,0);
  }
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
