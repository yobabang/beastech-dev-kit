  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Send 3E 00",TestStepIntervalTime);
  SID3E_TesterPresent(PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID3E(0x00,2);
  TestStep("Send 3E 80",TestStepIntervalTime);
  SID3E_TesterPresent(PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
