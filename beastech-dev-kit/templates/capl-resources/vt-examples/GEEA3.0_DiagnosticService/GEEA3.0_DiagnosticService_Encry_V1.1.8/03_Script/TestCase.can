  //SID2A_ReadDataByPeriodicIdentifier(SendAtMediumRate,Service_2A_DataIdentifer,PHYSICAL);
  CheckPosResponse_SID2A(0,0);
  
  TestStep("Verify that the frames use supported periodical response address according to configured list",TestStepIntervalTime);
  //CheckPeriodicID(PeriodicID,5000);
  TestStep("step11-13:Periodic read out from the defined DataIdentifier.TransmissionMode = fast",TestStepIntervalTime);
  //SID2A_ReadDataByPeriodicIdentifier(SendAtFastRate,Service_2A_DataIdentifer,PHYSICAL);
  CheckPosResponse_SID2A(0,0);
  
  TestStep("Verify that the frames use supported periodical response address according to configured list",TestStepIntervalTime);
  //CheckPeriodicID(PeriodicID,5000);
  TestStep("step14-15:Periodic read out from the defined DataIdentifier.TransmissionMode = stop",TestStepIntervalTime);
  //SID2A_ReadDataByPeriodicIdentifier(StopSending,Service_2A_DataIdentifer,PHYSICAL);
  CheckPosResponse_SID2A(0,0);
  
  TestStep("Confirm extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
