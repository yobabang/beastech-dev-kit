/// <石太佳>
int check_DID_is_22_DID(byte PID[])
/*
    20240214石太佳：检查DID是否22服务可以读的DID
    
*/
{
  
  int i;
  
  for(i=0;i<NumOfReadDIDAPP;i++)
  {
     if ((dword)(PID[0]*256+ PID[1])==DIDOfReadAPP[i].DID)
     {
          return 1; 
     }
    
  }
  return 0;
  
}

void set_trc_valid()
{
  int j;
  char info[1024];
  int i,k;
    /* 获取所有待测信号的数量并将信号值设置成有效值 */
  for(i=0;i<E2E_FRAME_NUM;i++) 
  { 
  	for(j=0;j<elcount(e2eFrameList[i].e2eSigGroupList);j++)
  	{
  		if(strncmp(e2eFrameList[i].e2eSigGroupList[j].sigGroupName,"",elcount(e2eFrameList[i].e2eSigGroupList[j].sigGroupName)) == 0) { break; }
  		else
  		{
  			for(k=0;k<e2eFrameList[i].e2eSigGroupList[j].sigNum;k++)
  			{
  				if(e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigUsed & SIGNALPROGRAMMING == SIGNALPROGRAMMING) 
          { 
            snprintf(info,elCount(info),"%s%s = %02X(Fulfilled)\n",info,e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigName,
  					e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_Fulfilled);
            e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue = e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_Fulfilled;
            e2eFrameList[i].simFrFlg = 1; e2eFrameList[i].simFrImtFlg = 1;
            //count++; 
          }
  			}
  		}
  	}
  }





}

/// <APP_CommonServiceTest>
testcase Service_0x10_Valid_Physical_All_Sessions_Supported_Service()
{
  char logName[400] = "";
  byte ExpectNRC[2]={0x12,0x7E};
  char info[1024];
  
  strncat(logName,"1350868_Service_0x10_Valid_Physical_All_Sessions_Supported_Service_R2",400);
  testCaseDescription("The intent is to verify that the ECU can transition between different session, with service DiagnosticSessionControl (0x10). The test will also verify that the sessionParameterRecord is correct.");
  testCaseTitle("1350868","Service_0x10_Valid_Physical_All_Sessions_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  gflag_check_ecu_init_time = 1;
  
  TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from defaultSession(0x01) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify defaultSession(0x01)",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  TestStep("Transition to programmingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify programmingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  SessionFlag=APP;
  
  TestStep("Transition from programmingSession(0x02) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to programmingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify programmingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  SessionFlag=APP;
  
  TestStep("Transition from programmingSession(0x02) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x03) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x03) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x03) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  
  TestStep("Transition from extendedDiagnosticSession(0x03) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to extendedDiagnosticSession(0x03) is not allowed",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckNegResponse(ExpectNRC,0,0,0,0);
  if(gRss!=NEG)
  {
    TestStepFail("Fail","ERROR:Unexpected response, testcase ends");
    PostCondition();
    return;
  }
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNegResponse(ExpectNRC,0,0,0,0);
  if(gRss!=NEG)
  {
    TestStepFail("Fail","ERROR:Unexpected response, testcase ends");
    PostCondition();
    return;
  }
  
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  SessionFlag=APP;
  
  TestStep("Transition from ProgrammingSession(0x02) to DefaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from DefaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  
  TestStep("Transition from extendedDiagnosticSession(0x03) to ProgrammingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  SessionFlag=APP;
  
  TestStep("Transition from ProgrammingSession(0x02) to defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  ECUinitHandle(0);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from DefaultSession(0x01) to DefaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);

  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from DefaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Transition from extendedDiagnosticSession(0x01) to DefaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    
  gflag_check_ecu_init_time = 0;
  /******************************以上为测试步骤*********************************/
  PostCondition();
}

/// <APP_CommonServiceTest>
testcase Service_0x10_Valid_Functional_All_Sessions_Supported_Service()
{
  char logName[400] = "";
  byte ExpectNRC[2]={0x12,0x7E};
  char info[1024];
  
  strncat(logName,"1350869_Service_0x10_Valid_Functional_All_Sessions_Supported_Service_R2",400);
  testCaseDescription("The intent is to verify that the ECU can transition between different session, with service DiagnosticSessionControl (0x10). The test will also verify that the sessionParameterRecord is correct.");
  testCaseTitle("1350869","Service_0x10_Valid_Functional_All_Sessions_Supported_Service");
	if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
