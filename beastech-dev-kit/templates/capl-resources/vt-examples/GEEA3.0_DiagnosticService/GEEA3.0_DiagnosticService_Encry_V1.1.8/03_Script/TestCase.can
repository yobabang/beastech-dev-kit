/// <APP_CommonServiceTest>
testcase Sercice_0x2F_Valid_Physical_ExtendedDiagnosticSession_Supported_Service()
{
  byte PID[2];
  int  i,g;
  byte ExpectNRC[4]={0x33,0x22,0x70,0x10};
  int  NumOfLenth;
  char Description[3000];
  char answer[100];
  byte ControlOptionRecord[50];
  byte ControlEnableMaskRecord[2];
  int tem1,tem2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350947_Sercice_0x2F_Valid_Physical_ExtendedDiagnosticSession_Supported_Service",400);
  testCaseDescription("The intent is to verify service InputOutputControlByIdentifier (0x2F) and sub function freezeCurrentState (0x02),returnControlToECU (0x00) and shortTermAdjustment (0x03) is supported in extendedDiagnosticSession");
  testCaseTitle("1350947","Sercice_0x2F_Valid_Physical_ExtendedDiagnosticSession_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  for(i=0;i<service_APP_Num;i++)
  {
    if(service_APP[i] == 0x2F)
      break;
    
    if(i==(service_APP_Num-1))
    {
    TestStepWarning("ECU doesn't support this service , test case exit!");
    Postcondition();
     
    return;
    }
    
  }
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  for(i=0; i<NumOfIO; i++)
  {
    PID[0]=IODID[i].DID>>8;
    PID[1]=IODID[i].DID&0xFF;
    
    if(IODID[i].SelectFlag != 1)
    {
      continue;
    }
    else
    {
      NumOfLenth = IODID[i].RequestLenth;
    }
    
    if(IODID[i].SecuLevel!=0xFF)
      {
        
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(IODID[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(IODID[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(IODID[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(IODID[i].SecuLevel,0,0);
      
      }
//
    if(IODID[i].Flag_Ser03==1)
    {
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,IODID[i].requestData,0,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
      
      TestStep("Short term adjustment",TestStepIntervalTime);
      SID2F_IOControl(PID,0x03,IODID[i].requestData,NumOfLenth,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x03,PID,0,0);
      
      TestStep("Short term adjustment",TestStepIntervalTime);
      SID2F_IOControl(PID,0x03,IODID[i].requestData,NumOfLenth,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x03,PID,0,0);
      
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,IODID[i].requestData,0,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
    }
    
    if(IODID[i].Flag_Ser02==1)
    {
      TestStep("freeze current state",TestStepIntervalTime);
      SID2F_IOControl(PID,0x02,IODID[i].requestData,NumOfLenth,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x02,PID,0,0);
      
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,IODID[i].requestData,0,ControlEnableMaskRecord,0,PHYSICAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
    }
  }

  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <APP_CommonServiceTest>
testcase Sercice_0x2F_Valid_Functional_ExtendedDiagnosticSession_Supported_Service()
{
  byte PID[2];
  int  i,g;
  byte ExpectNRC[4]={0x33,0x22,0x70,0x10};
  int  NumOfLenth;
  char Description[3000];
  char answer[100];
  byte ControlOptionRecord[50];
  byte ControlEnableMaskRecord[2];
  int tem1,tem2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350948_Sercice_0x2F_Valid_Functional_ExtendedDiagnosticSession_Supported_Service",400);
  testCaseDescription("The intent is to verify service InputOutputControlByIdentifier (0x2F) and sub function freezeCurrentState (0x02),returnControlToECU (0x00) and shortTermAdjustment (0x03) is supported in extendedDiagnosticSession");  
  testCaseTitle("1350948","Sercice_0x2F_Valid_Functional_ExtendedDiagnosticSession_Supported_Service");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
 
  SessionFlag=APP;
  
  for(i=0;i<service_APP_Num;i++)
  {
    if(service_APP[i] == 0x2F)
      break;
    
    if(i==(service_APP_Num-1))
    {
    TestStepWarning("ECU doesn't support this service , test case exit!");
    Postcondition();
     
    return;
    }
    
  }
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  for(i=0; i<NumOfIO; i++)
  {
    PID[0]=IODID[i].DID>>8;
    PID[1]=IODID[i].DID&0xFF;
    
    if(IODID[i].SelectFlag != 1)
    {
      continue;
    }
    else
    {
      NumOfLenth = IODID[i].RequestLenth;
    }
    if(IODID[i].SecuLevel!=0xFF)
    {
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      testWaitForTimeout(gTimeWaitForSecuAccess);
      SID27_SecurityAccess_RequestSeed(IODID[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(IODID[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(IODID[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(IODID[i].SecuLevel,0,0); 
    }
    if(IODID[i].Flag_Ser03==1)
    {
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,IODID[i].requestData,0,ControlEnableMaskRecord,0,FUNCTIONAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
      
      TestStep("Short term adjustment",TestStepIntervalTime);
      SID2F_IOControl(PID,0x03,IODID[i].requestData,NumOfLenth,ControlEnableMaskRecord,0,FUNCTIONAL);
      CheckPosResponse_SID2F(0x03,PID,0,0);
      
      TestStep("Short term adjustment",TestStepIntervalTime);
      SID2F_IOControl(PID,0x03,IODID[i].requestData,NumOfLenth,ControlEnableMaskRecord,0,FUNCTIONAL);
      CheckPosResponse_SID2F(0x03,PID,0,0);
      
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,IODID[i].requestData,0,ControlEnableMaskRecord,0,FUNCTIONAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
    }
    if(IODID[i].Flag_Ser02==1)
    {
      TestStep("freeze current state",TestStepIntervalTime);
      SID2F_IOControl(PID,0x02,IODID[i].requestData,NumOfLenth,ControlEnableMaskRecord,0,FUNCTIONAL);
      CheckPosResponse_SID2F(0x02,PID,0,0);
      
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,IODID[i].requestData,0,ControlEnableMaskRecord,0,FUNCTIONAL);
      CheckPosResponse_SID2F(0x00,PID,0,0);
    }
  }

  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}
