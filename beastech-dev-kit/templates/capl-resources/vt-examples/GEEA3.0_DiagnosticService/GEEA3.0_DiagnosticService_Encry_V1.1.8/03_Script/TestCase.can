  SessionFlag=APP;
  
  DesFlag = 0;
  DesFlag2 = 0;
  snprintf(Description,400,"The following DIDs gives wrong length for service 0x22:");
  snprintf(Description2,400,"The following DIDs gives unexpected negative response for service 0x22:");
  
  TestStep("Let Z1 Z2= First Dataidentifier from configured list.",TestStepIntervalTime);
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  //添加步骤，在未进行安全解锁的时候发送读安全日志相关的DID，期望回复负相应。
  CheckUnlockReadDID_ResponseNRC(FUNCTIONAL);
  // 
  
  for(i=0; i<NumOfReadDIDAPP; i++)
  {
    if(DIDOfReadAPP[i].Flag_Extended==0)
    {
      continue;
    }
    PID[0]=DIDOfReadAPP[i].DID>>8;
    PID[1]=DIDOfReadAPP[i].DID&0xFF;
    
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C))
    {
      continue;
    }
    if((PID[0] == 0xD0)&&(PID[1] == 0x3A))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x09))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0B))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0A))
    {
      continue;
    }
    
    if(i!=0)
    {
      TestStep("Jump to Step 4 until all the dataIdentifiers in the configured list are tested. Let Z1 Z2 = next dataIdentifier",TestStepIntervalTime,4);
    }
    
    if(DIDOfReadAPP[i].SecuLevel!=0xFF)
    {
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(DIDOfReadAPP[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(DIDOfReadAPP[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(DIDOfReadAPP[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(DIDOfReadAPP[i].SecuLevel,0,0);
    }
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    if((PID[0] == 0xD0)&&(PID[0] == 0x1C))
    {
     testWaitForTimeout(500);
    }
    else
    {
     Result=CheckPosResponse_SID22(PID,DIDOfReadAPP[i].Lenth,0,0); 
    }
    if(Result>0)
    {
      CheckParametersCoding(DIDOfReadAPP[i]);
      if(DIDOfReadAPP[i].Lenth != (gTpRxLength-3))
      {
        DesFlag = 1;
        snprintf(TemDescription,400,"[%02x %02x] ,",PID[0],PID[1]);
        strncat(Description,TemDescription,5000);
        TestStepFail("","Expect lenth is %d but get lenth is %d",DIDOfReadAPP[i].Lenth,gTpRxLength-3);
      }
      else
      {
        TestStepPass("","Expect lenth is %d and get lenth is %d",DIDOfReadAPP[i].Lenth,gTpRxLength-3);
      }
    }
    else
    {
      DesFlag2 = 1;
      snprintf(TemDescription,400,"[%02x %02x] ,",PID[0],PID[1]);
      strncat(Description2,TemDescription,5000);
    }
  }
  
  DesFlag1 = 0;
  snprintf(Description1,400,"The following DIDs gives wrong response for service 0x2E:");
  
  for(i=0;i<NumOfWriteDIDAPP;i++)
  {
    if(DIDOfWriteAPP[i].Flag_Extended==0)
    {
      continue;
    }
    PID[0]=DIDOfWriteAPP[i].DID>>8;
    PID[1]=DIDOfWriteAPP[i].DID&0xFF;
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C))
    {
      continue;
    }
    if((PID[0] == 0xD0)&&(PID[1] == 0x3A))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x09))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0B))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0A))
    {
      continue;
    }
    
    if(DIDOfWriteAPP[i].SecuLevel!=0xFF)
    {
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(DIDOfWriteAPP[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(DIDOfWriteAPP[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(DIDOfWriteAPP[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(DIDOfWriteAPP[i].SecuLevel,0,0);
    }
    
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    CheckPosResponse_SID22(PID,DIDOfWriteAPP[i].Lenth,0,0);
    RecordData();
    TestStep("Write data",TestStepIntervalTime);
    WriteTestData(DIDOfWriteAPP[i],FUNCTIONAL);
    if(CheckNegResponse(ExpectNRC,1,0,0,0)==0)
    {
      TestStep("The DID is not writable in active session.",TestStepIntervalTime);
      continue;
    }
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    CheckPosResponse_SID22(PID,DIDOfWriteAPP[i].Lenth,0,0);
    ComTestData();
    testWaitForTimeout(1000);
    
    SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID11(HARDRESET,0,0);
    
    ECUinitHandle(0);
    
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    if(DIDOfWriteAPP[i].SecuLevel!=0xFF)
    {
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(DIDOfWriteAPP[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(DIDOfWriteAPP[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(DIDOfWriteAPP[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(DIDOfWriteAPP[i].SecuLevel,0,0);
    }
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    CheckPosResponse_SID22(PID,DIDOfWriteAPP[i].Lenth,0,0);
    
    ComTestData();
    
    WritePreviousData(FUNCTIONAL);
    CheckPosResponse_SID2E(PID,0,0);
    
    //TestStep("Data recover",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWriteAPP[i].Lenth,0,0);
  }
  
  if(DesFlag == 1)
  {
    TestStep(Description);
  }
  if(DesFlag1 == 1)
  {
    TestStep(Description1);
  }
  if(DesFlag2 == 1)
  {
    TestStep(Description2);
  }
  
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <APP_CommonServiceTest>
testcase Sercice_0x23_ReadMemoryByAddress_Supported_DefaultSession_Physical()
{
  int i;
  dword S23DataAddress;
  dword S23DataLength;
  byte AddressByte[4];
  byte LengthByte[4];
  dword offset;
  char logName[400] = "";
  char info[1024];
  byte DID[2];
  word index = 5;
  byte tempStorage;
  
  word Ser23MemorySegmentNum_A=4;
  struct MemoryAddressLength Ser23Memory_A[500];
  
  strncat(logName,"1022413_Sercice_0x23_ReadMemoryByAddress_Supported_DefaultSession_Physical",400);
  testCaseDescription("Verify Service ReadMemoryByAddress (0x23) is supported."); 
  testCaseTitle("1022413","Sercice_0x23_ReadMemoryByAddress_Supported_DefaultSession_Physical");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  tempStorage=Ser23TestAutomated;
  DID[0]=0xD1;
  DID[1]=0x22;
  {
    int result;
    result = CheckDIDSupported(0xD122,DIDOfReadAPP);
    if(result != -1 && Ser23TestAutomated == 0) 
    {
      if(DIDOfReadAPP[result].Flag_Default == 0) { testStepWarning("Warning","0x%X%X can't be read in defaultSession!!!",DID[0],DID[1]); }
      else { Ser23TestAutomated = 1; }
    }
  }
  if(Ser23TestAutomated==1)
  {
    SID22_ReadDataByIdentifier(DID,PHYSICAL);
    if(CheckPosResponse_SID22(DID,0,0)!=2)
    {
      testStepFail("Fail","Read %X%X error,it is a issue",DID[0],DID[1]);
      //Ser23TestAutomated=0;
    }
    else
    {
      if(gTpRxData[4] != 0x14) { testStepFail("Fail","0x%X%X AddressAndLengthFormatIdentifier is %X not 0x14",DID[0],DID[1],gTpRxData[4]); }
      if((gTpRxLength-5)%5==0)
      {
        Ser23MemorySegmentNum_A=gTpRxData[3];
        if(gTpRxLength==(5+Ser23MemorySegmentNum_A*5))
        {
          index=5;
          for(i=0;i<Ser23MemorySegmentNum_A;i++)
          {
            Ser23Memory_A[i].Length=gTpRxData[index];
            Ser23Memory_A[i].Address=gTpRxData[index+1]<<24|gTpRxData[index+2]<<16|gTpRxData[index+3]<<8|gTpRxData[index+4];
            index+=5;
          }
        }
        else
        {
          testStepFail("Fail","%X%X format error",DID[0],DID[1]);
          //Ser23TestAutomated=0;
        }
      }
      else
      {
        testStepFail("Fail","%X%X format error",DID[0],DID[1]);
        //Ser23TestAutomated=0;
      }
    }
    if(Ser23TestAutomated==1)
    {
      for(i=0; i<Ser23MemorySegmentNum_A; i++)
      {
        offset=0;
        do
        {
          S23DataAddress=Ser23Memory_A[i].Address+offset;
          if((Ser23Memory_A[i].Length-offset)>=0xFF)
          {
            S23DataLength=0xFF;
            offset=offset+0xFF;
          }
          else
          {
            S23DataLength=Ser23Memory_A[i].Length-offset;
            offset=offset+S23DataLength;
          }
          
          AddressByte[3]=S23DataAddress;
          AddressByte[2]=S23DataAddress>>8;
          AddressByte[1]=S23DataAddress>>16;
          AddressByte[0]=S23DataAddress>>24;
          
  //        LengthByte[3]=S23DataLength;
  //        LengthByte[2]=S23DataLength>>8;
  //        LengthByte[1]=S23DataLength>>16;
          LengthByte[0]=S23DataLength;
           
          SID23_ReadMemoryByAdress(0x14,AddressByte,LengthByte,PHYSICAL);
          CheckPosResponse_SID23(S23DataLength,0,0);
          write("Ser23Memory_A[i].Length-offset=%x",Ser23Memory_A[i].Length-offset);
           
        }
        while((Ser23Memory_A[i].Length-offset)>0xFF);
      }
    }
  }
  
  if(Ser23AddLen14Supported==1&&Ser23TestAutomated==0)
  {
    for(i=0; i<Ser23MemorySegmentNum; i++)
    {
      offset=0;
      do
      {
        S23DataAddress=Ser23Memory[i].Address+offset;
        if((Ser23Memory[i].Length-offset)>=0xFF)
        {
          S23DataLength=0xFF;
          offset=offset+0xFF;
        }
        else
        {
          S23DataLength=Ser23Memory[i].Length-offset;
          offset=offset+S23DataLength;
        }
        
        AddressByte[3]=S23DataAddress;
        AddressByte[2]=S23DataAddress>>8;
        AddressByte[1]=S23DataAddress>>16;
        AddressByte[0]=S23DataAddress>>24;
        
//        LengthByte[3]=S23DataLength;
//        LengthByte[2]=S23DataLength>>8;
//        LengthByte[1]=S23DataLength>>16;
        LengthByte[0]=S23DataLength;
         
        SID23_ReadMemoryByAdress(0x14,AddressByte,LengthByte,PHYSICAL);
        CheckPosResponse_SID23(S23DataLength,0,0);
        write("Ser23Memory[i].Length-offset=%x",Ser23Memory[i].Length-offset);
         
      }
      while((Ser23Memory[i].Length-offset)>0xFF);
    }
  }
  
  Ser23TestAutomated=tempStorage;
  
  DID[0]=0xD1;
  DID[1]=0x23;
  {
    int result;
    result = CheckDIDSupported(0xD123,DIDOfReadAPP);
    if(result != -1 && Ser23TestAutomated == 0) 
    {
      if(DIDOfReadAPP[result].Flag_Default == 0) { testStepWarning("Warning","0x%X%X can't be read in defaultSession!!!",DID[0],DID[1]); }
      else { Ser23TestAutomated = 1; }
    }
  }
  if(Ser23TestAutomated==1)
  {
    SID22_ReadDataByIdentifier(DID,PHYSICAL);
    if(CheckPosResponse_SID22(DID,0,0)!=2)
    {
      testStepFail("Fail","Read %X%X error",DID[0],DID[1]);
      //Ser23TestAutomated=0;
    }
    else
    {
      if(gTpRxData[4] != 0x24) { testStepFail("Fail","0x%X%X AddressAndLengthFormatIdentifier is %X not 0x24",DID[0],DID[1],gTpRxData[4]); }
      if((gTpRxLength-5)%6==0)
      {
        Ser23MemorySegmentNum_A=gTpRxData[3];
        if(gTpRxLength==(5+Ser23MemorySegmentNum_A*6))
        {
          index=5;
          for(i=0;i<Ser23MemorySegmentNum_A;i++)
          {
            Ser23Memory_A[i].Length=gTpRxData[index]<<8|gTpRxData[index+1];
            Ser23Memory_A[i].Address=gTpRxData[index+2]<<24|gTpRxData[index+3]<<16|gTpRxData[index+4]<<8|gTpRxData[index+5];
            index+=6;
          }
        }
        else
        {
          testStepFail("Fail","%X%X format error",DID[0],DID[1]);
          //Ser23TestAutomated=0;
        }
      }
      else
      {
        testStepFail("Fail","%X%X format error",DID[0],DID[1]);
        //Ser23TestAutomated=0;
      }
    }
    if(Ser23TestAutomated==1)
    {
      for(i=0; i<Ser23MemorySegmentNum_A; i++)
      {
        offset=0;
        do
        {
          S23DataAddress=Ser23Memory_A[i].Address+offset;
          if((Ser23Memory_A[i].Length-offset)>ReadMaxLen)
          {
            S23DataLength=ReadMaxLen;
            offset=offset+ReadMaxLen;
          }
          else
          {
            S23DataLength=Ser23Memory_A[i].Length-offset;
            offset=offset+S23DataLength;
          }
          
          AddressByte[3]=S23DataAddress;
          AddressByte[2]=S23DataAddress>>8;
          AddressByte[1]=S23DataAddress>>16;
          AddressByte[0]=S23DataAddress>>24;
          
        //        LengthByte[3]=S23DataLength;
        //        LengthByte[2]=S23DataLength>>8;
          LengthByte[1]=S23DataLength;
          LengthByte[0]=S23DataLength>>8;
           
          SID23_ReadMemoryByAdress(0x24,AddressByte,LengthByte,PHYSICAL);
          CheckPosResponse_SID23(S23DataLength,0,0);
          write("Ser23Memory[i].Length-offset=%x",Ser23Memory_A[i].Length-offset);
           
        }
        while((Ser23Memory_A[i].Length-offset)>ReadMaxLen);
      }
    }
  }
  
  if(Ser23AddLen24Supported==1&&Ser23TestAutomated==0)
  {
    for(i=0; i<Ser23MemorySegmentNum; i++)
    {
      offset=0;
      do
      {
        S23DataAddress=Ser23Memory[i].Address+offset;
        if((Ser23Memory[i].Length-offset)>ReadMaxLen)
        {
          S23DataLength=ReadMaxLen;
          offset=offset+ReadMaxLen;
        }
        else
        {
          S23DataLength=Ser23Memory[i].Length-offset;
          offset=offset+S23DataLength;
        }
        
        AddressByte[3]=S23DataAddress;
        AddressByte[2]=S23DataAddress>>8;
        AddressByte[1]=S23DataAddress>>16;
        AddressByte[0]=S23DataAddress>>24;
        
//        LengthByte[3]=S23DataLength;
//        LengthByte[2]=S23DataLength>>8;
        LengthByte[1]=S23DataLength;
        LengthByte[0]=S23DataLength>>8;
         
        SID23_ReadMemoryByAdress(0x24,AddressByte,LengthByte,PHYSICAL);
        CheckPosResponse_SID23(S23DataLength,0,0);
        write("Ser23Memory[i].Length-offset=%x",Ser23Memory[i].Length-offset);
         
      }
      while((Ser23Memory[i].Length-offset)>ReadMaxLen);
    }
  }
  
  Ser23TestAutomated=tempStorage;
  
  DID[0]=0xD1;
  DID[1]=0x24;
  {
    int result;
    result = CheckDIDSupported(0xD124,DIDOfReadAPP);
    if(result != -1 && Ser23TestAutomated == 0) 
    {
      if(DIDOfReadAPP[result].Flag_Default == 0) { testStepWarning("Warning","0x%X%X can't be read in defaultSession!!!",DID[0],DID[1]); }
      else { Ser23TestAutomated = 1; }
    }
  }
  if(Ser23TestAutomated==1)
  {
    SID22_ReadDataByIdentifier(DID,PHYSICAL);
    if(CheckPosResponse_SID22(DID,0,0)!=2)
    {
      testStepFail("Fail","Read %X%X error",DID[0],DID[1]);
      //Ser23TestAutomated=0;
    }
    else
    {
      if(gTpRxData[4] != 0x44) { testStepFail("Fail","0x%X%X AddressAndLengthFormatIdentifier is %X not 0x44",DID[0],DID[1],gTpRxData[4]); }
      if((gTpRxLength-5)%6==0)
      {
        Ser23MemorySegmentNum_A=gTpRxData[3];
        if(gTpRxLength==(5+Ser23MemorySegmentNum_A*8))
        {
          index=5;
          for(i=0;i<Ser23MemorySegmentNum_A;i++)
          {
            Ser23Memory_A[i].Length=gTpRxData[index]<<24|gTpRxData[index+1]<<16|gTpRxData[index+2]<<8|gTpRxData[index+3];
            Ser23Memory_A[i].Address=gTpRxData[index+4]<<24|gTpRxData[index+5]<<16|gTpRxData[index+6]<<8|gTpRxData[index+7];
            index+=8;
          }
        }
        else
        {
          testStepFail("Fail","%X%X format error",DID[0],DID[1]);
          //Ser23TestAutomated=0;
        }
      }
      else
      {
        testStepFail("Fail","%X%X format error",DID[0],DID[1]);
        //Ser23TestAutomated=0;
      }
    }
    if(Ser23TestAutomated==1)
    {
      for(i=0; i<Ser23MemorySegmentNum_A; i++)
      {
        offset=0;
        do
        {
          S23DataAddress=Ser23Memory_A[i].Address+offset;
          if((Ser23Memory_A[i].Length-offset)>ReadMaxLen)
          {
            S23DataLength=ReadMaxLen;
            offset=offset+ReadMaxLen;
          }
          else
          {
            S23DataLength=Ser23Memory_A[i].Length-offset;
            offset=offset+S23DataLength;
          }
          
          AddressByte[3]=S23DataAddress;
          AddressByte[2]=S23DataAddress>>8;
          AddressByte[1]=S23DataAddress>>16;
          AddressByte[0]=S23DataAddress>>24;
          
          LengthByte[3]=S23DataLength;
          LengthByte[2]=S23DataLength>>8;
          LengthByte[1]=S23DataLength>>16;
          LengthByte[0]=S23DataLength>>24;
           
          SID23_ReadMemoryByAdress(0x44,AddressByte,LengthByte,PHYSICAL);
          CheckPosResponse_SID23(S23DataLength,0,0);
          write("Ser23Memory[i].Length-offset=%x",Ser23Memory_A[i].Length-offset);

        }
        while((Ser23Memory_A[i].Length-offset)>ReadMaxLen);
      }
    }
  }
  
  if(Ser23AddLen44Supported==1&&Ser23TestAutomated==0)
  {
    for(i=0; i<Ser23MemorySegmentNum; i++)
    {
      offset=0;
      do
      {
        S23DataAddress=Ser23Memory[i].Address+offset;
        if((Ser23Memory[i].Length-offset)>ReadMaxLen)
        {
          S23DataLength=ReadMaxLen;
          offset=offset+ReadMaxLen;
        }
        else
        {
          S23DataLength=Ser23Memory[i].Length-offset;
          offset=offset+S23DataLength;
        }
        
        AddressByte[3]=S23DataAddress;
        AddressByte[2]=S23DataAddress>>8;
        AddressByte[1]=S23DataAddress>>16;
        AddressByte[0]=S23DataAddress>>24;
        
        LengthByte[3]=S23DataLength;
        LengthByte[2]=S23DataLength>>8;
        LengthByte[1]=S23DataLength>>16;
        LengthByte[0]=S23DataLength>>24;
         
        SID23_ReadMemoryByAdress(0x44,AddressByte,LengthByte,PHYSICAL);
        CheckPosResponse_SID23(S23DataLength,0,0);
        write("Ser23Memory[i].Length-offset=%x",Ser23Memory[i].Length-offset);

      }
      while((Ser23Memory[i].Length-offset)>ReadMaxLen);
    }
  }
  
  TestStep("Verify defaultSession(0x01)",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <APP_CommonServiceTest>
testcase Sercice_0x23_ReadMemoryByAddress_Supported_ExtendedSession_Physical()
{
  int i;
  dword S23DataAddress;
  dword S23DataLength;
  byte AddressByte[4];
  byte LengthByte[4];
  dword offset;
  char logName[400] = "";
  char info[1024];
  byte DID[2];
  word index = 5;
  byte tempStorage;
  
  word Ser23MemorySegmentNum_A=4;
  struct MemoryAddressLength Ser23Memory_A[500];
  
  strncat(logName,"1022414_Sercice_0x23_ReadMemoryByAddress_Supported_ExtendedSession_Physical",400);
  testCaseDescription("Verify Service ReadMemoryByAddress (0x23) is supported.");
  testCaseTitle("1022414","Sercice_0x23_ReadMemoryByAddress_Supported_ExtendedSession_Physical");
  
  SetLog(logName);
//  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  
  if(Ser23SecurityLevel!=0xFF)
  {
    testWaitForTimeout(gTimeWaitForSecuAccess);
//    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Ser23SecurityLevel,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Ser23SecurityLevel,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Ser23SecurityLevel,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Ser23SecurityLevel,0,0);
  }
  tempStorage=Ser23TestAutomated;
  if(Ser23AddLen14Supported==1)
  {
        DID[0]=0xD1;
        DID[1]=0x22;
        {
          int result;
          result = CheckDIDSupported(0xD122,DIDOfReadAPP);
          if(result != -1 && Ser23TestAutomated == 0) 
          {
            if(DIDOfReadAPP[result].Flag_Extended == 0) { testStepWarning("Warning","0x%X%X can't be read in extendedSession!!!",DID[0],DID[1]); }
            else 
            { 
              Ser23TestAutomated = 1; 
              if(DIDOfReadAPP[result].SecuLevel != 0xFF && DIDOfReadAPP[result].SecuLevel != Ser23SecurityLevel)
              {
                SID27_SecurityAccess_RequestSeed(DIDOfReadAPP[result].SecuLevel,PHYSICAL);
                CheckPosResponse_SID27_ReqSeed(DIDOfReadAPP[result].SecuLevel,gSeedArray,16,0,0);
                PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
                SID27_SecurityAccess_SendKey(DIDOfReadAPP[result].SecuLevel,gKeyArray,PHYSICAL);
                CheckPosResponse_SID27_SenKey(DIDOfReadAPP[result].SecuLevel,0,0);
              }
            }
          }
        }
        if(Ser23TestAutomated==1)
        {
          SID22_ReadDataByIdentifier(DID,PHYSICAL);
          if(CheckPosResponse_SID22(DID,0,0)!=2)
          {
            testStepFail("Fail","Read %X%X error",DID[0],DID[1]);
            //Ser23TestAutomated=0;
          }
          else
          {
            if(gTpRxData[4] != 0x14) { testStepFail("Fail","0x%X%X AddressAndLengthFormatIdentifier is %X not 0x14",DID[0],DID[1],gTpRxData[4]); }
            if((gTpRxLength-5)%5==0)
            {
              Ser23MemorySegmentNum_A=gTpRxData[3];
              if(1)//(gTpRxLength==(5+Ser23MemorySegmentNum_A*5))
              {
                index=5;
                for(i=0;i<Ser23MemorySegmentNum_A;i++)
                {
                  Ser23Memory_A[i].Length=gTpRxData[index];
                  Ser23Memory_A[i].Address=gTpRxData[index+1]<<24|gTpRxData[index+2]<<16|gTpRxData[index+3]<<8|gTpRxData[index+4];
                  index+=5;
                }
              }
              else
              {
                testStepFail("Fail","%X%X format error",DID[0],DID[1]);
                //Ser23TestAutomated=0;
              }
            }
            else
            {
              testStepFail("Fail","%X%X format error",DID[0],DID[1]);
              //Ser23TestAutomated=0;
            }
          }
          if(Ser23TestAutomated==1)
          {
            for(i=0; i<Ser23MemorySegmentNum_A; i++)
            {
              offset=0;
              do
              {
                S23DataAddress=Ser23Memory_A[i].Address+offset;
                if((Ser23Memory_A[i].Length-offset)>=0xFF)
                {
                  S23DataLength=0xFF;
                  offset=offset+0xFF;
                }
                else
                {
                  S23DataLength=Ser23Memory_A[i].Length-offset;
                  offset=offset+S23DataLength;
                }
                
                AddressByte[3]=S23DataAddress;
                AddressByte[2]=S23DataAddress>>8;
                AddressByte[1]=S23DataAddress>>16;
                AddressByte[0]=S23DataAddress>>24;
                
        //        LengthByte[3]=S23DataLength;
        //        LengthByte[2]=S23DataLength>>8;
        //        LengthByte[1]=S23DataLength>>16;
                LengthByte[0]=S23DataLength;
                
                SID23_ReadMemoryByAdress(0x14,AddressByte,LengthByte,PHYSICAL);
                CheckPosResponse_SID23(S23DataLength,0,0);
                write("Ser23Memory_A[i].Length-offset=%x",Ser23Memory_A[i].Length-offset);
                
              }
              while((Ser23Memory_A[i].Length-offset)>0xFF);
            }
          }
        }
        
        if(Ser23AddLen14Supported==1&&Ser23TestAutomated==0)
        {
          for(i=0; i<Ser23MemorySegmentNum; i++)
          {
            offset=0;
            do
            {
              S23DataAddress=Ser23Memory[i].Address+offset;
              if((Ser23Memory[i].Length-offset)>=0xFF)
              {
                S23DataLength=0xFF;
                offset=offset+0xFF;
              }
              else
              {
                S23DataLength=Ser23Memory[i].Length-offset;
                offset=offset+S23DataLength;
              }
              
              AddressByte[3]=S23DataAddress;
              AddressByte[2]=S23DataAddress>>8;
              AddressByte[1]=S23DataAddress>>16;
              AddressByte[0]=S23DataAddress>>24;
              
      //        LengthByte[3]=S23DataLength;
      //        LengthByte[2]=S23DataLength>>8;
      //        LengthByte[1]=S23DataLength>>16;
              LengthByte[0]=S23DataLength;
              
              SID23_ReadMemoryByAdress(0x14,AddressByte,LengthByte,PHYSICAL);
              CheckPosResponse_SID23(S23DataLength,0,0);
              write("Ser23Memory[i].Length-offset=%x",Ser23Memory[i].Length-offset);
              
            }
            while((Ser23Memory[i].Length-offset)>0xFF);
          }
        }
  }
  
  Ser23TestAutomated=tempStorage;
  
  if(Ser23AddLen24Supported==1)
  {
        DID[0]=0xD1;
        DID[1]=0x23;
        {
          int result;
          result = CheckDIDSupported(0xD123,DIDOfReadAPP);
          if(result != -1 && Ser23TestAutomated == 0) 
          {
            if(DIDOfReadAPP[result].Flag_Extended == 0) { testStepWarning("Warning","0x%X%X can't be read in extendedSession!!!",DID[0],DID[1]); }
            else { Ser23TestAutomated = 1; }
          }
        }
        if(Ser23TestAutomated==1)
        {
          SID22_ReadDataByIdentifier(DID,PHYSICAL);
          if(CheckPosResponse_SID22(DID,0,0)!=2)
          {
            testStepFail("Fail","Read %X%X error",DID[0],DID[1]);
            //Ser23TestAutomated=0;
          }
          else
          {
            if(gTpRxData[4] != 0x24) { testStepFail("Fail","0x%X%X AddressAndLengthFormatIdentifier is %X not 0x24",DID[0],DID[1],gTpRxData[4]); }
            if((gTpRxLength-5)%6==0)
            {
              Ser23MemorySegmentNum_A=gTpRxData[3];
              if(1)//(gTpRxLength==(5+Ser23MemorySegmentNum_A*6))
              {
                index=5;
                for(i=0;i<Ser23MemorySegmentNum_A;i++)
                {
                  Ser23Memory_A[i].Length=gTpRxData[index]<<8|gTpRxData[index+1];
                  Ser23Memory_A[i].Address=gTpRxData[index+2]<<24|gTpRxData[index+3]<<16|gTpRxData[index+4]<<8|gTpRxData[index+5];
                  index+=6;
                }
              }
              else
              {
                testStepFail("Fail","%X%X format error",DID[0],DID[1]);
                //Ser23TestAutomated=0;
              }
            }
            else
            {
              testStepFail("Fail","%X%X format error",DID[0],DID[1]);
              //Ser23TestAutomated=0;
            }
          }
          if(Ser23TestAutomated==1)
          {
            for(i=0; i<Ser23MemorySegmentNum_A; i++)
            {
              offset=0;
              do
              {
                S23DataAddress=Ser23Memory_A[i].Address+offset;
                if((Ser23Memory_A[i].Length-offset)>ReadMaxLen)
                {
                  S23DataLength=ReadMaxLen;
                  offset=offset+ReadMaxLen;
                }
                else
                {
                  S23DataLength=Ser23Memory_A[i].Length-offset;
                  offset=offset+S23DataLength;
                }
                
                AddressByte[3]=S23DataAddress;
                AddressByte[2]=S23DataAddress>>8;
                AddressByte[1]=S23DataAddress>>16;
                AddressByte[0]=S23DataAddress>>24;
                
              //        LengthByte[3]=S23DataLength;
              //        LengthByte[2]=S23DataLength>>8;
                LengthByte[1]=S23DataLength;
                LengthByte[0]=S23DataLength>>8;
                
                SID23_ReadMemoryByAdress(0x24,AddressByte,LengthByte,PHYSICAL);
                CheckPosResponse_SID23(S23DataLength,0,0);
                write("Ser23Memory[i].Length-offset=%x",Ser23Memory_A[i].Length-offset);
                
              }
              while((Ser23Memory_A[i].Length-offset)>ReadMaxLen);
            }
          }
        }
        
        if(Ser23AddLen24Supported==1&&Ser23TestAutomated==0)
        {
          for(i=0; i<Ser23MemorySegmentNum; i++)
          {
            offset=0;
            do
            {
              S23DataAddress=Ser23Memory[i].Address+offset;
              if((Ser23Memory[i].Length-offset)>ReadMaxLen)
              {
                S23DataLength=ReadMaxLen;
                offset=offset+ReadMaxLen;
              }
              else
              {
                S23DataLength=Ser23Memory[i].Length-offset;
                offset=offset+S23DataLength;
              }
              
              AddressByte[3]=S23DataAddress;
              AddressByte[2]=S23DataAddress>>8;
              AddressByte[1]=S23DataAddress>>16;
              AddressByte[0]=S23DataAddress>>24;
              
      //        LengthByte[3]=S23DataLength;
      //        LengthByte[2]=S23DataLength>>8;
              LengthByte[1]=S23DataLength;
              LengthByte[0]=S23DataLength>>8;
              
              SID23_ReadMemoryByAdress(0x24,AddressByte,LengthByte,PHYSICAL);
              CheckPosResponse_SID23(S23DataLength,0,0);
              write("Ser23Memory[i].Length-offset=%x",Ser23Memory[i].Length-offset);
              
            }
            while((Ser23Memory[i].Length-offset)>ReadMaxLen);
          }
        }
  }
  
  Ser23TestAutomated=tempStorage;
  if(Ser23AddLen44Supported==1)
  {
        DID[0]=0xD1;
        DID[1]=0x24;
        {
          int result;
          result = CheckDIDSupported(0xD124,DIDOfReadAPP);
          if(result != -1 && Ser23TestAutomated == 0) 
          {
            if(DIDOfReadAPP[result].Flag_Extended == 0) { testStepWarning("Warning","0x%X%X can't be read in extendedSession!!!",DID[0],DID[1]); }
            else { Ser23TestAutomated = 1; }
          }
        }
        if(Ser23TestAutomated==1)
        {
          SID22_ReadDataByIdentifier(DID,PHYSICAL);
          if(CheckPosResponse_SID22(DID,0,0)!=2)
          {
            testStepFail("Fail","Read %X%X error",DID[0],DID[1]);
            //Ser23TestAutomated=0;
          }
          else
          {
            if(gTpRxData[4] != 0x44) { testStepFail("Fail","0x%X%X AddressAndLengthFormatIdentifier is %X not 0x44",DID[0],DID[1],gTpRxData[4]); }
            if((gTpRxLength-5)%8==0)
            {
              Ser23MemorySegmentNum_A=gTpRxData[3];
              if(1)//(gTpRxLength==(5+Ser23MemorySegmentNum_A*8))
              {
                index=5;
                for(i=0;i<Ser23MemorySegmentNum_A;i++)
                {
                  Ser23Memory_A[i].Length=gTpRxData[index]<<24|gTpRxData[index+1]<<16|gTpRxData[index+2]<<8|gTpRxData[index+3];
                  Ser23Memory_A[i].Address=gTpRxData[index+4]<<24|gTpRxData[index+5]<<16|gTpRxData[index+6]<<8|gTpRxData[index+7];
                  index+=8;
                }
              }
              else
              {
                testStepFail("Fail","%X%X format error",DID[0],DID[1]);
                //Ser23TestAutomated=0;
              }
            }
            else
            {
              testStepFail("Fail","%X%X format error",DID[0],DID[1]);
              //Ser23TestAutomated=0;
            }
          }
          if(Ser23TestAutomated==1)
          {
            for(i=0; i<Ser23MemorySegmentNum_A; i++)
            {
              offset=0;
              do
              {
                S23DataAddress=Ser23Memory_A[i].Address+offset;
                if((Ser23Memory_A[i].Length-offset)>ReadMaxLen)
                {
                  S23DataLength=ReadMaxLen;
                  offset=offset+ReadMaxLen;
                }
                else
                {
                  S23DataLength=Ser23Memory_A[i].Length-offset;
                  offset=offset+S23DataLength;
                }
                
                AddressByte[3]=S23DataAddress;
                AddressByte[2]=S23DataAddress>>8;
                AddressByte[1]=S23DataAddress>>16;
                AddressByte[0]=S23DataAddress>>24;
                
                LengthByte[3]=S23DataLength;
                LengthByte[2]=S23DataLength>>8;
                LengthByte[1]=S23DataLength>>16;
                LengthByte[0]=S23DataLength>>24;
                
                SID23_ReadMemoryByAdress(0x44,AddressByte,LengthByte,PHYSICAL);
                CheckPosResponse_SID23(S23DataLength,0,0);
                write("Ser23Memory[i].Length-offset=%x",Ser23Memory_A[i].Length-offset);

              }
              while((Ser23Memory_A[i].Length-offset)>ReadMaxLen);
            }
          }
        }
        
        if(Ser23AddLen44Supported==1&&Ser23TestAutomated==0)
        {
          for(i=0; i<Ser23MemorySegmentNum; i++)
          {
            offset=0;
            do
            {
              S23DataAddress=Ser23Memory[i].Address+offset;
              if((Ser23Memory[i].Length-offset)>ReadMaxLen)
              {
                S23DataLength=ReadMaxLen;
                offset=offset+ReadMaxLen;
              }
              else
              {
                S23DataLength=Ser23Memory[i].Length-offset;
                offset=offset+S23DataLength;
              }
              
              AddressByte[3]=S23DataAddress;
              AddressByte[2]=S23DataAddress>>8;
              AddressByte[1]=S23DataAddress>>16;
              AddressByte[0]=S23DataAddress>>24;
              
              LengthByte[3]=S23DataLength;
              LengthByte[2]=S23DataLength>>8;
              LengthByte[1]=S23DataLength>>16;
              LengthByte[0]=S23DataLength>>24;
              
              SID23_ReadMemoryByAdress(0x44,AddressByte,LengthByte,PHYSICAL);
              CheckPosResponse_SID23(S23DataLength,0,0);
              write("Ser23Memory[i].Length-offset=%x",Ser23Memory[i].Length-offset);

            }
            while((Ser23Memory[i].Length-offset)>ReadMaxLen);
          }
        }
  }
  TestStep("Verify EXTENDEDSESSION(0x03)",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}

/// <APP_CommonServiceTest>
testcase Sercice_0x27_Valid_Physical_ExtendedDiagnosticSession_Supported_Service()
{
  int i;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1022401_Sercice_0x27_Valid_Physical_ExtendedDiagnosticSession_Supported_Service_R2",400);
  testCaseDescription("The intent is to verify that the service SecurityAccess (0x27) and its subfunctions is supported.");
  testCaseTitle("1022401","Sercice_0x27_Valid_Physical_ExtendedDiagnosticSession_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);

  
  for(i=0; i<NumOfSecurityLv; i++)
  {
    if(i==0)
      TestStep("Let L1 = First security level from the configured security level array from configured list. ",TestStepIntervalTime);
    else
      TestStep("Let L1 be equal to next security level and jump to Step 4. ",TestStepIntervalTime,4);
    
    if(SELevel[i].SEFlagPBL == 1)
    {
      continue;
    }
    
    Level1=SELevel[i].SElevel;
    write("Level1 is %02x",Level1);
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    //执行解锁以确保控制器的错误计数器为0
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    //执行解锁以确保控制器的错误计数器为0
    testWaitForTimeout(1000);
    
    TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
//    TestStep("ECU unlock.",TestStepIntervalTime);
//    SID27_SecurityAccess_SendKey(Level1,gKeyArray,ByteNumOfSeed,DLLName,PHYSICAL);
//    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckNegResponse(0x35,0,0);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
     TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckNegResponse(0x36,0,0);
    TestStep("Wait for Delaytimer-1s.");
    testWaitForTimeout(DelayTimer-1000);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckNegResponse(0x37,0,0);
    TestStep("Wait for 2s.");
    testWaitForTimeout(2000);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Transition from extendedDiagnosticSession(0x03) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify defaultSession",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    TestStep("Transition from DefaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Disable functionally addressed periodic testerPresent.Wait for 4.8 seconds.");
    TP_TesterPresentSet(TP_OFF);
    delay(4800);
    TP_TesterPresentSet(TP_ON);
    
    TestStep("ECU response with seed. Verify that S1...S16 is equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(AllZero,gSeedArray);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    TestStep(":Wait for 6s.",TestStepIntervalTime);
    TP_TesterPresentSet(TP_OFF);
    delay(6000);
    TP_TesterPresentSet(TP_ON);
    TestStep("Verify defaultSession",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
    CheckNonResponse(0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000 and S1...S16 not equal to S1...S16 in step 32.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  }
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);

  /******************************以上为测试步骤*********************************/
  PostCondition();
}

void delay(long timeout)
{
    linFrame 0x30 msg;
    int m,i;
  
    if(gBusFlag==3)//LIN 总线单独处理，1s 发一个22 F1 86
    {
        m=timeout/1000;
        if(timeout<2000)
        {
             testWaitForTimeout(timeout); 
          
        }
        else
        {
              for(i=0;i<m;i++)
              {
                  //CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0); 
                  
                  msg.dlc=1;
                  msg.rtr=1;
                  output(msg);
                  testWaitForTimeout(1000);
              }
        }
        
        m=timeout%1000;
        testWaitForTimeout(m);
      
  
    }
    else
    {
       testWaitForTimeout(timeout); 
      
    }
    
    
}

void delaywithreq(long timeout)
{
    linFrame 0x30 msg;
    int m,i;
  
    if(gBusFlag==3)//LIN 总线单独处理，1s 发一个22 F1 86
    {
        m=timeout/1000;
        if(timeout<2000)
        {
             testWaitForTimeout(timeout); 
          
        }
        else
        {
              for(i=0;i<m;i++)
              {
                  SID3E_TesterPresent(PHYSICAL,SPRMIB_TRUE);
                  
                  //msg.dlc=1;
                  //msg.rtr=1;
                  //output(msg);
                  //testWaitForTimeout(1000);
              }
        }
        
        m=timeout%1000;
        testWaitForTimeout(m);
      
  
    }
    else
    {
       testWaitForTimeout(timeout); 
      
    }
    
    
}

/// <APP_CommonServiceTest>
testcase Sercice_0x27_Valid_Functional_ExtendedDiagnosticSession_Supported_Service()
{
  int i;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1022402_Sercice_0x27_Valid_Functional_ExtendedDiagnosticSession_Supported_Service_R2",400);
  testCaseDescription("The intent is to verify that the service SecurityAccess (0x27) and its subfunctions is supported.");
  testCaseTitle("1022402","Sercice_0x27_Valid_Functional_ExtendedDiagnosticSession_Supported_Service");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  else if(gBusFlag==1)
  {
		testStepWarning("Test","This test case does not apply to the Classical CAN bus");
		return;
  }
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
   
  SessionFlag=APP;
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);

  
  for(i=0; i<NumOfSecurityLv; i++)
  {
    if(i==0)
      TestStep("Let L1 = First security level from the configured security level array from configured list. ",TestStepIntervalTime);
    else
      TestStep("Let L1 be equal to next security level and jump to Step 4. ",TestStepIntervalTime);
    
    if(SELevel[i].SEFlagPBL == 1)
    {
      continue;
    }
    
    Level1=SELevel[i].SElevel;
    write("Level1 is %02x",Level1);
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    //执行解锁以确保控制器的错误计数器为0
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    //执行解锁以确保控制器的错误计数器为0
    testWaitForTimeout(1000);
    
    TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
//    TestStep("ECU unlock.",TestStepIntervalTime);
//    SID27_SecurityAccess_SendKey(Level1,gKeyArray,ByteNumOfSeed,DLLName,PHYSICAL);
//    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    
    TestStep("Send invalid key.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,FUNCTIONAL);
    CheckNegResponse(0x35,0,0);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
     TestStep("Generate wrong key from response.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;//产生错误的秘钥
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,FUNCTIONAL);
    CheckNegResponse(0x36,0,0);
    TestStep("Wait for Delaytimer-1s.");
    delaywithreq(DelayTimer-1000);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckNegResponse(0x37,0,0);
    TestStep("Wait for 2s.");
    testWaitForTimeout(2000);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,FUNCTIONAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Transition from extendedDiagnosticSession(0x03) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    //testWaitForTimeout(12000);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,FUNCTIONAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify defaultSession",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    TestStep("Transition from DefaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,FUNCTIONAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Disable functionally addressed periodic testerPresent.Wait for 4.8 seconds.");
    TP_TesterPresentSet(TP_OFF);
    delay(4800);
    TP_TesterPresentSet(TP_ON);
    
    TestStep("ECU response with seed. Verify that S1...S16 is equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,zeroseed,16,0,0);
    PID27_Parameters_Seeds_Chk(AllZero,gSeedArray);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,FUNCTIONAL,0,0);
    TestStep(":Wait for 6s.",TestStepIntervalTime);
    TP_TesterPresentSet(TP_OFF);
    delay(6000);
    TP_TesterPresentSet(TP_ON);
    TestStep("Verify defaultSession",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
    CheckNonResponse(0,0);
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
    TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000 and S1...S16 not equal to S1...S16 in step 32.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,FUNCTIONAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  }
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}

/// <APP_CommonServiceTest>
testcase Sercice_0x27_Valid_Physical_ExtendedDiagnosticSession_Supported_Service_But_Not_Subfunction()
{
  int i;
  byte ExpectNRC[2]={0x12,0x7E};
