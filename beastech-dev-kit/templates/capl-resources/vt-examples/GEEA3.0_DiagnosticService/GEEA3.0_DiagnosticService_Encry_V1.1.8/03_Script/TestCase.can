  char info[1024];
  
  strncat(logName,"1022403_Sercice_0x27_Valid_Physical_ExtendedDiagnosticSession_Supported_Service_But_Not_Subfunction_R2",400);
  testCaseDescription("The intent is to verify that the subfunction 0x01 and 0x81 is not supported.");
  testCaseTitle("1022403","Sercice_0x27_Valid_Physical_ExtendedDiagnosticSession_Supported_Service_But_Not_Subfunction");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  TestStep("ECU response with NRC12 and NRC7E. ",TestStepIntervalTime);
