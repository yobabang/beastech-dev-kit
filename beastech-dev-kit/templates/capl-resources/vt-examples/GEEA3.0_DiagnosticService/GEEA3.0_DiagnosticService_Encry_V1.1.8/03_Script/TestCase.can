/// <APP_GeneralTest>
testcase Read_Multiple_DataIdentifiers_Test_Valid_Physical_DefaultSession()
{
  byte MulDID[41]= {0x22,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86,0xF1,0x86};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350991_Read_Multiple_DataIdentifiers_Test_Valid_Physical_DefaultSession",400);
  testCaseDescription("The intent of the test is to verify that multiple number of data identifiers can be readout with the service ReadDataByIdentifier (0x22)");
  testCaseTitle("1350991","Read_Multiple_DataIdentifiers_Test_Valid_Physical_DefaultSession");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  TestStep("Request multiple DIDs",TestStepIntervalTime);
  if(gMaxNumberOfDIDsForReadDID_Default < 20)
  {
  TPSendRawMessage(MulDID,((gMaxNumberOfDIDsForReadDID_Default*2)+1),PHYSICAL);
  CheckPosResponse(0x22,((gMaxNumberOfDIDsForReadDID_Default*3)+1),0,0);
  }
  else
  {
    TPSendRawMessage(MulDID,((20*2)+1),PHYSICAL);
    CheckPosResponse(0x22,((20*3)+1),0,0);
  }
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}

