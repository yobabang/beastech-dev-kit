}
/// <APP_CommonServiceTest>
testcase Service_0x28_Phy_Timeout()
{
  byte expectSession[4]={0x01,0x02,0x03,0x04};
  byte SFOf28[4]={0x00,0x01,0x02,0x03};
  byte t28[3]={0x28,0x00,0x01};
  byte expectNRC[1]={0x31};
  int i=0,j=0;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1088543_Service_0x28_Phy_Timeout",400);
  testCaseTitle("1088543","Service_0x28_Phy_Timeout");
  
  if(gBusFlag==5 && SWRS_VERSION>=8 && EthNodeTypeNow==EdgeNode)
  {
     testStepWarning("","按照SWRS 版本>=V8,需求ID 987287定义 ,边缘节点应向车内发送3E 80 ，并维持自身的会话模式，所以不会跳转到默认会话,这个用例就不适用了");
     return;
  }
  
  
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  gFlagNM=0;
  output(NMMessage_Repeat);Teststep("INF","out put NM repeat request message");
  testwaitfortimeout(3000);
  if(gFlagNM==1)
  {
    TestStep("ECU support NM message",TestStepIntervalTime);
    TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(DEFAULTSESSION,0,6);
    ECUinitHandle(0);
    TestStep("Enter extendedsession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
    CheckCurrentSession(expectSession[2],PHYSICAL,0,0);
    
    TestStep("Tester Present on",TestStepIntervalTime);
    
    SID28_CommunicationControl(SFOf28[3],NCMAndNMM,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[3],0,0);
    TestStep("Check the APP Message are prohibited(All channels)",TestStepIntervalTime);
    CheckCommunication(DEALL,1);
    TestStep("Wait 20000ms");
    testwaitfortimeout(20000);
    
    TestStep("Check the APP Message are prohibited(All channels)",TestStepIntervalTime);
    CheckCommunication(DEALL,1);
    
    TestStep("Tester Present off",TestStepIntervalTime);
    TP_TesterPresentSet(TP_OFF);
    
    TestStep("Tester Send 3E 80",TestStepIntervalTime);
    SID3E_TesterPresent(FUNCTIONAL, SPRMIB_TRUE);
    
    TestStep("Wait 5500ms");
    testwaitfortimeout(5500);
    
    TestStep("Tester Send 3E 80",TestStepIntervalTime);
    SID3E_TesterPresent(FUNCTIONAL, SPRMIB_TRUE);
    
    TestStep("Tester Present on",TestStepIntervalTime);
    TP_TesterPresentSet(TP_ON);
    
    TestStep("Check the APP Message are sent normally(All channels)",TestStepIntervalTime);
    CheckCommunication(DENONE,1);
    TestStep("Tester Present off,Go to step 29",TestStepIntervalTime,29);
  }
  else if(gFlagNM==0)
  {
    TestStep("ECU not support NM message,Go to step 16",TestStepIntervalTime);
    TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(DEFAULTSESSION,0,6);
    ECUinitHandle(0);
    TestStep("Enter extendedsession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
    CheckCurrentSession(expectSession[2],PHYSICAL,0,0);
    
    TestStep("Tester Present on",TestStepIntervalTime);
    
    SID28_CommunicationControl(SFOf28[3],NCMAndNMM,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID28(SFOf28[3],0,0);
    TestStep("Check the APP Message are prohibited(All channels)",TestStepIntervalTime);
    CheckCommunication(DEAPP,1);
    TestStep("Wait 20000ms");
    testwaitfortimeout(20000);
    
    TestStep("Check the APP Message are prohibited(All channels)",TestStepIntervalTime);
    CheckCommunication(DEAPP,1);
    
    TestStep("Tester Present off",TestStepIntervalTime);
    TP_TesterPresentSet(TP_OFF);
    
    TestStep("Tester Send 3E 80",TestStepIntervalTime);
    SID3E_TesterPresent(FUNCTIONAL, SPRMIB_TRUE);
    
    TestStep("Wait 5500ms");
    testwaitfortimeout(5500);
    
    TestStep("Tester Send 3E 80",TestStepIntervalTime);
    SID3E_TesterPresent(FUNCTIONAL, SPRMIB_TRUE);
    
    TestStep("Tester Present on",TestStepIntervalTime);
    TP_TesterPresentSet(TP_ON);
    
    TestStep(":Check the APP Message are sent normally(All channels)",TestStepIntervalTime);
    CheckCommunication(DENONE,1);
  }
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
