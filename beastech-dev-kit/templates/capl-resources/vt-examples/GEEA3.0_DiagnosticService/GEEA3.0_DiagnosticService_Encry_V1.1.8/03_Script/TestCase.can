/// <PBL_SecurityAccessAlgorithm>
testcase DelayTimer_activated_at_every_start_PBL()
{
  int i,j;
  float T3,T4,Delta;
  char logName[400] = "";
  char info[1024];
  message 0x1 TpRes;
  int counter=0;
  
  strncat(logName,"1088591_DelayTimer_activated_at_every_start_PBL",400);
  testCaseTitle("1088591","DelayTimer_activated_at_every_start_PBL");
  
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  TPMsgInit(0);
  
  SessionFlag=APP;
  
  TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  SessionFlag=BOOT;
  TestStep("Transition to programmingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_TRUE);
//  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);

  SessionFlag=BOOT;
  TestStep("ECU reset");
  if((gBusFlag==1)||(gBusFlag==2))
  {
    msgF186.id=gCAN_RequestID;
    TestStep("10ms cycle send 22 F1 86");
    T4 = timeNowFloat()/10000;
    setTimerCyclic(SendF186,10);

    
    //write("Response ID is %03x",ResponseID);
    while(counter<1000)
    {
      counter++;
      testJoinMessageEvent(gCAN_ResponseID);
      if(TestWaitForAnyJoinedEvent(10)>0)
      {
        testGetWaitEventMsgData(TpRes);
        if((TpRes.byte(1)==0x62)&&(TpRes.byte(4)==0x02))
        {
          T3 = timeNowFloat()/10000;
          break;
        }
      }
    }
    cancelTimer(SendF186);
    if(counter==1000)
    {
      TestStepFail("","ECU Reset timeout");
    }
    else
    {
      Delta = (T3-T4)*100;
      TestStep("","**********\nThe ECU reset time is %f ms\n**********",Delta);
    }
    counter=0;
  }
  else
  {
    ECUinitHandle(0);
  }
  
  Level1=0x01;
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);

  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(Level1,0,0);
    
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  testWaitForTimeout(ECUIniTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  SessionFlag=BOOT;
  TestStep("ECU reset");
  if((gBusFlag==1)||(gBusFlag==2))
  {
    msgF186.id=gCAN_RequestID;
    TestStep("10ms cycle send 22 F1 86");
    T4 = timeNowFloat()/10000;
    setTimerCyclic(SendF186,10);

    
    //write("Response ID is %03x",ResponseID);
    while(counter<1000)
    {
      counter++;
      testJoinMessageEvent(gCAN_ResponseID);
      if(TestWaitForAnyJoinedEvent(10)>0)
      {
        testGetWaitEventMsgData(TpRes);
        if((TpRes.byte(1)==0x62)&&(TpRes.byte(4)==0x02))
        {
          T3 = timeNowFloat()/10000;
          break;
        }
      }
    }
    cancelTimer(SendF186);
    if(counter==1000)
    {
      TestStepFail("","ECU Reset timeout");
    }
    else
    {
      Delta = (T3-T4)*100;
      TestStep("","**********\nThe ECU reset time is %f ms\n**********",Delta);
    }
    counter=0;
  }
  else
  {
    ECUinitHandle(0);
  }
  Level1=0x01;
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(Level1,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <PBL_GeneralTest>
testcase S3_Timeout_Test_Physical_ProgrammingSession()
{
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351023_S3_Timeout_Test_Physical_ProgrammingSession",400);
  testCaseDescription("The intent of the test to verify:1.S3Server parameter timeout value. 2.The ECU returns to defaultSession from any non defaultSession when S3 timer times out.");
  testCaseTitle("1351023","S3_Timeout_Test_Physical_ProgrammingSession");
  if(gBusFlag==5 && SWRS_VERSION>=8 && EthNodeTypeNow==EdgeNode)
  {
     testStepWarning("","按照SWRS 版本>=V8,需求ID 987287定义 ,边缘节点应向车内发送3E 80 ，并维持自身的会话模式，所以不会跳转到默认会话,这个用例就不适用了");
     return;
  }
  
  SetLog(logName);
  Precondition();
  
  
   
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  
  TP_TesterPresentSet(TP_OFF);
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Wait 4800 ms, from last final response.");
  delay(4800);
  TestStep("Send 3E 80",TestStepIntervalTime);
  SID3E_TesterPresent(PHYSICAL,SPRMIB_TRUE);
  //CheckNonResponse(0,0);
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Wait 5500 ms, from last final response.");
  delay(5500);
  
  TestStep("Wait ECU startup time' from last request.");
  ECUinitHandle(0);
  
  SessionFlag=APP;
  
  TestStep("Verify defaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
