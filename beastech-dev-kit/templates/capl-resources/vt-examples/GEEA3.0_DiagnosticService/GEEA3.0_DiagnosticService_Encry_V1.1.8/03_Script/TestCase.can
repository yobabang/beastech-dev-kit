        {
          tem2 = 1;
          break;
        }

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      if(Routine_Sub0x01[i].AuthenticationFlag != 1)
      {
        CheckPosResponse(0x31,0,0);
      }  
