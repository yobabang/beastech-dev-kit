/// <APP_CommonServiceTest>
testcase Sercice_0x19_Sf0x15_Valid_Physical_DefaultSession_Supported_Service()
{
  byte DTC1[2000];
  byte DTC2[2000];
  int  DTC1Lenth;
  int  DTC2Lenth;
  int  i;
  int  Flag=0;
  int  IntroStatus;
  char logName[400] = "";
  char info[1024];
  byte GroupOfDTC[3]={0xff,0xff,0xff};
  
  strncat(logName,"1350894_Sercice_0x19_Sf0x15_Valid_Physical_DefaultSession_Supported_Service",400);
  testCaseDescription("The intent is to verify that service 0x19 with subfunction 0x15 is supported.");
  testCaseTitle("1350894","Sercice_0x19_Sf0x15_Valid_Physical_DefaultSession_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  if(Flag_1915 == 0)
  {
    TestStepWarning("ECU doesn't support this subfunction , test case exit!");
    Postcondition();
     
    return;
  }
  
  TestStep("Read DTC With Permanent Status",TestStepIntervalTime);
  SID19_Sub15_ReportDTCWithPermanentStatus(PHYSICAL);
  CheckPosResponse_SID19_15(AvailiableMask,0,0);
  StorageDTC();
  for(i=0; i<(gTpRxLength-3)/4; i++)
  {
    DTC1[3*i]=gTpRxData[i*4+3];
    DTC1[3*i+1]=gTpRxData[i*4+4];
    DTC1[3*i+2]=gTpRxData[i*4+5];
  }
  DTC1Lenth=(gTpRxLength-3)/4;
  TestStep("Clear DTCs",TestStepIntervalTime);
  SID14_ClearDTC(GroupOfDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Read DTC With Permanent Status",TestStepIntervalTime);
  SID19_Sub15_ReportDTCWithPermanentStatus(PHYSICAL);
  CheckPosResponse_SID19_15(0xff,0,0);
  StorageDTC();
  for(i=0; i<(gTpRxLength-3)/4; i++)
  {
    DTC2[3*i]=gTpRxData[i*4+3];
    DTC2[3*i+1]=gTpRxData[i*4+4];
    DTC2[3*i+2]=gTpRxData[i*4+5];
  }
  DTC2Lenth=(gTpRxLength-3)/4;
  for(i=1; i<DTC1Lenth*3; i++)
  {
    if(DTC1[i]==DTC2[i])
      Flag=1;
  }
  if(DTC1Lenth!=DTC2Lenth||Flag!=1)
    TestStepFail("Fail","The DTC change");
  TestStep("Verify defaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
