/// <PBL_GeneralTest>
testcase Immediate_Diagnostic_Request_Test_Physical_ProgrammingSession()
{
  byte DID[2];
  long i,j;
  message CAN1.0x00 request_message = { dlc=8,fdf=0 };
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351025_Immediate_Diagnostic_Request_Test_Physical_ProgrammingSession",400);
  testCaseDescription("To verify that an ECU can handle a request immediate (as close as possible) after it has responded to a previous diagnostic response.");
  testCaseTitle("1351025","Immediate_Diagnostic_Request_Test_Physical_ProgrammingSession");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  /*  1  */
  TestStep("Transition to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  SessionFlag=BOOT;
  /*  2  */
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  do
  {
    j++;
    /*  3  */
    TestStep("Send two requests as close as possible.",TestStepIntervalTime);
    DID[0]=gdid_queued_used[0] >> 8;
    DID[1]=gdid_queued_used[0] & 0xFF;
    if(1 == gflag_did_used || gBusFlag == 4 || gBusFlag == 5) { SID22_ReadDataByIdentifier(DID,PHYSICAL); }
    else                     
    {
      if(gBusFlag == 1 && glength_queued_used_1 <= 7)     // CAN Single Frame
      { request_message.id = gCAN_RequestID; request_message.byte(0) = glength_queued_used_1; for(i=0;i<glength_queued_used_1;i++) { request_message.byte(i+1) = gdata_queued_used_1[i]; } output(request_message); } 
      else if(gBusFlag == 1 && glength_queued_used_1 > 7) // CAN Multi Frame
      { TPSendRawMessage(gdata_queued_used_1,glength_queued_used_1,PHYSICAL); }
      else if(gBusFlag == 2 && glength_queued_used_1 <= 62) // CANFD Single Frame
      { 
        request_message.id = gCAN_RequestID; request_message.FDF = 1; request_message.BRS = 1; 
        if(glength_queued_used_1 <= 6) { request_message.dlc = 8; }
        else if(glength_queued_used_1 <= 10) { request_message.dlc = 9; }
        else if(glength_queued_used_1 <= 14) { request_message.dlc = 10; }
        else if(glength_queued_used_1 <= 18) { request_message.dlc = 11; }
        else if(glength_queued_used_1 <= 22) { request_message.dlc = 12; }
        else if(glength_queued_used_1 <= 30) { request_message.dlc = 13; }
        else if(glength_queued_used_1 <= 46) { request_message.dlc = 14; }
        else if(glength_queued_used_1 <= 62) { request_message.dlc = 15; }
        request_message.byte(0) = (glength_queued_used_1 | 0x1000) >> 8;
        request_message.byte(1) = glength_queued_used_1 | 0x1000; for(i=0;i<glength_queued_used_1;i++) { request_message.byte(i+2) = gdata_queued_used_1[i]; } 
        output(request_message);
      }
      else if(gBusFlag == 2 && glength_queued_used_1 > 62) // CANFD Multi Frame
      { TPSendRawMessage(gdata_queued_used_1,glength_queued_used_1,PHYSICAL); }
    }
    DID[0]=gdid_queued_used[1] >> 8;
    DID[1]=gdid_queued_used[1] & 0xFF;
    if(1 == gflag_did_used || gBusFlag == 4 || gBusFlag == 5) { SID22_ReadDataByIdentifier(DID,PHYSICAL); }
    else                     
    {
      if(gBusFlag == 1 && glength_queued_used_2 <= 7)     // CAN Single Frame
      { request_message.id = gCAN_RequestID; request_message.byte(0) = glength_queued_used_2; for(i=0;i<glength_queued_used_2;i++) { request_message.byte(i+1) = gdata_queued_used_2[i]; } output(request_message); } 
      else if(gBusFlag == 1 && glength_queued_used_2 > 7) // CAN Multi Frame
      { TPSendRawMessage(gdata_queued_used_2,glength_queued_used_2,PHYSICAL); }
      else if(gBusFlag == 2 && glength_queued_used_2 <= 62) // CANFD Single Frame
      { 
        request_message.id = gCAN_RequestID; request_message.FDF = 1; request_message.BRS = 1; 
        if(glength_queued_used_2 <= 6) { request_message.dlc = 8; }
        else if(glength_queued_used_2 <= 10) { request_message.dlc = 9; }
        else if(glength_queued_used_2 <= 14) { request_message.dlc = 10; }
        else if(glength_queued_used_2 <= 18) { request_message.dlc = 11; }
        else if(glength_queued_used_2 <= 22) { request_message.dlc = 12; }
        else if(glength_queued_used_2 <= 30) { request_message.dlc = 13; }
        else if(glength_queued_used_2 <= 46) { request_message.dlc = 14; }
        else if(glength_queued_used_2 <= 62) { request_message.dlc = 15; }
        request_message.byte(0) = (glength_queued_used_2 | 0x1000) >> 8;
        request_message.byte(1) = glength_queued_used_2 | 0x1000; for(i=0;i<glength_queued_used_2;i++) { request_message.byte(i+2) = gdata_queued_used_2[i]; } 
        output(request_message);
      }
      else if(gBusFlag == 2 && glength_queued_used_2 > 62) // CANFD Multi Frame
      { TPSendRawMessage(gdata_queued_used_2,glength_queued_used_2,PHYSICAL); }
    }
    if(1 == @Diagnostic::Receive_ConAll) { testStepWarning("Warning","第 %d 次测试, 未实现队列场景, 重新测试",j); testWaitForTimeout(100); continue; }
    Rss1=GetECUResponse();
    if(Rss1 == POS)
    {
      PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
      if(1 == gflag_did_used || gBusFlag == 4 || gBusFlag == 5)
      {
        if(gTpRxData[0]==0x62&&gTpRxData[1]==(gdid_queued_used[0] >> 8)&&gTpRxData[2]==(gdid_queued_used[0] & 0xFF))
        {
          testStepPass("Pass","The First response received");
          DID[0]=gdid_queued_used[2] >> 8;
          DID[1]=gdid_queued_used[2] & 0xFF;
          SID22_ReadDataByIdentifier(DID,PHYSICAL);
          Rss1=GetECUResponse();
          if(Rss1 == POS)
          {
            PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
            if(gTpRxData[0]==0x62&&gTpRxData[1]==(gdid_queued_used[1] >> 8)&&gTpRxData[2]==(gdid_queued_used[1] & 0xFF))
            {
              testStepPass("Pass","The Second response received");
              Rss1=GetECUResponse();
              if(Rss1 == POS)
              {
                PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
                if(gTpRxData[0]==0x62&&gTpRxData[1]==(gdid_queued_used[2] >> 8)&&gTpRxData[2]==(gdid_queued_used[2] & 0xFF))
                {
                  testStepPass("Pass","The Third response received"); j = 0; break;
                }
                else { testStepFail("Fail","The Third response is wrong, test end"); break; }
              }
              else if(Rss1 == NEG) { testStepFail("Fail","Neg.Response for Third response,test end"); break; }
              else { testStepFail("Fail","Time out no Third response received,test end"); break; }
            }
            else { testStepFail("Fail","The Second response is wrong, test end"); break; }
          }
          else if(Rss1 == NEG) { testStepFail("Fail","Neg.Response for Second response,test end"); break; }
          else { testStepFail("Fail","Time out no Second response received, test end"); break; }
        }
        else { testStepFail("Fail","The First response is wrong, test end"); break; }
      }
      else 
      {
        if(gTpRxData[0] != 0x40 + gdata_queued_used_1[0]) { testStepFail("Fail","The First response is wrong, test end"); break; }
        else
        {
          testStepPass("Pass","The First response received");
          if(gBusFlag == 1 && glength_queued_used_3 <= 7)     // CAN Single Frame
          { request_message.id = gCAN_RequestID; request_message.byte(0) = glength_queued_used_3; for(i=0;i<glength_queued_used_3;i++) { request_message.byte(i+1) = gdata_queued_used_3[i]; } output(request_message); } 
          else if(gBusFlag == 1 && glength_queued_used_3 > 7) // CAN Multi Frame
          { TPSendRawMessage(gdata_queued_used_3,glength_queued_used_3,PHYSICAL); }
          else if(gBusFlag == 2 && glength_queued_used_3 <= 62) // CANFD Single Frame
          { 
            request_message.id = gCAN_RequestID; request_message.FDF = 1; request_message.BRS = 1; 
            if(glength_queued_used_3 <= 6) { request_message.dlc = 8; }
            else if(glength_queued_used_3 <= 10) { request_message.dlc = 9; }
            else if(glength_queued_used_3 <= 14) { request_message.dlc = 10; }
            else if(glength_queued_used_3 <= 18) { request_message.dlc = 11; }
            else if(glength_queued_used_3 <= 22) { request_message.dlc = 12; }
            else if(glength_queued_used_3 <= 30) { request_message.dlc = 13; }
            else if(glength_queued_used_3 <= 46) { request_message.dlc = 14; }
            else if(glength_queued_used_3 <= 62) { request_message.dlc = 15; }
            request_message.byte(0) = (glength_queued_used_3 | 0x1000) >> 8;
            request_message.byte(1) = glength_queued_used_3 | 0x1000; for(i=0;i<glength_queued_used_3;i++) { request_message.byte(i+2) = gdata_queued_used_3[i]; } 
            output(request_message);
          }
          else if(gBusFlag == 2 && glength_queued_used_3 > 62) // CANFD Multi Frame
          { TPSendRawMessage(gdata_queued_used_3,glength_queued_used_3,PHYSICAL); }
          Rss1=GetECUResponse();
          if(Rss1 == POS)
          {
            PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
            if(gTpRxData[0] != 0x40 + gdata_queued_used_2[0]) { testStepFail("Fail","The Second response is wrong, test end"); break; }
            else
            {
              testStepPass("Pass","The Second response received");
              Rss1=GetECUResponse();
              if(Rss1 == POS)
              {
                PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
                if(gTpRxData[0] != 0x40 + gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else if(Rss1 == NEG)
              {
                PrintPID("UDS","Neg.Response for Third response:",gTpRxData,gTpRxLength);
                if(gTpRxData[1] != gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else { testStepFail("Fail","Time out no Third response received, test end"); break; }
            }
          }
          else if(Rss1 == NEG)
          {
            PrintPID("UDS","Neg.Response for Second response,test end:",gTpRxData,gTpRxLength);
            if(gTpRxData[1] != gdata_queued_used_2[0]) { testStepFail("Fail","The Second response is wrong, test end"); break; }
            else 
            { 
              testStepPass("Pass","The Second response received"); 
              Rss1=GetECUResponse();
              if(Rss1 == POS)
              {
                PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
                if(gTpRxData[0] != 0x40 + gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else if(Rss1 == NEG)
              {
                PrintPID("UDS","Neg.Response for Third response:",gTpRxData,gTpRxLength);
                if(gTpRxData[1] != gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else { testStepFail("Fail","Time out no Third response received, test end"); break; }
            }
          }
          else { testStepFail("Fail","Time out no Second response received, test end"); break; }
        }
      }
    }
    else if(Rss1 == NEG)
    {
      if(1 == gflag_did_used || gBusFlag == 4 || gBusFlag == 5) { testStepFail("Fail","Neg.Response for First response, test end"); break; }
      else
      {
        if(gTpRxData[1] != gdata_queued_used_1[0]) { testStepFail("Fail","The First response is wrong, test end"); break; }
        else 
        { 
          testStepPass("Pass","The First response received");
          if(gBusFlag == 1 && glength_queued_used_3 <= 7)     // CAN Single Frame
          { request_message.id = gCAN_RequestID; request_message.byte(0) = glength_queued_used_3; for(i=0;i<glength_queued_used_3;i++) { request_message.byte(i+1) = gdata_queued_used_3[i]; } output(request_message); } 
          else if(gBusFlag == 1 && glength_queued_used_3 > 7) // CAN Multi Frame
          { TPSendRawMessage(gdata_queued_used_3,glength_queued_used_3,PHYSICAL); }
          else if(gBusFlag == 2 && glength_queued_used_3 <= 62) // CANFD Single Frame
          { 
            request_message.id = gCAN_RequestID; request_message.FDF = 1; request_message.BRS = 1; 
            if(glength_queued_used_3 <= 6) { request_message.dlc = 8; }
            else if(glength_queued_used_3 <= 10) { request_message.dlc = 9; }
            else if(glength_queued_used_3 <= 14) { request_message.dlc = 10; }
            else if(glength_queued_used_3 <= 18) { request_message.dlc = 11; }
            else if(glength_queued_used_3 <= 22) { request_message.dlc = 12; }
            else if(glength_queued_used_3 <= 30) { request_message.dlc = 13; }
            else if(glength_queued_used_3 <= 46) { request_message.dlc = 14; }
            else if(glength_queued_used_3 <= 62) { request_message.dlc = 15; }
            request_message.byte(0) = (glength_queued_used_3 | 0x1000) >> 8;
            request_message.byte(1) = glength_queued_used_3 | 0x1000; for(i=0;i<glength_queued_used_3;i++) { request_message.byte(i+2) = gdata_queued_used_3[i]; } 
            output(request_message);
          }
          else if(gBusFlag == 2 && glength_queued_used_3 > 62) // CANFD Multi Frame
          { TPSendRawMessage(gdata_queued_used_3,glength_queued_used_3,PHYSICAL); }
          Rss1=GetECUResponse();
          if(Rss1 == POS)
          {
            PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
            if(gTpRxData[0] != 0x40 + gdata_queued_used_2[0]) { testStepFail("Fail","The Second response is wrong, test end"); break; }
            else
            {
              testStepPass("Pass","The Second response received");
              Rss1=GetECUResponse();
              if(Rss1 == POS)
              {
                PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
                if(gTpRxData[0] != 0x40 + gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else if(Rss1 == NEG)
              {
                PrintPID("UDS","Neg.Response for Third response:",gTpRxData,gTpRxLength);
                if(gTpRxData[1] != gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else { testStepFail("Fail","Time out no Third response received, test end"); break; }
            }
          }
          else if(Rss1 == NEG)
          {
            PrintPID("UDS","Neg.Response for Second response,test end:",gTpRxData,gTpRxLength);
            if(gTpRxData[1] != gdata_queued_used_2[0]) { testStepFail("Fail","The Second response is wrong, test end"); break; }
            else 
            { 
              testStepPass("Pass","The Second response received"); 
              Rss1=GetECUResponse();
              if(Rss1 == POS)
              {
                PrintPID("UDS","Pos.Response:",gTpRxData,gTpRxLength);
                if(gTpRxData[0] != 0x40 + gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else if(Rss1 == NEG)
              {
                PrintPID("UDS","Neg.Response for Third response:",gTpRxData,gTpRxLength);
                if(gTpRxData[1] != gdata_queued_used_3[0]) { testStepFail("Fail","The Third response is wrong, test end"); break; }
                else { testStepPass("Pass","The Third response received"); j = 0; break; }
              }
              else { testStepFail("Fail","Time out no Third response received, test end"); break; }
            }
          }
          else { testStepFail("Fail","Time out no Second response received, test end"); break; }
        }
      }
    }
    else { testStepFail("Fail","Time out no First response received, test end");  break; }
  }while(j < gtimes_queued_test);
  
  if(j != 0) { testStepFail("Fail","队列场景测试异常，请确认！！！"); }
  
  /*  4  */
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}

/// <PBL_GeneralTest>
testcase Seed_and_Key_Validity_Details_Test_Physical_ProgrammingSession()
{
  int  level1;
  int  level2;
  byte ExpectNRC[2]={0x12,0x7E};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1022504_Seed_and_Key_Validity_Details_Test_Physical_ProgrammingSession",400);
  testCaseDescription("The intent of this test is to verify that the security access requirements are implemented correctly.");
  testCaseTitle("1022504","Seed_and_Key_Validity_Details_Test_Physical_ProgrammingSession");
  
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);

  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);

  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("Request seed.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(0x01,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(0x01,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  TestStep("Send key",TestStepIntervalTime);
  SID27_SecurityAccess_SendKey(0x01,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(0x01,0,0);
  TestStep("Request seed.Subfunction 0x03 is not supported. ",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(0x03,PHYSICAL);
  CheckNegResponse(ExpectNRC,0,0,0,0);
  
  TestStep("Request seed.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(0x01,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(0x01,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(AllZero,gSeedArray);
  //GenerateKeyExOpt(gKeyArray,MaxKeyArraySize,DLLName);
  
  TP_TesterPresentSet(TP_OFF);
  TestStep("Wait for ECU times out to defaultSession, S3 timer plus 'ECU startup time' and an additional 500 ms.");
  delay(5500);
  
  ECUinitHandle(0);
  
  SessionFlag=APP;
  
  TestStep("Verify DefaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  
  SessionFlag=BOOT;
  
  TP_TesterPresentSet(TP_ON);
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("Request seed.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(0x01,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(0x01,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
  TP_TesterPresentSet(TP_OFF);
  
  TestStep("Wait for ECU times out to defaultSession, S3 timer plus 'ECU startup time' and an additional 500 ms.");
  delay(5500);
  
  ECUinitHandle(0);
  
  SessionFlag=APP;
  
  TestStep("Verify DefaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  
  SessionFlag=BOOT;
  
  TP_TesterPresentSet(TP_ON);
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  delay(5000);
  TestStep("Send key",TestStepIntervalTime);
  SID27_SecurityAccess_SendKey(0x01,gKeyArray,PHYSICAL);
  //TPSendRawMessage(gKeyArray,PHYSICAL);
  CheckNegResponse(0x24,0,0);
  TestStep("Request seed.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(0x01,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(0x01,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  TestStep("Send key",TestStepIntervalTime);
  SID27_SecurityAccess_SendKey(0x01,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(0x01,0,0);
  TestStep("Transition from ProgrammingSession(0x02) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  
  ECUinitHandle(0);
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("Request seed.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(0x01,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(0x01,gSeedArray,16,0,0);
  TestStep("The following test steps verify Invalid Key & false access attempts.",TestStepIntervalTime);
  
  gSeedArray[2]=gSeedArray[2]+1;
  TestStep("Generate wrong key from response.",TestStepIntervalTime);
  SID27_SecurityAccess_SendKey(0x01,gKeyArray,PHYSICAL);
  CheckNegResponse(0x35,0,0);
  
  TestStep("Request seed.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(0x01,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(0x01,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
  TestStep("Send key",TestStepIntervalTime);
  SID27_SecurityAccess_SendKey(0x01,gKeyArray,PHYSICAL);
  CheckPosResponse_SID27_SenKey(0x01,0,0);
  
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
