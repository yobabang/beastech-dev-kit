/// <APP_CommonServiceTest>
testcase Service_0x19_Sf0x03_0x04_Valid_Physical_DefaultSession_Supported_Service()
{
  byte DTC[3];
  int i,j;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350882_Service_0x19_Sf0x03_0x04_Valid_Physical_DefaultSession_Supported_Service_R2",400);
  testCaseDescription("The intent of the test is to verify that service ReadDTCInformation (0x19) and subfunction reportDTCSnapshotIdentification (0x03) and reportDTCSnapshotRecordByDTCNumber (0x04) is supported. ");
  testCaseTitle("1350882","Service_0x19_Sf0x03_0x04_Valid_Physical_DefaultSession_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  if(Flag_1904 == 0)
  {
    TestStepWarning("ECU doesn't support this subfunction , test case exit!");
    Postcondition();
    return;
  }

  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,PHYSICAL);
  CheckPosResponse_SID19_02(AvailiableMask,0,0);
  Rss1=gTpRxLength;
  if(Rss1<=3)
  {
    TestStepWarning("No avalible DTC,Test end");
    Postcondition();
    return;
  }
  //write("The number of storaged DTC is %d",Ndtc);
