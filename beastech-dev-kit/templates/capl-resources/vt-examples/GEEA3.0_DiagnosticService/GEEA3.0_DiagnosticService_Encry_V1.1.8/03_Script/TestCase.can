      SID27_SecurityAccess_RequestSeed(IODID[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(IODID[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(IODID[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(IODID[i].SecuLevel,0,0);    
    }
//
    Deauthenticate();
    
    if(IODID[i].Flag_Ser03==1)
    {
      TestStep("return control to ECU",TestStepIntervalTime);
      SID2F_IOControl(PID,0x00,ControlOptionRecord,0,ControlEnableMaskRecord,0,PHYSICAL);
      if(IODID[i].AuthenticationFlag != 1)
      {
        CheckPosResponse(0x2F,0,0);
      }
      else
      {
        CheckNegResponse(0x34,0,0);
      }
      
      
      TestStep("Short term adjustment",TestStepIntervalTime);
      SID2F_IOControl(PID,0x03,ControlOptionRecord,NumOfLenth,ControlEnableMaskRecord,0,PHYSICAL);
      if(IODID[i].AuthenticationFlag != 1)
      {
        CheckPosResponse(0x2F,0,0);
      }
      else
      {
        CheckNegResponse(0x34,0,0);
      }
      
