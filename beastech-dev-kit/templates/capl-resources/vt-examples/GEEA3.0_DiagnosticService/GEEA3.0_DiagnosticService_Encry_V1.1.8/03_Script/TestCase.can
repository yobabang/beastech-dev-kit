      TestStep("Jump to Step 2 until all the dataIdentifiers in the configured list are tested. Let Z1 Z2 = next dataIdentifier",TestStepIntervalTime,2);
    }

    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    if((PID[0] == 0xD0)&&(PID[0] == 0x1C))
    {
     testWaitForTimeout(500);
    }
    else
    {
     Result=CheckPosResponse_SID22(PID,DIDOfReadAPP[i].Lenth,0,0); 
    }
    if(Result>0)
    {
    CheckParametersCoding(DIDOfReadAPP[i]);
    if(DIDOfReadAPP[i].Lenth != (gTpRxLength-3))
