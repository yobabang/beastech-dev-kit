/// <APP_GeneralTest>
testcase Unsupported_Diagnostic_Subfunction_Test_APP_Valid_Physical_DefaultSession()
{
  int  i;
  byte data[2]={0x3e,0x01};
  byte ExpectNRC[2]={0x12,0x7E};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350983_Unsupported_Diagnostic_Subfunction_Test_APP_Valid_Physical_DefaultSession",400);
  testCaseDescription("To see if correct NRC is implemented.");
  testCaseTitle("1350983","Unsupported_Diagnostic_Subfunction_Test_APP_DefaultSession_Physical");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  for(i=1; i<=0xFF; i++)
  {
    if(i==1)
    {
      TestStep("Let SF=00",TestStepIntervalTime);
    }
    else
    {
      TestStep("If SF<0xFF add 1 to SF and jump to Step 2",TestStepIntervalTime,2);
    }
    
    if(i!=0x80)
    {
      data[1]=i;
    }
    else
    {
      TestStep("If SF equals a subfunction supported to service 0x3E from configured list jump to Step 4",TestStepIntervalTime,4);
    }
    TestStep("Send service 0x3E with unsupported subfunction",TestStepIntervalTime);
    TPSendRawMessage(data,PHYSICAL);
    CheckNegResponse(ExpectNRC,0,0,0,0);
  }
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}

