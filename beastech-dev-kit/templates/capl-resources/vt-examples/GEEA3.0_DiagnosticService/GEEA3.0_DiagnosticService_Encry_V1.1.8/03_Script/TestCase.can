/// <PBL_SecurityAccessAlgorithm>
testcase Basic_Random_Seed_Test_ProgrammingSession()
{
  int i;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1023156_Basic_Random_Seed_Test_ProgrammingSession",400);
  testCaseTitle("1023156","Basic_Random_Seed_Test_ProgrammingSession");
  
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;

  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0); 
 
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  Level1=0x01;  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  TestStep("ECU response with seed. Verify that S1...S16 not equal to 0x000000.",TestStepIntervalTime);
  SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
  CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
  PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <PBL_SecurityAccessAlgorithm>
testcase Extended_Random_Seed_Test_ProgrammingSession()
{
  int i,j,k,n=0;
  byte AllSeeds_PBL[20000][16];
  int repeatFlag=0;
  struct seedinforecord
  {
    byte seedinfo[16];
    int  seedtime;
  };
  
  struct seedinforecord seedrecord[10000];
  int  seednum = 0;
  int  checkflag;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1023157_Extended_Random_Seed_Test_ProgrammingSession",400);
  testCaseTitle("1023157","Extended_Random_Seed_Test_ProgrammingSession");
  
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;

  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
    
  Level1=0x01;    
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  for(i=0; i<5000; i++)
  {
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    for(j=0; j<i; j++)
    {
      if((AllSeeds_PBL[j][0] == gSeedArray[0]) && (AllSeeds_PBL[j][1] == gSeedArray[1]) && (AllSeeds_PBL[j][2] == gSeedArray[2])&& (AllSeeds_PBL[j][3] == gSeedArray[3])&& (AllSeeds_PBL[j][4] == gSeedArray[4])&& (AllSeeds_PBL[j][5] == gSeedArray[5])&& (AllSeeds_PBL[j][6] == gSeedArray[6])&& (AllSeeds_PBL[j][7] == gSeedArray[7])&& (AllSeeds_PBL[j][8] == gSeedArray[8])&& (AllSeeds_PBL[j][9] == gSeedArray[9])&& (AllSeeds_PBL[j][10] == gSeedArray[10])&& (AllSeeds_PBL[j][11] == gSeedArray[11])&& (AllSeeds_PBL[j][12] == gSeedArray[12])&& (AllSeeds_PBL[j][13] == gSeedArray[13])&& (AllSeeds_PBL[j][14] == gSeedArray[14])&& (AllSeeds_PBL[j][15] == gSeedArray[15]))
      {
        repeatFlag = 1;
        TestStepFail("Fail","Generated seed is repeated.");
        checkflag = 0;
          for(k = 0;k < seednum;k++)
          {
            if((seedrecord[k].seedinfo[0] == gSeedArray[0])&& (seedrecord[k].seedinfo[1] == gSeedArray[1]) && (seedrecord[k].seedinfo[2] == gSeedArray[2])&& (seedrecord[k].seedinfo[3] == gSeedArray[3])&& (seedrecord[k].seedinfo[4] == gSeedArray[4])&& (seedrecord[k].seedinfo[5] == gSeedArray[5])&& (seedrecord[k].seedinfo[6] == gSeedArray[6])&& (seedrecord[k].seedinfo[7] == gSeedArray[7])&& (seedrecord[k].seedinfo[8] == gSeedArray[8])&& (seedrecord[k].seedinfo[9] == gSeedArray[9])&& (seedrecord[k].seedinfo[10] == gSeedArray[10])&& (seedrecord[k].seedinfo[11] == gSeedArray[11])&& (seedrecord[k].seedinfo[12] == gSeedArray[12])&& (seedrecord[k].seedinfo[13] == gSeedArray[13])&& (seedrecord[k].seedinfo[14] == gSeedArray[14])&& (seedrecord[k].seedinfo[15] == gSeedArray[15]))
            {
              seedrecord[k].seedtime++;
              checkflag = 1;
            }
          }
          if(checkflag == 1)
          {
            
          }
          else
          {
            seedrecord[seednum].seedinfo[0] = gSeedArray[0];
            seedrecord[seednum].seedinfo[1] = gSeedArray[1];
            seedrecord[seednum].seedinfo[2] = gSeedArray[2];
            seedrecord[seednum].seedinfo[3] = gSeedArray[3];
            seedrecord[seednum].seedinfo[4] = gSeedArray[4];
            seedrecord[seednum].seedinfo[5] = gSeedArray[5];
            seedrecord[seednum].seedinfo[6] = gSeedArray[6];
            seedrecord[seednum].seedinfo[7] = gSeedArray[7];
            seedrecord[seednum].seedinfo[8] = gSeedArray[8];
            seedrecord[seednum].seedinfo[9] = gSeedArray[9];
            seedrecord[seednum].seedinfo[10] = gSeedArray[10];
            seedrecord[seednum].seedinfo[11] = gSeedArray[11];
            seedrecord[seednum].seedinfo[12] = gSeedArray[12];
            seedrecord[seednum].seedinfo[13] = gSeedArray[13];
            seedrecord[seednum].seedinfo[14] = gSeedArray[14];
            seedrecord[seednum].seedinfo[15] = gSeedArray[15];
            seedrecord[seednum].seedtime = 1;
            seednum++;
          }
      }
    }
    if(repeatFlag == 0)
    {
      AllSeeds_PBL[i][0] = gSeedArray[0];
      AllSeeds_PBL[i][1] = gSeedArray[1];
      AllSeeds_PBL[i][2] = gSeedArray[2];
