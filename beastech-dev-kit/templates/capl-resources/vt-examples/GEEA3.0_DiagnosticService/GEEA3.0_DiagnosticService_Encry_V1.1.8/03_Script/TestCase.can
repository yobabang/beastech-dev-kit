      {
        if(GEEA30_E245[i].canChannelNumber!=0)
        {
          Teststep("INF","=======================Now testing %s subnet communicationControl function=======================",GEEA30_E245[i].network);
          subnetComConTestingChannel=GEEA30_E245[i].canChannelNumber;
          CommType=(GEEA30_E245[i].value<<4)|0x3;
          SID28_CommunicationControl(SFOf28[3],CommType,PHYSICAL,SPRMIB_FALSE);
