  Precondition();
   
  /******************************以下为测试步骤*********************************/
  
//***************************************************************************//
  SessionFlag=APP;
  
//22&2E
  
  for(i=10;i<0xFF;i++)
  {
    for(j=0;j<service_APP_Num;j++)
    {
      if(service_APP[j]==i)
      {
        data[0]=i;
        TPSendRawMessage(data,PHYSICAL);
        CheckNegResponse(0x34,0,0);
        break;
      }

    }
    for(j=0;j<service_PBL_Num;j++)
    {
      if(service_PBL[j]==i)
      {
        data[0]=i;
        TPSendRawMessage(data,PHYSICAL);
        CheckNegResponse(0x34,0,0);
        break;
      }

    }
  }

  for(i=0; i<NumOfReadDIDAPP; i++)
  {
    if(DIDOfReadAPP[i].Flag_Extended==0)
    {
      continue;
    }
    PID[0]=DIDOfReadAPP[i].DID>>8;
    PID[1]=DIDOfReadAPP[i].DID&0xFF;
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C))
    {
      continue;
    }
    if((PID[0] == 0xD0)&&(PID[1] == 0x3A))
    {
      continue;
    }
