            {
              if((seedrecord[k].seedinfo[0] == gSeedArray[0])&& (seedrecord[k].seedinfo[1] == gSeedArray[1]) && (seedrecord[k].seedinfo[2] == gSeedArray[2])&& (seedrecord[k].seedinfo[3] == gSeedArray[3])&& (seedrecord[k].seedinfo[4] == gSeedArray[4])&& (seedrecord[k].seedinfo[5] == gSeedArray[5])&& (seedrecord[k].seedinfo[6] == gSeedArray[6])&& (seedrecord[k].seedinfo[7] == gSeedArray[7])&& (seedrecord[k].seedinfo[8] == gSeedArray[8])&& (seedrecord[k].seedinfo[9] == gSeedArray[9])&& (seedrecord[k].seedinfo[10] == gSeedArray[10])&& (seedrecord[k].seedinfo[11] == gSeedArray[11])&& (seedrecord[k].seedinfo[12] == gSeedArray[12])&& (seedrecord[k].seedinfo[13] == gSeedArray[13])&& (seedrecord[k].seedinfo[14] == gSeedArray[14])&& (seedrecord[k].seedinfo[15] == gSeedArray[15]))
              {
