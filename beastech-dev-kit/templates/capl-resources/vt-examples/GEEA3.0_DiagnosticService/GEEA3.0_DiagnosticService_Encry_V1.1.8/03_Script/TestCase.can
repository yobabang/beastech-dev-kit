      AllSeeds_PBL[i][4] = gSeedArray[4];
      AllSeeds_PBL[i][5] = gSeedArray[5];
      AllSeeds_PBL[i][6] = gSeedArray[6];
      AllSeeds_PBL[i][7] = gSeedArray[7];
      AllSeeds_PBL[i][8] = gSeedArray[8];
      AllSeeds_PBL[i][9] = gSeedArray[9];
      AllSeeds_PBL[i][10] = gSeedArray[10];
      AllSeeds_PBL[i][11] = gSeedArray[11];
      AllSeeds_PBL[i][12] = gSeedArray[12];
      AllSeeds_PBL[i][13] = gSeedArray[13];
      AllSeeds_PBL[i][14] = gSeedArray[14];
      AllSeeds_PBL[i][15] = gSeedArray[15];
    }
  }
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  for(i=5000; i<10000; i++)
  {
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    for(j=0; j<i; j++)
    {
      if((AllSeeds_PBL[j][0] == gSeedArray[0]) && (AllSeeds_PBL[j][1] == gSeedArray[1]) && (AllSeeds_PBL[j][2] == gSeedArray[2])&& (AllSeeds_PBL[j][3] == gSeedArray[3])&& (AllSeeds_PBL[j][4] == gSeedArray[4])&& (AllSeeds_PBL[j][5] == gSeedArray[5])&& (AllSeeds_PBL[j][6] == gSeedArray[6])&& (AllSeeds_PBL[j][7] == gSeedArray[7])&& (AllSeeds_PBL[j][8] == gSeedArray[8])&& (AllSeeds_PBL[j][9] == gSeedArray[9])&& (AllSeeds_PBL[j][10] == gSeedArray[10])&& (AllSeeds_PBL[j][11] == gSeedArray[11])&& (AllSeeds_PBL[j][12] == gSeedArray[12])&& (AllSeeds_PBL[j][13] == gSeedArray[13])&& (AllSeeds_PBL[j][14] == gSeedArray[14])&& (AllSeeds_PBL[j][15] == gSeedArray[15]))
      {
        repeatFlag = 1;
        TestStepFail("Fail","Generated seed is repeated.");
        checkflag = 0;
          for(k = 0;k < seednum;k++)
          {
            if((seedrecord[k].seedinfo[0] == gSeedArray[0])&& (seedrecord[k].seedinfo[1] == gSeedArray[1]) && (seedrecord[k].seedinfo[2] == gSeedArray[2])&& (seedrecord[k].seedinfo[3] == gSeedArray[3])&& (seedrecord[k].seedinfo[4] == gSeedArray[4])&& (seedrecord[k].seedinfo[5] == gSeedArray[5])&& (seedrecord[k].seedinfo[6] == gSeedArray[6])&& (seedrecord[k].seedinfo[7] == gSeedArray[7])&& (seedrecord[k].seedinfo[8] == gSeedArray[8])&& (seedrecord[k].seedinfo[9] == gSeedArray[9])&& (seedrecord[k].seedinfo[10] == gSeedArray[10])&& (seedrecord[k].seedinfo[11] == gSeedArray[11])&& (seedrecord[k].seedinfo[12] == gSeedArray[12])&& (seedrecord[k].seedinfo[13] == gSeedArray[13])&& (seedrecord[k].seedinfo[14] == gSeedArray[14])&& (seedrecord[k].seedinfo[15] == gSeedArray[15]))
