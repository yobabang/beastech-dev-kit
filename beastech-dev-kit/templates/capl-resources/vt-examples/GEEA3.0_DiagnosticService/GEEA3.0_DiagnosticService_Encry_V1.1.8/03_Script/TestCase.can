      ECUinitHandle(0);
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    }
    
    TestStep("11 01",TestStepIntervalTime);
    SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
    CheckNegResponse(nrc,0,0);
    if(gRss == POS) 
    { 
      ECUinitHandle(0); 
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    }
    /*  5  */
    TestStep("11 81",TestStepIntervalTime);
    SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_TRUE);
    CheckNegResponse(nrc,0,0);
    if(gRss == POS || gRss == TIMEOUT) 
    { 
      ECUinitHandle(0); 
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    }  
    
    if(m == count-1)     { TestStep("All different Entry conditions(not fulfilled) Completed!",TestStepIntervalTime); }
    else if(m < count-1) { TestStep("Repeat steps with different Entry conditions(not fulfilled)",TestStepIntervalTime,1); }
  }
  
  TestStep("Remove All Entry conditions and wait 5s",TestStepIntervalTime);
  if(gTestTypeFlag == 1) { StopTRC(); }
  else                   { testWaitForTesterConfirmation("Remove All Entry conditions and wait 5s"); }
  delay(5000);
  
  TestStep("Transition to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);

  TestStep("Check Programming Pre-condition",TestStepIntervalTime);
  TPSendRawMessage(Data,PHYSICAL);
  CheckPosResponse(0x31,0,0);
  if(gRss == POS)
  {
    if(gTpRxData[5] != 0x01)
    {
      TestStepFail("","The response data is not right , expect 71 01 02 06 10 01");
    }
  }
  
  TestStep("Transition to programmingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  SessionFlag=BOOT;
  
  TestStep("Verify programmingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse(0x11,0,0);
  ECUinitHandle(0);
  /******************************以上为测试步骤*********************************/
  
  Postcondition();
}
/// <APP_GeneralTest>
testcase Check_Programming_Pre_conditions_Precondition_Notfulfilled_Valid_Functional_ExtendedSession_Supported_Service()
{
  byte Data[4]={0x31,0x01,0x02,0x06};
  int  i,j,k,m,n,count;
  char logName[400] = "";
  char info[1024];
  byte nrc;
  
  strncat(logName,"28320_Check_Programming_Pre_conditions_Precondition_Notfulfilled_Valid_Functional_ExtendedSession_Supported_Service",400);
  testCaseDescription("The intent of the test is to verify that control routin 0206 is supported and response correct to precondition.");
  testCaseTitle("28320","Check_Programming_Pre_conditions_Precondition_Notfulfilled_Valid_Functional_ExtendedSession_Supported_Service");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  /* 获取所有待测信号的数量 */
  for(i=0;i<E2E_FRAME_NUM;i++) 
  { 
  	for(j=0;j<elcount(e2eFrameList[i].e2eSigGroupList);j++)
  	{
  		if(strncmp(e2eFrameList[i].e2eSigGroupList[j].sigGroupName,"",elcount(e2eFrameList[i].e2eSigGroupList[j].sigGroupName)) == 0) { break; }
  		else
  		{
  			for(k=0;k<e2eFrameList[i].e2eSigGroupList[j].sigNum;k++)
  			{
  				if(e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigUsed & SIGNALPROGRAMMING == SIGNALPROGRAMMING) { count++; }
  			}
  		}
  	}
  }
  if(count == 0) { testStepFail("Test","No Signal About Programming Precondition in ParameterOfSigGroups.cin, Test Abort!!!"); return;  }
  
  /* 遍历所有待测的信号，信号值不满足场景 */
  for(m=0;m<count;m++) 
  {
  	n = 0;
  	strncpy(info,"",elCount(info));   //清空打印信息
  	for(i=0;i<E2E_FRAME_NUM;i++) 
  	{ 
      e2eFrameList[i].simFrFlg = 0; e2eFrameList[i].simFrImtFlg = 0;
  		for(j=0;j<elcount(e2eFrameList[i].e2eSigGroupList);j++)
  		{
  			if(strncmp(e2eFrameList[i].e2eSigGroupList[j].sigGroupName,"",elcount(e2eFrameList[i].e2eSigGroupList[j].sigGroupName)) == 0) { break; }
  			else
  			{
          
  				for(k=0;k<e2eFrameList[i].e2eSigGroupList[j].sigNum;k++)
  				{
  					if(e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigUsed & SIGNALPROGRAMMING == SIGNALPROGRAMMING) 
  					{ 
  						if(m == n) //当前测试信号设置成不满足条件值
  						{ 
                nrc=e2eFrameList[i].e2eSigGroupList[j].nrc;
  							snprintf(info,elCount(info),"%s%s = %02X(NotFulfilled)\n",info,e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigName,
  							e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_NotFulfilled);
  							e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue = e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_NotFulfilled; 
  						}
  						else //其余测试信号设置成满足条件值
  						{ 
  							snprintf(info,elCount(info),"%s%s = %02X(Fulfilled)\n",info,e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigName,
  							e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_Fulfilled);
  							e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue = e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_Fulfilled; 
  						}
  						n++;
              e2eFrameList[i].simFrFlg = 1; e2eFrameList[i].simFrImtFlg = 1;
  					}
  				}
  			}
  		}
  	}
    snprintf(info,elCount(info),"Set condition %d: \n%s",m+1,info);
    
    TestStep(info);
    if(gTestTypeFlag == 1) { SimTRC(); }
    else                   { testWaitForTesterConfirmation(info); }
    delay(5000);
    
    TestStep("Transition to extendedSession(0x03)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    TestStep("Verify extendedSession",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    TestStep("Check Programming Pre-condition",TestStepIntervalTime);
    TPSendRawMessage(Data,FUNCTIONAL);
    CheckPosResponse(0x31,0,0);
    if(gRss == POS)
    {
      if(gTpRxData[5] != 0x02 || gTpRxData[4] != 0x10) { TestStepFail("","The response data is not right , expect 71 01 02 06 10 02"); }
    }
    
    TestStep("Transition to ProgrammingSession(0x02)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
    CheckNegResponse(nrc,0,0);
    if(gRss == POS)
    {
      ECUinitHandle(0);
      SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      ECUinitHandle(0);
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    }
    
    TestStep("Transition to ProgrammingSession(0x82)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_TRUE);
    CheckNegResponse(nrc,0,0);
    if(gRss == POS || gRss == TIMEOUT)
    {
      ECUinitHandle(0);
      SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      ECUinitHandle(0);
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    }
    
    TestStep("11 01",TestStepIntervalTime);
    SID11_ECUReset(HARDRESET,FUNCTIONAL,SPRMIB_FALSE);
    CheckNegResponse(nrc,0,0);
    if(gRss == POS) 
    { 
      ECUinitHandle(0); 
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    }
    /*  5  */
    TestStep("11 81",TestStepIntervalTime);
    SID11_ECUReset(HARDRESET,FUNCTIONAL,SPRMIB_TRUE);
    CheckNegResponse(nrc,0,0);
    if(gRss == POS || gRss == TIMEOUT) 
    { 
      ECUinitHandle(0); 
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    }  
    
    if(m == count-1)     { TestStep("All different Entry conditions(not fulfilled) Completed!",TestStepIntervalTime); }
    else if(m < count-1) { TestStep("Repeat steps with different Entry conditions(not fulfilled)",TestStepIntervalTime,1); }
  }
  
  set_trc_valid();//20251021 石太佳：这里要把所有的仿真信号设置会fulfilled
  TestStep("Remove All Entry conditions and wait 5s",TestStepIntervalTime);
  if(gTestTypeFlag == 1) { StopTRC(); }
  else                   { testWaitForTesterConfirmation("Remove All Entry conditions and wait 5s"); }
  delay(5000);
  
  TestStep("Transition to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);

  TestStep("Check Programming Pre-condition",TestStepIntervalTime);
  TPSendRawMessage(Data,FUNCTIONAL);
  CheckPosResponse(0x31,0,0);
  if(gRss == POS)
  {
    if(gTpRxData[5] != 0x01)
    {
      TestStepFail("","The response data is not right , expect 71 01 02 06 10 01");
    }
  }
  
  TestStep("Transition to programmingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  SessionFlag=BOOT;
  
  TestStep("Verify programmingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  SID11_ECUReset(HARDRESET,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse(0x11,0,0);
  ECUinitHandle(0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}

/// <APP_GeneralTest>
testcase Seed_and_Key_Validity_Details_Test_Physical_ExtendedSession()
{
  int  L1,LX,B;
  byte ExpectNRC[2]={0x12,0x7E};
  int  i,j=0;
  char logName[400] = "";
  char info[1024];
  byte tempseedarray[16];
  
  struct SecurtiyLevelToTest{
    byte levelTestRecord;
    byte TestedFlag;
  };
  struct SecurtiyLevelToTest APP_SecurityTestLevel[50];
  byte levelToTestNum,levelToTestNumNow;
  
  strncat(logName,"1022762_Seed_and_Key_Validity_Details_Test_Physical_ExtendedSession",400);
  testCaseDescription("The intent of this test is to verify that the security access requirements are implemented correctly.");
  testCaseTitle("1022762","Seed_and_Key_Validity_Details_Test_Physical_ExtendedSession");
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  
  TestStep("Transition from defaultSession(0x01) to Extendedsession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  
  TestStep("Verify ExtendedSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  testWaitForTimeout(gTimeWaitForSecuAccess);
  
  levelToTestNum=0;
  for(i=0; i<NumOfSecurityLv; i++)
  {
    if(SELevel[i].SEFlagPBL == 1)
    {
      continue;
    }
    APP_SecurityTestLevel[levelToTestNum].levelTestRecord=SELevel[i].SElevel;
    APP_SecurityTestLevel[levelToTestNum].TestedFlag=0;
    levelToTestNum++;
  }
  
  levelToTestNumNow=levelToTestNum;
  for(i=0; i<levelToTestNum; i++)
  {
    if(i==0)
      TestStep("Let L1 = First security level from the configured security level array from configured list. ",TestStepIntervalTime);
    else
    {
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
      TestStep("If more security levels are supported jump to step 3 and let L1 be the next supported requestSeed level in ascending order after the last tested level. Note this means that L2 shall also increase level with same amount as L1.  ",TestStepIntervalTime,3);
    }
  
    L1=APP_SecurityTestLevel[i].levelTestRecord;
    
    if(levelToTestNumNow>=2)
    {
      TestStep("If more than one security level is implemented in current session, then go to step 5, else go to step 12",TestStepIntervalTime,5);
    
      TestStep("Request seed L1",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      
      TestStep("Let LX be next security level from configured security level array list");
      LX=APP_SecurityTestLevel[i+1].levelTestRecord;

      TestStep("Send key LX",TestStepIntervalTime);
      SID27_SecurityAccess_SendKey(LX,gKeyArray,PHYSICAL);
      CheckNegResponse(0x24,0,0);

      TestStep("Send key L1",TestStepIntervalTime);
      SID27_SecurityAccess_SendKey(L1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x24,0,0);
        
      TestStep("Request seed L1.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);

      TestStep("Request seed LX.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(LX,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(LX,tempseedarray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,tempseedarray);
      
      TestStep("Send key L1",TestStepIntervalTime);
      SID27_SecurityAccess_SendKey(L1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x24,0,0);

    }
    else
    {
      TestStep("If more than one security level is implemented in current session, then go to step 5, else go to step 12",TestStepIntervalTime,12);
    }

    TestStep("Request seed L1.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    
    TestStep("Send key L1",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(L1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(L1,0,0);
    
    TestStep("Disable functionally addressed periodic testerPresent. Wait for 6 seconds.Resume functionally addressed periodic testerPresent.");
    TP_TesterPresentSet(TP_OFF); 
    delay(6000);
    TP_TesterPresentSet(TP_ON);
    
    TestStep("Verify DefaultSession.",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);

    TestStep("Transition from defaultSession(0x01) to ExtendedSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
    CheckNonResponse(0,0);
    
    ECUinitHandle(0);
    TestStep("Verify ExtendedSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    TestStep("Request Seed L1",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
    
    TestStep("Disable functionally addressed periodic testerPresent. Wait for 6 seconds.Resume functionally addressed periodic testerPresent.");
    TP_TesterPresentSet(TP_OFF); 
    delay(6000);
    TP_TesterPresentSet(TP_ON);
    
    TestStep("Verify DefaultSession.",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);

    TestStep("Transition from defaultSession(0x01) to ExtendedSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
    CheckNonResponse(0,0);
    
    ECUinitHandle(0);
    TestStep("Verify ExtendedSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    TestStep("Send key L1",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(L1,gKeyArray,PHYSICAL);
    CheckNegResponse(0x24,0,0);
    
    
    
    TestStep("The following test cases verify Invalid Key and false access attempts.");
    TestStep("Check minimum false attemps without time delay starts.");
    TestStep("Let B=1");
    
    for(B=1;B<2;B++)
    {
      TestStep("Request seed L1.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
      
      gSeedArray[15]=~gSeedArray[15];
      TestStep("Send wrong key L1",TestStepIntervalTime);
      SID27_SecurityAccess_SendKey(L1,gKeyArray,PHYSICAL);
      CheckNegResponse(0x35,0,0); 
      
      if(B<2)
        TestStep(" if B<2, repeat step 27 & step 28, with no delay between requests. ",TestStepIntervalTime,27);
      else
      {
        TestStep(" if B<2, repeat step 27 & step 28, with no delay between requests. ",TestStepIntervalTime);
      }
    }
    
      TestStep("Request seed L1.",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
      PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);

      TestStep("Send key L1",TestStepIntervalTime);
      SID27_SecurityAccess_SendKey(L1,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(L1,0,0);

      TestStep("Verify ExtendedSession.",TestStepIntervalTime);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
      TestStep("The following test cases verify that server will relock after transitioning to same session");

      TestStep("Transition to ExtendedSession(0x03).",TestStepIntervalTime);
      SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);

      TestStep("Verify ExtendedSession.",TestStepIntervalTime);
      CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
      TestStep("Request seed L1",TestStepIntervalTime);
      SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
      if(levelToTestNumNow>=2)
      {
        TestStep("If more than one security level is implemented the following sequence will verify that a currently open security session will lock if an other level is open. ");
        TestStep("Request seed L1.",TestStepIntervalTime);
        SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
        PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);

        TestStep("Send key L1",TestStepIntervalTime);
        SID27_SecurityAccess_SendKey(L1,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(L1,0,0);
        
        TestStep("Request seed LX.",TestStepIntervalTime);
        SID27_SecurityAccess_RequestSeed(LX,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(LX,gSeedArray,16,0,0);
        PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);

        TestStep("Send key LX",TestStepIntervalTime);
        SID27_SecurityAccess_SendKey(LX,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(LX,0,0);
        
        TestStep("Request seed L1.",TestStepIntervalTime);
        SID27_SecurityAccess_RequestSeed(L1,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(L1,gSeedArray,16,0,0);
        PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
        
        TestStep("Verify ExtendedSession.",TestStepIntervalTime);
        CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
      }
      else 
      {
        TestStep("If only one security level is implemented jump to step 44. ",TestStepIntervalTime,44);
       
      }
   levelToTestNumNow--;
  }
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <APP_GeneralTest>
testcase Unsupported_Diagnostic_Service_Test_APP_Valid_Physical_DefaultSesion()
{
  int i,j,k;
  byte TestSD_service[1]= {0x00};
  int Flag,startFlag=0;
  int StartService;
  char logName[400] = "";
  char info[1024];
  byte expectNRC[2]={0x11,0x7F};
  byte SID28Sup=0,SID85Sup=0;
  
  strncat(logName,"1350979_Unsupported_Diagnostic_Service_Test_APP_Valid_Physical_DefaultSesion",400);
  testCaseDescription("To ensure that no other services is implemented than those in configured list.");
  testCaseTitle("1350979","Unsupported_Diagnostic_Service_Test_APP_Valid_Physical_DefaultSesion");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/

  if(gBusFlag!=3)
	{
    for(k=0;k<service_APP_Num;k++)
    {
      if(service_APP[k]==0x28)
        SID28Sup=1;
      if(service_APP[k]==0x85)
        SID85Sup=1;
    }
    if(SID28Sup!=1)
    {
      testStepFail("Fail","Service 0x28 expect support according SWRS,but not support in SDDB");
    }
    if(SID85Sup!=1)
    {
      testStepFail("Fail","Service 0x85 expect support according SWRS,but not support in SDDB");
    }
	}

  SessionFlag=APP;
  
  if(Flag_OBDNode == 1)
    StartService = 0x10;
  else
    StartService = 0x00;
  
  for(i=StartService; i<=0xFF; i++)
  {
    Flag = 0;
    
    if((i==0x10||i==0)&&startFlag==0)
    {
      startFlag=1;
      snprintf(info,elcount(info),"Let SV=%02x",StartService);
      TestStep(info,TestStepIntervalTime);
    }
    else
    {
      TestStep("If SV<0xFF add 1 to SV and jump to Step 2",TestStepIntervalTime,2);
    }
    
    for(j=0;j<service_APP_Num;j++)
    {
      if(service_APP[j] == i)
        Flag = 1;
    }
    if(Flag == 1)
    {
      TestStep("If SV equals a service from configured list jump to Step 4",TestStepIntervalTime,4);
      continue;
    }
      
    TestSD_service[0]=i;
    TestStep("Request unsupported service",TestStepIntervalTime);
    TPSendRawMessage(TestSD_service,PHYSICAL);
    CheckNegResponse(expectNRC,0,0,0,0);
  }
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}
/// <APP_GeneralTest>
testcase Unsupported_Diagnostic_Service_Test_APP_Valid_Functional_DefaultSesion()
{
  int i,j,k;
  byte TestSD_service[1]= {0x00};
  int Flag,startFlag=0;
  int StartService;
  char logName[400] = "";
  char info[1024];
  byte SID28Sup=0,SID85Sup=0;
  
  strncat(logName,"1350981_Unsupported_Diagnostic_Service_Test_APP_Valid_Functional_DefaultSesion",400);
  testCaseDescription("To ensure that no other services is implemented than those in configured list.");
  testCaseTitle("1350981","Unsupported_Diagnostic_Service_Test_APP_Valid_Functional_DefaultSesion");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  if(gBusFlag!=3)
	{
    for(k=0;k<service_APP_Num;k++)
    {
      if(service_APP[k]==0x28)
        SID28Sup=1;
      if(service_APP[k]==0x85)
        SID85Sup=1;
    }
    if(SID28Sup!=1)
    {
      testStepFail("Fail","Service 0x28 expect support according SWRS,but not support in SDDB");
    }
    if(SID85Sup!=1)
    {
      testStepFail("Fail","Service 0x85 expect support according SWRS,but not support in SDDB");
    }
	}
  
  SessionFlag=APP;
  
  if(Flag_OBDNode == 1)
    StartService = 0x10;
  else
    StartService = 0x00;
  
  for(i=StartService; i<=0xFF; i++)
  {
    Flag = 0;
    
    if((i==0x10||i==0)&&startFlag==0)
    {
      startFlag=1;
      snprintf(info,elcount(info),"Let SV=%02x",StartService);
      TestStep(info,TestStepIntervalTime);
    }
    else
    {
      TestStep("If SV<0xFF add 1 to SV and jump to Step 2",TestStepIntervalTime,2);
    }
    
    for(j=0;j<service_APP_Num;j++)
    {
      if(service_APP[j] == i)
        Flag = 1;
    }
    if(Flag == 1)
    {
      TestStep("If SV equals a service from configured list jump to Step 4",TestStepIntervalTime,4);
      continue;
    }
    
    TestSD_service[0]=i;
    TestStep("Request unsupported service",TestStepIntervalTime);
    TPSendRawMessage(TestSD_service,FUNCTIONAL);
    CheckNonResponse(0,0);
  }
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
