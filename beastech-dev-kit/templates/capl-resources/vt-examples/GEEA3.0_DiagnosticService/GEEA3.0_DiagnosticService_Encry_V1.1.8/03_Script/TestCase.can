/// <PBL_CommonServiceTest>
testcase Service_0x22_Physical_ProgrammingSession_Supported_Service()
{
  int  i;
  byte PID[2];
  int  code;
  int Result;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351003_Service_0x22_Physical_ProgrammingSession_Supported_Service",400);
  testCaseDescription("That the ECU supports the service ReadDataByIdentifier (0x22) by reading out supported DataIdentifiers (DID).That the ECU supports the service WriteDataByIdentifier (0x2E) by writing data to supported DataIdentifiers (DID).");
  testCaseTitle("1351003","Service_0x22_Physical_ProgrammingSession_Supported_Service");
  
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=BOOT;
  
  TestStep("Let Z1 Z2= First DataIdentifier from configured list.",TestStepIntervalTime);
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  for(i=0; i<NumOfReadDIDPBL; i++)
  {
    PID[0]=DIDOfReadPBL[i].DID>>8;
    PID[1]=DIDOfReadPBL[i].DID&0xFF;
    
    if(DIDOfReadPBL[i].Flag_Programming==0) { continue; }
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C)) { continue; }
    if((PID[0] == 0xD0)&&(PID[1] == 0x3A)) { continue; }
    if((PID[0] == 0xF1)&&(PID[1] == 0x09)) { continue; }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0B)) { continue; }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0A)) { continue; }
    
    if(i!=0)
    {
      TestStep("Jump to Step 4 until all the dataIdentifiers in configured list are tested. Let Z1 Z2 = next dataIdentifier.",TestStepIntervalTime);
    }
    
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    Result=CheckPosResponse_SID22(PID,DIDOfReadPBL[i].Lenth,0,0); 
    
    if(Result>0)
    {
    CheckParametersCoding(DIDOfReadPBL[i]);
    if(DIDOfReadPBL[i].Lenth!=(gTpRxLength-3))
      TestStepFail("Fail","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
    else
      TestStepPass("Pass","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
    }
    
    TestStep("","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
  }
  
  for(i=0;i<NumOfWriteDIDPBL;i++)
  {
    if(DIDOfWritePBL[i].Flag_Programming==0)
    {
      continue;
    }
    if(DIDOfWritePBL[i].SecuLevel!=0xFF)
    {
      SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
      
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(DIDOfWritePBL[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(DIDOfWritePBL[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(DIDOfWritePBL[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(DIDOfWritePBL[i].SecuLevel,0,0);
    }
      
    PID[0]=DIDOfWritePBL[i].DID>>8;
    PID[1]=DIDOfWritePBL[i].DID&0xFF;
      
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
    RecordData();
    TestStep("Write data",TestStepIntervalTime);
    WriteTestData(DIDOfWritePBL[i],PHYSICAL);
    CheckPosResponse_SID2E(PID,0,0);
      
      
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
    ComTestData();
      
    testWaitForTimeout(500);
    WritePreviousData(PHYSICAL);
    CheckPosResponse_SID2E(PID,0,0);

    TestStep("Data recover",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
  }
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <PBL_CommonServiceTest>
testcase Service_0x22_Functional_ProgrammingSession_Supported_Service()
{
  int  i;
  byte PID[2];
  int  code;
  int Result;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351004_Service_0x22_Functional_ProgrammingSession_Supported_Service",400);
  testCaseDescription("That the ECU supports the service ReadDataByIdentifier (0x22) by reading out supported DataIdentifiers (DID).That the ECU supports the service WriteDataByIdentifier (0x2E) by writing data to supported DataIdentifiers (DID).");
  testCaseTitle("1351004","Service_0x22_Functional_ProgrammingSession_Supported_Service");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
 TestStep("Let Z1 Z2= First DataIdentifier from configured list.",TestStepIntervalTime);
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  for(i=0; i<NumOfReadDIDPBL; i++)
  {
    PID[0]=DIDOfReadPBL[i].DID>>8;
    PID[1]=DIDOfReadPBL[i].DID&0xFF;
    
    if(DIDOfReadPBL[i].Flag_Programming==0) { continue; }
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C)) { continue; }
    if((PID[0] == 0xD0)&&(PID[1] == 0x3A)) { continue; }
    if((PID[0] == 0xF1)&&(PID[1] == 0x09)) { continue; }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0B)) { continue; }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0A)) { continue; }
    
    if(i!=0)
    {
      TestStep("Jump to Step 4 until all the dataIdentifiers in configured list are tested. Let Z1 Z2 = next dataIdentifier.",TestStepIntervalTime,4);
    }
    
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,FUNCTIONAL);
    Result=CheckPosResponse_SID22(PID,DIDOfReadPBL[i].Lenth,0,0); 
    if(Result>0)
    {
    CheckParametersCoding(DIDOfReadPBL[i]);
    if(DIDOfReadPBL[i].Lenth!=(gTpRxLength-3))
      TestStepFail("Fail","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
    else
      TestStepPass("Pass","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
    }
    
    TestStep("","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
  }
  
  for(i=0;i<NumOfWriteDIDPBL;i++)
  {
      if(DIDOfWritePBL[i].Flag_Programming==0)
      {
        continue;
      }
    PID[0]=DIDOfWritePBL[i].DID>>8;
    PID[1]=DIDOfWritePBL[i].DID&0xFF;
      
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
    RecordData();
    TestStep("Write data",TestStepIntervalTime);
    WriteTestData(DIDOfWritePBL[i],PHYSICAL);
    CheckPosResponse_SID2E(PID,0,0);
      
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
    ComTestData();
      
    testWaitForTimeout(500);
    WritePreviousData(PHYSICAL);
    CheckPosResponse_SID2E(PID,0,0);

    TestStep("Data recover",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
  }
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <PBL_CommonServiceTest>
testcase Service_0x31_valid_physical_programmingSession_supported_service_locked()
{
  
  char logPath[1000] = "";
  byte RID[2];
  byte Record[1];
  byte PID[2];
  int  i,j;
  byte StuffByte[400];
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351008_Service_0x31_valid_physical_programmingSession_supported_service_locked_R3",400);
  testCaseDescription("The power to the ECU will be cycled.After power cycled wait to operation cycle start.Read out of diagnostic session");
  testCaseTitle("1351008","Service_0x31_valid_physical_programmingSession_supported_service_locked_R3");
  
  
  SetLog(logName);
  Precondition();

  
  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  TestStep("Transition from defaultSession(0x01) to programmingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  SessionFlag=BOOT;
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  //ECUinitHandle(0);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  for(i=0; i<NumOfRoutine_Sub0x01; i++)
  {
    PID[0]=Routine_Sub0x01[i].DID>>8;
    PID[1]=Routine_Sub0x01[i].DID&0xFF;
  //
    if((Routine_Sub0x01[i].Flag_Ser02==1)&&(Routine_Sub0x01[i].SecuLevel!=0xFF))
    {
      TestStep("StartRoutine when ECU is locked",TestStepIntervalTime);
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求   
      CheckNegResponse(0x33,0,0);
    }
  }
  
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0); 
  /******************************以上为测试步骤*********************************/
  
   Postcondition();
}


/// <PBL_CommonServiceTest>
testcase Service_0x31_valid_physical_programmingSession_supported_service()
{
  byte RID[2];
  byte Record[1];
  byte sunFunction;
  byte PID[2];
  int  i,j,k;
  byte StuffByte[400];
  byte ExpectNRC[4]={0x33,0x22,0x70,0x10};
  byte ExpectNRC2[2]={0x33,0x24};
  int  NumOfLenth;
  char Description[3000];
  char answer[100];
  byte Para[50];
  int tem1,tem2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351009_Service_0x31_valid_physical_programmingSession_supported_service_R3",400);
  testCaseDescription("The power to the ECU will be cycled.After power cycled wait to operation cycle start.Read out of diagnostic session");
  testCaseTitle("1351009","Service_0x31_valid_physical_programmingSession_supported_service_R3");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  TestStep("Transition from defaultSession(0x01) to programmingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  SessionFlag=BOOT;
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  //ECUinitHandle(0);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  
  ////判断0x31服务是否支持
  for(i=0;i<service_APP_Num;i++)
  {
    if(service_APP[i] == 0x31)
      break;
  }
  if(i==service_APP_Num)
  {
    TestStepWarning("ECU doesn't support this service , test case exit!");
    Postcondition();
     
    return;
  }
  
  for(i=0;i<NumOfRoutine_Sub0x01_PBL;i++)//遍历所有例程
  {
    if(Routine_Sub0x01_PBL[i].Flag_Ser03 != 1)
    {
      continue;
    }
    if(Routine_Sub0x01_PBL[i].routinetype == 1)//筛选所有例程类型为1的例程
    {
      tem1 = 0;
      PID[0]=Routine_Sub0x01_PBL[i].DID>>8;
      PID[1]=Routine_Sub0x01_PBL[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03_PBL;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01_PBL[i].DID == Routine_Sub0x03_PBL[j].DID)
        {
          tem1 = 1;
          break;
        }  
      }
      if(Routine_Sub0x01_PBL[i].SecuLevel!=0xFF)
      {
  		  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  		  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  		  
  		  ECUinitHandle(0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01_PBL[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01_PBL[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01_PBL[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01_PBL[i].SecuLevel,2,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01_PBL[i].requestData,Routine_Sub0x01_PBL[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      if( (gRss==NEG) && (gTpRxData[2]==0x22))
      {
        TestStepWarning("warning","Received NRC0x22 for Service 0x31,test next RID");
        continue;
      }
      testWaitForTimeout(2000);
      
      if(Routine_Sub0x01_PBL[i].SecuLevel!=0xFF)
      {
        
  		  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  		  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  		  
  		  ECUinitHandle(0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01_PBL[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01_PBL[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01_PBL[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01_PBL[i].SecuLevel,2,0,0);
      
      }
      
      if(tem1 == 1)
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      }
      
    }
    else if(Routine_Sub0x01_PBL[i].routinetype == 2)//筛选所有例程类型为2的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01_PBL[i].DID>>8;
      PID[1]=Routine_Sub0x01_PBL[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03_PBL;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01_PBL[i].DID == Routine_Sub0x03_PBL[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02_PBL;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01_PBL[i].DID == Routine_Sub0x02_PBL[k].DID)
        {
          tem2 = 1;
          break;
        }

      }
      
      if(Routine_Sub0x01_PBL[i].SecuLevel!=0xFF)
      {
        
  		  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  		  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  		  
  		  ECUinitHandle(0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01_PBL[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01_PBL[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01_PBL[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01_PBL[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02_PBL[k].requestData,Routine_Sub0x02_PBL[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);

      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);
  
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01_PBL[i].requestData,Routine_Sub0x01_PBL[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x22)
      {
        TestStepWarning("Chk","No 0x22 maybe routine has finished executing");
      }
      testWaitForTimeout(Routine_Sub0x01_PBL[i].runtime+10);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
      
      if(Routine_Sub0x01_PBL[i].SecuLevel!=0xFF)
      {
        
  		  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  		  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  		  
  		  ECUinitHandle(0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01_PBL[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01_PBL[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01_PBL[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01_PBL[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02_PBL[k].requestData,Routine_Sub0x02_PBL[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }

      
      if(Routine_Sub0x01_PBL[i].SecuLevel!=0xFF)
      {
  		  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  		  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  		  
  		  ECUinitHandle(0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01_PBL[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01_PBL[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01_PBL[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01_PBL[i].SecuLevel,2,0,0);
      
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01_PBL[i].requestData,Routine_Sub0x01_PBL[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02_PBL[k].requestData,Routine_Sub0x02_PBL[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
      }
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
    }
    else if(Routine_Sub0x01_PBL[i].routinetype == 3)//筛选所有例程类型为3的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01_PBL[i].DID>>8;
      PID[1]=Routine_Sub0x01_PBL[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03_PBL;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01_PBL[i].DID == Routine_Sub0x03_PBL[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02_PBL;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01_PBL[i].DID == Routine_Sub0x02_PBL[k].DID)
        {
          tem2 = 1;
          break;
        }
      } 
      if(Routine_Sub0x01_PBL[i].SecuLevel!=0xFF)
      {
  		  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  		  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  		  
  		  ECUinitHandle(0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01_PBL[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01_PBL[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01_PBL[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01_PBL[i].SecuLevel,2,0,0);
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02_PBL[k].requestData,Routine_Sub0x02_PBL[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01_PBL[i].requestData,Routine_Sub0x01_PBL[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x32)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem1 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02_PBL[k].requestData,Routine_Sub0x02_PBL[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03_PBL[j].requestData,Routine_Sub0x03_PBL[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }     
    }
  }
  
  TestStep("programmingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0); 
  /******************************以上为测试步骤*********************************/
  Postcondition();
}
/// <PBL_CommonServiceTest>
testcase Service_0x31_valid_functional_programmingSession_supported_service()
{
  char logPath[1000] = "";
  byte RID[2];
  byte Record[1];
  byte sunFunction;
  byte PID[2];
  int  i,j;
  byte StuffByte[400];
  byte ExpectNRC[4]={0x33,0x22,0x70,0x10};
  byte ExpectNRC2[2]={0x33,0x24};
  int  NumOfLenth;
  char Description[3000];
  char answer[100];
  byte Para[50];
  int tem1,tem2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351010_Service_0x31_valid_functional_programmingSession_supported_service_R3",400);
  testCaseDescription("The power to the ECU will be cycled.After power cycled wait to operation cycle start.Read out of diagnostic session");
  testCaseTitle("1351010","Service_0x31_valid_functional_programmingSession_supported_service_R3");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  TestStep("Transition from defaultSession(0x01) to programmingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  SessionFlag=BOOT;
  TestStep("Verify programmingDiagnosticSession.",TestStepIntervalTime);
  //ECUinitHandle(0);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  for(i=0; i<NumOfRoutine_Sub0x01; i++)
  {
    PID[0]=Routine_Sub0x01[i].DID>>8;
    PID[1]=Routine_Sub0x01[i].DID&0xFF;
    
    if((Routine_Sub0x01[i].SelectFlag != 1)||(Routine_Sub0x01[i].Flag_Ser02!=1))
    {
      continue;
    }
    else
    {
      NumOfLenth = Routine_Sub0x01[i].RequestLenth;
    }
    if(Routine_Sub0x01[i].Flag_Ser02==1)
    {
      for(j=0;j<NumOfRoutine_Sub0x03;j++)
      {
       if(Routine_Sub0x01[i].DID==Routine_Sub0x03[j].DID)
        {
          SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[i].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
          CheckNegResponse(ExpectNRC2,1,1,0,0);
        }
      }
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      }

      TestStep("Request routine control",TestStepIntervalTime);
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求 
      CheckNegResponse(ExpectNRC,1,1,0,0);
      
      for(j=0;j<NumOfRoutine_Sub0x03;j++)
      {
       if(Routine_Sub0x01[i].DID==Routine_Sub0x03[j].DID)
        {
          SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[i].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
          CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        } 
      }
      for(j=0;j<NumOfRoutine_Sub0x02;j++)
      {
        if(Routine_Sub0x01[i].DID==Routine_Sub0x02[j].DID)
        {
          SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//正常请求    
          CheckNegResponse(ExpectNRC,1,1,0,0);

          SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x03[i].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 02
          CheckNegResponse(ExpectNRC,1,1,0,0);
        }
      }
      
      for(j=0;j<NumOfRoutine_Sub0x03;j++)
      {
       if(Routine_Sub0x01[i].DID==Routine_Sub0x03[j].DID)
        {
          SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[i].requestData,Routine_Sub0x03[j].RequestLenth,FUNCTIONAL,SPRMIB_FALSE);//发送31 03
          CheckNegResponse(ExpectNRC,1,1,0,0);
        } 
      }
    }
  }
  TestStep("Check ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0); 
  /******************************以上为测试步骤*********************************/
  Postcondition(); 
}
