/// <APP_SecurityAccessAlgorithm>
testcase Extended_Random_Seed_Test_extendedDiagnosticSession()
{
  int i,j,k,n=0;
  byte AllSeeds[20000][16];
  int repeatFlag=0;
  struct seedinforecord
  {
    byte seedinfo[16];
    int  seedtime;
  };
  
  struct seedinforecord seedrecord[10000];
  int  seednum = 0;
  int  checkflag;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1023152_Extended_Random_Seed_Test_extendedDiagnosticSession",400);
  testCaseTitle("1023152","Extended_Random_Seed_Test_extendedDiagnosticSession");
  
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  for(n=0; n<NumOfSecurityLv; n++)
  {
    if(SELevel[n].SEFlagPBL == 1)
    {
      continue;
    }
    Level1=SELevel[n].SElevel;  
    
    TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    
    TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    
    for(i=0; i<5000; i++)
    {
      SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
      for(j=0; j<i; j++)
      {
        if((AllSeeds[j][0] == gSeedArray[0]) && (AllSeeds[j][1] == gSeedArray[1]) && (AllSeeds[j][2] == gSeedArray[2])&& (AllSeeds[j][3] == gSeedArray[3])&& (AllSeeds[j][4] == gSeedArray[4])&& (AllSeeds[j][5] == gSeedArray[5])&& (AllSeeds[j][6] == gSeedArray[6])&& (AllSeeds[j][7] == gSeedArray[7])&& (AllSeeds[j][8] == gSeedArray[8])&& (AllSeeds[j][9] == gSeedArray[9])&& (AllSeeds[j][10] == gSeedArray[10])&& (AllSeeds[j][11] == gSeedArray[11])&& (AllSeeds[j][12] == gSeedArray[12])&& (AllSeeds[j][13] == gSeedArray[13])&& (AllSeeds[j][14] == gSeedArray[14])&& (AllSeeds[j][15] == gSeedArray[15]))
        {
          repeatFlag = 1;
          TestStepFail("Fail","Generated seed is repeated.");
          checkflag = 0;
            for(k = 0;k < seednum;k++)
            {
              if((seedrecord[k].seedinfo[0] == gSeedArray[0])&& (seedrecord[k].seedinfo[1] == gSeedArray[1]) && (seedrecord[k].seedinfo[2] == gSeedArray[2])&& (seedrecord[k].seedinfo[3] == gSeedArray[3])&& (seedrecord[k].seedinfo[4] == gSeedArray[4])&& (seedrecord[k].seedinfo[5] == gSeedArray[5])&& (seedrecord[k].seedinfo[6] == gSeedArray[6])&& (seedrecord[k].seedinfo[7] == gSeedArray[7])&& (seedrecord[k].seedinfo[8] == gSeedArray[8])&& (seedrecord[k].seedinfo[9] == gSeedArray[9])&& (seedrecord[k].seedinfo[10] == gSeedArray[10])&& (seedrecord[k].seedinfo[11] == gSeedArray[11])&& (seedrecord[k].seedinfo[12] == gSeedArray[12])&& (seedrecord[k].seedinfo[13] == gSeedArray[13])&& (seedrecord[k].seedinfo[14] == gSeedArray[14])&& (seedrecord[k].seedinfo[15] == gSeedArray[15]))
              {
                seedrecord[k].seedtime++;
                checkflag = 1;
              }
            }
            if(checkflag == 1)
            {
              
            }
            else
            {
              seedrecord[seednum].seedinfo[0] = gSeedArray[0];
              seedrecord[seednum].seedinfo[1] = gSeedArray[1];
              seedrecord[seednum].seedinfo[2] = gSeedArray[2];
              seedrecord[seednum].seedinfo[3] = gSeedArray[3];
              seedrecord[seednum].seedinfo[4] = gSeedArray[4];
