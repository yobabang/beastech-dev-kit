/// <APP_CommonServiceTest>
testcase Sercice_0x31_Valid_Physical_DefaultSession_Supported_Service()
{
  byte PID[2];
  int  i,j;
  byte StuffByte[400];
  byte ExpectNRC[4]={0x33,0x22,0x70,0x10};
  int  NumOfLenth;
  char Description[3000];
  char answer[100];
  byte Para[50];
  int tem1,tem2;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350949_Sercice_0x31_Valid_Physical_DefaultSession_Supported_Service",400);
  testCaseDescription("The intent is to verify that the service RoutineControl (0x31) and sub functions is supported. RoutineType on identifier will also be verified. ");
  testCaseTitle("1350949","Sercice_0x31_Valid_Physical_DefaultSession_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  ////判断0x31服务是否支持
  for(i=0;i<service_APP_Num;i++)
  {
    if(service_APP[i] == 0x31)
      break;
  }
  if(i==service_APP_Num)
  {
    TestStepWarning("ECU doesn't support this service , test case exit!");
    Postcondition();
    return;
  }
  
  TestStep("Transition to defaultSession",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  
  TestStep("Verify default session",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  
  for(i=0;i<NumOfRoutine_Sub0x01;i++)//遍历所有例程
  {
    if(Routine_Sub0x01[i].Flag_Ser01 != 1)
    {
      continue;
    }
    if(Routine_Sub0x01[i].routinetype == 1)//筛选所有例程类型为1的例程
    {
      tem1 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }   
      }
      if(tem1 == 1)//直接发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }

      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      if( (gRss==NEG) && (gTpRxData[2]==0x22))
      {
        TestStepWarning("warning","Received NRC0x22 for Service 0x31,test next RID");
        continue;
      }

      testWaitForTimeout(2000);
      
      if(tem1 == 1)
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      }
      
    }
    else if(Routine_Sub0x01[i].routinetype == 2)//筛选所有例程类型为2的例程
    {
      TestStepFail("Fail","Routine type 2 should not be supported in default session , but RID %04x support",Routine_Sub0x01[i].DID);
    }
    else if(Routine_Sub0x01[i].routinetype == 3)//筛选所有例程类型为3的例程
    {
      TestStepFail("Fail","Routine type 3 should not be supported in default session , but RID %04x support",Routine_Sub0x01[i].DID);
    }
    
  }
  
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
