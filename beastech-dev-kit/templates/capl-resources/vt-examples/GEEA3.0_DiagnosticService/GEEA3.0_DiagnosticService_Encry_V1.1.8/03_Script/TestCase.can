        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);
        if(Routine_Sub0x01[i].AuthenticationFlag != 1)
        {
