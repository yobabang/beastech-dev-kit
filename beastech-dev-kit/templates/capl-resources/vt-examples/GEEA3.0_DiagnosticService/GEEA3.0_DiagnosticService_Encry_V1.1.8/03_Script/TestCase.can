}
/// <APP_CommonServiceTest>
testcase Service_0x28_Phy_Function()
{
  byte expectSession[4]={0x01,0x02,0x03,0x04};
  byte SFOf28[4]={0x00,0x01,0x02,0x03};
  byte t28[3]={0x28,0x00,0x01};
  byte expectNRC[1]={0x31};
  byte CommType;
  int i=0,j=0;
