/// <PBL_GeneralTest>
testcase Power_Up_Default_Session_Test_Physical_All_Session()
{
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351019_Power_Up_Default_Session_Test_Physical_All_Session",400);
  testCaseDescription("The power to the ECU will be cycled.After power cycled wait to operation cycle start.Read out of diagnostic session");
  testCaseTitle("1351019","Power_Up_Default_Session_Test_Physical_All_Session");
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  TestStep("Cycle the power to the ECU.",TestStepIntervalTime);
//  testWaitForTesterConfirmation("Please recycle the power of the ECU");
  kl30(T_off);
  kl15(T_off);
  testWaitForTimeout(1000);
  kl30(T_on);
  kl15(T_on);
  
  TestStep("Wait to operation cycle start.");
  ECUinitHandle(0);
  
  SessionFlag=APP;
  TestStep("Verify defaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  
  ECUinitHandle(0);
  TestStep("Verify ProgrammingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  //SID11_ECUReset(HardReset,SPRMIB_False,PHYSICAL);
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  
  SessionFlag=APP;
  
  TestStep("Wait to operation cycle start.");
  ECUinitHandle(0);
  TestStep("Verify defaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <PBL_GeneralTest>
testcase S3_Server_SuspensionDuringSegmentedResponseTest_Valid_Physical_ProgrammingSession()
{
  long res,msgdlc,CFNum;
  message 0x1 TpRes;
  int i=0;
  char logName[400] = "";
  char info[1024];
  byte testPreFillFlag=0;
  
  strncat(logName,"1351020_S3_Server_SuspensionDuringSegmentedResponseTest_Valid_Physical_ProgrammingSession",400);
  testCaseDescription("The intent is to verify that S3Server timer is suspended during segmented response and the ECU do not time out.");
  testCaseTitle("1351020","S3_Server_SuspensionDuringSegmentedResponseTest_Valid_Physical_ProgrammingSession");
  if((gBusFlag!=1)&&(gBusFlag!=2))
	{
		testStepWarning("Test","This test case only apply to the CAN or CANFD bus");
		return;
	}
  SetLog(logName);
  Precondition();

  //*****************************以下为测试步骤********************************
  TestStep("Disable functional addressed TesterPresent(0x3E) during the test",TestStepIntervalTime);
  TPMsgInit(0);
  SessionFlag=BOOT;
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingDiagnosticSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  TestStep("Read data by data identifer",TestStepIntervalTime);
  
  CloseCANConnection();
  testJoinMessageEvent(gCAN_ResponseID);
  testStep("Chk","Send a SF to request MultiFrame");
  output(TP_RequestMultiFrame);
  
  res= testWaitForAnyJoinedEvent(1000);
  if(res>0)
  {
    testGetWaitEventMsgData(TpRes);
    CheckNRC78(TpRes);//判断收到的报文是否为NRC78
  }
  else
    testStepFail("Chk","DUT doesn't response FF during test");

  if(res>0)
  {
    testGetWaitEventMsgData(TpRes);
    if((TpRes.byte(0)&0xF0) == 0x10 )
    {
      testStepPass("Chk","DUT Response a FF");
      msgdlc=((TpRes.byte(0) & 0x0F)<<8) + TpRes.byte(1);
      if(gBusFlag==2)
      {
        if((msgdlc-62)%63 > 0)//CFNum = 有多少CF帧
        { 
          CFNum = (msgdlc-62) / 63 + 1;  
        }
        else
          CFNum = (msgdlc-62) / 63;   
      }
      else if(gBusFlag==1)
      {
        if((msgdlc-6)%8 > 0)//CFNum = 有多少CF帧
        { 
          CFNum = (msgdlc-6) / 8 + 1;  
        }
        else
          CFNum = (msgdlc-6) / 8;   
      }
      TestStep("Wait (N_Bs timeout * 0.95) after receiving first frame and before sending flow control frame continue to send");
      testWaitForTimeout(950);
      
      output(TP_FC_CTS);
      testStep("Chk","Send FC(CTS)");
      for(i=1;i<=CFNum;i++)
      {
        testJoinMessageEvent(gCAN_ResponseID);
        res= testWaitForAnyJoinedEvent(1000);
        if(res>0)
        {
          testGetWaitEventMsgData(TpRes);
          if((TpRes.byte(0)) == (0x20|(i)) )
          {
            testStepPass("Chk","DUT Response CF%d",i);
          }
          if(i==CFNum)
          {
            testPreFillFlag=1;
            testStepPass("Chk","ALL CF received");
            TestStep("After last frame response in step 5 wait 4900 ms ");
            testWaitForTimeout(4900);
          }
        }
        else if(i==1)
        {
          testPreFillFlag=0;
          testStepFail("Chk","DUT not response CF");
          break;
        }
        else
        {
          testPreFillFlag=0;
          testStepFail("Chk","Not receive all CF");
          break;
        } 
      }
      OpenCANConnection();
      if(testPreFillFlag==1)
      {
        TestStep("Verify ProgrammingDiagnosticSession",TestStepIntervalTime);
        CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
      }
      else 
      {
        testStepFail("Fail","DUT Response Wrong,Test precondition not fullfilled,test end");
      }
    }
    else
    {
      testPreFillFlag=0;
      OpenCANConnection();
      testStepFail("Chk","DUT doesn't response FF during test");
    }
  }
  else
  {
    testPreFillFlag=0;
    OpenCANConnection();
    testStepFail("Chk","DUT doesn't response FF during test");
  }
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  //*****************************以上为测试步骤********************************
  Postcondition();
   
}
