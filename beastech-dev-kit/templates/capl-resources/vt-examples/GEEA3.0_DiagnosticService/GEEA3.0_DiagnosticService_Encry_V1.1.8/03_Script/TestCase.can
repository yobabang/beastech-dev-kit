/// <Authentication_Test>
testcase JumpOCSP_WrongOCSP()
{
  char logName[400] = "";
  char info[1024];
  
  byte OCSP_RID[2]={0x70,0x27};
  byte tempdata[3075];
  char errorMsg[500];
  byte challenge[32]={0xAD,0x95,0x37,0xF6,0xC8,0x04,0x56,0x99,0xCE,0x04,0x19,0x88,0x68,0x83,0xB3,0xA1};
  char hashFunction[10]="SHA-256";  
//  char testerCertName[300] = "Geely3.0";
  byte testerCertByte[2000];
  dword testerCertByteLength;
  char testerCertString[4000];
  byte ownerShip[1000];
  dword ownerShipLength;
  char ownerShipString[2000];
  dword i=0;
  dword tempI;
  
  
  strncat(logName,"JumpOCSP_WrongOCSP",400);
  testCaseTitle("","JumpOCSP_WrongOCSP");
  
  if(gBusFlag==5&&EthNodeTypeNow==EdgeNode)
  {
    
  }
  else
  {
    testStepWarning("Warning","This test case is only applicable for ETH_Edgenode");
    return;
  }
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  
  checkAuthenticateState(Deauthenticated);
  
  SID29_Authentication_authenticationConfiguration(PHYSICAL);
  CheckPosResponse_SID29_authenticationConfiguration(0x2,0,0);
  
  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }

  SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
  CheckNegResponse(0x57,0,0);
  
  /////another new sequence
  SID29_Authentication_authenticationConfiguration(PHYSICAL);
  CheckPosResponse_SID29_authenticationConfiguration(0x2,0,0);
  
  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  
  string2array(ocspResponseString,ocspBytearray,ocspLen);
  memcpy(tempdata,ocspBytearray,ocspLen);
  tempdata[0]=ocspLen>>8;
  tempdata[1]=ocspLen;
  for(i=0;i<ocspLen;i++)
  {
    tempdata[2+i]=0xFF;
  }
  
  tempdata[2050]=testerCertByteLength>>8;
  tempdata[2051]=testerCertByteLength;
  
  for(i=0;i<testerCertByteLength;i++)
  {
    tempdata[2052+i]=testerCertByte[i];
  }

  SID31_RoutineControl(StartRoutine,OCSP_RID,tempdata,3076,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID31(StartRoutine,OCSP_RID,0,0);
  if(gTpRxData[4]==0x10&&gTpRxData[5]==0x01)
  {
    
  }
  else
  {
    testStepFail("Fail","get wrong routine parameter0x%x%x instead of 0x10 01",gTpRxData[4],gTpRxData[5]);
  }
  
  SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
  CheckNegResponse(0x57,0,0);
  
  checkAuthenticateState(Deauthenticated);


  /******************************以上为测试步骤*********************************/
  Postcondition();
}
