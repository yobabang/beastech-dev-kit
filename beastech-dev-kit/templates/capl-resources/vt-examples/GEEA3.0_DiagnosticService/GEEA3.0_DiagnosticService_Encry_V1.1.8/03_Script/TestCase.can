/// <APP_CommonServiceTest>
testcase Service_0x85_Phy_PositiveResponse()
{
  byte SubFunOf85[2]={0x01,0x02};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350931_Service_0x85_Phy_PositiveResponse",400);
  testCaseTitle("1350931","Service_0x85_Phy_PositiveResponse");
	if(gBusFlag==3)//2025-11-17-石太佳-移除对LIN ECU的限制
	{
		//testStepWarning("Test","This test case does not apply to the LIN bus");
		//return;
	}
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  
  SID85_ControlDTCSetting(SubFunOf85[0],PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID85(SubFunOf85[0],0,0);
  
  SID85_ControlDTCSetting(SubFunOf85[1],PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID85(SubFunOf85[1],0,0);
  
  SID85_ControlDTCSetting(SubFunOf85[0],PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  
  SID85_ControlDTCSetting(SubFunOf85[1],PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
/// <APP_CommonServiceTest>
testcase Service_0x85_Func_PositiveResponse()
{
  byte SubFunOf85[2]={0x01,0x02};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350932_Service_0x85_Func_PositiveResponse",400);
  testCaseTitle("1350932","Service_0x85_Func_PositiveResponse");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  
  SID85_ControlDTCSetting(SubFunOf85[0],FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID85(SubFunOf85[0],0,0);
  
  SID85_ControlDTCSetting(SubFunOf85[1],FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID85(SubFunOf85[1],0,0);
  
  SID85_ControlDTCSetting(SubFunOf85[0],FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  
  SID85_ControlDTCSetting(SubFunOf85[1],FUNCTIONAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  /******************************以上为测试步骤*********************************/
  PostCondition();
}

/// <APP_CommonServiceTest>
testcase Service_0x85_Phy_8501Request()
{
  byte clearDTC[3]={0xFF,0xFF,0xFF};
  byte SFOf85[2]={0x01,0x02};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350933_Service_0x85_Phy_8501Request",400);
  testCaseTitle("1350933","Service_0x85_Phy_8501Request");
	if(gBusFlag==3)//2025-11-17-石太佳-移除对LIN ECU的限制
	{
		//testStepWarning("Test","This test case does not apply to the LIN bus");
		//return;
	}
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  SimTRC();
  
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  TestStep("Tester Present on",TestStepIntervalTime);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,PHYSICAL);
  CheckPosResponse_SID19_02(AvailiableMask,0,0);
  Rss1=gTpRxLength;
  if(Rss1<=3)
  {
    TestStepWarning("No avalible DTC,Test end");
    StopTRC();
    Postcondition();
    return;
  }
  TestStep("Request DTC setting off",TestStepIntervalTime);
  SID85_ControlDTCSetting(SFOf85[1],PHYSICAL,SPRMIB_FALSE);   //禁止DTC更新
  CheckPosResponse_SID85(SFOf85[1],0,0);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,PHYSICAL);
  CheckPosResponse_SID19_02(AvailiableMask,0,0);
  DTCSettingCheck(2);
  TestStep("Request DTC setting on",TestStepIntervalTime);
  SID85_ControlDTCSetting(SFOf85[0],PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID85(SFOf85[0],0,0);
  
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,PHYSICAL);
  CheckPosResponse_SID19_02(AvailiableMask,0,0);
  DTCSettingCheck(1);
  
///////one more
  TestStep("Repeat step 1-14 once, set service 0x85 SPRMIB=True",TestStepIntervalTime);
  ResetStepIndex();
  
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  TestStep("Tester Present on",TestStepIntervalTime);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 5s");
  delay(5000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,PHYSICAL);
  CheckPosResponse_SID19_02(AvailiableMask,0,0);
  Rss1=gTpRxLength;
  if(Rss1<=3)
  {
    TestStepWarning("No avalible DTC,Test end");
    StopTRC();
    Postcondition();
    return;
  }
  TestStep("Request DTC setting off",TestStepIntervalTime);
  SID85_ControlDTCSetting(SFOf85[1],PHYSICAL,SPRMIB_TRUE);   //禁止DTC更新
  CheckNonResponse(0,0);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,PHYSICAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  DTCSettingCheck(2);
  TestStep("Request DTC setting on",TestStepIntervalTime);
  SID85_ControlDTCSetting(SFOf85[0],PHYSICAL,SPRMIB_TRUE);
  CheckNonResponse(0,0);
  
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,PHYSICAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  DTCSettingCheck(1);
  
  StopTRC();
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
