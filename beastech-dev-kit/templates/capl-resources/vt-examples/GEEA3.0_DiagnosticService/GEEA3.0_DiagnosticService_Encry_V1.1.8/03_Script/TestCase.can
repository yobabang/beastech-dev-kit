        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem1 == 1)
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      }
      
    }
    else if(Routine_Sub0x01[i].routinetype == 2)//筛选所有例程类型为2的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }

      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);

      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 02
        CheckNegResponse(0x24,0,0);
  
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x22)
      {
        TestStepWarning("Chk","No 0x22 maybe routine has finished executing");
      }
      testWaitForTimeout(Routine_Sub0x01[i].runtime+10);
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        
        SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }

      
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      
      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
      }
      
      SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
      if(gTpRxData[4]!= 0x20)
      {
        TestStepFail("Fail","Routine still not finished after running time timeout");
      }
    }
    else if(Routine_Sub0x01[i].routinetype == 3)//筛选所有例程类型为3的例程
    {
      tem1 = 0;tem2 = 0;
      PID[0]=Routine_Sub0x01[i].DID>>8;
      PID[1]=Routine_Sub0x01[i].DID&0xFF;
      for(j=0;j<NumOfRoutine_Sub0x03;j++)//找到该例程是否支持03子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x03[j].DID)
        {
          tem1 = 1;
          break;
        }

      }
      for(k=0;k<NumOfRoutine_Sub0x02;k++)//找到该例程是否支持02子功能
      {
        if(Routine_Sub0x01[i].DID == Routine_Sub0x02[k].DID)
        {
          tem2 = 1;
          break;
        }
      } 
      if(Routine_Sub0x01[i].SecuLevel!=0xFF)
      {
        SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
        CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
        
        testWaitForTimeout(gTimeWaitForSecuAccess);
        
        SID27_SecurityAccess_RequestSeed(Routine_Sub0x01[i].SecuLevel,PHYSICAL);
        CheckPosResponse_SID27_ReqSeed(Routine_Sub0x01[i].SecuLevel,gSeedArray,16,0,0);
        SID27_SecurityAccess_SendKey(Routine_Sub0x01[i].SecuLevel,gKeyArray,PHYSICAL);
        CheckPosResponse_SID27_SenKey(Routine_Sub0x01[i].SecuLevel,2,0,0);
      }
      
      if(tem2 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);
      }
      
      if(tem1 == 1)//直接发送31 03
      {
        
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//发送31 03
        CheckNegResponse(0x24,0,0);

      }
      
      SID31_RoutineControl(StartRoutine,PID,Routine_Sub0x01[i].requestData,Routine_Sub0x01[i].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
      CheckPosResponse_SID31(StartRoutine,PID,0,0);
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x32)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem1 == 1)//直接发送31 02
      {
        SID31_RoutineControl(StopRoutine,PID,Routine_Sub0x02[k].requestData,Routine_Sub0x02[k].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(StopRoutine,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }
      
      if(tem2 == 1)//发送31 03
      {
        SID31_RoutineControl(RequestRoutineResult,PID,Routine_Sub0x03[j].requestData,Routine_Sub0x03[j].RequestLenth,PHYSICAL,SPRMIB_FALSE);//正常请求
        CheckPosResponse_SID31(RequestRoutineResult,PID,0,0);
        if(gTpRxData[4]!= 0x30)
        {
          TestStepFail("Chk","Routine can't run");
        }
      }     
    }
  }
  TestStep("programmingSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0); 
//31
//***************************************************************************//
  
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
  
}
/// <Authentication_Test>
testcase RandomChallengeByteTest()
{
  char logName[400] = "";
  char info[1024];
  
  byte OCSP_RID[2]={0x70,0x27};
  byte tempdata[3075];
  char errorMsg[500];
  byte challenge[32]={0xAD,0x95,0x37,0xF6,0xC8,0x04,0x56,0x99,0xCE,0x04,0x19,0x88,0x68,0x83,0xB3,0xA1};
  char hashFunction[10]="SHA-256";  
//  char testerCertName[300] = "Geely3.0";
  byte testerCertByte[2000];
  dword testerCertByteLength;
  char testerCertString[4000];
  byte ownerShip[1000];
  dword ownerShipLength;
  char ownerShipString[2000];
  dword i,j;
  byte Data[10000][32];
  dword compareTime=0;
  strncat(logName,"1318683 RandomChallengeByteTest",400);
  testCaseTitle("1318683","RandomChallengeByteTest");
  
  if(gBusFlag==5&&EthNodeTypeNow==EdgeNode)
  {
    
  }
  else
  {
    testStepWarning("Warning","This test case is only applicable for ETH_Edgenode");
    return;
  }
  
  SetLog(logName);
//  Precondition();
   
  /******************************以下为测试步骤*********************************/

  SessionFlag=APP;

  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  ocspCheckSequence();
  
  for(i=0;i<5000;i++)
  {
    SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
    gRss=CheckPosResponse_SID29_verifyCertificateUnidirectional(0x11,0x20,challenge,0,0,0);
    if(gRss==2)
    {
      for(j=0;j<32;j++)
      {
        Data[i][j]=gTpRxData[5+j];
      }
      PrintPID("Byte","ChallengeByte：",Data[i],32);
      compareTime++;
      testWaitForTimeout(1);
    }
  }
  
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  ECUinitHandle(0);
  
  CheckCurrentSession(0x01,PHYSICAL,0,0);
  
  for(i=5000;i<9999;i++)
  {
    SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
    gRss=CheckPosResponse_SID29_verifyCertificateUnidirectional(0x11,0x20,challenge,0,0,0);
    if(gRss==2)
    {
      for(j=0;j<32;j++)
      {
        Data[i][j]=gTpRxData[5+j];
      }
      PrintPID("Byte","ChallengeByte：",Data[i],32);
      compareTime++;
      testWaitForTimeout(1);
    }
  }
  
  compareData(Data,compareTime);

  /******************************以上为测试步骤*********************************/
//  Postcondition();
  
}

/// <Authentication_Test>
testcase TiAndDatelndn_AbnormalTest()
{
  char logName[400] = "";
  char info[1024];
  
  byte OCSP_RID[2]={0x70,0x27};
  byte tempdata[5000];
  char errorMsg[500];
  byte challenge[32]={0xAD,0x95,0x37,0xF6,0xC8,0x04,0x56,0x99,0xCE,0x04,0x19,0x88,0x68,0x83,0xB3,0xA1};
  char hashFunction[10]="SHA-256";  
//  char testerCertName[300] = "Geely3.0";
  byte testerCertByte[2000];
  dword testerCertByteLength;
  char testerCertString[4000];
  byte ownerShip[1000];
  dword ownerShipLength;
  char ownerShipString[2000];
  dword i=0;
  dword tempI;
  strncat(logName,"TiAndDatelndn_AbnormalTest",400);
  testCaseTitle("","TiAndDatelndn_AbnormalTest");
  
  if(gBusFlag==5&&EthNodeTypeNow==EdgeNode)
  {
    
  }
  else
  {
    testStepWarning("Warning","This test case is only applicable for ETH_Edgenode");
    return;
  }
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  
  checkAuthenticateState(Deauthenticated);
  
  TestStep("仿真正确的TiAndDatelndn信号");
  testWaitForTesterConfirmation("请仿真正确的TiAndDatelndn信号");
  testWaitForTimeout(5000);
  
  SID29_Authentication_authenticationConfiguration(PHYSICAL);
  CheckPosResponse_SID29_authenticationConfiguration(0x2,0,0);
  
  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  ocspCheckSequence();
  
  SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
  CheckPosResponse_SID29_verifyCertificateUnidirectional(0x11,0x20,challenge,0,0,0);
  
  if(CreateOwnership(testerCertName, hashFunction, challenge, elcount(challenge), ownerShip, ownerShipLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  
  SID29_Authentication_proofOfOwnership(ownerShipLength,ownerShip,0,PHYSICAL);
  CheckPosResponse_SID29_proofOfOwnership(0x12,0,0);
  
  checkAuthenticateState(Authenticated);
  
  SID29_Authentication_deAuthenticate(PHYSICAL);
  CheckPosResponse_SID29_deAuthenticate(0x10,0,0);
  
  checkAuthenticateState(Deauthenticated);
  
  TestStep("仿真无效的TiAndDatelndn信号，比如月份为13");
  testWaitForTesterConfirmation("请仿真无效的TiAndDatelndn信号，比如月份为13");
  testWaitForTimeout(5000);
  
  SID29_Authentication_authenticationConfiguration(PHYSICAL);
  CheckPosResponse_SID29_authenticationConfiguration(0x2,0,0);
  
  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  ocspCheckSequence();
  
  SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
  CheckPosResponse_SID29_verifyCertificateUnidirectional(0x11,0x20,challenge,0,0,0);
  
  if(CreateOwnership(testerCertName, hashFunction, challenge, elcount(challenge), ownerShip, ownerShipLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  
  SID29_Authentication_proofOfOwnership(ownerShipLength,ownerShip,0,PHYSICAL);
  CheckPosResponse_SID29_proofOfOwnership(0x12,0,0);
  
  checkAuthenticateState(Authenticated);
  
  SID29_Authentication_deAuthenticate(PHYSICAL);
  CheckPosResponse_SID29_deAuthenticate(0x10,0,0);
  
  checkAuthenticateState(Deauthenticated);

  TestStep("仿真TiAndDatelndn信号为超出证书有效期的时间");
  testWaitForTesterConfirmation("请仿真TiAndDatelndn信号为超出证书有效期的时间");
  testWaitForTimeout(5000);
  
  SID29_Authentication_authenticationConfiguration(PHYSICAL);
  CheckPosResponse_SID29_authenticationConfiguration(0x2,0,0);
  
  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }

  ocspCheckSequence();
  
  SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
  CheckNegResponse(0x50,0,0);
  
  checkAuthenticateState(Deauthenticated);
  
  TestStep("停止仿真TiAndDatelndn信号");
  testWaitForTesterConfirmation("停止仿真TiAndDatelndn信号");
  testWaitForTimeout(5000);
  
  SID29_Authentication_authenticationConfiguration(PHYSICAL);
  CheckPosResponse_SID29_authenticationConfiguration(0x2,0,0);
  
  if(GetCertificateAsBinaryByName(testerCertName, testerCertByte, testerCertByteLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  string2array(ocspResponseString,ocspBytearray,ocspLen);
  memcpy(tempdata,ocspBytearray,ocspLen);
  tempdata[0]=ocspLen>>8;
  tempdata[1]=ocspLen;
  for(i=0;i<ocspLen;i++)
  {
    tempdata[2+i]=ocspBytearray[i];
  }
  
  tempdata[2050]=testerCertByteLength>>8;
  tempdata[2051]=testerCertByteLength;
  
  for(i=0;i<testerCertByteLength;i++)
  {
    tempdata[2052+i]=testerCertByte[i];
  }

  SID31_RoutineControl(StartRoutine,OCSP_RID,tempdata,3076,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID31(StartRoutine,OCSP_RID,0,0);
  if(gTpRxData[4]==0x10&&gTpRxData[5]==0x01)
  {
    
  }
  else
  {
    testStepFail("Fail","get wrong routine parameter0x%x%x instead of 0x10 01",gTpRxData[4],gTpRxData[5]);
  }
  
  SID29_Authentication_verifyCertificateUnidirectional(0,testerCertByteLength,testerCertByte,0,PHYSICAL);
  CheckPosResponse_SID29_verifyCertificateUnidirectional(0x11,0x20,challenge,0,0,0);
  
  if(CreateOwnership(testerCertName, hashFunction, challenge, elcount(challenge), ownerShip, ownerShipLength, errorMsg)!=1)
  {
    testStepFail("Fail","%s",errorMsg);
    return;
  }
  
  SID29_Authentication_proofOfOwnership(ownerShipLength,ownerShip,0,PHYSICAL);
  CheckPosResponse_SID29_proofOfOwnership(0x12,0,0);
  
  checkAuthenticateState(Authenticated);
  
  SID29_Authentication_deAuthenticate(PHYSICAL);
  CheckPosResponse_SID29_deAuthenticate(0x10,0,0);
  
  checkAuthenticateState(Deauthenticated);
  /******************************以上为测试步骤*********************************/
  Postcondition();
}


testcase ReadSWandHWVersion()
{
 char logName[400] = "";
  byte ExpectNRC[2]={0x12,0x7E};
  char info[1024];
  byte PID[2];
  
  strncat(logName,"ReadSWandHWVersion",400);
  testCaseTitle("-","ReadSWandHWVersion");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);

  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify EXTENDEDSESSION",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  PID[0]=0xF1;
  PID[1]=0xAA;
  
  TestStep("Read data",TestStepIntervalTime);
  SID22_ReadDataByIdentifier(PID,PHYSICAL);
  CheckPosResponse_SID22(PID,0,0); 
  
  PID[0]=0xF1;
  PID[1]=0xAE;
  
  TestStep("Read data",TestStepIntervalTime);
  SID22_ReadDataByIdentifier(PID,PHYSICAL);
  CheckPosResponse_SID22(PID,0,0); 
    
  /******************************以上为测试步骤*********************************/
  PostCondition();
}

