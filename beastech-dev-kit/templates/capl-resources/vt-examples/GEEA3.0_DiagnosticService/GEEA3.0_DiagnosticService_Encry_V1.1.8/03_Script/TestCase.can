  if(DesFlag2 == 1)
  {
    TestStep(Description2);
  }
  
  SessionFlag=BOOT;
  
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  for(i=0; i<NumOfReadDIDPBL; i++)
  {
    
    if(i!=0)
    {
      TestStep("Jump to Step 4 until all the dataIdentifiers in configured list are tested. Let Z1 Z2 = next dataIdentifier.",TestStepIntervalTime);
    }
    if(DIDOfReadPBL[i].Flag_Programming==0)
    {
      continue;
    }
    if(DIDOfReadPBL[i].AuthenticationFlag==0)
    {
      continue;
    }
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C))
    {
      continue;
    }
    if((PID[0] == 0xD0)&&(PID[1] == 0x3A))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x09))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0B))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0A))
    {
      continue;
    }
    
    PID[0]=DIDOfReadPBL[i].DID>>8;
    PID[1]=DIDOfReadPBL[i].DID&0xFF;
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C))
    {
      continue;
    }
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    if((PID[0] == 0xD0)&&(PID[0] == 0x1C))
    {
     testWaitForTimeout(500);
    }
    else
    {
     Result=CheckPosResponse_SID22(PID,DIDOfReadPBL[i].Lenth,0,0); 
    }
    if(Result>0)
    {
    CheckParametersCoding(DIDOfReadPBL[i]);
    if(DIDOfReadPBL[i].Lenth!=(gTpRxLength-3))
      TestStepFail("Fail","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
    else
      TestStepPass("Pass","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
    }
    
    TestStep("","Expect lenth is %d and get lenth is %d",DIDOfReadPBL[i].Lenth,gTpRxLength-3);
  }
  
  for(i=0;i<NumOfWriteDIDPBL;i++)
  {
    if(DIDOfWritePBL[i].Flag_Programming==0)
    {
      continue;
    }
    if(DIDOfWritePBL[i].AuthenticationFlag==0)
    {
      continue;
    }
    if(DIDOfReadPBL[i].Flag_Programming==0)
    {
      continue;
    }
    if(DIDOfReadPBL[i].AuthenticationFlag==0)
    {
      continue;
    }
    if((PID[0] == 0xD0)&&(PID[1] == 0x1C))
    {
      continue;
    }
    if((PID[0] == 0xD0)&&(PID[1] == 0x3A))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x09))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0B))
    {
      continue;
    }
    if((PID[0] == 0xF1)&&(PID[1] == 0x0A))
    {
      continue;
    }
    PID[0]=DIDOfWritePBL[i].DID>>8;
    PID[1]=DIDOfWritePBL[i].DID&0xFF;
      
    if(DIDOfWritePBL[i].SecuLevel!=0xFF)
    {
      SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
      CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
      ECUinitHandle(0);
      TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
      CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
        
      testWaitForTimeout(gTimeWaitForSecuAccess);
      
      SID27_SecurityAccess_RequestSeed(DIDOfWritePBL[i].SecuLevel,PHYSICAL);
      CheckPosResponse_SID27_ReqSeed(DIDOfWritePBL[i].SecuLevel,gSeedArray,16,0,0);
      SID27_SecurityAccess_SendKey(DIDOfWritePBL[i].SecuLevel,gKeyArray,PHYSICAL);
      CheckPosResponse_SID27_SenKey(DIDOfWritePBL[i].SecuLevel,0,0);
    }
    
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
    RecordData();
    TestStep("Write data",TestStepIntervalTime);
    WriteTestData(DIDOfWritePBL[i],PHYSICAL);
    TestStep("Read data",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
    testWaitForTimeout(500);
    WritePreviousData(PHYSICAL);
    CheckPosResponse_SID2E(PID,0,0);

    TestStep("Data recover",TestStepIntervalTime);
    SID22_ReadDataByIdentifier(PID,PHYSICAL);
    CheckPosResponse_SID22(PID,DIDOfWritePBL[i].Lenth,0,0);
  }
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
//22&2E
  
  
//2F
  
  SessionFlag=APP;
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  for(i=0; i<NumOfIO; i++)
  {
    PID[0]=IODID[i].DID>>8;
    PID[1]=IODID[i].DID&0xFF;
    if(IODID[i].AuthenticationFlag != 1)
    {
      continue;
    }
    if(IODID[i].SelectFlag != 1)
    {
      continue;
    }
    else
    {
      NumOfLenth = IODID[i].RequestLenth;
      
//      if(NumOfLenth>0)
//      {
//        snprintf(Description,3000,"Please input %d byte input parameter(s) for IO control DID:%02x %02x\nExample(2Byte):010A",NumOfLenth,PID[0],PID[1]);
//        testWaitForStringInput(Description);
