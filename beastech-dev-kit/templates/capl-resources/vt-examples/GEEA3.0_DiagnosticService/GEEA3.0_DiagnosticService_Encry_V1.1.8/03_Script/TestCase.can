/// <APP_CommonServiceTest>
testcase Service_0x19_Sf0x02_Valid_Physical_DefaultSession_Supported_Service()
{
  int i;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350878_Service_0x19_Sf0x02_Valid_Physical_DefaultSession_Supported_Service_R2",400);
  testCaseDescription("The intent is to verify that the service ReadDTCInformation (0x19) and its subfunction reportDTCByStatusMask (0x02) is supported.");
  testCaseTitle("1350878","Service_0x19_Sf0x02_Valid_Physical_DefaultSession_Supported_Service");
  
  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  if(Flag_1902 == 0)
  {
    TestStepWarning("ECU doesn't support this subfunction , test case exit!");
    Postcondition();
     
    return;
  }

  for(i=0; i<=0xff; i++)
  {
    if(i==0)
    {
      TestStep("Let DS(DTC ststus mask)=0x00",TestStepIntervalTime);
    }
    else
    {
      TestStep("If DS<0xFF,let DS=DS+1,jump to step2",TestStepIntervalTime,2);
    }
    
    TestStep("Report DTCs",TestStepIntervalTime);
    SID19_Sub02_ReportDTCByStatusMask(i,PHYSICAL);
    CheckPosResponse_SID19_02(0xFF,0,0);
    StorageDTC();
    CheckDTCState(i);
    testWaitForTimeout(100);
  }
  TestStep("Verify defaultSession",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
 
