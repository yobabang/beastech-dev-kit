testcase Service_0x85_Func_SessionChange()
{
  byte clearDTC[3]={0xFF,0xFF,0xFF};
  byte SFOf85[2]={0x01,0x02};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350942_Service_0x85_Func_SessionChange",400);
  testCaseTitle("1350942","Service_0x85_Func_SessionChange");
  if(gBusFlag==3)
	{
		testStepWarning("Test","This test case does not apply to the LIN bus");
		return;
	}
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  SimTRC();
  
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  TestStep("Tester Present on",TestStepIntervalTime);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,FUNCTIONAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  Rss1=gTpRxLength;
  if(Rss1<=3)
  {
    TestStepWarning("No avalible DTC,Test end");
    StopTRC();
    Postcondition();
    return;
  }
  TestStep("Request DTC setting off",TestStepIntervalTime);
  SID85_ControlDTCSetting(SFOf85[1],FUNCTIONAL,SPRMIB_FALSE);   //禁止DTC更新
  CheckPosResponse_SID85(SFOf85[1],0,0);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,FUNCTIONAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  DTCSettingCheck(2);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  
  TestStep("Wait for 1s");
  testWaitForTimeout(1000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,FUNCTIONAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  DTCSettingCheck(2);
  
///////one more
  TestStep("Repeat step 1-13 once, set service 0x85 SPRMIB=True",TestStepIntervalTime);
  ResetStepIndex();
  
  TestStep("Enter defaultSession(0x01)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(DEFAULTSESSION,0,6);
  ECUinitHandle(0);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  TestStep("Tester Present on",TestStepIntervalTime);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 5s");
  delay(5000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,FUNCTIONAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  Rss1=gTpRxLength;
  if(Rss1<=3)
  {
    TestStepWarning("No avalible DTC,Test end");
    StopTRC();
    Postcondition();
    return;
  }
  TestStep("Request DTC setting off",TestStepIntervalTime);
  SID85_ControlDTCSetting(SFOf85[1],FUNCTIONAL,SPRMIB_TRUE);   //禁止DTC更新
  CheckNonResponse(0,0);
  TestStep("Clear all DTC",TestStepIntervalTime);
  SID14_ClearDTC(clearDTC,FUNCTIONAL);
  CheckPosResponse_SID14(0,0);
  
  TestStep("Wait 10s");
  delay(10000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,FUNCTIONAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  DTCSettingCheck(2);
  TestStep("Enter extendedSession(0x03)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,FUNCTIONAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,0,6);
  
  TestStep("Wait for 1s");
  testWaitForTimeout(1000);
  
  TestStep("Report DTCs",TestStepIntervalTime);
  SID19_Sub02_ReportDTCByStatusMask(0x27,FUNCTIONAL);
  CheckPosResponse_SID19_02(0xFF,0,0);
  DTCSettingCheck(2);
  StopTRC();
  /******************************以上为测试步骤*********************************/
  PostCondition();
}
/// <APP_GeneralTest>
testcase Power_Up_Default_Session_Test_APP()
{
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350963_Power_Up_Default_Session_Test_APP",400);
  testCaseDescription("The intent is to verify that the ECU is in defaultSession after power cycle off/on. ");
  testCaseTitle("1350963","Power_Up_Default_Session_Test_APP");
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Cycle the power to the ECU.",TestStepIntervalTime);
  
//  testWaitForTesterConfirmation("Please recycle the power of the ECU");
  kl30(T_off);
  kl15(T_off);
  testWaitForTimeout(1000);
  kl30(T_on);
  kl15(T_on);

  TestStep("Wait to operation start.");
  ECUinitHandle(0);

  TestStep("Verify defaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("ECU Reset (hard reset)",TestStepIntervalTime);
  //SID11_ECUReset(HardReset,SPRMIB_False,PHYSICAL);
  SID11_ECUReset(HARDRESET,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID11(HARDRESET,0,0);
  
  TestStep("Wait to operation cycle start");
  ECUinitHandle(0);
  TestStep("Verify defaultSession.",TestStepIntervalTime);
  CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <APP_GeneralTest>
testcase S3_Timeout_Test_App()
{
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1350967_S3_Timeout_Test_APP",400);
  testCaseDescription("The intent of the test to verify:1.S3Server parameter timeout value. 2.The ECU returns to defaultSession from any non defaultSession when S3 timer times out.");
  testCaseTitle("1350967","S3_Timeout_Test_APP");
  
  SetLog(logName);
  Precondition();
   
  /******************************以下为测试步骤*********************************/
  
  SessionFlag=APP;
  
  TestStep("Transition from defaultSession(0x01) to extendedDiagnosticSession(0x03).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(EXTENDEDSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(EXTENDEDSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  
  TP_TesterPresentSet(TP_OFF);
  TestStep("Wait for 4800 ms, from last final response.");
  delay(4800);
  TestStep("Send 3E 80",TestStepIntervalTime);
  SID3E_TesterPresent(PHYSICAL,SPRMIB_TRUE);
  //CheckNonResponse(0,0);//20250214 这里不判断无响应
  TestStep("Verify extendedDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
  TestStep("Wait for 5500 ms, from last final response.");
  delay(5500);
  
  
  if(gBusFlag==5 && SWRS_VERSION>=8 && EthNodeTypeNow==EdgeNode)
  {
     TestStep("Verify defaultSession.",TestStepIntervalTime);
     testStepWarning("","按照需求ID 987287,边缘节点应向车内发送3E 80 ，并维持自身的会话模式，所以不会跳转到默认会话");
     CheckCurrentSession(EXTENDEDSESSION,PHYSICAL,0,0);
    
  }
  else
  {
       ECUinitHandle(0,0);//20251210  这里
      TestStep("Verify defaultSession.",TestStepIntervalTime);
      CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  }
  
  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
/// <APP_GeneralTest>
testcase Check_Programming_Pre_conditions_Precondition_fulfilled_Valid_Physical_DefaultSession_Supported_Service()
{
  byte Data[4]={0x31,0x01,0x02,0x06};
  int  i,j,k,m,n,count;
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"28299_Check_Programming_Pre_conditions_Precondition_fulfilled_Valid_Physical_DefaultSession_Supported_Service",400);
  testCaseDescription(" The intent of the test is to verify that control routine 0206 is supported and response correct to precondition.");
  testCaseTitle("28299","Check_Programming_Pre_conditions_Precondition_fulfilled_Valid_Physical_DefaultSession_Supported_Service");

  SetLog(logName);
  Precondition();

  /******************************以下为测试步骤*********************************/
  SessionFlag=APP;
  /* 获取所有待测信号的数量并将信号值设置成有效值 */
  for(i=0;i<E2E_FRAME_NUM;i++) 
  { 
  	for(j=0;j<elcount(e2eFrameList[i].e2eSigGroupList);j++)
  	{
  		if(strncmp(e2eFrameList[i].e2eSigGroupList[j].sigGroupName,"",elcount(e2eFrameList[i].e2eSigGroupList[j].sigGroupName)) == 0) { break; }
  		else
  		{
  			for(k=0;k<e2eFrameList[i].e2eSigGroupList[j].sigNum;k++)
  			{
  				if(e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigUsed & SIGNALPROGRAMMING == SIGNALPROGRAMMING) 
          { 
            snprintf(info,elCount(info),"%s%s = %02X(Fulfilled)\n",info,e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigName,
  					e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_Fulfilled);
            e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue = e2eFrameList[i].e2eSigGroupList[j].e2eSignalList[k].sigValue_Fulfilled;
            e2eFrameList[i].simFrFlg = 1; e2eFrameList[i].simFrImtFlg = 1;
            count++; 
          }
  			}
  		}
  	}
  }
  if(count == 0) { testStepWarning("Test","No Signal About Programming Precondition in ParameterOfSigGroups.cin !!!"); }
  
  snprintf(info,elCount(info),"Set condition: \n%s",info);
  teststep(info); 
  
  if(gTestTypeFlag==1) { SimTRC(); }
  else                 { testWaitForTesterConfirmation(info); }

  delay(5000);
  
  TestStep("Check Programming Pre-condition",TestStepIntervalTime);
  TPSendRawMessage(Data,PHYSICAL);
  CheckPosResponse(0x31,0,0);
  if(gRss == POS)
  {
    if(gTpRxData[5] != 0x01)
    {
      TestStepFail("","The response data is not right , expect 71 01 02 06 10 01");
    }
  }
  
  TestStep("Transition to programmingSession(0x02)",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  SessionFlag=BOOT;
  
  TestStep("Verify programmingSession",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
  if(gTestTypeFlag==1) { StopTRC(); }
  else                 { testWaitForTesterConfirmation("Stop simulation signals"); }
  /******************************以上为测试步骤*********************************/
  
  Postcondition();
}
