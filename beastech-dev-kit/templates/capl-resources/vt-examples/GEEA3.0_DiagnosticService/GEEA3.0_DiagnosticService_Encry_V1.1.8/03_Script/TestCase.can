              seedrecord[seednum].seedinfo[9] = gSeedArray[9];
              seedrecord[seednum].seedinfo[10] = gSeedArray[10];
              seedrecord[seednum].seedinfo[11] = gSeedArray[11];
              seedrecord[seednum].seedinfo[12] = gSeedArray[12];
              seedrecord[seednum].seedinfo[13] = gSeedArray[13];
              seedrecord[seednum].seedinfo[14] = gSeedArray[14];
              seedrecord[seednum].seedinfo[15] = gSeedArray[15];
              seedrecord[seednum].seedtime = 1;
              seednum++;
            }
        }
      }
      if(repeatFlag == 0)
      {
        AllSeeds[i][0] = gSeedArray[0];
        AllSeeds[i][1] = gSeedArray[1];
        AllSeeds[i][2] = gSeedArray[2];
        AllSeeds[i][3] = gSeedArray[3];
        AllSeeds[i][4] = gSeedArray[4];
        AllSeeds[i][5] = gSeedArray[5];
        AllSeeds[i][6] = gSeedArray[6];
        AllSeeds[i][7] = gSeedArray[7];
        AllSeeds[i][8] = gSeedArray[8];
        AllSeeds[i][9] = gSeedArray[9];
        AllSeeds[i][10] = gSeedArray[10];
        AllSeeds[i][11] = gSeedArray[11];
        AllSeeds[i][12] = gSeedArray[12];
        AllSeeds[i][13] = gSeedArray[13];
        AllSeeds[i][14] = gSeedArray[14];
        AllSeeds[i][15] = gSeedArray[15];
