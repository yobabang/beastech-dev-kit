/// <PBL_CommonServiceTest>
testcase Sercice_0x27_Valid_Physical_ProgrammingDiagnosticSession_Supported_Service()
{
  int i;
  char logPath[400] = "";
  byte ExpectNRC[2] ={0x12,0x7E};
  char logName[400] = "";
  char info[1024];
  
  strncat(logName,"1351002_Sercice_0x27_Valid_Physical_ProgrammingDiagnosticSession_Supported_Service",400);
  testCaseDescription("That the ECU supports the service Security Access (0x27).That the ECU supports subfunction SecurityAccessType, sendKey and requestSeed.");
  testCaseTitle("1351002","Sercice_0x27_Valid_Physical_ProgrammingDiagnosticSession_Supported_Service");
  
  SetLog(logName);
  Precondition();
  /******************************以下为测试步骤*********************************/
  
  TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
  SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
  CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
  ECUinitHandle(0);
  SessionFlag=BOOT;
  
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
    TP_TesterPresentSet(TP_ON);
//  for(i=1; i<=LevelInProgramming; i++)
//  {
    Level1=0x01;
    testWaitForTimeout(gTimeWaitForSecuAccess);
  
    //执行解锁以确保控制器的错误计数器为0
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
  
    SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
    ECUinitHandle(0);
    //执行解锁以确保控制器的错误计数器为0
    testWaitForTimeout(gTimeWaitForSecuAccess);
    TestStep("ECU response with seed. Verify that S1 S2 S3 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
    TestStep("Generate K1 K2 K3 from response in step 3.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;
  
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckNegResponse(0x35,0,0);
    TestStep("ECU response with seed. Verify that S1 S2 S3 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
    TestStep("Generate K1 K2 K3 from response in step 6.",TestStepIntervalTime);
    gSeedArray[2]=gSeedArray[2]+1;
    TestStep("Generate wrong key from response.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckNegResponse(0x36,0,0);
    TestStep("Wait for Delaytimer-1s.");
    delaywithreq(DelayTimer-1000);
    TestStep("requiredTimeDelayNotExpired",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckNegResponse(0x37,0,0);
    TestStep("Wait for 2s.");
    testWaitForTimeout(2000);
    TestStep("ECU response with seed. Verify that S1 S2 S3 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
  
    TestStep("Generate K1 K2 K3 from response in step 12.",TestStepIntervalTime);
    //gSeedArray[2]=gSeedArray[2]+1;
    TestStep("ECU unlocks.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Transition from ProgrammingDiagnosticSession(0x02) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
    ECUinitHandle(0);
    TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
    
    testWaitForTimeout(gTimeWaitForSecuAccess);
    TestStep("ECU response with seed. Verify that S1 S2 S3 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlocks.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    SessionFlag=APP;
  
    TestStep("Transition to defaultSesion(0x01)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(DEFAULTSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(DEFAULTSESSION,gP2Client_APP,gP2StarClientFor10Check,0,0);
    ECUinitHandle(0);
    TestStep("Verify defaultSession",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
    SessionFlag=BOOT;
  
    TestStep("Transition from DefaultSession(0x01) to ProgrammingDiagnosticSession(0x02).",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_FALSE);
    CheckPosResponse_SID10(PROGRAMMINGSESSION,gP2Client_BOOT,gP2StarClientFor10Check,0,0);
    ECUinitHandle(0);
    TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
  
    testWaitForTimeout(gTimeWaitForSecuAccess);
    TestStep("ECU response with seed. Verify that S1 S2 S3 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
    TestStep("ECU unlock.",TestStepIntervalTime);
    SID27_SecurityAccess_SendKey(Level1,gKeyArray,PHYSICAL);
    CheckPosResponse_SID27_SenKey(Level1,0,0);
    TestStep("Disable functionally addressed periodic testerPresent.Wait for 4.8 seconds.");
    TP_TesterPresentSet(TP_OFF);
    delay(4800);
    TestStep("ECU response with seed. Verify that S1 S2 S3 equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(AllZero,gSeedArray);
  
    TestStep("Wait for 4s.");
    delay(4000);
  
    TestStep("ECU response with seed. Verify that S1 S2 S3 equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(AllZero,gSeedArray);
    for(i=0;i<elcount(gSeedArray);i++)
    {
      write("seedarray %d is %02x",i,gSeedArray[i]);
    }
    TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
    TestStep("Wait for ECU times out to defaultSession, S3 timer plus 'ECU startup time' and an additional 500 ms.");
    delay(5500);
  
    ECUinitHandle(0);
  
    SessionFlag=APP;
    TestStep("Verify defaultSession",TestStepIntervalTime);
    CheckCurrentSession(DEFAULTSESSION,PHYSICAL,0,0);
  
    SessionFlag=BOOT;
    TP_TesterPresentSet(TP_ON);
    TestStep("Transition from defaultSession(0x01) to ProgrammingDiagnosticSession(0x02)",TestStepIntervalTime);
    SID10_DiagnosticSessionControl(PROGRAMMINGSESSION,PHYSICAL,SPRMIB_TRUE);
    CheckNonResponse(0,0);
  
    ECUinitHandle(0);
    TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
    CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);
    testWaitForTimeout(gTimeWaitForSecuAccess);
    TestStep("ECU response with seed. Verify that S1 S2 S3 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);
//  }
    TestStep("ECU response with seed.S1 S2 S3 not equal to 0x000000 and S1 S2 S3 not equal to S1 S2 S3 from step 34",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckPosResponse_SID27_ReqSeed(Level1,gSeedArray,16,0,0);
    PID27_Parameters_Seeds_Chk(NotAllZero,gSeedArray);

  TestStep("Test of non supported subfunctions.",TestStepIntervalTime);
  for(i=0x03; i<0xFE; i=i+2)
  {
    if(i==3)
    TestStep("Let L1 be 03)",TestStepIntervalTime);
    else
    {
      TestStep("Add L1 + 2 If L1 =0x81 add +2 If L1 != 0x01 jump to step 38. ",TestStepIntervalTime);
    }
    if(i!=0x81)
    {
      Level1=i;
    }
    TestStep("ECU response with seed. Verify that S1 S2 S3 not equal to 0x000000.",TestStepIntervalTime);
    SID27_SecurityAccess_RequestSeed(Level1,PHYSICAL);
    CheckNegResponse(ExpectNRC,0,0,0,0);
  }
  TestStep("Verify ProgrammingDiagnosticSession.",TestStepIntervalTime);
  CheckCurrentSession(PROGRAMMINGSESSION,PHYSICAL,0,0);

  /******************************以上为测试步骤*********************************/
  Postcondition();
   
}
