    {
      TestStep("Info","%d.种子%02X %02X %02X %02X %02X %02X %02X %02X %02X %02X %02X %02X %02X %02X %02X %02X出现%d次",k,seedrecord[k].seedinfo[0],seedrecord[k].seedinfo[1],seedrecord[k].seedinfo[2],seedrecord[k].seedinfo[3],seedrecord[k].seedinfo[4],seedrecord[k].seedinfo[5],seedrecord[k].seedinfo[6],seedrecord[k].seedinfo[7],seedrecord[k].seedinfo[8],seedrecord[k].seedinfo[9],seedrecord[k].seedinfo[10],seedrecord[k].seedinfo[11],seedrecord[k].seedinfo[12],seedrecord[k].seedinfo[13],seedrecord[k].seedinfo[14],seedrecord[k].seedinfo[15],seedrecord[k].seedtime);
