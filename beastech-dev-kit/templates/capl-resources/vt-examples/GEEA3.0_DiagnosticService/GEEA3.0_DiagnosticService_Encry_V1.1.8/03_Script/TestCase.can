      CheckNonResponse(0,0);
    }
    if(i==3)
    {
      SID28_CommunicationControl(SFOf28[0],NCMAndNMM,FUNCTIONAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);   
      SID28_CommunicationControl(SFOf28[1],NCMAndNMM,FUNCTIONAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);       
      SID28_CommunicationControl(SFOf28[2],NCMAndNMM,FUNCTIONAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
      SID28_CommunicationControl(SFOf28[3],NCMAndNMM,FUNCTIONAL,SPRMIB_TRUE);
      CheckNonResponse(0,0);
    }
  }
