/**********************************SID 2C**********************************/
byte SID2C_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  txPackage.Packet.Length = 4;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1];         //sub-function
  txPackage.Packet.Payload[2] = rxPackage.Payload[2];         //ID_High
  txPackage.Packet.Payload[3] = rxPackage.Payload[3];         //ID_Low
  
  return POSITIVERESPONSE;
}

/**********************************SID 2E**********************************/
byte SID2E_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  txPackage.Packet.Length = 3;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1];         //ID_High
  txPackage.Packet.Payload[2] = rxPackage.Payload[2];         //ID_Low
  
  return POSITIVERESPONSE;
}

/**********************************SID 31**********************************/
byte SID31_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  word RoutineID;
  
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1];         //routineControlType
  txPackage.Packet.Payload[2] = rxPackage.Payload[2];         //ID_H
  txPackage.Packet.Payload[3] = rxPackage.Payload[3];         //ID_L
  
  RoutineID = ((word)rxPackage.Payload[2] << 8) | rxPackage.Payload[3];
  if(rxPackage.Payload[1] == 0x1) //startRoutine
  {
    switch(RoutineID)
    {
      case 0x0206:  //Prepare to enter programming mode
      {
        txPackage.Packet.Length = 4 + 2;
        txPackage.Packet.Payload[4] = 0x01;
        txPackage.Packet.Payload[5] = 0x01;
      }
      break; 
      case 0xFF00:  //Erase Memory
      {
        txPackage.Packet.Length = 4 + 1;
        txPackage.Packet.Payload[4] = 0x01;
      }
      break;
      case 0x0301:  //
      {
        txPackage.Packet.Length = 4 + 1;
        txPackage.Packet.Payload[4] = 0x01;
      }
      break;
      case 0x0205:  //
      {
        txPackage.Packet.Length = 4 + 1;
        txPackage.Packet.Payload[4] = 0x01;
      }
      break;
      case 0xFF01:  //CheckProgramming
      {
        txPackage.Packet.Length = 4 + 1;
        txPackage.Packet.Payload[4] = 0x01;
      }
      break;
    }
  }
  
  return POSITIVERESPONSE;
}
/**********************************SID 34**********************************/
byte SID34_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  txPackage.Packet.Length = 1;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[2] & 0xF0;  //lengthFormatIdentifier
  txPackage.Packet.Payload[2] = 0x00;                              //maxNumberOfBlockLength
  txPackage.Packet.Payload[3] = 0x00;
  txPackage.Packet.Payload[4] = 0x04;
  txPackage.Packet.Payload[5] = 0x00;  //1kB 长度待定
  
  return POSITIVERESPONSE;
}

/**********************************SID 35**********************************/
byte SID35_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  txPackage.Packet.Length = 6;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[2] & 0xF0;  //lengthFormatIdentifier
  txPackage.Packet.Payload[2] = 0x00;                              //maxNumberOfBlockLength
  txPackage.Packet.Payload[3] = 0x00;
  txPackage.Packet.Payload[4] = 0x10;
  txPackage.Packet.Payload[5] = 0x00;  //4kB 长度待定
  
  txPackage.SID36_Counter = 0;
  
  return POSITIVERESPONSE;
}

/**********************************SID 36**********************************/
byte SID36_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  //write("36resp");
  if(@GW::QueRequest_flag==1)
  {
    txPackage.Packet.Length = 2;
    txPackage.Packet.Payload[0] = rxPackage.Payload[0]+0x40;  
    txPackage.Packet.Payload[1] = rxPackage.Payload[1];         
    txPackage.Flag = 1;   
  }
  else
  {
    txPackage.Packet.Length = 3;
    txPackage.Packet.Payload[0] = 0x7F;  
    txPackage.Packet.Payload[1] = rxPackage.Payload[0];  
    txPackage.Packet.Payload[2] = rxPackage.Payload[1];         
    txPackage.Flag = 1;
  }
  return POSITIVERESPONSE;
}

/**********************************SID 37**********************************/
byte SID37_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  txPackage.Packet.Length = 2;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1];       
  
  return POSITIVERESPONSE;
}

/**********************************SID 3E**********************************/
byte SID3E_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  txPackage.Packet.Length = 1;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  
  if((rxPackage.Payload[1] & 0x80) == 0x80)
  {
    txPackage.Req_SPRMIB = 1;
  }
  else 
  {
    txPackage.Req_SPRMIB = 0;
  }
  
  return POSITIVERESPONSE;
}

/**********************************SID A5**********************************/
byte SIDA5_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  int i;
  if(@GW::Response_data == 1 )
  {
    txPackage.Packet.Length=responseBufferAPP1;
    for(i=0;i<txPackage.Packet.Length;i++)
      txPackage.Packet.Payload[i]=0xA5;
  }
  else if(@GW::Response_data == 2)
  {
    txPackage.Packet.Length=responseBufferBoot1;
    for(i=0;i<txPackage.Packet.Length;i++)
      txPackage.Packet.Payload[i]=0xA5;
  }
  else
  {
    txPackage.Packet.Length = rxPackage.Length;
    memcpy(txPackage.Packet.Payload,rxPackage.Payload,txPackage.Packet.Length);
  }
//////  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
//////  txPackage.Packet.Payload[1] = rxPackage.Payload[1];       
  txPackage.Flag = 1;
  
  return POSITIVERESPONSE;
}
