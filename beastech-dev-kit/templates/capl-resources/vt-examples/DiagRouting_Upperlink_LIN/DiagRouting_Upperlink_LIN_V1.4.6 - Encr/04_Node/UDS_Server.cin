/*@!Encoding:936*/
includes
{
  
}

variables
{ 
  enum ResponseCodeType
  {
    POSITIVERESPONSE = 0
  };

  struct  SDU_Data
  {
    word   SourceID;
    word   TargetID;
    dword  Length;
    byte   Payload[65536];
  };
  struct ServiceVars
  {
    word   Flag;
    word   Network_num;
    word   Req_SPRMIB;
    word   SID36_Counter;
    word   SID2A_Response;
    double TimeStamp;
    word   QueueOrder;
    struct SDU_Data Packet;
  };
  
  struct ServiceVars  Response;
  struct ServiceVars  Response_NRC;
  
  enum TestCase_List //用于Ecu仿真节点应答不同的数据
  {
    DID_EDA0_900B  =  5,
    DID_EDA0_100B  =  1,
    DID_EDA0_1kB   =  2,
    DID_EDA0_4kB   =  3,
    DID_EDA0_8kB   =  4
  };
}

byte SID10_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  word SN,i;
  
  txPackage.Flag = 1;
  txPackage.Packet.Length = 6;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1] & 0x7F;  //subfunction
  txPackage.Packet.Payload[2] = 0x00;
  txPackage.Packet.Payload[3] = 0x32;
  txPackage.Packet.Payload[4] = 0x00;
  txPackage.Packet.Payload[5] = 0xC8;
  
  if((rxPackage.Payload[1] & 0x80) == 0x80)
  {
    txPackage.Req_SPRMIB = 1;
  }
  else 
  {
    txPackage.Req_SPRMIB = 0;
  }
  
  return POSITIVERESPONSE;
}

/**********************************SID 11**********************************/
byte SID11_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  word SN,i;
  
  txPackage.Flag = 1;
  txPackage.Packet.Length = 2;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1] & 0x7F;  //subfunction
  
  if((rxPackage.Payload[1] & 0x80) == 0x80)
  {
    txPackage.Req_SPRMIB = 1;
  }
  else 
  {
    txPackage.Req_SPRMIB = 0;
  }
  
  
  return POSITIVERESPONSE;
}

/**********************************SID 22**********************************/
byte SID22_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  word  Identifier,SN;
  dword i,j;
  
  txPackage.Flag = 1;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1];         //ID_High
  txPackage.Packet.Payload[2] = rxPackage.Payload[2];         //ID_Low
  
  Identifier = rxPackage.Payload[1] << 8 | rxPackage.Payload[2];
  //write("1234!!! Response_data=%x",@GW::Response_data);
  switch(Identifier)
  {
    case 0xF186: 
    {
      //WRITE("86");
      txPackage.Packet.Length = 3 + 1;
      txPackage.Packet.Payload[3] = 0x1;
    }
    break;
    case 0xEDA0: 
    {
      txPackage.Packet.Length = @GW::Response_data;
      for(i=3; i<txPackage.Packet.Length; i++)
      {
        if(((i - 3) % 14) / 7 == 0)
        {
          txPackage.Packet.Payload[i] = 0x33;
        }
        else 
        {
          txPackage.Packet.Payload[i] = 0x44;
        }
      }
    }
    break;
    case 0xF12A:
    {
      txPackage.Packet.Length = 3;
      //txPackage.Packet.Payload[3] = 0xAA;
    }
    break;
    case 0xF18C:
    {
      txPackage.Packet.Length = 3;
      //txPackage.Packet.Payload[3] = 0xAA;
    }
    break;
    case 0xF125:
    {
      txPackage.Packet.Length = 3;
      //txPackage.Packet.Payload[3] = 0xAA;
    }
    break;
    case 0xF123:
    {
      txPackage.Packet.Length = 3;
      //txPackage.Packet.Payload[3] = 0xAA;
    }
    break;
    
    default: break;
  }
  
  return POSITIVERESPONSE;
}

/**********************************SID 27**********************************/
byte SID27_Response(struct ECU_SDU rxPackage, struct ServiceVars txPackage)
{
  byte subFunction;
  byte sendKey[4];
  
  txPackage.Flag = 1;
  txPackage.Packet.Payload[0] = rxPackage.Payload[0] | 0x40;  //SID
  txPackage.Packet.Payload[1] = rxPackage.Payload[1];         //subfunction
  
  subFunction = rxPackage.Payload[1];
  switch(subFunction)
  {  
    case 0x01: 
    {
      txPackage.Packet.Length = 6;
      sendKey[0] = rxPackage.Payload[2];
      sendKey[1] = rxPackage.Payload[3];
      sendKey[2] = rxPackage.Payload[4];
      sendKey[3] = rxPackage.Payload[5];
    }
    break;
    
    case 0x02: 
    {
      txPackage.Packet.Length = 2;
    }
    break;
  }
  
  return POSITIVERESPONSE;
}

