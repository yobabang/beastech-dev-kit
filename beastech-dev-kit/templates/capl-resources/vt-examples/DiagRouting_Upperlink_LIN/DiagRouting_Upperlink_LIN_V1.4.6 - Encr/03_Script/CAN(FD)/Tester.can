/// <TestGroup08_ParallelRequests>
testcase TC1322807_ParallelRequests_ProgrammingSession_R2()
{
  char TestcaseName[80]="TC1322807_ParallelRequests_ProgrammingSession_R2";
  int i,j,flag,N;
  word k[NetworkNumber];
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging(); 
  testCaseTitle("TC1322807","Parallel Requests");  
  
  TestCasePrecondition(); 
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [ProgrammingSession= 0x02], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[ProgrammingSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(ProgrammingSession);
  testWaitForTimeout(ECUResetTime);
  CheckRequestTrans();
    
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(1000);   
  
  testStep("","");
  teststep("Step3","Send segementented request to 2 target ECU/TA ids on same network");
  flag=0;
  for(N=2; N<EcuSum; N++)
	{
    if(EcuAddressTable[N].domain == EcuAddressTable[N-1].domain)
    {
      k[EcuAddressTable[N].domain-1]++;
      if(k[EcuAddressTable[N].domain-1] >= 1)
      {
        flag=1;
        break; 
      }     
    }
  }
  if(flag==0)
  {
    testStepWarning("","The number of ECUs for each network is less than 2,the case is not applicable");
    return;
  }
  
  for(i=N-1; i<N+1; i++)
  {
    SetResponseTask(i);
    Request[i].Packet.SourceID = EcuAddressTable[i].SourceID;
    Request[i].Packet.TargetID = EcuAddressTable[i].TargetID;
    Request[i].Packet.Length = 100;
    Request[i].Packet.Payload[0]=0x36;Request[i].Packet.Payload[1]=0x01;
    for(j=2;j<Request[i].Packet.Length;j++)
      Request[i].Packet.Payload[j]=0xA5;
    Request[i].Flag=1;
    SendDiagRequest(Request[i]); 
  }
  
  testWaitForTimeout(2000);
  CheckRequestTrans();  
  CheckResponseTrans();
  @GW::Response_Indication=0;

  testStep("","");
  teststep("Step4","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);  
   
  testStep("","");
  teststep("Step5","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(1000);
  CheckRequestTrans(); 
  
  TestCasePostcondition();
}

/// <TestGroup09_QueuedRequests>
testcase TC1322809_QueuedRequests_ProgrammingSession_R2()
{
  char TestcaseName[80]="TC1322809_QueuedRequests_ProgrammingSession_R2";
  int i, j;
  float t1,t2;
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging(); 
  testCaseTitle("TC1322809","Queued Requests");
  
	TestCasePrecondition(); 
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [ProgrammingSession= 0x02], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[ProgrammingSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(ProgrammingSession);
  testWaitForTimeout(ECUResetTime);
  CheckRequestTrans();
  
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);
  
  @GW::QueRequest_flag=1;
  for(i=2; i<EcuSum; i++)
    @GW::QueRequestNum[i]=0;
  
	teststep("Step3","Send queue requests");
  for(i=2; i<EcuSum; i++)
  {
    SetResponseTask(i);
    Send36Confirm[i][0].NUM=0x1;
    Request[i].Packet.SourceID = EcuAddressTable[i].SourceID;
    Request[i].Packet.TargetID = EcuAddressTable[i].TargetID;
    Request[i].Packet.Length = 100;
    Request[i].Packet.Payload[0]=0x36;Request[i].Packet.Payload[1]=Send36Confirm[i][0].NUM;
    for(j=2;j<Request[i].Packet.Length;j++)
      Request[i].Packet.Payload[j]=0xA5;
    SendDiagRequest(Request[i]); 
    Send36Confirm[i][0].flag=1;
    
    Send36Confirm[i][1].NUM=0x2;
    QueRequest[i].Packet.SourceID = EcuAddressTable[i].SourceID;
    QueRequest[i].Packet.TargetID = EcuAddressTable[i].TargetID;
    QueRequest[i].Packet.Length = 100;
    QueRequest[i].Packet.Payload[0]=0x36;QueRequest[i].Packet.Payload[1]=Send36Confirm[i][1].NUM;
    for(j=2;j<QueRequest[i].Packet.Length;j++)
      QueRequest[i].Packet.Payload[j]=0xA5;
    SendDiagRequest(QueRequest[i]);  
    Send36Confirm[i][1].flag=1;
    
    testWaitForTimeout(1000);
  }
  
  testWaitForTimeout(4000);
  @GW::QueRequest_flag=0;
  for(i=2; i<EcuSum; i++)
    @GW::QueRequestNum[i]=0;

  for(i=2; i<EcuSum; i++)
  {
    teststep("step","check transmit of Request of 0x%x",EcuAddressTable[i].TargetID);
    CheckDataTransmit_Request(Request[i].Packet, QueRequestTrans[i][0].Packet); 
    CheckDataTransmit_Request(QueRequest[i].Packet, QueRequestTrans[i][1].Packet); 
    memcpy(ResponseTrans[i],void_Request);
    Response[i].flag=0;
  }  
  @GW::Response_Indication=0;
  
	teststep("Step4","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
	SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  
  teststep("Step5","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");  
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();

	TestCasePostcondition();
}

