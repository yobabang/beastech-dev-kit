/// <TestGroup14_FunctionalAddressingSimultaneousForwardingTest>
testcase TC1375995_FunctionalRequestStressTesting_DefaultSession_R2()
{
  int i, j,M=0;
  char TestcaseName[100]="TC1375995_FunctionalRequestStressTesting_DefaultSession_R2";
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging();
	testCaseTitle("TC1375995","Functional Request Stress Testing R2");
	testCaseDescription("This test verifies that functional requests are not delayed through the gateway.");
	testCaseComment("Purpose:\nCriteria:");

	TestCasePrecondition();

  testStep("","");
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();
  
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);
  
  @GW::FunRequestNum=0;
  @GW::FunRequest_flag=1;//功能寻址数据存储标志位
  @GW::EnDetect_3E80 = 1;//开启功能寻址3E80检测  
    
  testStep("","");
  teststep("Step3","Send 2 functional request immediately!");
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  Request[0].Packet.Length = 2; 
  Request[0].Packet.Payload[0] =0x3E;
  Request[0].Packet.Payload[1] =0x80;
  SendDiagRequest(Request[0]);
  
  testWaitForTimeout(1);
  
  Request[0].Packet.Payload[0] =0x11;
  Request[0].Packet.Payload[1] =0x81;
  SendDiagRequest(Request[0]);
  
  CurrentSessionchange(DefaultSession); 
  testWaitForTimeout(ECUResetTime);
  teststep("chk","Check functional Request transmit on target network!");
  if(@GW::FunRequestNum==NetworkNumber*2)
    testStepPass("chk","Both functional addressing can be forwarded normally");
  else
    testStepFail("chk","Functionally addressed forwarding exception %d/%d",@GW::FunRequestNum,NetworkNumber*2);
   
  @GW::FunRequestNum=0;
  @GW::FunRequest_flag=0;//功能寻址数据存储标志位
  @GW::EnDetect_3E80 = 0;  
  
  testStep("","");
  teststep("Step4","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000); 
 
  TestCasePostcondition();
}

