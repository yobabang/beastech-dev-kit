/// <TestGroup04_FunctionallyAddressedRequestTransfer>
testcase TC1322681_FunctionallyAddressedRequestTransfer_DefaultSession_R2()
{
  char TestcaseName[80]="TC1322681_FunctionallyAddressedRequestTransfer_DefaultSession_R2";
  int i, j;
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging(); 
  testCaseTitle("TC1322681","Functionally Addressed Request Transfer");
   
  TestCasePrecondition(); 
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();
  
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);  
  
  @GW::FunRequestNum = 0;
  @GW::FunRequest_flag = 1;
  for(i=1;i<(NetworkNumber+1);i++)
    @GW::Flag_3DSend[i] = 0;
  
  testStep("","");
  teststep("Step3","Sending function addressing 3E 00");
  Request[FunctionalReq].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[FunctionalReq].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SID3E_TesterPresent(SID3E_Request[TesterPresent],Request[FunctionalReq]);
  SendDiagRequest(Request[FunctionalReq]);
  testWaitForTimeout(2000);
  
  CheckECU_Response_Fun(Request[FunctionalReq],GatewayResp);
  CheckRequestTran_Fun();
  testStep("","");
  Check3DHeader_send();
  
  for(i=1;i<(NetworkNumber+1);i++)
    @GW::Flag_3DSend[i] = 0;
  @GW::FunRequestNum = 0;
  @GW::EnDetect_3E80 = 1;
  testStep("","");
  teststep("Step4","Sending function addressing 3E 80");
  Request[FunctionalReq].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[FunctionalReq].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SID3E_TesterPresent(SID3E_Request[TesterPresent_SPRMIB],Request[FunctionalReq]);
  SendDiagRequest(Request[FunctionalReq]);
  testWaitForTimeout(2000);
  
  CheckRequestTran_Fun();  
  testStep("","");
  Check3DHeader_send();
  
  @GW::FunRequestNum = 0;
  @GW::FunRequest_flag = 0;
  for(i=1;i<(NetworkNumber+1);i++)
    @GW::Flag_3DSend[i] = 0;
  @GW::EnDetect_3E80 = 0;
  
  testStep("","");
  teststep("Step5","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(1000);
