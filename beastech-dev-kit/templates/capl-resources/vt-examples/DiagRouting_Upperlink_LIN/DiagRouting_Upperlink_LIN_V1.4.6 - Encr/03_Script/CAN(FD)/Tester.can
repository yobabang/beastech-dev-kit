/// <TestGroup12_DomianFunctionallyAddressedRequest>
/*********************************************************************************
Testcase     :  ResetOfGatewayWithPendingRequests
Description  :  
Reference    :  
Calls        :
History      :  Create by Polelink
*********************************************************************************/
testcase TC1366353_DomianFunctionallyAddressedRequest_DefaultSession_R2()
{
  char TestcaseName[80]="TC1366353_DomianFunctionallyAddressedRequest_DefaultSession_R2";
  int i,j;
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging(); 
  testCaseTitle("TC1366353","Reset of gateway with pending requests R2");
	testCaseDescription("This test verifies when sending functional requests DiagnosticSessionControl will be transmitted through the gateway Before the domain gateway will reset itself.");
	testCaseComment("Purpose:\n Criteria:GW will sent out functional request before ECU reset is executed.");
	 
  TestCasePrecondition(); 
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();
  
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(1000); 
  
  if(elcount(EcuAddressTable_Fun)==1)
  {
    testStepFail("Chk","DUT does not support domain functional addressing");
    return;
  }

  @GW::FunRequestNum=0;
  @GW::FunRequest_flag=1;//功能寻址数据存储标志位
  for(i=1; i<elcount(EcuAddressTable_Fun); i++)
	{
    testStep("","");
    teststep("Step3","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
    @GW::FunRequestNum=0;  
    Request[0].Packet.SourceID = EcuAddressTable_Fun[i].SourceID;
    Request[0].Packet.TargetID = EcuAddressTable_Fun[i].TargetID;
    SID22_ReadDataByIdentifier(SID22_Request[Read_F186], Request[0]);
    SendDiagRequest(Request[0]);
    testWaitForTimeout(1000);
    if(EcuAddressTable_Fun[i].domain==0)
    {
      CheckECU_Response_Fun(Request[0],GatewayResp);
    }
    else
    {
      int j,flag;
      flag=0;
      for(j=0;j<@GW::FunRequestNum;j++)
      {
        if(FunRequest[j].Network_num==EcuAddressTable_Fun[i].domain)
        {
          flag=1;
          testStepPass("chk","Functional addressing forwarding to the target network（Domian=%d Time=%f）",EcuAddressTable_Fun[i].domain,FunRequest[j].TimeStamp);  
          break;
        }
      }
      if(flag==0)
        testStepFail("chk","Functional addressing not forwarded to the target network（Domian=%d）",EcuAddressTable_Fun[i].domain);      
    }
    FunRequestBufferClear();    
    testWaitForTimeout(2000);
  }
  
  @GW::FunRequestNum=0;
  @GW::FunRequest_flag=0;//功能寻址数据存储标志位
	
  testStep("","");
  teststep("Step4","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);  
  
  TestCasePostcondition();
}
