/*@!Encoding:936*/
includes
{
  #pragma library("..\..\02_Library\02_DLL\capldll.dll")
  #pragma library("..\..\02_Library\02_DLL\CodeMeter.dll")
  #include "..\..\01_Input\TestParameter.cin"
  #include "..\Context.cin"
  #include "CANFD_TP.cin"
  #include "..\UDS_Client.cin"
  #include "..\TaskScheduling.cin"
  #include "TesterConfig.cin"
  #include "..\UserDetection.cin"
}

variables
{
  char tim[50]="";
  char logpath[100]="";
  float t_CAN_tx[EcuSum];
}

void CheckRequestTran_Fun()
{ 
  int i,j;
  linWakeup();
  linSetWakeupParams(100,2);
  linSendWakeup(150,3,250);
  for(i=2; i<EcuSum; i++)
	{
    int flag;
    flag=0;
    if(EcuAddressTable[i].domain==EcuAddressTable[i-1].domain)
      continue;
    for(j=0;j<@GW::FunRequestNum;j++)
    {
      if(EcuAddressTable[i].domain==FunRequest[j].Network_num)
      {
        flag=1;
        testStep("","");
        testStepPass("chk","Functional addressing forwarding to the target network（Domian=%d Time=%f）",EcuAddressTable[i].domain,FunRequest[j].TimeStamp);  
        CheckDataTransmit_Request(Request[0].Packet, FunRequest[j].Packet); 
        if((FunRequest[j].TimeStamp-t_CAN_tx[0])<=MaxTransTime)
          testStepPass("chk","Diagnosis request forwarding time is %f less than %dms",(FunRequest[j].TimeStamp-t_CAN_tx[0]),MaxTransTime);
        else
          testStepFail("chk","Diagnosis request forwarding time is %f more than %dms",(FunRequest[j].TimeStamp-t_CAN_tx[0]),MaxTransTime);
        break;
      }
    }
    if(flag==0)
      testStepFail("chk","Functional addressing not forwarded to the target network（Domian=%d）",EcuAddressTable[i].domain);      
  }
  
  for(j=0;j<@GW::FunRequestNum;j++)
    memcpy(FunRequest[j],void_Request);
}

on linWakeupFrame
{
  linWakeup();
  linSetWakeupParams(100,2);
  linSendWakeup(150,3,250);
}

/// <TestGroup01_LINMasterRoutingFunctionalRequests>
/*********************************************************************************
Testcase     :  LIN master Time routing incoming Diagnostic request
Description  :  
Reference    :  
Calls        :
History      :  Create by Polelink LiXiong
*********************************************************************************/
testcase TC1322471_FunctionallyAddressedResetRequest_DefaultSession_R2()
{
  char TestcaseName[80]="TC1322471_FunctionallyAddressedResetRequest_DefaultSession_R2";
  int i,j;
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging(); 
  testCaseTitle("TC1322471","Reset of gateway with pending requests DefaultSession");
	testCaseDescription("This test verifies when sending functional requests DiagnosticSessionControl will be transmitted through the gateway Before the domain gateway will reset itself.");
	testCaseComment("Purpose:\n Criteria:GW will sent out functional request before ECU reset is executed.");
   
  TestCasePrecondition(); 
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();
  
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(1000);  

  @GW::FunRequestNum=0;
  @GW::FunRequest_flag=1;//功能寻址数据存储标志位
  
  testStep("","");
  teststep("Step3","DiagnosticSessionControl_Request(diagnosticSessionType = [programmingSession = 0x02], suppressPosRspMsgIndicationBit = [TRUE])");
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SID10_DiagnosticSessionControl(SID10_Request[ProgrammingSession], Request[0]);
  SendDiagRequest(Request[0]);
  CurrentSessionchange(ProgrammingSession);

  testWaitForTimeout(ECUResetTime);  
  CheckRequestTran_Fun();
  
  @GW::FunRequestNum=0;
  @GW::FunRequest_flag=0;//功能寻址数据存储标志位
	
  testStep("","");
  teststep("Step4","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000); 
 
  testStep("","");
  teststep("Step5","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(1000);
  CheckRequestTrans(); 
  
  TestCasePostcondition();
}

