    for(j=1;j<(NetworkNumber+1);j++)
      @GW::Flag_3DSend[j] = 0;
    testWaitForTimeout(100);
    CheckResponseTrans();
    testStep("","");
    Check3DHeader_send(0,EcuAddressTable[i].domain);
    @GW::Response_NRC78=0;
    @GW::Response_multsend=0;
  }

  testStep("","");
  teststep("Step12","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(1000);
  CheckRequestTrans(); 
  
  TestCasePostcondition();
}

/// <TestGroup07_TimeoutForNRC78>
testcase TC1322805_TimeoutForNRC78_ExtendedSession_R2()
{
  char TestcaseName[80]="TC1322805_TimeoutForNRC78_ExtendedSession_R2";
  int i, j;
  float t1,t2;
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging(); 
  testCaseTitle("TC1322805","Timeout For NRC78"); 
  
	TestCasePrecondition(); 
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [ExtendedSession= 0x03], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[ExtendedSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(ExtendedSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();
  
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); 
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(1000);  
  
  for(i=2;i<EcuSum;i++)
  {
    if(EcuAddressTable[i].domain==EcuAddressTable[i-1].domain)
      continue;
      
    @GW::Flag_DataReceived_LIN[EcuAddressTable[i].domain] = 0;
    testStep("","");
  	teststep("Step3","Send diagnostic request：22 F1 86");
    Request[i].Packet.SourceID = EcuAddressTable[i].SourceID;
    Request[i].Packet.TargetID = EcuAddressTable[i].TargetID;
    SID22_ReadDataByIdentifier(SID22_Request[Read_F186], Request[i]);   
    SendDiagRequest(Request[i]); 
    t1 = timeNow()/100.0;
    while(@GW::Flag_DataReceived_LIN[EcuAddressTable[i].domain] == 0) 
    { 
      testWaitForTimeout(1); 
      t2 = timeNow()/100.0;
      if(t2-t1>MaxTransTime) 
        break;
    }
    if(t2-t1>MaxTransTime) 
    { 
      testStepFail("Fail","Diagnostic request not forwarded to LIN network segment"); 
      return; 
    }
    @GW::Response_NRC78=0;
    teststep("Step4","Send diagnostic response：7F 22 78");
    SetNRC78ResponseTask(i);
    
    testStep("","");
    teststep("Step5","等待4950ms");
    testWaitForTimeout(4850);
    for(j=1;j<(NetworkNumber+1);j++)
      @GW::Flag_3DSend[j] = 0;
    CheckRequestTrans();
    testWaitForTimeout(100);
    
    @GW::Response_NRC78=0;
    CheckResponseTrans();
    testStep("","");
    Check3DHeader_send(0,EcuAddressTable[i].domain);
    if(@GW::Flag_3DSend[EcuAddressTable[i].domain]==0)
    {
      testStepFail("step","3D header not send correctly(stop send)! ");
      continue;
    }
    
    testStep("","");
    teststep("Step6","等待100ms"); 
    testWaitForTimeout(100);
    for(j=1;j<(NetworkNumber+1);j++)
      @GW::Flag_3DSend[j] = 0;
    testWaitForTimeout(100);
    Check3DHeader_send(1,EcuAddressTable[i].domain);
    
    @GW::Flag_DataReceived_LIN[EcuAddressTable[i].domain] = 0;  

    testWaitForTimeout(1000);
    testStep("","");
  	teststep("Step7","Send diagnostic request：22 F1 86");
    SendDiagRequest(Request[i]); 
    t1 = timeNow()/100.0;
    while(@GW::Flag_DataReceived_LIN[EcuAddressTable[i].domain] == 0) 
    { 
      testWaitForTimeout(1); 
      t2 = timeNow()/100.0;
      if(t2-t1>MaxTransTime) 
        break;
    }
    if(t2-t1>MaxTransTime) 
    { 
      testStepFail("Fail","Diagnostic request not forwarded to LIN network segment"); 
      return; 
    }
    teststep("Step8","Send diagnostic response：7F 22 78");
    SetNRC78ResponseTask(i);
    testStep("","");
    teststep("Step9","等待4950ms");
    testWaitForTimeout(4850);
    for(j=1;j<(NetworkNumber+1);j++)
      @GW::Flag_3DSend[j] = 0;
    testWaitForTimeout(100);
    CheckRequestTrans();
    
    @GW::Response_NRC78=0;
    Check3DHeader_send(0,EcuAddressTable[i].domain);
    if(@GW::Flag_3DSend[EcuAddressTable[i].domain]==0)
    {
      testStepFail("step","3D header not send correctly(stop send)! ");
      continue;
    }
    
    @GW::Response_multsend=1;
    testStep("","");
    teststep("Step10","Send diagnostic response：7F 22 78");
    SetNRC78ResponseTask(i);
    testStep("","");
    teststep("Step11","等待100ms"); 
    testWaitForTimeout(100);
    for(j=1;j<(NetworkNumber+1);j++)
      @GW::Flag_3DSend[j] = 0;
    testWaitForTimeout(100);
    CheckResponseTrans();
    testStep("","");
    Check3DHeader_send(0,EcuAddressTable[i].domain);
    @GW::Response_NRC78=0;
    @GW::Response_multsend=0;
  }

  testStep("","");
  teststep("Step12","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);  
   
  testStep("","");
  teststep("Step13","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(1000);
  CheckRequestTrans(); 
  
  TestCasePostcondition();
}

/// <TestGroup08_ParallelRequests>
testcase TC1322806_ParallelRequests_DefaultSession_R2()
{
  char TestcaseName[80]="TC1322806_ParallelRequests_DefaultSession_R2";
  int i,j,flag,N;
  word k[NetworkNumber];
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging(); 
  testCaseTitle("TC1322806","Parallel Requests"); 
  
  TestCasePrecondition(); 
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();
  
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);  
  
  testStep("","");
  teststep("Step3","Send segementented request to 2 target ECU/TA ids on same network");
  flag=0;
  for(N=2; N<EcuSum; N++)
	{
    if(EcuAddressTable[N].domain == EcuAddressTable[N-1].domain)
    {
      k[EcuAddressTable[N].domain-1]++;
      if(k[EcuAddressTable[N].domain-1] >= 1)
      {
        flag=1;
        break; 
      }     
    }
  }
  if(flag==0)
  {
    testStepWarning("","The number of ECUs for each network is less than 2,the case is not applicable");
    return;
  }
  
  for(i=N-1; i<N+1; i++)
  {
    SetResponseTask(i);
    Request[i].Packet.SourceID = EcuAddressTable[i].SourceID;
    Request[i].Packet.TargetID = EcuAddressTable[i].TargetID;
    Request[i].Packet.Length = 100;
    Request[i].Packet.Payload[0]=0x36;Request[i].Packet.Payload[1]=0x01;
    for(j=2;j<Request[i].Packet.Length;j++)
      Request[i].Packet.Payload[j]=0xA5;
    Request[i].Flag=1;
    SendDiagRequest(Request[i]); 
  }
  
  testWaitForTimeout(2000);
  CheckRequestTrans();  
  CheckResponseTrans();
  @GW::Response_Indication=0;

  testStep("","");
  teststep("Step4","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(1000);
  CheckRequestTrans(); 
  
  TestCasePostcondition();
}

