/// <TestGroup13_FunctionalRequestStressTesting>
testcase TC1375992_FunctionalRequestStressTesting_DefaultSession_R2()
{
  int i, j,M=0;
  char TestcaseName[100]="TC1375992_FunctionalRequestStressTesting_DefaultSession_R2";
  stopLogging();
  SetLogPath(TestcaseName,1);
  startLogging();
	testCaseTitle("TC1375992","Functional Request Stress Testing R2");
	testCaseDescription("This test verifies that functional requests are not delayed through the gateway.");
	testCaseComment("Purpose:\nCriteria:");

	TestCasePrecondition();

  testStep("","");
  teststep("Step1","DiagnosticSessionControl_Request(diagnosticSessionType = [DefaultSession= 0x01], suppressPosRspMsgIndicationBit = [FALSE])");
  SID10_DiagnosticSessionControl(SID10_Request[DefaultSession], Request[0]);
  Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
  Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
  SendDiagRequest(Request[0]);
  CurrentSessionchange(DefaultSession);
  testWaitForTimeout(2000);
  CheckRequestTrans();
  
  testStep("","");
	teststep("Step2","ReadDataByIdentifier_Request(dataIdentifier = [ActiveDiagnosticSession = 0xF186])");
  SID22_ReadDataByIdentifier(SID22_Request[Read_F186], GatewayReq); //CheckCurrentSession
  SendDiagRequest(GatewayReq);
  CheckGatewayResponse();
  testWaitForTimeout(2000);
  
  for(i=0;i<100;i++)
  {
    testStep("","");
    testStep("","Number of cycles:%d",i+1);   
    @GW::FunRequestNum=0;
    @GW::FunRequest_flag=1;//功能寻址数据存储标志位
//    @GW::EnDetect_3E80 = 1;//开启功能寻址3E80检测  
      
    testStep("","");
    teststep("Step3","Send functional request immediately!");
    Request[0].Packet.SourceID = EcuAddressTable[FunctionalReq].SourceID;
    Request[0].Packet.TargetID = EcuAddressTable[FunctionalReq].TargetID;
    Request[0].Packet.Length = 2; 
