///**********************************SID 37**********************************/
void SID37_RequestTransferExit(struct RequestTransferExit SID37_Package, struct ServiceVars txPackage)
{
  txPackage.SID36_Counter = 0;
  
  SID37_Package.SID=0x37;
  SID37_Package.Length=0x1;
  txPackage.Req_SPRMIB = SID37_Package.GW_SPRMIB;
  txPackage.Packet.Length = SID37_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID37_Package, PDU_Offset, txPackage.Packet.Length);
  
 // txPackage.Flag = 1;
}
void CheckPosResponse_SID37(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  //testerReq.TransferRespParaRec = ecuResp.Packet.Payload[1]<<8 + ecuResp.Packet.Payload[2];
  
  if(1 == ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
}

/**********************************SID 3E**********************************/
void SID3E_TesterPresent(struct TesterPresent SID3E_Package, struct ServiceVars txPackage)
{
  txPackage.Req_SPRMIB = (SID3E_Package.SubFunction & 0x80) >> 7;
  txPackage.Packet.Length = SID3E_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID3E_Package, PDU_Offset, txPackage.Packet.Length);
  
  txPackage.Flag = 1;
}

void CheckPosResponse_SID3E(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  if(2==ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
}

