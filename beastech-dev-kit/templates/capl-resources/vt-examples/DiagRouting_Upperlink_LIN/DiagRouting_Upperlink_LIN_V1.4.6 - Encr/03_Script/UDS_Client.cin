  //txPackage.Flag = 1;
}
void CheckPosResponse_SID31(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  word RoutineID;
  
  //Subfunction
  if(ecuResp.Packet.Payload[1] != testerReq.Packet.Payload[1]) 
  {
    testStepFail("Chk","Response Subfunction is [0x%x]",ecuResp.Packet.Payload[1]);    
  }
  else
  {
    testSteppass("Chk","Response Subfunction is [0x%x]",ecuResp.Packet.Payload[1]);   
  }
  
  //Routine Identifier
  if((ecuResp.Packet.Payload[2] != testerReq.Packet.Payload[2])&&(ecuResp.Packet.Payload[3] != testerReq.Packet.Payload[3]))
  {
    testStepFail("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[2],ecuResp.Packet.Payload[3]);    
  }
  else
  {
    testSteppass("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[2],ecuResp.Packet.Payload[3]);   
  }
  
  RoutineID = ((word)ecuResp.Packet.Payload[2] << 8) | ecuResp.Packet.Payload[3];
  if(ecuResp.Packet.Payload[1] == 0x1) //startRoutine
  {
    switch(RoutineID)
    {
      case 0x0206:  //Prepare to enter programming mode
      {
        if(6 == ecuResp.Packet.Length)
        {
          testStepPass("Chk","Response data length is correct");
        }
        else
        {
          testStepFail("Chk","Response data length is not correct");
        }
      }
      break;
      
      case 0xFF00:  //Erase Memory
      {
        if(5 == ecuResp.Packet.Length)
        {
          testStepPass("Chk","Response data length is correct");
        }
        else
        {
          testStepFail("Chk","Response data length is not correct");
        }
      }
      break;
    }
  }
}
///**********************************SID 34**********************************/
void SID34_RequestDownload(struct RequestDownload SID34_Package, struct ServiceVars txPackage)
{
  
  txPackage.SID36_Counter = 0;
  SID34_Package.SID = 0x34;
  txPackage.Req_SPRMIB = SID34_Package.GW_SPRMIB;
  txPackage.Packet.Length = SID34_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID34_Package, PDU_Offset, txPackage.Packet.Length);
  
  //txPackage.Flag = 1;
}

void CheckPosResponse_SID34(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  //testerReq.MaxNumberOfBlockLength = (ecuResp.Packet.Payload[2]<<8) + ecuResp.Packet.Payload[3] - 2;//
  
  if(0x20 == ecuResp.Packet.Payload[1]) //lengthFormatIdentifier
  {  
    testStepPass("Chk","PositiveResponselengthFormatIdentifier n %x",ecuResp.Packet.Payload[1]);
  }
  else
  {
    testStepFail("Chk","Unexpect PositiveResponselengthFormatIdentifier %x",ecuResp.Packet.Payload[1]);    
  }
  
  if(4==ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
}
