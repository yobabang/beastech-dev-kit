///**********************************SID 10**********************************/
void SID10_DiagnosticSessionControl(struct DiagnosticSessionControl SID10_Package, struct ServiceVars txPackage)
{
  word SN,i;
  
  txPackage.Req_SPRMIB = (SID10_Package.SubFunction & 0x80) >> 7;
  txPackage.Packet.Length = SID10_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID10_Package, PDU_Offset, txPackage.Packet.Length);
  
  //@sysvar::GW::CurrentSession = SID10_Package.SubFunction & 0x7F; //保存当前会话模式

  txPackage.Flag = 1;
}

void CheckPosResponse_SID10(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  byte P2_Server[4];
  
//  if(gRSS == TIMEOUT)       { testStepFail("Fail","Timeout No Response Received!"); return; }
//  else if(gRSS == NEGETIVE) { testStepFail("Fail","Negetive Response Received!");   return; }
  
  testStep("step","ecuResp.Packet.Length=%x",ecuResp.Packet.Length);
  if(6 == ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
  
  if(ecuResp.Packet.Payload[1]==testerReq.Packet.Payload[1])
  {  
    testStepPass("Chk","PositiveResponseSubfunction 0x%x",ecuResp.Packet.Payload[1]);
  }
  else
  {
    testStepFail("Chk","Unexpect PositiveResponseSubfunction 0x%x",ecuResp.Packet.Payload[1]);  
  }
  
  if(ecuResp.Packet.Payload[1] == 0x02)
  {
    P2_Server[0] = 0x00;
    P2_Server[1] = 0x19;
    P2_Server[2] = 0x01;
    P2_Server[3] = 0xF4;
  }
  else 
  {
    P2_Server[0] = 0x00;
    P2_Server[1] = 0x32;
    P2_Server[2] = 0x01;
    P2_Server[3] = 0xF4;
  }
  
  if((ecuResp.Packet.Payload[2] == P2_Server[0]) && (ecuResp.Packet.Payload[3] == P2_Server[1])
    && (ecuResp.Packet.Payload[4] == P2_Server[2]) && (ecuResp.Packet.Payload[5] == P2_Server[3]))
  {
    testSteppass("Chk","Parameter P2 is 0x%02X%02X",ecuResp.Packet.Payload[2],ecuResp.Packet.Payload[3]);
    testSteppass("Chk","Parameter P2* is 0x%02X%02X",ecuResp.Packet.Payload[4],ecuResp.Packet.Payload[5]);
  }
  else
  {
     testStepfail("Chk","Parameter P2 is 0x%02X%02X,Expect P2 is 0x%02X%02X",ecuResp.Packet.Payload[2],ecuResp.Packet.Payload[3],P2_Server[0],P2_Server[1]);
     testStepfail("Chk","Parameter P2* is 0x%02X%02X,Expect P2* is 0x%02X%02X",ecuResp.Packet.Payload[4],ecuResp.Packet.Payload[5],P2_Server[2],P2_Server[3]); 
  }
}
