///**********************************SID 2C**********************************/
void SID2C_DynamicallyDefinedDataIdentifier(struct DynamicallyDefinedDataIdentifier SID2C_Package, struct ServiceVars txPackage)
{
  
  txPackage.Req_SPRMIB = SID2C_Package.GW_SPRMIB;
  txPackage.Packet.Length = SID2C_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID2C_Package, PDU_Offset, txPackage.Packet.Length);
  
  txPackage.Flag = 1;
}
//
void CheckPosResponse_SID2C(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  if(4 == ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
	
	//Subfunction
  if(ecuResp.Packet.Payload[1] != testerReq.Packet.Payload[1]) 
  {
    testStepFail("Chk","Response Subfunction is [0x%x]",ecuResp.Packet.Payload[1]);    
  }
  else
  {
    testSteppass("Chk","Response Subfunction is [0x%x]",ecuResp.Packet.Payload[1]);   
  }
  
  //Identifier
  if((ecuResp.Packet.Payload[2] != testerReq.Packet.Payload[2])&&(ecuResp.Packet.Payload[3] != testerReq.Packet.Payload[3]))
  {
    testStepFail("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[2],ecuResp.Packet.Payload[3]);    
  }
  else
  {
    testSteppass("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[2],ecuResp.Packet.Payload[3]);   
  }
}

/**********************************SID 2E**********************************/
void SID2E_WriteDataByIdentifier(struct WriteDataByIdentifier SID2E_Package, struct ServiceVars txPackage)
{
  
  txPackage.Req_SPRMIB = SID2E_Package.GW_SPRMIB;
  txPackage.Packet.Length = SID2E_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID2E_Package, PDU_Offset, txPackage.Packet.Length);
  
  txPackage.Flag = 1;
}

void CheckPosResponse_SID2E(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  if(3==ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
  
  if(ecuResp.Packet.Payload[1]!=testerReq.Packet.Payload[1] && ecuResp.Packet.Payload[2]!=testerReq.Packet.Payload[1])
  {
    testStepFail("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[1],ecuResp.Packet.Payload[2]);    
  }
  else
  {
    testSteppass("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[1],ecuResp.Packet.Payload[2]);   
  }
}
