///**********************************SID 36**********************************/
void SID36_TransferData(struct TransferData SID36_Package, struct ServiceVars txPackage)
{
  SID36_Package.SID=0x36;
  //SID36_Package.BS_Counter=txPackage.SID36_Counter;

  txPackage.Req_SPRMIB = SID36_Package.GW_SPRMIB;
  txPackage.Packet.Length = SID36_Package.Length;
  txPackage.SID36_Counter = 0x1;
  memcpy_off(txPackage.Packet.Payload, 0, SID36_Package, PDU_Offset, txPackage.Packet.Length);
  
  txPackage.Flag = 1;
}

void CheckPosResponse_SID36(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  //testerReq.SID36_Counter++;
  if(ecuResp.Packet.Payload[1]==testerReq.SID36_Counter)
  {  
    testStepPass("Chk","PositiveResponseblockSequenceCounter  n %x",ecuResp.Packet.Payload[1]);
  }
  else
  {
    testStepFail("Chk","Unexpect PositiveResponseblockSequenceCounter %x except %x",ecuResp.Packet.Payload[1],testerReq.SID36_Counter);   
  }
  
  if(2==ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
}
