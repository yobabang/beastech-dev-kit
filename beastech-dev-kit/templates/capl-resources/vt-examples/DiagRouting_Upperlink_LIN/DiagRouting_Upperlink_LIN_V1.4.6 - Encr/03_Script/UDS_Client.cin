///**********************************SID 11**********************************/
void SID11_ECUReset(struct ECUReset SID11_Package,struct ServiceVars txPackage)
{
  txPackage.Req_SPRMIB = (SID11_Package.SubFunction & 0x80) >> 7;
  txPackage.Packet.Length = SID11_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID11_Package, PDU_Offset, txPackage.Packet.Length); 
  
  //CurrentSession[GW] = 1;
  
  txPackage.Flag = 1;
}

void CheckPosResponse_SID11(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  if(2 == ecuResp.Packet.Length)
  {
    testStepPass("Chk","Response data length is correct");
  }
  else
  {
    testStepFail("Chk","Response data length is not correct");
  }
  
  if(ecuResp.Packet.Payload[1]==testerReq.Packet.Payload[1])
  {  
    testStepPass("Chk","PositiveResponseSubfunction %x",ecuResp.Packet.Payload[1]);
  }
  else
  {
    testStepFail("Chk","Unexpect PositiveResponseSubfunction %x",ecuResp.Packet.Payload[1]);  
  }
}
