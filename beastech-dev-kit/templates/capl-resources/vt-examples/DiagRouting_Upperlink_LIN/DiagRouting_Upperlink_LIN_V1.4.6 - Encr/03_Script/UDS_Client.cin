///**********************************SID 22**********************************/
void SID22_ReadDataByIdentifier(struct ReadDataByIdentifier SID22_Package, struct ServiceVars txPackage)
{
  
  txPackage.Req_SPRMIB = SID22_Package.GW_SPRMIB;
  txPackage.Packet.Length = SID22_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID22_Package, PDU_Offset, txPackage.Packet.Length);
  
  txPackage.Flag = 1;
}

void CheckPosResponse_SID22(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  word Identifier;
  byte SN;
    
  if((ecuResp.Packet.Payload[1] != testerReq.Packet.Payload[1])&&(ecuResp.Packet.Payload[2] != testerReq.Packet.Payload[2]))
  {
    testStepFail("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[1],ecuResp.Packet.Payload[2]);    
  }
  else
  {
    testSteppass("Chk","Response PID is [0x%x %x]",ecuResp.Packet.Payload[1],ecuResp.Packet.Payload[2]);   
  }
  
  Identifier = ecuResp.Packet.Payload[1] << 8 | ecuResp.Packet.Payload[2];
  switch(Identifier)
  {
    case 0xF186: 
    {
      if(4 == ecuResp.Packet.Length)
      {
        testStepPass("Chk","Response data length is correct");
      }
      else
      {
        testStepFail("Chk","Response data length is not correct");
      }
      
      SN = GetEcuSN(ecuResp.Packet.SourceID);
      if(ecuResp.Packet.Payload[3] == @sysvar::GW::CurrentSession)
      {
        //testStepPass("Chk","The Current Session is %x", @sysvar::GW::CurrentSession);
        testStepPass("Chk","The Current Session is %x(expect %x)", ecuResp.Packet.Payload[3],@sysvar::GW::CurrentSession);
      }
      else
      {
        //testStepFail("Chk","The Current Session is %x", @sysvar::GW::CurrentSession);
        testStepFail("Chk","The Current Session is %x(expect %x)", ecuResp.Packet.Payload[3],@sysvar::GW::CurrentSession);
      }
    }break;
    
    case 0xF12A: 
    {
      if(8 == ecuResp.Packet.Length)
      {
        testStepPass("Chk","Response data length is correct");
      }
      else
      {
        testStepFail("Chk","Response data length is not correct");
      }
    }break;
  }
}

///**********************************SID 27**********************************/
void SID27_SecurityAccess(struct SecurityAccess SID27_Package, struct ServiceVars txPackage)
{
  SID27_Package.SID = 0x27;
  txPackage.Req_SPRMIB = SID27_Package.GW_SPRMIB;
  txPackage.Packet.Length = SID27_Package.Length;
  memcpy_off(txPackage.Packet.Payload, 0, SID27_Package, PDU_Offset, txPackage.Packet.Length);
}

void CheckPosResponse_SID27(struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
  byte subFunction;
  byte requestSeed[4],sendKey[4];
  
  subFunction = ecuResp.Packet.Payload[1];
  switch(subFunction)
  {
    requestSeed[0] = ecuResp.Packet.Payload[2];
    requestSeed[1] = ecuResp.Packet.Payload[3];
    requestSeed[2] = ecuResp.Packet.Payload[4];
    //requestSeed[3] = ecuResp.Packet.Payload[5];
    case 0x01: 
    {
      if(5 == ecuResp.Packet.Length)
      {
        testStepPass("Chk","Response data length is correct");
      }
      else
      {
        testStepFail("Chk","Response data length is not correct");
      }
      
    }
    break;
    
    case 0x02: 
    {
      if(2 == ecuResp.Packet.Length)
      {
        testStepPass("Chk","Response data length is correct");
      }
      else
      {
        testStepFail("Chk","Response data length is not correct");
      }
    }
    break;
  }
}
