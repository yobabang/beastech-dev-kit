/*@!Encoding:936*/
variables
{ 
  struct  SDU_Data
  {
    word   SourceID;
    word   TargetID;
    dword  Length;
    byte   Payload[65536];
  };

  struct ServiceVars
  {
    word   Flag;
    word   Network_num;
    word   Req_SPRMIB;
    word   SID36_Counter;
    word   SID2A_Response;
    double TimeStamp;
    word   QueueOrder;
    struct SDU_Data Packet;
  };
  struct ServiceVarsForQueueCheck
  {
    word   Flag;
    word   Req_SPRMIB;
    word   SID36_Counter;
    word   SID2A_Response;
    double TimeStamp;
    word   QueueOrder;
    struct SDU_Data Packet[3];
  };
  struct SendBuffer
  {
    word   sendFlag;          //0,空   1,有数据
    word   Num;
    struct SDU_Data Packet;
  };
  struct SendBuffer   ETHTxBuffer[EcuSum][2];
  struct ServiceVars  GatewayReq;    //存放网关的诊断请求
  struct ServiceVars  GatewayResp;   //存放网关的诊断应答 
  struct ServiceVars  Request[EcuSum];        //存放诊断请求的数据包
  struct ServiceVars  QueRequest[EcuSum];     //存放队列请求的数据包
  struct ServiceVars  Response[EcuSum];
  struct ServiceVars  RequestTrans[EcuSum]; 
  struct ServiceVars  FunRequest[EcuSum*2]; 
  struct ServiceVars  ResponseTrans[EcuSum]; 
  struct ServiceVars  QueRequestTrans[EcuSum][2];
  struct ServiceVars  void_Request;        
  /**************************************************/
  /**************************************************/
  
  enum TestCase_List //用于Ecu仿真节点应答不同的数据
  {
    DID_EDA0_900B  =  5,
    DID_EDA0_100B  =  1,
    DID_EDA0_1kB   =  2,
    DID_EDA0_4kB   =  3,
    DID_EDA0_8kB   =  4
  };
  
  enum DiagnosticSession
  {
    DefaultSession            = 0x0,
    ProgrammingSession        = 0x1,
    ExtendedSession           = 0x2,
    DefaultSession_SPRMIB     = 0x3,
    ProgrammingSession_SPRMIB = 0x4,
    ExtendedSession_SPRMIB    = 0x5
  };
  enum TesterPresent
  {
    TesterPresent             = 0x00,
    TesterPresent_SPRMIB      = 0x01
  };
  
  enum ECUReset
  {
    HardReset         = 0x0,
    HardReset_SPRMIB  = 0x1
  };
  enum ReadDataByIdentifier
  {
    Read_F186         = 0x0,
    Read_EDA0         = 0x1,
    Read_F1AE         = 0x2,
    Read_F1AA         = 0x3,
    Read_D01C         = 0x4,
    Read_ED20         = 0x5
  };
  enum WriteDataByIdentifier
  {
    Write_EDA0        = 0x0,
    Write_1122        = 0x1
  };
  enum RoutineControl
  {
    RID_0206          = 0x0,
    RID_FF00          = 0x1,
    RID_0301          = 0x2,
    RID_0205          = 0x3,
    RID_FF01          = 0x4
  };
  enum TransferData
  {
    Tran_0264          = 0x0,
    Tran_2000          = 0x1,
    Tran_0064          = 0x02
  };
  struct SourceDataPars  //SID2C_Packageameter
  {
    byte DID[2];
    byte Position;
    byte MemorySize;
  };
  
  /****************Diagnostic Service Package Define*******************/
  struct DiagnosticSessionControl  //Service_10
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  SubFunction;
  }; 
  
  struct ECUReset  //Service_11
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  SubFunction;
  }; 
  struct ReadDataByIdentifier  //Service_22
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  Identifier[2];
  };
  struct SecurityAccess  //Service_27
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  SubFunction;
    byte  Data[4];
  }; 
  struct ReadDataByPeriodicIdentifier  //Service_2A
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  TransmissionMode;
    byte  PeriodicDataIdentifier[1];
  }; 
  struct DynamicallyDefinedDataIdentifier //Service_2C
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  SubFunction;
    byte  DyDefinedDID[2];
    struct SourceDataPars SourData[100];
  };
  struct WriteDataByIdentifier  //Service_2E
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  Identifier[2];
    byte  Data[65536];
  };
  struct RoutineControl  //Service_31
  {
    byte  GW_SPRMIB;
    dword Length;
//    byte  SID;
//    byte  SubFunction;
//    byte  Identifier[2];
    byte  Data[500];
  };
  struct RequestDownload    //Service_34
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  DataFormatIdentifier;
    byte  DataFormatIdentifier1;
    byte  MemoryAddress[4];
    byte  MemorySize[4];
  };
  Struct RequestUpload      //Service_35
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    word  DataFormatIdentifier;
    byte  MemoryAddress[4];
    byte  MemorySize[4];
  };
  Struct TransferData       //Service_36
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  BS_Counter;
    byte  Data[65535];
  };
  Struct RequestTransferExit //Service_37
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
  };
  Struct TesterPresent //Service_3E
  {
    byte  GW_SPRMIB;
    dword Length;
    byte  SID;
    byte  SubFunction;
  };
 
  /****************variable Define*******************/  
  struct SID2A_Response //SID2A_PeriodicResponse
  {
    byte Request_Enable;
    byte Length;
    byte TransmissionMode;
    byte PeriodicDataIdentifier[1];
    
  }SID2A_PeriodicResponse;
  
//  byte  CurrentSession[EcuSum];
  word  PDU_Offset = 8; //诊断服务结构体到Doip PDU映射偏移量
  
  // 20231026：yangjing
  enum  UDS_SessionMode  { DEFAULTSESSION = 0x01, EXTENDEDSESSION = 0x03, PROGRAMMINGSESSION = 0x02 };
}
  
/********************************Transmit/response data check******************************/
//Check ECU Response
void CheckECU_Response(double P2, struct ServiceVars testerReq, struct ServiceVars ecuResp)
{
//  if(P2 < P2Client)
//  {
//    testStep("1","ecuResp.Packet.TargetID=0x%x",ecuResp.Packet.TargetID);
//    testStep("2","ecuResp.Packet.SourceID=0x%x",ecuResp.Packet.SourceID);
//    testStep("1","testerReq.Packet.TargetID=0x%x",testerReq.Packet.TargetID);
//    testStep("2","testerReq.Packet.SourceID=0x%x",testerReq.Packet.SourceID);
  
    if((testerReq.Packet.TargetID == ecuResp.Packet.SourceID) && (testerReq.Packet.SourceID == ecuResp.Packet.TargetID))
    {
      if(ecuResp.Packet.Payload[0] == 0x7F)
      {
        testStepWarning("Chk","Unexpect NegativeResponseServiceID 0x%x (NRC:0x%x)",ecuResp.Packet.Payload[1],ecuResp.Packet.Payload[2]);
      }
      else if(ecuResp.Packet.Payload[0] != (testerReq.Packet.Payload[0] + 0x40))
      { 
        if(SID2A_PeriodicResponse.Request_Enable == 1)
        {
          if(ecuResp.Packet.Payload[0] != SID2A_PeriodicResponse.PeriodicDataIdentifier[0])
          {
            testStepFail("Chk","Unexpect SID2A PeriodicResponseID 0x%x",ecuResp.Packet.Payload[0]);
          }
          else 
          {
            testStepPass("Chk","Expect SID2A PeriodicResponseID 0x%x",ecuResp.Packet.Payload[0]);
            
            CheckPeriodicResponse_SID2A(testerReq, ecuResp);
          }
        }
        else 
        {
          testStepFail("Chk","Unexpect PositiveResponseServiceID 0x%x",ecuResp.Packet.Payload[0]);
        }
      }
      else
      {
        testStepPass("Chk","PositiveResponseServiceID 0x%x",ecuResp.Packet.Payload[0]);
        
        switch(testerReq.Packet.Payload[0])
        {
          case 0x10: CheckPosResponse_SID10(testerReq, ecuResp); break;
          case 0x11: CheckPosResponse_SID11(testerReq, ecuResp); break;
          case 0x22: CheckPosResponse_SID22(testerReq, ecuResp); break;
          case 0x27: CheckPosResponse_SID27(testerReq, ecuResp); break;
          case 0x2A: CheckPosResponse_SID2A(testerReq, ecuResp); break;
          case 0x2C: CheckPosResponse_SID2C(testerReq, ecuResp); break;
          case 0x2E: CheckPosResponse_SID2E(testerReq, ecuResp); break;
          case 0x31: CheckPosResponse_SID31(testerReq, ecuResp); break;
          case 0x34: CheckPosResponse_SID34(testerReq, ecuResp); break;
          case 0x35: CheckPosResponse_SID35(testerReq, ecuResp); break;
          case 0x36: CheckPosResponse_SID36(testerReq, ecuResp); break;
          case 0x37: CheckPosResponse_SID37(testerReq, ecuResp); break;
          case 0x3E: CheckPosResponse_SID3E(testerReq, ecuResp); break;
          default: break;
        }
      }
    }
    else
    {
      testStepFail("ChkID","Diagnostic Address ID is not Correct");
    }
//  }
//  else 
//  {
//    testStepFail("Chk","Timeout Non Response recived");
//  }
}

