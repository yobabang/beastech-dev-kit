on timer SimHighLoadTimer_HighPriority
{
  int burst[network_quantity],busload[network_quantity],testchannel,buschannel,h;
  char busaname[20],bustype[20];
  for(testchannel=0;testchannel<network_quantity;testchannel++)
  {
    getbusbytestchannel(busaname,bustype,testchannel);
    if((strncmp(bustype,"CANFD",strlen("CANFD"))==0)||(strncmp(bustype,"CAN",strlen("CAN"))==0))
    {
      buschannel=GetBusNameContext(busaname);
      CANFD_switch_HighLoad(busaname);
      for(h=0; h<burst[testchannel] ;h++)
      { 

         HighPriority_Msg1.can=buschannel;
         output(HighPriority_Msg1);

      }
      
      busload[testchannel] = canGetBusLoad(buschannel);
      if(busload[testchannel]<80)
        burst[testchannel]++; 
    }      
  }
}

on timer SimHighLoadTimer_LowPriority
{
  int burst[network_quantity],busload[network_quantity],testchannel,buschannel,h;
  char busaname[20],bustype[20];
  for(testchannel=0;testchannel<network_quantity;testchannel++)
  {
    getbusbytestchannel(busaname,bustype,testchannel);
    if((strncmp(bustype,"CANFD",strlen("CANFD"))==0)||(strncmp(bustype,"CAN",strlen("CAN"))==0))
    {
      buschannel=GetBusNameContext(busaname);
      CANFD_switch_HighLoad(busaname);
      for(h=0; h<burst[testchannel] ;h++)
      { 

         LowPriority_Msg1.can=buschannel;
         output(LowPriority_Msg1);

      }
      
      busload[testchannel] = canGetBusLoad(buschannel);
      if(busload[testchannel]<80)
        burst[testchannel]++; 
    }      
  }
}
