                    des_BmsCem_Lin6Fr10.byte(k) = data[k];
                }
                linUpdateResponse(des_BmsCem_Lin6Fr10);
                break;
            case 0x2:
                for (k = 0; k < des_BmsCem_Lin6Fr01.dlc; k++) {
                    des_BmsCem_Lin6Fr01.byte(k) = data[k];
                }
                linUpdateResponse(des_BmsCem_Lin6Fr01);
                break;
            case 0x29:
                for (k = 0; k < des_BmsCem_Lin6Fr12.dlc; k++) {
                    des_BmsCem_Lin6Fr12.byte(k) = data[k];
                }
                linUpdateResponse(des_BmsCem_Lin6Fr12);
                break;
            case 0x16:
                for (k = 0; k < des_FmdmCem_Lin6Fr01.dlc; k++) {
                    des_FmdmCem_Lin6Fr01.byte(k) = data[k];
                }
                linUpdateResponse(des_FmdmCem_Lin6Fr01);
                break;
            case 0x2a:
                for (k = 0; k < des_BmsCem_Lin6Fr13.dlc; k++) {
