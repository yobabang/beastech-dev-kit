  struct gSignal{
    char sig_name[100];
    char scr_can[100];
    char scr_network_type[100];
    int scr_slotid_fr;
    int scr_basecycle_fr;
    int scr_repetition_fr;
    int scr_startbit;
    int sig_length;
    int des_slotid_fr;
    int des_basecycle_fr;
    int des_repetition_fr;
    int des_startbit;
    int scr_cyc;
    int scr_id;
    int scr_dlc;
    int des_cyc;
    int des_id;  
    int updatebit; //source
    int des_updatebit;
    qword InitValue; 
  };
  
