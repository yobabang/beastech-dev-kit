                }
                linUpdateResponse(des_BmsCem_Lin6Fr13);
                break;
            case 0x18:
                for (k = 0; k < des_FdmlCem_Lin6Fr01.dlc; k++) {
                    des_FdmlCem_Lin6Fr01.byte(k) = data[k];
                }
                linUpdateResponse(des_FdmlCem_Lin6Fr01);
                break;
            case 0x3:
                for (k = 0; k < des_BmsCem_Lin6Fr02.dlc; k++) {
                    des_BmsCem_Lin6Fr02.byte(k) = data[k];
                }
                linUpdateResponse(des_BmsCem_Lin6Fr02);
                break;
            case 0x26:
                for (k = 0; k < des_BmsCem_Lin6Fr16.dlc; k++) {
                    des_BmsCem_Lin6Fr16.byte(k) = data[k];
                }
                linUpdateResponse(des_BmsCem_Lin6Fr16);
