void settestchannel(int num)
{
  switch(num)
  {
  case 0:

        setBusContext(getBusNameContext("ZCUD_LIN1"));
        teststep("step", "Start test on ZCUD_LIN1");
        break;
  case 1:

        setBusContext(getBusNameContext("CEM_LIN3"));
        teststep("step", "Start test on CEM_LIN3");
        break;
  case 2:

        setBusContext(getBusNameContext("CEM_LIN2"));
        teststep("step", "Start test on CEM_LIN2");
        break;
  case 3:

        setBusContext(getBusNameContext("CEM_LIN6"));
        teststep("step", "Start test on CEM_LIN6");
        break;
  case 4:

        setBusContext(getBusNameContext("CEM_LIN1"));
        teststep("step", "Start test on CEM_LIN1");
        break;
  case 5:

        setBusContext(getBusNameContext("CEM_LIN4"));
        teststep("step", "Start test on CEM_LIN4");
        break;
  case 6:

        setBusContext(getBusNameContext("ZCUD_LIN2"));
        teststep("step", "Start test on ZCUD_LIN2");
        break;
  case 7:

        setBusContext(getBusNameContext("ZCUD_LIN3"));
        teststep("step", "Start test on ZCUD_LIN3");
        break;
  case 8:

        setBusContext(getBusNameContext("CEM_LIN7"));
        teststep("step", "Start test on CEM_LIN7");
        break;
  case 9:

        setBusContext(getBusNameContext("PropulsionCAN"));
        teststep("step", "Start test on PropulsionCAN");
        break;
  case 10:

        setBusContext(getBusNameContext("ChassisCAN1"));
        teststep("step", "Start test on ChassisCAN1");
        break;
  case 11:

        setBusContext(getBusNameContext("ZCU_CANFD1"));
        teststep("step", "Start test on ZCU_CANFD1");
        break;
  case 12:

        setBusContext(getBusNameContext("ZCUD_CANFD3"));
        teststep("step", "Start test on ZCUD_CANFD3");
        break;
  case 13:

        setBusContext(getBusNameContext("ChassisCANFD2"));
        teststep("step", "Start test on ChassisCANFD2");
        break;
  case 14:

        setBusContext(getBusNameContext("ZCUD_CAN1"));
        teststep("step", "Start test on ZCUD_CAN1");
        break;
  case 15:

        setBusContext(getBusNameContext("ZCUD_CANFD4"));
        teststep("step", "Start test on ZCUD_CANFD4");
        break;
  case 16:

        setBusContext(getBusNameContext("ZCU_CANFD2"));
        teststep("step", "Start test on ZCU_CANFD2");
        break;
  case 17:

        setBusContext(getBusNameContext("BodyExposedCAN"));
        teststep("step", "Start test on BodyExposedCAN");
        break;

  Default:
        testStepFail("step", "Bus context channel number is wrong!");
  }
}



void getbusbytestchannel(char BusName[],char BusType[],int num)
{
  switch(num)
  {

    case 0:
        strncpy(BusName,"ZCUD_LIN1",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 1:
        strncpy(BusName,"CEM_LIN3",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 2:
        strncpy(BusName,"CEM_LIN2",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 3:
        strncpy(BusName,"CEM_LIN6",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 4:
        strncpy(BusName,"CEM_LIN1",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 5:
        strncpy(BusName,"CEM_LIN4",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 6:
        strncpy(BusName,"ZCUD_LIN2",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 7:
        strncpy(BusName,"ZCUD_LIN3",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 8:
        strncpy(BusName,"CEM_LIN7",elcount(BusName));
        strncpy(BusType,"LIN",elcount(BusType));
        break;
    case 9:
        strncpy(BusName,"PropulsionCAN",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 10:
        strncpy(BusName,"ChassisCAN1",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 11:
        strncpy(BusName,"ZCU_CANFD1",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 12:
        strncpy(BusName,"ZCUD_CANFD3",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 13:
        strncpy(BusName,"ChassisCANFD2",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 14:
        strncpy(BusName,"ZCUD_CAN1",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 15:
        strncpy(BusName,"ZCUD_CANFD4",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 16:
        strncpy(BusName,"ZCU_CANFD2",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    case 17:
        strncpy(BusName,"BodyExposedCAN",elcount(BusName));
        strncpy(BusType,"CAN",elcount(BusType));
        break;
    Default:
        testStepFail("step","Bus context channel number is wrong!");
        break;
  }
}

void CANFD_switch_HighLoad(char souce_network[])
{
    if(strstr(souce_network,"CANFD")>0)
    {
        HighPriority_Msg1.FDF=1;
        LowPriority_Msg1.FDF=1;
    }
    else
    {
        HighPriority_Msg1.FDF=0;
        LowPriority_Msg1.FDF=0;
    }
}
        
void CANFD_switch(char souce_network[])
{
    if(strncmp(souce_network,"CANFD",10)==0)
    {
        temp_message.FDF = 1;
    }
    else
    {
        temp_message.FDF = 0;
    }
}


void Loggingfilenameset(int num, char testcaseid[], char group[], char caseid[], char sub[])
{
    char name[100];
    char network[20];
    switch(num)
    {

    case 0:
        strncpy(network,"ZCUD_LIN1",20);
        break;
    
    case 1:
        strncpy(network,"CEM_LIN3",20);
        break;
    
    case 2:
        strncpy(network,"CEM_LIN2",20);
        break;
    
    case 3:
        strncpy(network,"CEM_LIN6",20);
        break;
    
    case 4:
        strncpy(network,"CEM_LIN1",20);
        break;
    
    case 5:
        strncpy(network,"CEM_LIN4",20);
        break;
    
    case 6:
        strncpy(network,"ZCUD_LIN2",20);
        break;
    
    case 7:
        strncpy(network,"ZCUD_LIN3",20);
        break;
    
    case 8:
        strncpy(network,"CEM_LIN7",20);
        break;
    
    case 9:
        strncpy(network,"PropulsionCAN",20);
        break;
    
    case 10:
        strncpy(network,"ChassisCAN1",20);
        break;
    
    case 11:
        strncpy(network,"ZCU_CANFD1",20);
        break;
    
    case 12:
        strncpy(network,"ZCUD_CANFD3",20);
        break;
    
    case 13:
        strncpy(network,"ChassisCANFD2",20);
        break;
    
    case 14:
        strncpy(network,"ZCUD_CAN1",20);
        break;
    
    case 15:
        strncpy(network,"ZCUD_CANFD4",20);
        break;
    
    case 16:
        strncpy(network,"ZCU_CANFD2",20);
        break;
    
    case 17:
        strncpy(network,"BodyExposedCAN",20);
        break;
    
  Default:
      strncpy(network,"Default",20);
      testStepFail("step","logging channel number is wrong!");
      break;
  }

    strncpy(name,"\\per_testcase\\TC_GW_xx_yy_Vzz_net",100);
    str_replace_regex(name,"TC",testcaseid);
    str_replace_regex(name,"xx",group);
    str_replace_regex(name,"yy",caseid);
    str_replace_regex(name,"zz",sub);
    str_replace_regex(name,"net",network);
    //setLogFileName(name);
    SetLogPath_sig(name, 1);
}

