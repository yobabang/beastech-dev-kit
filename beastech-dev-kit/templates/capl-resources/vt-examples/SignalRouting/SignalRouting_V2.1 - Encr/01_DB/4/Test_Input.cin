                }
                linUpdateResponse(des_AwmCem_Lin3Fr01);
                break;
            case 0x16:
                for (k = 0; k < des_OhcCem_Lin3Fr05.dlc; k++) {
                    des_OhcCem_Lin3Fr05.byte(k) = data[k];
                }
                linUpdateResponse(des_OhcCem_Lin3Fr05);
                break;
            case 0xe:
                for (k = 0; k < des_Awm2Cem_Lin3SertNrFr01.dlc; k++) {
                    des_Awm2Cem_Lin3SertNrFr01.byte(k) = data[k];
