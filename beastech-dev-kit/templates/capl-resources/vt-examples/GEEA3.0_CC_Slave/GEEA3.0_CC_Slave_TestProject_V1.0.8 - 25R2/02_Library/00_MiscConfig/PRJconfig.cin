testfunction TestMoudlePostcondition()
{
  NM_Sim(Sim_off);
  UsageMode_Sim(Sim_off);
  stopLogging("DiagLogging");
  stopLogging("FullLogging");
  //VH1150_Close();
  gTest_loop=0;
  stop();
}